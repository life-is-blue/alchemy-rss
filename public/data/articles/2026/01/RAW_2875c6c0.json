iz.qpic.cn%2Fsz_mmbiz_png%2FePw3ZeGRruzEtdscVL4fo9icic3VPWxlWgkibhEVfFeiclmWzK21WB2MWWOQgRE0L3D8ibZZMMB8FOo4ejibUxRDq20w%2F640%3Fwx_fmt%3Dpng%26from%3Dappmsg\"></p>\n    <p class=\"js_darkmode__0\" data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:32px 8px 0px;visibility:visible;letter-spacing:0.544px;clear:both;text-decoration-style:initial;line-height:2em;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><span style=\"-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;color: rgb(255, 104, 39);font-family: Futura-Medium;font-size: 32px;font-weight: 700;letter-spacing: 1px;visibility: visible;\"><span leaf=\"\" style=\"-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">01</span></span></p>\n    <p class=\"js_darkmode__1\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:0px 8px 16px;visibility:visible;letter-spacing:0.544px;clear:both;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><strong class=\"js_darkmode__2\" style=\"-webkit-tap-highlight-color:transparent;padding:0px;margin:0px;outline:0px;max-width:100%;visibility:visible;letter-spacing:0.544px;font-size:17px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box !important;overflow-wrap:break-word !important;\"><span style=\"-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 16px;visibility: visible;\"><span leaf=\"\" style=\"-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\"><span textstyle=\"\" style=\"font-size: 16px;\">开源项目简介</span></span></span></strong></p>\n    <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><ms-cmark-node><strong><ms-cmark-node><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 14px;\">AgentCPM-Explore</span></span></ms-cmark-node></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 14px;\">是这个开源项目的核心模型，</span><span textstyle=\"\" style=\"font-size: 14px;font-weight: bold;\">专注于解决长周期、多步交互的复杂任务。</span></span></ms-cmark-node></p>\n    <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><ms-cmark-node><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 14px;\">它是基于 Qwen3-4B-thinking-2507 进行深度后训练。是首个具备 GAIA、Xbench、Browsercomp 等 8 个高难度智能体任务处理能力的 4B 端侧模型。</span></span></ms-cmark-node></p>\n    <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><ms-cmark-node><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 14px;\">在多个榜单上超越了 8B 级 SOTA 模型，甚至在 Xbench-DeepResearch 上表现优于 OpenAI-o3 和 Claude-3.5-Sonnet。</span></span></ms-cmark-node></p>\n    <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><ms-cmark-node><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, Blin