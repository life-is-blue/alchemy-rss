eue&quot;, Arial, &quot;PingFang SC&quot;, &quot;Microsoft YaHei&quot;, sans-serif;font-style: normal;font-variant-ligatures: normal;font-variant-caps: normal;font-weight: 400;letter-spacing: normal;orphans: 2;text-align: left;text-indent: 0px;text-transform: none;widows: 2;word-spacing: 0px;-webkit-text-stroke-width: 0px;white-space: normal;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;box-sizing: border-box;margin: 1.5em 0px 0px;color: rgb(100, 116, 139);border-top: 1px solid rgb(226, 232, 240);padding-top: 0.75em;font-size: 0.875em;\"></p>\n  <h4 style=\"box-sizing: border-box;margin: 1.25em 0px 0.4em;overflow-wrap: break-word;font-family: Georgia, &quot;Times New Roman&quot;, &quot;Songti SC&quot;, SimSun, serif;font-weight: 600;line-height: 1.3;color: rgb(71, 85, 105);font-size: 1.125em;\"><span style=\"box-sizing: border-box;margin: 0px;\"><span leaf=\"\">References</span></span></h4>\n  <ol style=\"box-sizing: border-box;margin: 0px 0px 0.9em;list-style-type: decimal;padding-left: 1.25em;\" class=\"list-paddingleft-1\">\n   <li style=\"box-sizing: border-box;margin: 0px 0px 0.2em;\"><span style=\"box-sizing: border-box;margin: 0px;\"><span leaf=\"\">Document-illustrator-skill:&nbsp;</span></span><span style=\"box-sizing: border-box;margin: 0px;word-break: break-all;\"><span leaf=\"\"><a href=\"https://github.com/op7418/Document-illustrator-skill\" target=\"_blank\">https://github.com/op7418/Document-illustrator-skill</a></span></span></li>\n  </ol>\n </body>\n</html>",
  "aiSummary": "本文分享了备受关注的“票据风”AI 图片提示词及其自动化生成工具 Document-illustrator-skill，旨在帮助创作者快速生成高质量的文章配图。",
