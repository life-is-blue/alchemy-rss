ter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">OmniPart (Ours)</span></span></p>\n     </td>\n    </tr>\n    <tr>\n     <td>\n      <p style=\"margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">时间（分钟）</span></span></p>\n     </td>\n     <td>\n      <p style=\"margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">~15</span></span></p>\n     </td>\n     <td>\n      <p style=\"margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">~5</span></span></p>\n     </td>\n     <td>\n      <p style=\"margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">~0.75</span></span></p>\n     </td>\n    </tr>\n   </tbody>\n  </table>\n  <ol class=\"list-paddingleft-1\" start=\"3\">\n   <li>\n    <p style=\"line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">Huggingface demo 展示</span></span></p>\n   </li>\n  </ol>\n  <p><span data-lark-record-data=\"{&quot;rootId&quot;:&quot;Q5eSdsYZ7o5cudxH4q7cg9S2n4f&quot;,&quot;text&quot;:{&quot;initialAttributedTexts&quot;:{&quot;text&quot;:{&quot;0&quot;:&quot;Huggingface demo 展示&quot;},&quot;attribs&quot;:{&quot;0&quot;:&quot;*0+j&quot;}},&quot;apool&quot;:{&quot;numToAttrib&quot;:{&quot;0&quot;:[&quot;author&quot;,&quot;7391834241908260868&quot;]},&quot;nextNum&quot;:1}},&quot;type&quot;:&quot;ordered&quot;,&quot;referenceRecordMap&quot;:{},&quot;extra&quot;:{&quot;channel&quot;:&quot;saas&quot;,&quot;isEqualBlockSelection&quot;:true,&quot;pasteRandomId&quot;:&quot;8feebe91-6cc4-4cc0-a122-fb2e02b86f15&quot;,&quot;mention_page_title&quot;:{},&quot;external_mention_url&quot;:{}},&quot;isKeepQuoteContainer&quot;:false,&quot;isFromCode&quot;:false,&quot;selection&quot;:[{&quot;id&quot;:45,&quot;type&quot;:&quot;text&quot;,&quot;selection&quot;:{&quot;start&quot;:0,&quot;end&quot;:19},&quot;recordId&quot;:&quot;IGgLdTNu8osVozxcLOLcgTMPnbe&quot;}],&quot;payloadMap&quot;:{},&quot;isCut&quot;:false}\" data-lark-record-format=\"docx/text\"></span></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\"></p>\n  <h2 style=\"margin-left: 8px;margin-right: 8px;line-height: 1.75em;text-align: center;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 16px;font-weight: bold;\">丰富的下游应用</span></span></h2>\n  <p style=\"margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">得益于其出色的部件可控性，OmniPart 自然地支持一系列激动人心的下游应用：</span></span></p>\n  <p style=\"text-align: center;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\"><img data-imgfileid=\"503511064\" class=\"rich_pages wxw-img js_insertlocalimg\" data-ratio=\"0.45859375\" data-s=\"300,640\" data-type=\"png\" data-w=\"1280\" style=\"width:100%;\" type=\"block\" data-backw=\"578\" data-backh=\"265\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=7446dfed&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_png%2FKmXPKA19gW9ScciaOLgKiaTpH80iaT5xHHptvStIc9bdLZ4anhaNfgCCAYF6jKCsiamp1EBWgL2zsQubU5qdqDOmew%2F640%3Fwx_fmt%3Dpng%26from%3Dappmsg\"></p>\n  <ul style=\"margin-left: 8px;margin-right: 8px;\" class=\"list-paddingleft-1\">\n   <li>\n    <p style=\"line-height: 1.75em;\"><strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;color: rgb(61, 170, 214);font-weight: bold;\">掩码控制生成 (Mask-Controlled Generation)</span></span></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">：用户可通过编辑2D掩码，精确指导3D部件的结构生成。</span></span></p>\n   </li>\n   <li>\n    <p style=\"line-height: 1.75em;\"><strong style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;color: rgb(61, 170, 214);font-weight: bold;\">多粒度生成 (Multi-Granularity Generation)</span></span></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">：通过调整掩码的精细程度，可以生成不同细节层次的部件组合。</span></span></p>\n   </li>\n   <li>\n    <p style=\"line-height: 1.75em;\"><strong style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;color: rgb(61, 170, 214);font-weight: bold;\">材质编辑 (Material Editing)</span></span></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">：可以对特定部件（如企鹅的帽子、衣服）进行独立的材质或纹理修改。</span></span></p>\n   </li>\n   <li>\n    <p style=\"line-height: 1.75em;\"><strong style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;color: rgb(61, 170, 214);font-weight: bold;\">几何处理 (Geometry Processing)</span></span></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">：生成的高质量部件有利于后续的网格重构（remeshing）等几何处理，不会在部件连接处产生伪影。</span></span></p>\n   </li>\n  </ul>\n  <h2 style=\"margin-left: 8px;margin-right: 8px;line-height: 1.75em;text-align: center;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 16px;font-weight: bold;\">总结</span></span></h2>\n  <p style=\"margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">OmniPart 框架通过其创新的“规划-生成”两阶段流程，并引入灵活的2D掩码作为引导，成功地实现了高质量、可控的部件级3D内容生成。它不仅在生成质量和效率上树立了新的标杆，其强大的可编辑性和应用潜力也为游戏开发、动画制作和虚拟现实等领域铺平了道路，推动了可解释、可编辑3D内容的创作边界。</span></span></p>\n  <p data-pm-slice=\"0 0 []\" style=\"margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">值得一提的是，该团队近期在3D部件领域已经积累了多篇高质量的研究成果，形成了系统性的探索。其中包括专注</span></span><strong style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;color: rgb(61, 170, 214);font-weight: bold;\">3D部件分割</span></span></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">的工作</span></span><strong style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;color: rgb(61, 170, 214);font-weight: bold;\">SAMPart3D</span></span></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">(<a href=\"https://yhyang-myron.github.io/SAMPart3D-website/)，该研究旨在实现对任意3D物体进行精细化的部件分割。另一项相关研究\" target=\"_blank\">https://yhyang-myron.github.io/SAMPart3D-website/)，该研究旨在实现对任意3D物体进行精细化的部件分割。另一项相关研究</a></span></span><strong style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;color: rgb(61, 170, 214);font-weight: bold;\">HoloPart</span></span></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">(<a href=\"https://vast-ai-research.github.io/HoloPart/)\" target=\"_blank\">https://vast-ai-research.github.io/HoloPart/)</a> 则致力于解决从不完整的表面部件信息（Amodal Segmentation）中</span></span><strong style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;color: rgb(61, 170, 214);font-weight: bold;\">生成完整的3D部件</span></span></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">几何。从部件的</span></span><strong style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;color: rgb(61, 170, 214);font-weight: bold;\">分割 (SAMPart3D)</span></span></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;color: rgb(61, 170, 214);font-weight: bold;\">、</span></span><strong style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;color: rgb(61, 170, 214);font-weight: bold;\">补全 (HoloPart)</span></span></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;color: rgb(61, 170, 214);font-weight: bold;\">&nbsp;</span></span><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">到如今的</span></span><strong style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;line-height:1.75em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;color: rgb(61, 170, 214);font-weight: bold;\">生成 (OmniPart)</span></span></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;\">，这些工作共同构建了一个围绕“部件级3D物体”的AIGC技术矩阵。</span></span></p>\n </body>\n</html>",
  "aiSummary": "OmniPart 框架通过“规划-生成”两阶段策略和 2D 掩码控制，实现了高质量、可控的部件级 3D 内容生成，大幅提升了创作效率和可编辑性。",
  "oneSentenceSummary": "OmniPart 框架通过“规划-生成”两阶段策略和 2D 掩码控制，实现了高质量、可控的部件级 3D 内容生成，大幅提升了创作效率和可编辑性。",
  "summary": "本文详细介绍了香港大学等机构提出的 OmniPart 框架，该研究已被计算机图形学顶会 SIGGRAPH Asia 2025 接收，旨在解决现有 3D 生成模型缺乏内在部件结构的问题。OmniPart 创新性地将 3D 生成任务分解为“先规划，后生成”两个协同阶段，通过自回归 Transformer 模型基于 2D 掩码规划 3D 部件结构，并利用高效微调的预训练生成器并行联合优化生成高质量、带纹理的独立部件。OmniPart 在生成质量和效率上均显著优于现有方法，能将生成时间从数分钟缩短至不到 1 分钟，并支持掩码控制生成、多粒度生成、材质编辑和几何处理等丰富的下游应用，为游戏、VR 和动画制作等领域的可解释、可编辑 3D 内容创作开辟了新路径。此外，OmniPart 与 SAMPart3D、HoloPart 等工作共同构建了一个围绕“部件级 3D 物体”的 AIGC 技术矩阵，展现了该团队在该领域的系统性探索。",
  "mainPoints": [
    {
      "point": "OmniPart 框架解决了现有 3D 生成模型缺乏部件结构的问题",
      "explanation": "现有 AI 模型虽能生成高质量 3D 整体形状，但缺乏内在部件结构，限制了在部件编辑、动画制作等关键应用中的价值，OmniPart 旨在弥补这一缺陷。"
    },
    {
      "point": "采用“规划-生成”两阶段策略实现语义解耦与结构协调",
      "explanation": "将生成任务解耦为结构规划和部件生成，确保部件之间高度独立（语义解耦）同时又能完美组合成一个整体，提升了生成的可控性与质量。"
    },
    {
      "point": "通过 2D 掩码实现用户对 3D 部件的直观精细控制",
      "explanation": "用户只需提供简单灵活的 2D 部件掩码，即可直观控制部件的分解粒度，大大降低了控制难度，增强了后续编辑的灵活性。"
    },
