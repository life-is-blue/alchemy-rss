  "content": "<html>\n <head></head>\n <body>\n  <p>\n   <br>\n  </p>\n  <div data-tool=\"mdnice编辑器\" data-website=\"https://www.mdnice.com\" style=\"background-size:auto;background-attachment:scroll;padding-left:0px;font-size:16px;overflow-wrap:break-word;background-color:rgba(0, 0, 0, 0);margin-left:0px;background-repeat:no-repeat;word-spacing:0em;background-position-x:0%;background-position-y:0%;word-break:break-word;font-family:'Microsoft YaHei';margin-top:0px;background-image:none;text-align:left;padding-top:0px;letter-spacing:0em;padding-bottom:0px;line-height:1.5em;margin-right:0px;background-clip:border-box;width:auto;background-origin:padding-box;margin-bottom:0px;padding-right:0px;\" data-pm-slice=\"0 0 []\">\n   <h2 data-tool=\"mdnice编辑器\" style=\"padding-top: 0px;padding-bottom: 0px;padding-left: 10px;padding-right: 0px;display: block;color: rgb(0, 150, 136);margin-top: 0.2rem;margin-right: auto;margin-bottom: 0.2rem;margin-left: auto;border-left-width: 3px;border-left-style: solid;border-left-color: rgb(0, 150, 136);\"><span style=\"display: none;\"></span><span style=\"font-weight:bold;letter-spacing:0em;display:block;font-size:22px;line-height:1.5em;text-align:left;\"><span leaf=\"\">mhogomchungu/media-downloader</span><span style=\"font-size: 0.58em;font-weight: normal;font-style: italic;color: graytext;display: block;text-decoration: underline;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;\"><span leaf=\"\"><a href=\"https://github.com/mhogomchungu/media-downloader\" target=\"_blank\">https://github.com/mhogomchungu/media-downloader</a></span></span></span><span style=\"display: none;\"></span></h2>\n   <p data-tool=\"mdnice编辑器\" style=\"padding-top:3px;letter-spacing:0em;padding-left:0px;font-size:16px;padding-bottom:3px;line-height:1.5em;margin-right:0px;margin-left:0px;text-indent:0em;margin-top:0px;margin-bottom:0px;text-align:justify;padding-right:0px;\"><span leaf=\"\">Stars:&nbsp;</span><code style=\"font-size: 14px;line-height: 1.2em;letter-spacing: 0em;background-attachment: scroll;background-clip: border-box;background-color: rgba(27, 31, 35, 0.05);background-image: none;background-origin: padding-box;background-position-x: 0%;background-position-y: 0%;background-repeat: no-repeat;background-size: auto;width: auto;height: auto;margin-top: 0px;margin-bottom: 0px;margin-left: 2px;margin-right: 2px;padding-top: 2px;padding-bottom: 2px;padding-left: 4px;padding-right: 4px;border-top-style: none;border-bottom-style: none;border-left-style: none;border-right-style: none;border-top-width: 3px;border-bottom-width: 3px;border-left-width: 3px;border-right-width: 3px;border-top-color: rgb(0, 0, 0);border-bottom-color: rgba(0, 0, 0, 0.4);border-left-color: rgba(0, 0, 0, 0.4);border-right-color: rgba(0, 0, 0, 0.4);border-top-left-radius: 4px;border-top-right-radius: 4px;border-bottom-right-radius: 4px;border-bottom-left-radius: 4px;overflow-wrap: break-word;font-family: Consolas, Monaco, Menlo, monospace;word-break: break-all;color: rgb(0, 150, 136);\"><span leaf=\"\">3.2k</span></code><span leaf=\"\">&nbsp; License:&nbsp;</span><code style=\"font-size: 14px;line-height: 1.2em;letter-spacing: 0em;background-attachment: scroll;background-clip: border-box;background-color: rgba(27, 31, 35, 0.05);background-image: none;background-origin: padding-box;background-position-x: 0%;background-position-y: 0%;background-repeat: no-repeat;background-size: auto;width: auto;height: auto;margin-top: 0px;margin-bottom: 0px;margin-left: 2px;margin-right: 2px;padding-top: 2px;padding-bottom: 2px;padding-left: 4px;padding-right: 4px;border-top-style: none;border-bottom-style: none;border-left-style: none;border-right-style: none;border-top-width: 3px;border-bottom-width: 3px;border-left-width: 3px;border-right-width: 3px;border-top-color: rgb(0, 0, 0);border-bottom-color: rgba(0, 0, 0, 0.4);border-left-color: rgba(0, 0, 0, 0.4);border-right-color: rgba(0, 0, 0, 0.4);border-top-left-radius: 4px;border-top-right-radius: 4px;border-bottom-right-radius: 4px;border-bottom-left-radius: 4px;overflow-wrap: break-word;font-family: Consolas, Monaco, Menlo, monospace;word-break: break-all;color: rgb(0, 150, 136);\"><span leaf=\"\">GPL-2.0</span></code></p>\n   <p data-tool=\"mdnice编辑器\" style=\"padding-top:3px;letter-spacing:0em;padding-left:0px;font-size:16px;padding-bottom:3px;line-height:1.5em;margin-right:0px;margin-left:0px;text-indent:0em;margin-top:0px;margin-bottom:0px;text-align:justify;padding-right:0px;\"><span leaf=\"\">media-downloader 是一个基于 Qt/C++ 的图形界面前端，整合了多个命令行工具（如 yt-dlp、youtube-dl、gallery-dl 等）用于在线媒体下载。</span></p>\n   <ul style=\"margin-left:0px;padding-top:0px;list-style-type:disc;padding-left:1rem;padding-bottom:0px;margin-top:8px;margin-bottom:8px;margin-right:0px;padding-right:0px;\" class=\"list-paddingleft-1\">\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">支持通过安装的扩展从任意支持的网站下载媒体内容</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">提供可配置的预设选项以便选择多种格式进行下载</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">支持无限数量的并发下载和批量链接导入，方便高效管理任务</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">能够直接下载播放列表并管理订阅，实现对播放列表活动的监控</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">多语言支持，包括中文、西班牙语、俄语等多达十几种语言</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">通过“扩展”功能灵活添加不同命令行工具，提高兼容性和功能丰富度</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">提供跨平台二进制包及便携版本，适配 Windows 和 macOS 系统</span></p>\n    </li>\n   </ul>\n   <h2 data-tool=\"mdnice编辑器\" style=\"padding-top: 0px;padding-bottom: 0px;padding-left: 10px;padding-right: 0px;display: block;color: rgb(0, 150, 136);margin-top: 0.2rem;margin-right: auto;margin-bottom: 0.2rem;margin-left: auto;border-left-width: 3px;border-left-style: solid;border-left-color: rgb(0, 150, 136);\"><span style=\"display: none;\"></span><span style=\"font-weight:bold;letter-spacing:0em;display:block;font-size:22px;line-height:1.5em;text-align:left;\"><span leaf=\"\">cirediatpl/FigmaChain</span><span style=\"font-size: 0.58em;font-weight: normal;font-style: italic;color: graytext;display: block;text-decoration: underline;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;\"><span leaf=\"\"><a href=\"https://github.com/cirediatpl/FigmaChain\" target=\"_blank\">https://github.com/cirediatpl/FigmaChain</a></span></span></span><span style=\"display: none;\"></span></h2>\n   <p data-tool=\"mdnice编辑器\" style=\"padding-top:3px;letter-spacing:0em;padding-left:0px;font-size:16px;padding-bottom:3px;line-height:1.5em;margin-right:0px;margin-left:0px;text-indent:0em;margin-top:0px;margin-bottom:0px;text-align:justify;padding-right:0px;\"><span leaf=\"\">Stars:&nbsp;</span><code style=\"font-size: 14px;line-height: 1.2em;letter-spacing: 0em;background-attachment: scroll;background-clip: border-box;background-color: rgba(27, 31, 35, 0.05);background-image: none;background-origin: padding-box;background-position-x: 0%;background-position-y: 0%;background-repeat: no-repeat;background-size: auto;width: auto;height: auto;margin-top: 0px;margin