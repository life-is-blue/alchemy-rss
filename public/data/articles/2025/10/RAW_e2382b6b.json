  "content": "<html>\n <head></head>\n <body>\n  <p>\n   <br>\n  </p>\n  <div data-tool=\"mdnice编辑器\" data-website=\"https://www.mdnice.com\" style=\"background-size:auto;background-attachment:scroll;padding-left:0px;font-size:16px;overflow-wrap:break-word;background-color:rgba(0, 0, 0, 0);margin-left:0px;background-repeat:no-repeat;word-spacing:0em;background-position-x:0%;background-position-y:0%;word-break:break-word;font-family:'Microsoft YaHei';margin-top:0px;background-image:none;text-align:left;padding-top:0px;letter-spacing:0em;padding-bottom:0px;line-height:1.5em;margin-right:0px;background-clip:border-box;width:auto;background-origin:padding-box;margin-bottom:0px;padding-right:0px;\" data-pm-slice=\"0 0 []\">\n   <h2 data-tool=\"mdnice编辑器\" style=\"padding-top: 0px;padding-bottom: 0px;padding-left: 10px;padding-right: 0px;display: block;color: rgb(0, 150, 136);margin-top: 0.2rem;margin-right: auto;margin-bottom: 0.2rem;margin-left: auto;border-left-width: 3px;border-left-style: solid;border-left-color: rgb(0, 150, 136);\"><span style=\"display: none;\"></span><span style=\"font-weight:bold;letter-spacing:0em;display:block;font-size:22px;line-height:1.5em;text-align:left;\"><span leaf=\"\">hsliuping/TradingAgents-CN</span><span style=\"font-size: 0.58em;font-weight: normal;font-style: italic;color: graytext;display: block;text-decoration: underline;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;\"><span leaf=\"\"><a href=\"https://github.com/hsliuping/TradingAgents-CN\" target=\"_blank\">https://github.com/hsliuping/TradingAgents-CN</a></span></span></span><span style=\"display: none;\"></span></h2>\n   <p data-tool=\"mdnice编辑器\" style=\"padding-top:3px;letter-spacing:0em;padding-left:0px;font-size:16px;padding-bottom:3px;line-height:1.5em;margin-right:0px;margin-left:0px;text-indent:0em;margin-top:0px;margin-bottom:0px;text-align:justify;padding-right:0px;\"><span leaf=\"\">Stars:&nbsp;</span><code style=\"font-size: 14px;line-height: 1.2em;letter-spacing: 0em;background-attachment: scroll;background-clip: border-box;background-color: rgba(27, 31, 35, 0.05);background-image: none;background-origin: padding-box;background-position-x: 0%;background-position-y: 0%;background-repeat: no-repeat;background-size: auto;width: auto;height: auto;margin-top: 0px;margin-bottom: 0px;margin-left: 2px;margin-right: 2px;padding-top: 2px;padding-bottom: 2px;padding-left: 4px;padding-right: 4px;border-top-style: none;border-bottom-style: none;border-left-style: none;border-right-style: none;border-top-width: 3px;border-bottom-width: 3px;border-left-width: 3px;border-right-width: 3px;border-top-color: rgb(0, 0, 0);border-bottom-color: rgba(0, 0, 0, 0.4);border-left-color: rgba(0, 0, 0, 0.4);border-right-color: rgba(0, 0, 0, 0.4);border-top-left-radius: 4px;border-top-right-radius: 4px;border-bottom-right-radius: 4px;border-bottom-left-radius: 4px;overflow-wrap: break-word;font-family: Consolas, Monaco, Menlo, monospace;word-break: break-all;color: rgb(0, 150, 136);\"><span leaf=\"\">7.8k</span></code><span leaf=\"\">&nbsp; License:&nbsp;</span><code style=\"font-size: 14px;line-height: 1.2em;letter-spacing: 0em;background-attachment: scroll;background-clip: border-box;background-color: rgba(27, 31, 35, 0.05);background-image: none;background-origin: padding-box;background-position-x: 0%;background-position-y: 0%;background-repeat: no-repeat;background-size: auto;width: auto;height: auto;margin-top: 0px;margin-bottom: 0px;margin-left: 2px;margin-right: 2px;padding-top: 2px;padding-bottom: 2px;padding-left: 4px;padding-right: 4px;border-top-style: none;border-bottom-style: none;border-left-style: none;border-right-style: none;border-top-width: 3px;border-bottom-width: 3px;border-left-width: 3px;border-right-width: 3px;border-top-color: rgb(0, 0, 0);border-bottom-color: rgba(0, 0, 0, 0.4);border-left-color: rgba(0, 0, 0, 0.4);border-right-color: rgba(0, 0, 0, 0.4);border-top-left-radius: 4px;border-top-right-radius: 4px;border-bottom-right-radius: 4px;border-bottom-left-radius: 4px;overflow-wrap: break-word;font-family: Consolas, Monaco, Menlo, monospace;word-break: break-all;color: rgb(0, 150, 136);\"><span leaf=\"\">Apache-2.0</span></code></p>\n   <p data-tool=\"mdnice编辑器\" style=\"padding-top:3px;letter-spacing:0em;padding-left:0px;font-size:16px;padding-bottom:3px;line-height:1.5em;margin-right:0px;margin-left:0px;text-indent:0em;margin-top:0px;margin-bottom:0px;text-align:justify;padding-right:0px;\"><span leaf=\"\">TradingAgents-CN 是一个基于多智能体大语言模型的中文金融交易决策框架，专为中文用户设计，支持 A 股、港股、美股市场的股票分析和投资决策。</span></p>\n   <ul style=\"margin-left:0px;padding-top:0px;list-style-type:disc;padding-left:1rem;padding-bottom:0px;margin-top:8px;margin-bottom:8px;margin-right:0px;padding-right:0px;\" class=\"list-paddingleft-1\">\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">多智能体协作架构，包括基本面、技术面、新闻面和社交媒体分析师，实现结构化辩论与风险管理</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">原生支持 OpenAI 及 Google AI 生态系统，多厂商、多模型灵活选择与统一适配器架构</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">完整企业级开发工具链，包含分支保护、安全策略、测试覆盖及部署指南</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">智能新闻过滤模块，多层次质量评估保障信息准确性</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">现代化响应式 Web 界面，提供实时进度跟踪、多维度专业报告展示及一键导出功能</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">支持多市场股票代码格式输入，并可根据需求选择不同深度的研究等级以满足快速或全面分析需求</span></p>\n    </li>\n   </ul>\n   <h2 data-tool=\"mdnice编辑器\" style=\"padding-top: 0px;padding-bottom: 0px;padding-left: 10px;padding-right: 0px;display: block;color: rgb(0, 150, 136);margin-top: 0.2rem;margin-right: auto;margin-bottom: 0.2rem;margin-left: auto;border-left-width: 3px;border-left-style: solid;border-left-color: rgb(0, 150, 136);\"><span style=\"display: none;\"></span><span style=\"font-weight:bold;letter-spacing:0em;display:block;font-size:22px;line-height:1.5em;text-align:left;\"><span leaf=\"\">google/tunix</span><span style=\"font-size: 0.58em;font-weight: normal;font-style: italic;color: graytext;display: block;text-decoration: underline;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;\"><span leaf=\"\"><a href=\"https://github.com/google/tunix\" target=\"_blank\">https://github.com/google/tunix</a></span></span></span><span style=\"display: none;\"></span></h2>\n   <p data-tool=\"mdnice编辑器\" style=\"padding-top:3px;letter-spacing:0em;padding-left:0px;font-size:16px;padding-bottom:3px;line-height:1.5em;margin-right:0px;margin-left:0px;text-indent:0em;margin-top:0px;margin-bottom:0px;text-align:justify;padding-right:0px;\"><span leaf=\"\">Stars:&nbsp;</span><code style=\"font-size: 14px;line-height: 1.2em;letter-spacing: 0em;background-attachment: scroll;background-clip: border-box;background-color: rgba(27, 31, 35, 0.05);background-image: none;background-origin: padding-box;background-position-x: 0%;background-position-y: 0%;background-repeat: no-repeat;background-size: auto;width: auto;height: auto;margin-top: 0px;margin-bottom: 0px;margin-left: 2px;margin-right: 2px;padding-top: 2px;padding-bottom: 2px;padding-left: 4px;padding-right: 4px;border-top-style: none;border-bottom-style: none;border-left-style: none;border-right-style: none;border-top-width: 3px;border-bottom-width: 3px;border-left-width: 3px;border-right-width: 3px;border-top-color: rgb(0, 0, 0);border-bottom-color: rgba(0, 0, 0, 0.4);border-left-color: rgba(0, 0, 0, 0.4);border-right-color: rgba(0, 0, 0, 0.4);border-top-left-radius: 4px;border-top-right-radius: 4px;border-bottom-right-radius: 4px;border-bottom-left-radius: 4px;overflow-wrap: break-word;font-family: Consolas, Monaco, Menlo, monospace;word-break: break-all;color: rgb(0, 150, 136);\"><span leaf=\"\">844</span></code><span leaf=\"\">&nbsp; License:&nbsp;</span><code style=\"font-size: 14px;line-height: 1.2em;letter-spacing: 0em;background-attachment: scroll;background-clip: border-box;background-color: rgba(27, 31, 35, 0.05);background-image: none;background-origin: padding-box;background-position-x: 0%;background-position-y: 0%;background-repeat: no-repeat;background-size: auto;width: auto;height: auto;margin-top: 0px;margin-bottom: 0px;margin-left: 2px;margin-right: 2px;padding-top: 2px;padding-bottom: 2px;padding-left: 4px;padding-right: 4px;border-top-style: none;border-bottom-style: none;border-left-style: none;border-right-style: none;border-top-width: 3px;border-bottom-width: 3px;border-left-width: 3px;border-right-width: 3px;border-top-color: rgb(0, 0, 0);border-bottom-color: rgba(0, 0, 0, 0.4);border-left-color: rgba(0, 0, 0, 0.4);border-right-color: rgba(0, 0, 0, 0.4);border-top-left-radius: 4px;border-top-right-radius: 4px;border-bottom-right-radius: 4px;border-bottom-left-radius: 4px;overflow-wrap: break-word;font-family: Consolas, Monaco, Menlo, monospace;word-break: break-all;color: rgb(0, 150, 136);\"><span leaf=\"\">Apache-2.0</span></code></p>\n   <p data-tool=\"mdnice编辑器\" style=\"padding-top:3px;letter-spacing:0em;padding-left:0px;font-size:16px;padding-bottom:3px;line-height:1.5em;margin-right:0px;margin-left:0px;text-indent:0em;margin-top:0px;margin-bottom:0px;text-align:justify;padding-right:0px;\"><span leaf=\"\">tunix 是一个基于 JAX 的大型语言模型（LLM）后训练库。</span></p>\n   <ul style=\"margin-left:0px;padding-top:0px;list-style-type:disc;padding-left:1rem;padding-bottom:0px;margin-top:8px;margin-bottom:8px;margin-right:0px;padding-right:0px;\" class=\"list-paddingleft-1\">\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">支持监督微调、强化学习（RL）、知识蒸馏等多种后训练方法</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">提供全权重微调和参数高效微调（PEFT），支持 LoRA/Q-LoRA 层</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">实现多种强化学习算法，如 PPO、GRPO 和 GSPO-token，及偏好对齐的直接偏好优化（DPO）</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">知识蒸馏包含经典的 Logit 策略以及注意力传递与特征投影策略，适配不同架构模型间的对齐需求</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">组件模块化设计，便于复用和扩展，自带分布式训练支持，包括数据并行、FSDP 和张量并行等策略，并针对 TPU 加速优化</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">正在开发中，将增加异步 rollout、多轮多步交互、高级 RL 算法及更强大的可扩展性功能，同时提供丰富示例和教程以助入门</span></p>\n    </li>\n   </ul>\n   <h2 data-tool=\"mdnice编辑器\" style=\"padding-top: 0px;padding-bottom: 0px;padding-left: 10px;padding-right: 0px;display: block;color: rgb(0, 150, 136);margin-top: 0.2rem;margin-right: auto;margin-bottom: 0.2rem;margin-left: auto;border-left-width: 3px;border-left-style: solid;border-left-color: rgb(0, 150, 136);\"><span style=\"display: none;\"></span><span style=\"font-weight:bold;letter-spacing:0em;display:block;font-size:22px;line-height:1.5em;text-align:left;\"><span leaf=\"\">kyegomez/LongNet</span><span style=\"font-size: 0.58em;font-weight: normal;font-style: italic;color: graytext;display: block;text-decoration: underline;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;\"><span leaf=\"\"><a href=\"https://github.com/kyegomez/LongNet\" target=\"_blank\">https://github.com/kyegomez/LongNet</a></span></span></span><span style=\"display: none;\"></span></h2>\n   <p data-tool=\"mdnice编辑器\" style=\"padding-top:3px;letter-spacing:0em;padding-left:0px;font-size:16px;padding-bottom:3px;line-height:1.5em;margin-right:0px;margin-left:0px;text-indent:0em;margin-top:0px;margin-bottom:0px;text-align:justify;padding-right:0px;\"><span leaf=\"\">Stars:&nbsp;</span><code style=\"font-size: 14px;line-height: 1.2em;letter-spacing: 0em;background-attachment: scroll;background-clip: border-box;background-color: rgba(27, 31, 35, 0.05);background-image: none;background-origin: padding-box;background-position-x: 0%;background-position-y: 0%;background-repeat: no-repeat;background-size: auto;width: auto;height: auto;margin-top: 0px;margin-bottom: 0px;margin-left: 2px;margin-right: 2px;padding-top: 2px;padding-bottom: 2px;padding-left: 4px;padding-right: 4px;border-top-style: none;border-bottom-style: none;border-left-style: none;border-right-style: none;border-top-width: 3px;border-bottom-width: 3px;border-left-width: 3px;border-right-width: 3px;border-top-color: rgb(0, 0, 0);border-bottom-color: rgba(0, 0, 0, 0.4);border-left-color: rgba(0, 0, 0, 0.4);border-right-color: rgba(0, 0, 0, 0.4);border-top-left-radius: 4px;border-top-right-radius: 4px;border-bottom-right-radius: 4px;border-bottom-left-radius: 4px;overflow-wrap: break-word;font-family: Consolas, Monaco, Menlo, monospace;word-break: break-all;color: rgb(0, 150, 136);\"><span leaf=\"\">711</span></cod