  "content": "<html>\n <head></head>\n <body>\n  <h3 data-mpa-powered-by=\"yiban.io\" style=\"outline:0px;visibility:visible;letter-spacing:0.544px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;\">\n   <div data-tools=\"135编辑器\" data-id=\"88402\" style=\"outline: 0px;line-height: 27.2px;widows: 1;visibility: visible;\">\n    <div data-tools=\"135编辑器\" data-id=\"88402\" style=\"outline: 0px;letter-spacing: 0.544px;line-height: 27.2px;visibility: visible;\">\n     <div data-style=\"line-height: 1.8; text-align: justify; font-size: 15px; letter-spacing: 0px; color: rgb(117, 114, 114);white-space: normal;\" style=\"outline: 0px;visibility: visible;\">\n      <div style=\"outline: 0px;visibility: visible;\">\n       <p style=\"margin-bottom: 8px;\"><span leaf=\"\"><img data-imgfileid=\"505150419\" class=\"rich_pages wxw-img\" data-ratio=\"0.42643923240938164\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"2345\" style=\"width: 100%;\" type=\"block\" data-backw=\"578\" data-backh=\"246\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=77cc8021&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_jpg%2FUicQ7HgWiaUb2cBzF9PCvq3vhIvtd7BOAStUPj5SPTiaHb1icODbjwKahVEVxs0QI1nibq8rthSfCRMCnedD0fOmibHA%2F640%3Fwx_fmt%3Djpeg%26from%3Dappmsg\"></span></p>\n      </div>\n     </div>\n    </div>\n   </div>\n  </h3>\n  <h3 style=\"outline:0px;visibility:visible;letter-spacing:0.544px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;\">\n   <div data-tools=\"135编辑器\" data-id=\"88402\" style=\"outline: 0px;line-height: 27.2px;widows: 1;visibility: visible;\">\n    <div data-tools=\"135编辑器\" data-id=\"88402\" style=\"outline: 0px;letter-spacing: 0.544px;line-height: 27.2px;visibility: visible;\">\n     <div data-style=\"line-height: 1.8; text-align: justify; font-size: 15px; letter-spacing: 0px; color: rgb(117, 114, 114);white-space: normal;\" style=\"outline: 0px;visibility: visible;\">\n      <div style=\"outline: 0px;visibility: visible;\">\n       <div style=\"outline: 0px;visibility: visible;\">\n        <hr style=\"outline: 0px;font-size: 17px;letter-spacing: 0.544px;visibility: visible;\">\n        <p style=\"margin-top: -1.2em;margin-right: 8px;margin-left: 8px;outline: 0px;font-size: 17px;letter-spacing: 0.544px;text-align: center;line-height: 1.75em;visibility: visible;\"><span style=\"outline: 0px;letter-spacing: 1px;visibility: visible;\"><strong style=\"outline: 0px;font-family: inherit;font-size: 1em;text-decoration: inherit;visibility: visible;\"><span style=\"background-color:rgb(127, 127, 127);outline:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;font-family:inherit;\"><span leaf=\"\">&nbsp;&nbsp;</span></span></strong><strong style=\"outline: 0px;font-size: 1em;font-family: inherit;text-decoration: inherit;visibility: visible;\"><span style=\"background-color:rgb(127, 127, 127);outline:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;font-family:inherit;\"><span leaf=\"\">新智元报道 &nbsp;</span></span></strong></span></p>\n       </div>\n      </div>\n     </div>\n    </div>\n   </div>\n  </h3>\n  <p style=\"margin-left:8px;outline:0px;visibility:visible;letter-spacing:0.544px;min-height:1em;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;margin-bottom:0px;margin-right:8px;text-align:center;\"><span style=\"outline: 0px;font-size: 12px;color: rgb(136, 136, 136);font-family: &quot;Helvetica Neue&quot;, Helvetica, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;letter-spacing: 1px;visibility: visible;\"><span leaf=\"\">编辑：好困</span></span></p>\n  <div powered-by=\"xiumi.us\" style=\"outline:0px;visibility:visible;letter-spacing:0.544px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;\">\n   <div style=\"outline: 0px;visibility: visible;\">\n    <p style=\"outline: 0px;visibility: visible;\"></p>\n    <h5 style=\"padding:10px;visibility:visible;letter-spacing:0.544px;font-size:14px;line-height:1.75em;margin-right:8px;margin-left:8px;border-radius:3px;outline:0px;word-spacing:1px !important;word-break:break-all !important;margin-top:10px;font-family:Arial, Helvetica, sans-serif;\"><span style=\"outline: 0px;letter-spacing: 1px;font-size: 15px;visibility: visible;\"><strong style=\"outline: 0px;visibility: visible;\"><span leaf=\"\">【新智元导读】</span><span leaf=\"\"><span textstyle=\"\" style=\"font-weight: normal;\">在杭州奥体中心演唱会现场，一套名为「Co-Sight 2.0」的AI系统成功保障了网络稳定，其背后是中兴通讯研发的、新近登顶Hugging Face&nbsp;</span></span><span leaf=\"\"><span textstyle=\"\" style=\"font-weight: normal;\">GAIA</span></span><span leaf=\"\"><span textstyle=\"\" style=\"font-weight: normal;\">全球权威榜单的超级智能体。</span></span></strong></span></h5>\n    <p></p>\n   </div>\n  </div>\n  <p data-pm-slice=\"0 0 []\" style=\"margin-left: 8px;margin-right: 8px;margin-bottom: 24px;line-height: 1.75em;\"><span style=\"font-weight:normal;letter-spacing:0.034em;font-size:15px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"mgpd4twb1d2u\"><span style=\"letter-spacing: 1px;font-size: 15px;\" mpa-font-style=\"mgpd54c31ddw\"><span leaf=\"\">演唱会现场，数万个手机屏幕汇成一片星海，</span><span leaf=\"\">网络性能正面临极限的挑战</span><span leaf=\"\">。</span></span></span></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;margin-bottom: 24px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:15px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"mgpd54c31xpo\"><span textstyle=\"\" style=\"letter-spacing: 1px;\">后台，没有一群焦头烂额的工程师，只有一套AI系统在冷静地调度。</span></span></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;margin-bottom: 24px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:15px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"mgpd54c31aml\"><span textstyle=\"\" style=\"letter-spacing: 1px;\">它预测到流量洪峰，提前规划了网络重路由方案，并派出一个「行动智能体」执行，同时还有一个「验证智能体」在旁监督，确保万无一失。</span></span></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;margin-bottom: 24px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:15px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"mgpd54c31cbk\"><span textstyle=\"\" style=\"letter-spacing: 1px;\">这不是科幻电影，而是发生在杭州奥体中心的真实一幕。</span></span></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;margin-bottom: 24px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:15px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"mgpd54c3c28\"><span textstyle=\"\" style=\"letter-spacing: 1px;\">这套系统的核心，正是刚刚登顶Hugging Face全球权威榜单的「中国造」超级智能体——Co-Sight 2.0。</span></span></p>\n  <p style=\"text-align: center;margin-top: 0px;margin-bottom: 0px;\"><span leaf=\"\"><img data-imgfileid=\"505095291\" class=\"rich_pages wxw-img\" data-ratio=\"0.5267857142857143\" data-s=\"300,640\" data-type=\"png\" data-w=\"112\" style=\"width: 85px;height: 40px;\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=6568e90c&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_png%2FUicQ7HgWiaUb3uEdSPKrwGNmZEOaaGyzVvZ8dTtE9jU1rFsda3llYbCZpmWfiazUYjWBLTGvlPpXucH8Q0lEUJN3Q%2F640%3Fwx_fmt%3Dpng%26from%3Dappmsg\"></span></p>\n  <p style=\"text-align: center;margin-bottom: 0px;margin-top: 8px;line-height: 1.75em;\"><span style=\"letter-spacing:1px;font-size:19px;\"><strong><span leaf=\"\">Hugging Face榜一被「中国造」拿下</span></strong></span></p>\n  <p style=\"text-align: center;margin-bottom: 24px;margin-top: 8px;line-height: 1.75em;\"><span style=\"letter-spacing:1px;font-size:19px;\"><strong><span leaf=\"\">Co-Sight2.0凭什么领跑全球？</span></strong></span></p>\n  <p style=\"text-align: center;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\"><img data-imgfileid=\"505150494\" class=\"rich_pages wxw-img js_insertlocalimg\" data-ratio=\"0.253125\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1280\" style=\"width: 100%;\" type=\"block\" data-backw=\"578\" data-backh=\"146\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=24a5cc27&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_jpg%2FUicQ7HgWiaUb0Hte1ibgObCpQM5nT6IMia2lxvMrMYLQHQdpaSCdrYo4bicZB7SLbtmDHdyLX0fcm0icB3ibmSmAoAa9w%2F640%3Fwx_fmt%3Djpeg%26from%3Dappmsg\"></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;margin-bottom: 24px;line-height: 1.75em;\"><span style=\"font-weight:normal;letter-spacing:0.034em;font-size:15px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"mgpd54c3180k\" data-mpa-action-id=\"mgpd5lml100q\" data-pm-slice=\"0 0 []\"><span leaf=\"\"><span textstyle=\"\" style=\"letter-spacing: 1px;\">在Meta与Hugging Face联合打造的GAIA评测基准</span></span><span style=\"letter-spacing: 1px;color: #888888;font-size: 13px;\" mpa-font-style=\"mgpd5lmd1gzo\"><span leaf=\"\">（覆盖复杂任务规划、跨工具调用、多模态理解等12类核心能力的全球权威榜单）</span></span><span leaf=\"\"><span textstyle=\"\" style=\"letter-spacing: 1px;\">中，中兴通讯开源的Co-Sight超级智能体2.0以87.04%的综合成绩蝉联榜首，其登顶底气源于对传统智能体三大核心痛点的精准击破：</span></span></span></p>\n  <p style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;margin-bottom:24px;margin-right:8px;\" nodeleaf=\"\"><img data-imgfileid=\"505150407\" class=\"rich_pages wxw-img\" data-ratio=\"0.2663891779396462\" data-type=\"png\" data-w=\"961\" style=\"background-color:transparent;width:100%;\" data-width=\"961\" data-height=\"256\" data-backw=\"562\" data-backh=\"150\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=3a66bf01&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_png%2FUicQ7HgWiaUb2cBzF9PCvq3vhIvtd7BOASQZXfuxOkJ99cNicMq7UttKskoZAiaOPnnvVicoHlWxQYs4eL61eicWfe8A%2F640%3Fwx_fmt%3Dpng%26from%3Dappmsg\"></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;margin-bottom: 24px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:15px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"mgpd54c31g3l\"><span textstyle=\"\" style=\"letter-spacing: 1px;\">这一突破并非偶然。中兴与中国移动联合开发的「多智能体协同赋能端到端网络自动化运维」方案，已在杭州奥体中心演唱会、西安大唐不夜城等场景验证实效。其中，前者实现监控人员投入减少30%，后者达成场景流量提升20%。</span></span></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;margin-bottom: 24px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:15px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"mgpd54c31gf\"><span textstyle=\"\" style=\"letter-spacing: 1px;\">不仅如此，该方案更斩获2025年GSMA Foundry网络效率及优化大奖，成为技术落地的有力佐证。</span></span></p>\n  <p style=\"text-align: center;margin-top: 0px;margin-bottom: 0px;\"><span leaf=\"\"><img data-imgfileid=\"505095291\" class=\"rich_pages wxw-img\" data-ratio=\"0.5267857142857143\" data-s=\"300,640\" data-type=\"png\" data-w=\"112\" style=\"width: 85px;height: 40px;\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=6568e90c&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_png%2FUicQ7HgWiaUb3uEdSPKrwGNmZEOaaGyzVvZ8dTtE9jU1rFsda3llYbCZpmWfiazUYjWBLTGvlPpXucH8Q0lEUJN3Q%2F640%3Fwx_fmt%3Dpng%26from%3Dappmsg\"></span></p>\n  <p style=\"text-align: center;margin-bottom: 0px;margin-top: 8px;line-height: 1.75em;\"><span style=\"letter-spacing:1px;font-size:19px;\"><strong><span leaf=\"\">从「痛点」到「突破」</span></strong></span></p>\n  <p style=\"text-align: center;margin-bottom: 0px;margin-top: 8px;line-height: 1.75em;\"><span style=\"letter-spacing:1px;font-size:19px;\"><strong><span leaf=\"\">Co-Sight 2.0以创新架构领跑</span></strong></span></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;margin-bottom: 24px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:15px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"mgpd54c31n2l\"><span textstyle=\"\" style=\"letter-spacing: 1px;\">据前瞻产业研究院数据，2025年国内智能体相关公司单笔融资均值较2023年增长280%，但快速增长的背后仍面临诸多痛点：</span></span></p>\n  <div style=\"line-height: 1.75;letter-spacing: 1px;word-break: break-word;color: rgb(91, 91, 91);border-left: 8px solid rgba(158, 158, 158, 0.3);border-radius: 5px;background: rgba(158, 158, 158, 0.1);padding-top: 24px;padding-bottom: 24px;padding-right: 8px;margin-top: 0px;margin-bottom: 0px;\">\n   <p style=\"font-size: 15px;margin: 0 8px;padding-left: 8px;padding-right: 8px;line-height: 1.75em;letter-spacing: 1px;\"><span leaf=\"\">智能体在垂直行业遭遇「私域鸿沟」难以落地、暴力检索信息利用率低、扁平化记忆引发的「认知短视」、AI黑盒化带来的决策信任危机等，让多数智能体始终停留在「能用」却「不敢放心用」的阶段。</span></p>\n  </div>\n  <p style=\"margin-left: 8px;margin-right: 8px;margin-bottom: 24px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:15px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"mgpd54c3tb9\"><span textstyle=\"\" style=\"letter-spacing: 1px;\">中兴通讯Co-Sight 2.0之所以能在GAIA榜单中脱颖而出，核心在于它针对传统智能体的核心短板，给出了能落地、可验证的解决方案。</span></span></p>\n  <div style=\"margin-bottom: 0px;\">\n   <p style=\"line-height: 1.75em;margin: 0px 8px 8px;\"><strong style=\"letter-spacing: 0.578px;font-family: mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-size: var(--articleFontsize);\"><span leaf=\"\"><img data-imgfileid=\"505100592\" class=\"rich_pages wxw-img\" data-ratio=\"0.25\" data-s=\"300,640\" data-type=\"png\" data-w=\"292\" style=\"height: 20px;width: 81px;\" type=\"block\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=0356db0c&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_png%2FUicQ7HgWiaUb351381bTy5MO2IN89mV41M88GEiaCCibDxJoaQjYV6HfRtafnmEmfM3R1p0tmkHgBOVuXBD6UJKpsQ%2F640%3Fwx_fmt%3Dpng%26from%3Dappmsg\"></span></strong></p>\n  </div>\n  <p style=\"margin-bottom: 0px;line-height: 1.75em;margin-left: 8px;margin-right: 8px;\"><span style=\"letter-spacing: 1px;\"><strong><span leaf=\"\">全链路可信计算框架：筑牢数据信任基石</span></strong></span></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;margin-bottom: 24px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:15px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"mgpd54c34ip\"><span textstyle=\"\" style=\"letter-spacing: 1px;\">针对通信行业「认知断层（难获隐形知识）」与「数据壁垒（跨系统数据难关联）」，Co-Sight 2.0构建「可信信息金字塔」五级架构，为每一步数据处理打上「可信钢印」：</span></span></p>\n  <ul style=\"margin-left: 8px;margin-right: 8px;\" class=\"list-paddingleft-1\">\n   <li style=\"font-weight:bold;\">\n    <p style=\"margin-bottom: 24px;line-height: 1.75em;\"><span mpa-font-style=\"mgpd54c31nxj\" style=\"font-size: 15px;\"><strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"letter-spacing: 1px;font-weight: bold;\">五级架构</span></span></strong><strong><span l