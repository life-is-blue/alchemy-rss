  "content": "\n \n \n  <section style=\"text-align: center;margin-top: 0px;margin-bottom: 0px;\" nodeleaf=\"\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/ab181027-b42b-47a6-b8e6-8c59d335bb00/public\" class=\"rich_pages wxw-img js_insertlocalimg\" data-ratio=\"0.33611111111111114\" data-s=\"300,640\" data-type=\"png\" data-w=\"1080\" style=\"width: 100%;\" type=\"block\" data-backw=\"578\" data-backh=\"194\" data-imgfileid=\"100012076\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/ab181027-b42b-47a6-b8e6-8c59d335bb00/public\">\n  </section>\n  <section style=\"margin-top: 0px;margin-bottom: 0px;\" nodeleaf=\"\">\n   <iframe class=\"video_iframe rich_pages\" data-src=\"https://mp.weixin.qq.com/mp/readtemplate?t=pages/video_player_tmpl&amp;action=mpvideo&amp;auto=0&amp;vid=wxv_3927161829100617728\" data-mpvid=\"wxv_3927161829100617728\" data-vidtype=\"2\" data-cover=\"http%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_jpg%2FkfTykfMJicWN9BnEhyLfbhncM32bftYjwOibr6GMhgejUnEnBjEBEcqSydr0vMIGQzJoJyQ6GiakUPUPJ5btsLEww%2F0%3Fwx_fmt%3Djpeg\"></iframe>\n  </section>\n  <section style=\"text-align: center;margin-top: 0px;margin-bottom: 0px;\" nodeleaf=\"\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/83bc5f9b-99d3-4515-4710-7ccd77937500/public\" class=\"rich_pages wxw-img\" data-ratio=\"1.5694444444444444\" data-s=\"300,640\" data-type=\"png\" data-w=\"1080\" style=\"width: 100%;\" type=\"block\" data-backw=\"578\" data-backh=\"907\" data-imgfileid=\"100012082\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/83bc5f9b-99d3-4515-4710-7ccd77937500/public\">\n  </section>\n  <section style=\"box-sizing: border-box;font-style: normal;font-weight: 400;text-align: justify;font-size: 16px;color: rgb(62, 62, 62);\" data-pm-slice=\"0 0 []\">\n   <section style=\"margin: 30px 0% 10px;text-align: left;justify-content: flex-start;display: flex;flex-flow: row;box-sizing: border-box;\">\n    <section style=\"align-self:flex-start;padding:0px 0px 10px 10px;flex:0 0 auto;display:inline-block;width:100%;vertical-align:top;box-sizing:border-box;\">\n     <section style=\"display: flex;flex-flow: row;text-align: justify;justify-content: flex-start;box-sizing: border-box;\">\n      <section style=\"display: inline-block;vertical-align: top;width: auto;margin: -20px 0px 0px;min-width: 10%;max-width: 100%;flex: 0 0 auto;height: auto;align-self: flex-start;padding: 0px 5px 0px 0px;box-sizing: border-box;\">\n       <section style=\"margin: 0px 0%;text-align: center;box-sizing: border-box;\">\n        <section style=\"display: inline-block;vertical-align: top;box-sizing: border-box;\">\n         <section style=\"display: inline-block;vertical-align: top;border-right: 0.35em solid rgb(97, 92, 237);border-bottom: 0.65em solid rgb(97, 92, 237);max-width: 5% !important;border-top: 0.65em solid transparent !important;border-left: 0.35em solid transparent !important;box-sizing: border-box;\">\n          <svg viewBox=\"0 0 1 1\" style=\"float:left;line-height:0;width:0;vertical-align:top;\"></svg>\n         </section>\n         <section style=\"background-color:rgb(146, 146, 255);padding:0px 8px;max-width:95% !important;display:inline-block;letter-spacing:0px;vertical-align:top;font-size:19px;line-height:2;box-sizing:border-box;\">\n          <p style=\"margin: 0px;padding: 0px;box-sizing: border-box;\"><b style=\"box-sizing: border-box;\"><span leaf=\"\">Q1</span></b></p>\n         </section>\n        </section>\n       </section>\n      </section>\n      <section style=\"display: inline-block;width: auto;vertical-align: top;flex: 100 100 0%;align-self: flex-start;height: auto;padding: 3px 0px 3px 10px;background-color: rgb(97, 92, 237);box-sizing: border-box;\">\n       <section style=\"font-size:15px;box-sizing:border-box;\">\n        <p style=\"margin: 0px;padding: 0px;box-sizing: border-box;\"><strong style=\"box-sizing: border-box;\"><span leaf=\"\">LHM是什么？</span></strong></p>\n       </section>\n      </section>\n     </section>\n     <section style=\"text-align: justify;justify-content: flex-start;display: flex;flex-flow: row;box-sizing: border-box;\">\n      <section style=\"display: inline-block;width: 100%;vertical-align: top;padding: 10px 10px 0px;align-self: flex-start;flex: 0 0 auto;box-sizing: border-box;\">\n       <section style=\"font-size: 15px;color: rgb(106, 106, 106);box-sizing: border-box;\">\n        <p style=\"white-space: normal;margin: 0px;padding: 0px;box-sizing: border-box;\"><span leaf=\"\">LHM是一个单视角输入、端到端的Transformer模型，依赖于人体先验模型SMPL-X进行驱动，最终输出一个可驱动的高斯3D人体模型。你可以把LHM看作一个“魔法工具”，它能帮你用一张照片快速生成一个可以在电脑里动起来的3D数字人。</span></p>\n        <p style=\"white-space: normal;margin: 0px;padding: 0px;box-sizing: border-box;\"><span leaf=\"\"><br></span></p>\n        <section style=\"text-align: center;\" nodeleaf=\"\">\n         <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/e292c3a5-5e91-443e-1855-1aec6aba5d00/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.725\" data-s=\"300,640\" data-type=\"png\" data-w=\"1080\" type=\"block\" data-imgfileid=\"100012086\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/e292c3a5-5e91-443e-1855-1aec6aba5d00/public\">\n        </section>\n        <p style=\"white-space: normal;margin: 0px;padding: 0px;box-sizing: border-box;text-align: center;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 12px;\">LHM架构图</span></span></p>\n       </section>\n      </section>\n     </section>\n    </section>\n   </section>\n  </section>\n  <section style=\"box-sizing: border-box;font-style: normal;font-weight: 400;text-align: justify;font-size: 16px;color: rgb(62, 62, 62);\" data-pm-slice=\"0 0 []\">\n   <section style=\"margin: 30px 0% 10px;text-align: left;justify-content: flex-start;display: flex;flex-flow: row;box-sizing: border-box;\">\n    <section style=\"align-self:flex-start;padding:0px 0px 10px 10px;flex:0 0 auto;display:inline-block;width:100%;vertical-align:top;box-sizing:border-box;\">\n     <section style=\"display: flex;flex-flow: row;text-align: justify;justify-content: flex-start;box-sizing: border-box;\">\n      <section style=\"display: inline-block;vertical-align: top;width: auto;margin: -20px 0px 0px;min-width: 10%;max-width: 100%;flex: 0 0 auto;height: auto;align-self: flex-start;padding: 0px 5px 0px 0px;box-sizing: border-box;\">\n       <section style=\"margin: 0px 0%;text-align: center;box-sizing: border-box;\">\n        <section style=\"display: inline-block;vertical-align: top;box-sizing: border-box;\">\n         <section style=\"display: inline-block;vertical-align: top;border-right: 0.35em solid rgb(97, 92, 237);border-bottom: 0.65em solid rgb(97, 92, 237);max-width: 5% !important;border-top: 0.65em solid transparent !important;border-left: 0.35em solid transparent !important;box-sizing: border-box;\">\n          <svg viewBox=\"0 0 1 1\" style=\"float:left;line-height:0;width:0;vertical-align:top;\"></svg>\n         </section>\n         <section style=\"background-color:rgb(146, 146, 255);padding:0px 8px;max-width:95% !important;display:inline-block;letter-spacing:0px;vertical-align:top;font-size:19px;line-height:2;box-sizing:border-box;\">\n          <p style=\"margin: 0px;padding: 0px;box-sizing: border-box;\"><b style=\"box-sizing: border-box;\"><span leaf=\"\">Q2</span></b></p>\n         </section>\n        </section>\n       </section>\n      </section>\n      <section style=\"display: inline-block;width: auto;vertical-align: top;flex: 100 100 0%;align-self: flex-start;height: auto;padding: 3px 0px 3px 10px;background-color: rgb(97, 92, 237);box-sizing: border-box;\">\n       <section style=\"font-size:15px;box-sizing:border-box;\">\n        <p style=\"margin: 0px;padding: 0px;box-sizing: border-box;\"><strong style=\"box-sizing: border-box;\"><span leaf=\"\">如何将单张图片Token化？</span></strong></p>\n       </section>\n      </section>\n     </section>\n     <section style=\"text-align: justify;justify-content: flex-start;display: flex;flex-flow: row;box-sizing: border-box;\">\n      <section style=\"display: inline-block;width: 100%;vertical-align: top;padding: 10px 10px 0px;align-self: flex-start;flex: 0 0 auto;box-sizing: border-box;\">\n       <section style=\"font-size: 15px;color: rgb(106, 106, 106);box-sizing: border-box;\">\n        <p style=\"white-space: normal;margin: 0px;padding: 0px;box-sizing: border-box;\"><span leaf=\"\">我们通过Vision Transformer技术将单张图片拆解为小块，并借助Meta的Mae模型编码身体特征。为获取更精细的人体头部特征，我们设计了Head Tokenization方式（借鉴DINOv2网络结构），通过提取多感受的特征信息，并结合MLP映射，捕捉头部的整体结构细节。</span></p>\n       </section>\n      </section>\n     </section>\n    </section>\n   </section>\n  </section>\n  <section style=\"box-sizing: border-box;font-style: normal;font-weight: 400;text-align: justify;font-size: 16px;color: rgb(62, 62, 62);\" data-pm-slice=\"0 0 []\">\n   <section style=\"margin: 30px 0% 10px;text-align: left;justify-content: flex-start;display: flex;flex-flow: row;box-sizing: border-box;\">\n    <section style=\"align-self:flex-start;padding:0px 0px 10px 10px;flex:0 0 auto;display:inline-block;width:100%;vertical-align:top;box-sizing:border-box;\">\n     <section style=\"display: flex;flex-flow: row;text-align: justify;justify-content: flex-start;box-sizing: border-box;\">\n      <section style=\"display: inline-block;vertical-align: top;width: auto;margin: -20px 0px 0px;min-width: 10%;max-width: 100%;flex: 0 0 auto;height: auto;align-self: flex-start;padding: 0px 5px 0px 0px;box-sizing: border-box;\">\n       <section style=\"margin: 0px 0%;text-align: center;box-sizing: border-box;\">\n        <section style=\"display: inline-block;vertical-align: top;box-sizing: border-box;\">\n         <section style=\"display: inline-block;vertical-align: top;border-right: 0.35em solid rgb(97, 92, 237);border-bottom: 0.65em solid rgb(97, 92, 237);max-width: 5% !important;border-top: 0.65em solid transparent !important;border-left: 0.35em solid transparent !important;box-sizing: border-box;\">\n          <svg viewBox=\"0 0 1 1\" style=\"float:left;line-height:0;width:0;vertical-align:top;\"></svg>\n         </section>\n         <section style=\"background-color:rgb(146, 146, 255);padding:0px 8px;max-width:95% !important;display:inline-block;letter-spacing:0px;vertical-align:top;font-size:19px;line-height:2;box-sizing:border-box;\">\n          <p style=\"margin: 0px;padding: 0px;box-sizing: border-box;\"><b style=\"box-sizing: border-box;\"><span leaf=\"\">Q3</span></b></p>\n         </section>\n        </section>\n       </section>\n      </section>\n      <section style=\"display: inline-block;width: auto;vertical-align: top;flex: 100 100 0%;align-self: flex-start;height: auto;padding: 3px 0px 3px 10px;background-color: rgb(97, 92, 237);box-sizing: border-box;\">\n       <section style=\"font-size:15px;box-sizing:border-box;\">\n        <p style=\"margin: 0px;padding: 0px;box-sizing: border-box;\"><strong style=\"box-sizing: border-box;\"><span leaf=\"\">如何得到可驱动的3D高斯模型？</span></strong></p>\n       </section>\n      </section>\n     </section>\n     <section style=\"text-align: justify;justify-content: flex-start;display: flex;flex-flow: row;box-sizing: border-box;\">\n      <section style=\"display: inline-block;width: 100%;vertical-align: top;padding: 10px 10px 0px;align-self: flex-start;flex: 0 0 auto;box-sizing: border-box;\">\n       <section style=\"font-size: 15px;color: rgb(106, 106, 106);box-sizing: border-box;\">\n        <p style=\"white-space: normal;margin: 0px;padding: 0px;box-sizing: border-box;\"><span leaf=\"\">我们基于人体先验模型SMPL-X，基于Transformer回归出五个关键高斯特征：坐标偏移、透视程度、表面颜色值、高斯大小和旋转向量。这些特征定义了3D模型的形状、颜色和动态表现能力。&nbsp;</span></p>\n        <p style=\"white-space: normal;margin: 0px;padding: 0px;box-sizing: border-box;\"><span leaf=\"\"><br></span></p>\n        <section style=\"text-align: center;\" nodeleaf=\"\">\n         <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/e5462e0a-156b-4bf4-9aec-cac0becd9f00/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.2759259259259259\" data-s=\"300,640\" data-type=\"png\" data-w=\"1080\" type=\"block\" data-imgfileid=\"100012087\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/e5462e0a-156b-4bf4-9aec-cac0becd9f00/public\">\n        </section>\n        <p style=\"white-space: normal;margin: 0px;padding: 0px;box-sizing: border-box;text-align: center;\"><span leaf=\"\" data-pm-slice=\"0 0 []\"><span textstyle=\"\" style=\"font-size: 12px;\">3D高斯模型生成pipeline</span></span></p>\n        <p style=\"white-space: normal;margin: 0px;padding: 0px;box-sizing: border-box;text-align: center;\"><span leaf=\"\" data-pm-slice=\"0 0 []\"><br></span></p>\n        <p style=\"white-space: normal;margin: 0px;padding: 0px;box-sizing: border-box;\" data-pm-slice=\"0 0 []\"><span data-type=\"text\"><span leaf=\"\">通过高斯渲染技术，得到T-pose</span></span><span data-type=\"text\"><span leaf=\"\">下的人体先验图，并与SMPL-X建立一</span></span><span data-type=\"text\"><span leaf=\"\">一映射关系，就可以直接索引SMPL-X中的骨骼，从而实现让3D数字人动起来的效果，最终得到一个真实且可驱动的3D高斯模型。</span></span></p>\n       </section>\n      </section>\n     </section>\n    </section>\n   </section>\n  </section>\n  <section style=\"box-sizing: border-box;font-style: normal;font-weight: 400;text-align: justify;font-size: 16px;color: rgb(62, 62, 62);\" data-pm-slice=\"0 0 []\">\n   <section style=\"margin: 30px 0% 10px;text-align: left;justify-content: flex-start;display: flex;flex-flow: row;box-sizing: border-box;\">\n    <section style=\"align-self:flex-start;padding:0px 0px 10px 10px;flex:0 0 auto;display:inline-block;width:100%;vertical-align:top;box-sizing:border-box;\">\n     <section style=\"display: flex;flex-flow: row;text-align: justify;justify-content: flex-start;box-sizing: border-box;\">\n      <section style=\"display: inline-block;vertical-align: top;width: auto;margin: -20px 0px 0px;min-width: 10%;max-width: 100%;flex: 0 0 auto;height: auto;align-self: flex-start;padding: 0px 5px 0px 0px;box-sizing: border-box;\">\n       <section style=\"margin: 0px 0%;text-align: center;box-sizing: border-box;\">\n        <section style=\"display: inline-block;vertical-align: top;box-sizing: border-box;\">\n         <section style=\"display: inline-block;vertical-align: top;border-right: 0.35em solid rgb(97, 92, 237);border-bottom: 0.65em solid rgb(97, 92, 237);max-width: 5% !important;border-top: 0.65em solid transparent !important;border-left: 0.35em solid transparent !important;box-sizing: border-box;\">\n          <svg viewBox=\"0 0 1 1\" style=\"float:left;line-height:0;width:0;vertical-align:top;\"></svg>\n         </section>\n         <section style=\"background-color:rgb(146, 146, 255);padding:0px 8px;max-width:95% !important;display:inline-block;letter-spacing:0px;vertical-align:top;font-size:19px;line-height:2;box-sizing:border-box;\">\n          <p style=\"margin: 0px;padding: 0px;box-sizing: border-box;\"><b style=\"box-sizing: border-box;\"><span leaf=\"\">Q4</span></b></p>\n         </section>\n        </section>\n       </section>\n      </section>\n      <section style=\"display: inline-block;width: auto;vertical-align: top;flex: 100 100 0%;align-self: flex-start;height: auto;padding: 3px 0px 3px 10px;background-color: rgb(97, 92, 237);box-sizing: border-box;\">\n       <section style=\"font-size:15px;box-sizing:border-box;\">\n        <p style=\"margin: 0px;padding: 0px;box-sizing: border-box;\"><strong style=\"box-sizing: border-box;\"><span leaf=\"\">如何有效的将2D与3D Token结合？</span></strong></p>\n       </section>\n      </section>\n     </section>\n     <section style=\"text-align: justify;justify-content: flex-start;display: flex;flex-flow: row;box-sizing: border-box;\">\n      <section style=\"display: inline-block;width: 100%;vertical-align: top;padding: 10px 10px 0px;align-self: flex-start;flex: 0 0 auto;box-sizing: border-box;\">\n       <section style=\"font-size: 15px;color: rgb(106, 106, 106);box-sizing: border-box;\">\n        <p style=\"white-space: normal;margin: 0px;padding: 0px;box-sizing: border-box;\"><span leaf=\"\">我们提出了Body-Head Transformer架构，借鉴了多模态Transformer（SD3）的设计理念，通过自适应Token和多层次Self-Attention机制，有效融合2D与3D Token。具体来说，我们先将头部Token输入到Multi-modality Transformer中学习头部特征，再将其与身体的随机Token结合，输入到Body Multi-modality Transformer 中，同步学习头部和身体的特征。</span></p>\n        <p style=\"white-space: normal;margin: 0px;padding: 0px;box-sizing: border-box;\"><span leaf=\"\"><br></span></p>\n        <article data-clipboard-cangjie=\"[&quot;root&quot;,{},[&quot;p&quot;,{&quot;ind&quot;:{&quot;left&quot;:0},&quot;uuid&quot;:&quot;m8zc1isgoow7mfib4y&quot;},[&quot;img&quot;,{&quot;uuid&quot;:&quot;r5fqpz&quot;,&quot;name&quot;:&quot;截屏2025-04-02 10.53.24.png&quot;,&quot;size&quot;:1362499,&quot;width&quot;:748,&quot;height&quot;:254.08900999091736,&quot;src&quot;:&quot;https://alidocs.dingtalk.com/core/api/resources/img/5eecdaf48460cde51b386278bcdf362e91beea78b7eade5158e70b814913bc360a414d3de9277d871abf3af1cbd75249ebae0b4c9d8a983c9b0baa24efb505fbd08cd348ae928d30475fa97a2789d3aff15f3b62837133a8fc653b69905bac42?tmpCode=d24f9946-527a-4108-87ed-1af857aea439&quot;,&quot;extraData&quot;:{&quot;resourceId&quot;:&quot;e8ac1668-adbd-4872-8e91-b916fc86f359&quot;,&quot;metaData&quot;:{&quot;size&quot;:1362499,&quot;originWidth&quot;:2202,&quot;originHeight&quot;:748,&quot;format&quot;:&quot;png&quot;,&quot;ratio&quot;:1}}},[&quot;span&quot;,{&quot;data-type&quot;:&quot;text&quot;},[&quot;span&quot;,{&quot;data-type&quot;:&quot;leaf&quot;},&quot;&quot;]]]]]\" data-identifier-application__slash__x-cangjie-fragment=\"\" data-identifier-application__slash__x-doc-key=\"1GXn4L3QyJdknDQ4\" data-pm-slice=\"0 0 []\">\n         <section style=\"text-align:left;text-indent:0;margin-left:0;margin-top:0;margin-bottom:0;\" nodeleaf=\"\">\n          <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/6f399a3e-cdfd-414b-4c18-a4c629f5b600/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.3398148148148148\" data-type=\"png\" data-w=\"1080\" style=\"width:748px;height:254.08900999091736px;\" data-imgfileid=\"100012088\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/6f399a3e-cdfd-414b-4c18-a4c629f5b600/public\">\n         </section>\n        </article>\n        <article data-clipboard-cangjie=\"[&quot;root&quot;,{},[&quot;p&quot;,{&quot;uuid&quot;:&quot;m8zc1n8y50cuot3xry2&quot;,&quot;jc&quot;:&quot;center&quot;},[&quot;span&quot;,{&quot;data-type&quot;:&quot;text&quot;},[&quot;span&quot;,{&quot;bold&quot;:false,&quot;sz&quot;:9,&quot;szUnit&quot;:&quot;pt&quot;,&quot;color&quot;:&quot;#A4A5A5&quot;,&quot;spacing&quot;:0.12000000000000001,&quot;data-type&quot;:&quot;leaf&quot;},&quot;Body-Head Transformer架构图&quot;]]]]\" data-identifier-application__slash__x-cangjie-fragment=\"\" data-identifier-application__slash__x-doc-key=\"1GXn4L3QyJdknDQ4\" data-pm-slice=\"0 0 []\">\n         <p style=\"text-align:center;text-indent:0;margin-left:0;margin-top:0;margin-bottom:0;\"><span data-type=\"text\" style=\"font-size:9pt;color:#A4A5A5;letter-spacing:0.12000000000000001pt;\"><span leaf=\"\">Body-Head Transformer架构图</span></span></p>\n        </article>\n       </section>\n      </section>\n     </section>\n    </section>\n   </section>\n  </section>\n  <section style=\"box-sizing: border-box;font-style: normal;font-weight: 400;text-align: justify;font-size: 16px;color: rgb(62, 62, 62);\" data-pm-slice=\"0 0 []\">\n   <section style=\"margin: 30px 0% 10px;text-align: left;justify-content: flex-start;display: flex;flex-flow: row;box-sizing: border-box;\">\n    <section style=\"align-self:flex-start;padding:0px 0px 10px 10px;flex:0 0 auto;display:inline-block;width:100%;vertical-align:top;box-sizing:border-box;\">\n     <section style=\"display: flex;flex-flow: row;text-align: justify;justify-content: flex-start;box-sizing: border-box;\">\n      <section style=\"display: inline-block;vertical-align: top;width: auto;margin: -20px 0px 0px;min-width: 10%;max-width: 100%;flex: 0 0 auto;height: auto;align-self: flex-start;padding: 0px 5px 0px 0px;box-sizing: border-box;\"