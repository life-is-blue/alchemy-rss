  "content": "\n \n \n  <h3 data-mpa-powered-by=\"yiban.io\" style=\"outline:0px;visibility:visible;letter-spacing:0.544px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;\">\n   <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"outline: 0px;line-height: 27.2px;widows: 1;visibility: visible;\">\n    <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"outline: 0px;letter-spacing: 0.544px;line-height: 27.2px;visibility: visible;\">\n     <section data-style=\"line-height: 1.8; text-align: justify; font-size: 15px; letter-spacing: 0px; color: rgb(117, 114, 114);white-space: normal;\" style=\"outline: 0px;visibility: visible;\">\n      <section style=\"outline: 0px;visibility: visible;\">\n       <section style=\"text-align: center;margin-bottom: 8px;\" nodeleaf=\"\">\n        <img class=\"rich_pages wxw-img\" data-backh=\"246\" data-backw=\"578\" data-imgfileid=\"505104611\" data-ratio=\"0.42643923240938164\" data-s=\"300,640\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/bf567d58-f8e9-4bee-369d-b84e61952300/public\" data-type=\"jpeg\" data-w=\"2345\" style=\"width: 100%;\" type=\"block\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/bf567d58-f8e9-4bee-369d-b84e61952300/public\">\n       </section>\n      </section>\n     </section>\n    </section>\n   </section></h3>\n  <h3 style=\"outline:0px;visibility:visible;letter-spacing:0.544px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;\">\n   <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"outline: 0px;line-height: 27.2px;widows: 1;visibility: visible;\">\n    <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"outline: 0px;letter-spacing: 0.544px;line-height: 27.2px;visibility: visible;\">\n     <section data-style=\"line-height: 1.8; text-align: justify; font-size: 15px; letter-spacing: 0px; color: rgb(117, 114, 114);white-space: normal;\" style=\"outline: 0px;visibility: visible;\">\n      <section style=\"outline: 0px;visibility: visible;\">\n       <section style=\"outline: 0px;visibility: visible;\">\n        <hr style=\"outline: 0px;font-size: 17px;letter-spacing: 0.544px;visibility: visible;\">\n        <p style=\"margin-top: -1.2em;margin-right: 8px;margin-left: 8px;outline: 0px;font-size: 17px;letter-spacing: 0.544px;line-height: 1.75em;visibility: visible;\"><span leaf=\"\"><br></span></p>\n        <p style=\"margin-top: -1.2em;margin-right: 8px;margin-left: 8px;outline: 0px;font-size: 17px;letter-spacing: 0.544px;text-align: center;line-height: 1.75em;visibility: visible;\"><span style=\"outline: 0px;letter-spacing: 1px;visibility: visible;\"><strong style=\"outline: 0px;font-family: inherit;font-size: 1em;text-decoration: inherit;visibility: visible;\"><span style=\"background-color:rgb(127, 127, 127);outline:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;font-family:inherit;\"><span leaf=\"\">&nbsp;&nbsp;</span></span></strong><strong style=\"outline: 0px;font-size: 1em;font-family: inherit;text-decoration: inherit;visibility: visible;\"><span style=\"background-color:rgb(127, 127, 127);outline:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;font-family:inherit;\"><span leaf=\"\">新智元报道 &nbsp;</span></span></strong></span></p>\n       </section>\n      </section>\n     </section>\n    </section>\n   </section></h3>\n  <section style=\"margin-left:8px;outline:0px;visibility:visible;letter-spacing:0.544px;min-height:1em;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;margin-bottom:0px;margin-right:8px;text-align:center;\">\n   <span style=\"outline: 0px;font-size: 12px;color: rgb(136, 136, 136);font-family: &quot;Helvetica Neue&quot;, Helvetica, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;letter-spacing: 1px;visibility: visible;\"><span leaf=\"\">编辑：LRST 好困</span></span>\n  </section>\n  <section powered-by=\"xiumi.us\" style=\"outline:0px;visibility:visible;letter-spacing:0.544px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;\">\n   <section style=\"outline: 0px;visibility: visible;\">\n    <section style=\"outline: 0px;visibility: visible;\">\n     <h5 style=\"padding:10px;visibility:visible;letter-spacing:0.544px;font-size:14px;line-height:1.75em;margin-right:8px;margin-left:8px;border-radius:3px;outline:0px;word-spacing:1px !important;word-break:break-all !important;margin-top:10px;font-family:Arial, Helvetica, sans-serif;\"><span style=\"outline: 0px;letter-spacing: 1px;font-size: 15px;visibility: visible;\"><strong style=\"outline: 0px;visibility: visible;\"><span leaf=\"\">【新智元导读】</span><span leaf=\"\"><span textstyle=\"\" style=\"font-weight: normal;\">通过蒙特卡洛树搜索筛选高难度样本，ThinkLite-VL仅用少量数据就能显著提升视觉语言模型的推理能力，无需知识蒸馏，为高效训练提供了新思路。</span></span><span leaf=\"\"><br></span></strong></span></h5>\n    </section>\n   </section>\n  </section>\n  <p data-pm-slice=\"0 0 []\" style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-top: 24px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">在大模型时代，视觉语言模型（Vision-Language Models, VLMs）正在从感知走向推理。在诸如图像问答、图表理解、科学推理等任务中，VLM不再只需要「看见」和「描述」，而是要能「看懂」和「想清楚」。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">然而，当前主流的推理能力提升方法普遍存在两个问题：</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">1. 训练样本质量参差不齐：常见的数据集虽然体量庞大，但真正「有挑战性」的样本比例较低。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">2. 过度依赖知识蒸馏：许多模型在训练时依赖大型模型（如GPT-4o）的推理过程作为教师信号，使得训练流程复杂且难以推广。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">这使得训练一个高性能的VLM成本极高，也限制了模型的自主学习能力。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;font-weight: bold;\">能否通过自我提升，训练出高性能的推理模型？</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">近日，来自马里兰大学，密歇根大学，和微软的团队联合提出了ThinkLite-VL模型试图打破这种依赖，探索「数据更少、能力更强」的可能性。</span></span></p>\n  <section style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;margin-bottom:0px;text-align:justify;margin-right:8px;\" nodeleaf=\"\">\n   <span></span>\n  </section>\n  <section data-pm-slice=\"0 0 []\" style=\"margin-bottom: 0px;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/a518fab6-d3fb-42a6-a72c-33a793336800/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.39814814814814814\" data-type=\"png\" data-w=\"1080\" style=\"width: 100%;\" data-width=\"1398\" data-height=\"556\" data-backw=\"578\" data-backh=\"230\" data-imgfileid=\"505103657\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/a518fab6-d3fb-42a6-a72c-33a793336800/public\">\n  </section>\n  <p style=\"text-align: justify;margin: 0px 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 13px;letter-spacing: 1px;color: rgb(136, 136, 136);\">论文链接：https://arxiv.org/pdf/2504.07934</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-bottom: 0px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 13px;letter-spacing: 1px;color: rgb(136, 136, 136);\">GitHub项目：https://github.com/si0wang/ThinkLite-VL</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 13px;letter-spacing: 1px;color: rgb(136, 136, 136);\">Hugging Face：https://huggingface.co/russwang/ThinkLite-VL-7B</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">论文主要关注一个核心问题：如果不给VLM额外的「教师指导」（如知识蒸馏），能否仅通过自身的反馈机制和强化学习训练，获得强大的推理能力？</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">直觉上，答案是肯定的：人类也可以通过不断尝试、失败和总结来提升自己的推理能力。但对模型而言，这需要我们解决一个关键挑战——如何准确判断哪些训练样本是「值得学」的？</span></span></p>\n  <section data-pm-slice=\"0 0 []\" nodeleaf=\"\" style=\"margin-left: 8px;margin-right: 8px;\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/993686e5-45cd-4540-aff3-d9dd0a751900/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.337037037037037\" data-type=\"png\" data-w=\"1080\" style=\"width: 100%;\" data-width=\"1280\" data-height=\"431\" data-backw=\"578\" data-backh=\"195\" data-imgfileid=\"505103658\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/993686e5-45cd-4540-aff3-d9dd0a751900/public\">\n  </section>\n  <section style=\"text-align: center;margin-top: 0px;margin-bottom: 0px;\">\n   <span leaf=\"\"><img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/47efb6c6-e260-4865-e30a-092b5639f000/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.5267857142857143\" data-s=\"300,640\" data-type=\"png\" data-w=\"112\" style=\"width: 85px;height: 40px;\" data-imgfileid=\"505095291\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/47efb6c6-e260-4865-e30a-092b5639f000/public\"></span>\n  </section>\n  <section style=\"text-align: center;margin-bottom: 0px;margin-top: 8px;line-height: 1.75em;\">\n   <span style=\"letter-spacing:1px;font-size:19px;\"><strong><span leaf=\"\">用MCTS判断「样本难度」，筛选高质量训练集</span></strong></span>\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-top: 24px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">ThinkLite-VL的最大创新在于：</span><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;font-weight: bold;\">用蒙特卡洛树搜索（Monte Carlo Tree Search, MCTS）来重新定义「样本难度」。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">研究人员首先从广泛使用的开源多模态训练数据集中收集了70k的样本，涵盖了三个关键的视觉任务：数学推理，自然图像理解和图表理解，具体的数据分布和来源如下表所示。</span></span></p>\n  <section data-pm-slice=\"0 0 []\" nodeleaf=\"\" style=\"margin-left: 8px;margin-right: 8px;\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/df9998e1-c303-44a3-4ac9-4c75a1187c00/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.32592592592592595\" data-type=\"png\" data-w=\"1080\" style=\"width: 100%;\" data-width=\"1280\" data-height=\"417\" data-backw=\"578\" data-backh=\"188\" data-imgfileid=\"505103659\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/df9998e1-c303-44a3-4ac9-4c75a1187c00/public\">\n  </section>\n  <section style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;text-align:justify;margin-right:8px;\" nodeleaf=\"\">\n   <span></span>\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">值得注意的是，为了避免大模型在回答过程中因为选择题选项中提供了正确答案而「蒙对」，研究人员将大部分的样本从选择题格式改成了开放问答格式，这样一来模型就必须依靠自身的推理能力真正理解题目并解决问题，真正的把题做对。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">之后，研究人员提出了一种基于蒙特卡洛树搜索（MCTS）的样本选择方式。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">具体来说，大模型将问题和图像作为输入，让模型通过蒙特卡洛树搜索进行一步步推理，然后记录模型需要通过多少次推理迭代才能得到正确答案。模型所需要的MCTS迭代次数越多，说明模型需要通过更多的探索和思考才能解决问题，表明该问题对于模型来说更难。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">整个过程中，只使用了VLM本身的LLM部分判断MCTS final answer的正确与否，模型通过解题成功的探索次数认识到哪些题是「难题」，并将其作为学习重点。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">在对所有的样本都进行MCTS之后，作者最终筛选出迭代次数大于5或在50次迭代内模型都无法解决的样本，总共11k，作为最终的训练集。</span></span></p>\n  <section data-pm-slice=\"0 0 []\" nodeleaf=\"\" style=\"text-align: center;\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/d4466fc8-9f5f-452b-475e-da75953de500/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.802675585284281\" data-type=\"png\" data-w=\"897\" style=\"width: 79%;flex-basis: auto;height: auto !important;\" data-width=\"897\" data-height=\"720\" data-backw=\"578\" data-backh=\"464\" data-imgfileid=\"505103660\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/d4466fc8-9f5f-452b-475e-da75953de500/public\">\n  </section>\n  <section style=\"text-align: center;margin-top: 0px;margin-bottom: 0px;\">\n   <span leaf=\"\"><img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/47efb6c6-e260-4865-e30a-092b5639f000/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.5267857142857143\" data-s=\"300,640\" data-type=\"png\" data-w=\"112\" style=\"width: 85px;height: 40px;\" data-imgfileid=\"505095291\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/47efb6c6-e260-4865-e30a-092b5639f000/public\"></span>\n  </section>\n  <section style=\"text-align: center;margin-bottom: 0px;margin-top: 8px;line-height: 1.75em;\">\n   <span style=\"letter-spacing:1px;font-size:19px;\"><strong><span leaf=\"\">强化学习训练：少样本+困难样本，推理效果更强</span></strong></span>\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-top: 24px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">研究人员基于Qwen2.5-VL-7B-Instruct，在选出的11k样本上使用GRPO进行了强化学习训练，得到了最终的模型 ThinkLite-VL-7B。相比于其他reasoning model来说，ThinkLite-VL-7B大大减少了训练数据量，并且没有蒸馏任何外部推理模型的知识。</span></span></p>\n  <section data-pm-slice=\"0 0 []\" nodeleaf=\"\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/8bf78605-34e6-4369-6197-547d1a4b7400/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.26296296296296295\" data-type=\"png\" data-w=\"1080\" style=\"width:100%;\" data-width=\"1280\" data-height=\"336\" data-backw=\"578\" data-backh=\"152\" data-imgfileid=\"505103661\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/8bf78605-34e6-4369-6197-547d1a4b7400/public\">\n  </section>\n  <section style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;text-align:justify;margin-right:8px;\" nodeleaf=\"\">\n   <span></span>\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">在八个主流视觉推理任务上进行测试，包括MathVista, MathVerse, MathVision，MMMU，MMStar, MMVet, MMBench和AI2D, 结果发现ThinkLite-VL-7B的平均性能相比base model Qwen2.5-VL-7B-Instruct提升了7%，从59.69 提高到 63.89，并且显著优于使用随机采样选择相同大小数据量进行强化学习训练的模型。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">此外，相比7B级别的其他reasoning VLM，ThinkLite-VL-7B同样具有明显优势，包括OpenVLThinker-7B，MM-Eureka-Qwen-7B等。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">特别地，在MathVista上ThinkLite-VL-7B达到了75.1的SoTA准确率，超过了GPT-4o和o1等闭源模型和Qwen2.5-VL-72B等开源更大参数量的模型。</span></span></p>\n  <section data-pm-slice=\"0 0 []\" nodeleaf=\"\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/202724fb-34aa-40cb-65f7-e2807a203500/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.4666666666666667\" data-type=\"png\" data-w=\"1080\" style=\"width:100%;\" data-width=\"1280\" data-height=\"597\" data-backw=\"578\" data-backh=\"270\" data-imgfileid=\"505103664\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/202724fb-34aa-40cb-65f7-e2807a203500/public\">\n  </section>\n  <section>\n   <span data-lark-record-format=\"docx/record\"></span>\n  </section>\n  <section data-pm-slice=\"0 0 []\" nodeleaf=\"\" style=\"text-align: center;\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/f3c5e333-d206-4dc8-5915-e8aee5744a00/public\" class=\"rich_pages wxw-img\" data-ratio=\"1.0138888888888888\" data-type=\"png\" data-w=\"720\" style=\"width: 57%;flex-basis: auto;height: auto !important;\" data-width=\"720\" data-height=\"730\" data-backw=\"578\" data-backh=\"586\" data-imgfileid=\"505103665\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/f3c5e333-d206-4dc8-5915-e8aee5744a00/public\">\n  </section>\n  <section>\n   <span data-lark-record-format=\"docx/record\"></span>\n  </section>\n  <section style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;text-align:justify;margin-right:8px;\" nodeleaf=\"\">\n   <span></span>\n  </section>\n  <section style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;text-align:justify;margin-right:8px;\" nodeleaf=\"\">\n   <span></span>\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">这意味着，即使在没有额外监督、没有知识蒸馏、没有大规模数据的前提下，只需要正确选择少量对于VLM具有挑战性的高质量样本，VLM也能通过self-improve显著提升推理能力。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">研究人员进一步对不同难度组合的训练集进行了消融分析，发现：</span></span></p>\n  <ol style=\"margin-left: 8px;margin-right: 8px;\" class=\"list-paddingleft-1\">\n   <li>\n    <p style=\"text-align: justify;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">仅用最难的样本（无法解出）可以提升能力，但效果不及中等+困难样本的组合；</span></span></p>\n    <p style=\"text-align: justify;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><br></span></p></li>\n   <li>\n    <p style=\"text-align: justify;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">简单样本虽然在训练过程中快速提升reward，但对最终推理能力提升作用有限；</span></span></p>\n    <p style=\"text-align: justify;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><br></span></p></li>\n   <li>\n    <p style=\"text-align: justify;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">使用中等难度加上困难样本的组合才能最大程度提升模型的推理能力，即使模型在训练中无法解决全部的样本。</span></span></p></li>\n  </ol>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-top: 24px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">这一发现对未来的模型训练有重要启示：合理的样本难度分布比样本数量更关键。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">论文一作王玺尧是马里兰大学计算机系三年级phd，导师为Furong Huang教授，主要研究方向为强化学习在大语言模型和视觉语言模型训练中的应用，在ICML, NeurIPS, ICLR, ACL, EMNLP, NAACL, CVPR等会议上发表过多篇论文。</span></span></p>\n  <section style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;margin-bottom:0px;text-align:center;margin-right:8px;\" nodeleaf=\"\">\n   <span></span>\n  </section>\n  <section data-pm-slice=\"0 0 []\" style=\"text-align: center;margin-bottom: 0px;\" nodeleaf=\"\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/dfac0035-bae4-44e4-489e-3b2f63341900/public\" class=\"rich_pages wxw-img\" data-ratio=\"1\" data-type=\"png\" data-w=\"512\" style=\"width: 57%;flex-basis: auto;height: auto !important;\" data-width=\"512\" data-height=\"512\" data-backw=\"512\" data-backh=\"512\" data-imgfileid=\"505103666\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/dfac0035-bae4-44e4-489e-3b2f63341900/public\">\n  </section>\n  <section style=\"margin-left:8px;letter-spacing:0.544px;min-height:1em;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;margin-bottom:0px;margin-right:8px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\"><span leaf=\"\">参考资料：</span></span>\n  </section>\n  <section style=\"margin-left:8px;letter-spacing:0.544px;min-height:1em;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;margin-bottom:0px;margin-right:8px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\"><span leaf=\"\">https://arxiv.org/pdf/2504.07934</span></span></section>\n  <p style=\"display: none;\"><mp-style-type data-value=\"3\"></mp-style-type></p>\n \n",
  "aiSummary": "ThinkLite-VL 模型利用少量数据，通过蒙特卡洛树搜索筛选高难度样本，显著提升视觉语言模型推理能力，超越 GPT，且无需知识蒸馏。",
  "oneSentenceSummary": "ThinkLite-VL 模型利用少量数据，通过蒙特卡洛树搜索筛选高难度样本，显著提升视觉语言模型推理能力，超越 GPT，且无需知识蒸馏。",
  "summary": "文章介绍了马里兰大学、密歇根大学和微软团队联合提出的 ThinkLite-VL 模型，该模型旨在解决视觉语言模型（Vision-Language Models， VLMs）训练中对高质量样本不足和过度依赖知识蒸馏的问题。ThinkLite-VL 的核心创新在于使用蒙特卡洛树搜索（Monte Carlo Tree Search， MCTS）来评估和筛选训练样本的难度，仅选择模型在推理过程中需要多次迭代或无法解决的难题作为训练集。通过这种方式，模型仅用少量数据（11k 样本）进行强化学习训练，在多个视觉推理任务上取得了显著的性能提升，甚至在 MathVista 数据集上达到了 75.1% 的 SoTA 准确率，超越了 GPT-4o 等大型模型。研究表明，合理的样本难度分布比样本数量更关键，为未来的模型训练提供了新思路。",
  "mainPoints": [
    {
      "point": "MCTS 能有效筛选出对 VLM 更具挑战性的高质量训练样本",
      "explanation": "通过 MCTS 评估样本难度，选择需要更多推理迭代次数的样本，使模型专注于学习自身难以解决的问题。"
    },
    {
      "point": "少量高质量困难样本训练能显著提升 VLM 推理能力",
      "explanation": "ThinkLite-VL 仅使用 11k 样本进行强化学习，在多个视觉推理任务上超越了使用更多数据训练的其他模型。"
    },
    {
      "point": "样本难度分布对模型训练至关重要",
      "explanation": "中等难度加困难样本的组合能最大程度提升模型推理能力，而简单样本对最终推理能力提升作用有限。"
    }
  ],
