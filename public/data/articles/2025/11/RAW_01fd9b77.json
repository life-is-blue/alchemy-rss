-top: 0px;padding-bottom: 0px;padding-left: 0px;padding-right: 0px;display: flex;flex-direction: column;justify-content: center;align-items: center;margin-top: 0px;margin-right: auto;margin-bottom: 0px;margin-left: auto;\">\n    <span leaf=\"\"><img data-imgfileid=\"100009939\" class=\"rich_pages wxw-img\" data-ratio=\"1.2315270935960592\" data-type=\"jpeg\" data-w=\"203\" style=\"display: block;margin-top: 0px;margin-right: auto;margin-bottom: 0px;margin-left: auto;max-width: 100%;border-top-style: none;border-bottom-style: none;border-left-style: none;border-right-style: none;border-top-width: 3px;border-bottom-width: 3px;border-left-width: 3px;border-right-width: 3px;border-top-color: rgba(0, 0, 0, 0.4);border-bottom-color: rgba(0, 0, 0, 0.4);border-left-color: rgba(0, 0, 0, 0.4);border-right-color: rgba(0, 0, 0, 0.4);object-fit: fill;box-shadow: rgba(0, 0, 0, 0) 0px 0px 0px 0px;border-top-left-radius: 15px;border-top-right-radius: 15px;border-bottom-right-radius: 15px;border-bottom-left-radius: 15px;\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=fcd80240&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fmmbiz_jpg%2FicvmTEvIjJrdqMeDAPHgAoeofph9FCwnR7SibgWtkZolHvicicm1yhbfiaBOD5TJgcwnSjT9O2sdxiaicMMCTIFicDOjHg%2F640%3Fwx_fmt%3Djpeg%26from%3Dappmsg\"></span>\n   </figure>\n   <p data-tool=\"mdnice编辑器\" style=\"padding-top:3px;letter-spacing:0em;padding-left:0px;font-size:16px;padding-bottom:3px;line-height:1.5em;margin-right:0px;margin-left:0px;text-indent:0em;margin-top:0px;margin-bottom:0px;text-align:justify;padding-right:0px;\"><span leaf=\"\">generative_ai_with_langchain 是一个用于构建大型语言模型（LLM）应用的 Python 代码库，配合《Generative AI with LangChain》一书使用。</span></p>\n   <ul style=\"margin-left:0px;padding-top:0px;list-style-type:disc;padding-left:1rem;padding-bottom:0px;margin-top:8px;margin-bottom:8px;margin-right:0px;padding-right:0px;\" class=\"list-paddingleft-1\">\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;