  "id": "RAW_2affa10f",
  "title": "星巴克中国交易：激进的扩张，韩国的剧本，未决的根本问题",
  "url": "https://mp.weixin.qq.com/s?__biz=MzU3Mjk1OTQ0Ng==&mid=2247530284&idx=1&sn=66082ee6f5f9ab2b91d83c43691e28bb",
  "date": "2025-11-04 15:57:00",
