  "id": "RAW_78b5a9ae",
  "title": "AI Native 的影像公司们，颠覆赛道的机会来了！",
  "url": "https://mp.weixin.qq.com/s?__biz=Mzg5NTc0MjgwMw==&mid=2247520971&idx=1&sn=ea2bd5652e9e74b5899dd89d6218e9b0",
  "date": "2025-11-16 03:03:00",
