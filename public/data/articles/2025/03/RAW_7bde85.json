bottom: 5px;color: rgb(58, 58, 58);font-size: 16px;line-height: 1.8em;letter-spacing: 0em;text-align: left;font-weight: normal;\">\n      <strong style=\"border-right-style:none;background-size:auto;border-top-width:3px;border-bottom-color:rgba(0, 0, 0, 0.4);background-attachment:scroll;font-weight:bold;padding-left:0px;border-left-color:rgba(0, 0, 0, 0.4);background-color:rgba(0, 0, 0, 0);margin-left:0px;background-repeat:no-repeat;background-position-x:0%;background-position-y:0%;border-left-style:none;border-top-color:rgba(0, 0, 0, 0.4);border-top-left-radius:0px;margin-top:0px;border-bottom-right-radius:0px;background-image:none;height:auto;padding-top:0px;border-bottom-left-radius:0px;border-right-width:3px;padding-bottom:0px;border-right-color:rgba(0, 0, 0, 0.4);border-top-right-radius:0px;border-left-width:3px;border-top-style:none;margin-right:0px;background-clip:border-box;width:auto;border-bottom-width:3px;border-bottom-style:none;background-origin:padding-box;margin-bottom:0px;padding-right:0px;\"><span leaf=\"\">模块化设计</span></strong><span leaf=\"\">：采用模块化架构，开发者可以根据需求选择性地使用不同模块来构建 AI 应用。</span>\n     </section></li>\n    <li>\n     <section style=\"margin-top: 5px;margin-bottom: 5px;color: rgb(58, 58, 58);font-size: 16px;line-height: 1.8em;letter-spacing: 0em;text-align: left;font-weight: normal;\">\n      <strong style=\"border-right-style:none;background-size:auto;border-top-width:3px;border-bottom-color:rgba(0, 0, 0, 0.4);background-attachment:scroll;font-weight:bold;padding-left:0px;border-left-color:rgba(0, 0, 0, 0.4);background-color:rgba(0, 0, 0, 0);margin-left:0px;background-repeat:no-repeat;background-position-x:0%;background-position-y:0%;border-left-style:none;border-top-color:rgba(0, 0, 0, 0.4);border-top-left-radius:0px;margin-top:0px;border-bottom-right-radius:0px;background-image:none;height:auto;padding-top:0px;border-bottom-left-radius:0px;border-right-width:3px;padding-bottom:0px;border-right-color:rgba(0, 0, 0, 0.4);border-top-right-rad