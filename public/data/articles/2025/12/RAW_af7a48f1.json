t%3Dpng\"></span></p>\n  <ne-clipboard source=\"https%3A%2F%2Fwww.yuque.com%2Fqone%2Fyys%2Fui4vh8x5zgs0e4en%23YHgv6\" data-pm-slice=\"0 0 []\"></ne-clipboard>\n  <h2 style=\"-webkit-text-stroke-width:0px;padding:0px;font-variant-caps:normal;margin:24px 8px 8px;white-space:normal;font-weight:400;letter-spacing:normal;font-size:17px;text-decoration-style:initial;line-height:2em;font-style:normal;text-decoration-thickness:initial;text-transform:none;word-spacing:0px;text-indent:0px;font-family:mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;text-decoration-color:initial;font-variant-ligatures:normal;text-align:left;\"><span leaf=\"\" style=\"font-family: mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style: normal;font-variant-ligatures: normal;font-variant-caps: normal;letter-spacing: normal;text-indent: 0px;text-transform: none;white-space: normal;word-spacing: 0px;-webkit-text-stroke-width: 0px;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;line-height: 2em;text-align: left;color: rgb(1, 194, 96);font-weight: bold;margin-top: 0px;margin-bottom: 0px;padding: 0px;font-size: 18px;\">▌内容分散：移动端优先设计的3个缺点</span></h2>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">链接：</span></span><span style=\"font-size: 14px;\"><span leaf=\"\"><a class=\"normal_text_link\" target=\"_blank\" style=\"\" href=\"https://mp.weixin.qq.com/s?__biz=MzIyNTk0NjY5OA==&amp;mid=2247488590&amp;idx=1&amp;sn=22c5d96049eba82cad72cc4823649e4f&amp;scene=21#wechat_redirect\" textvalue=\"\" linktype=\"text\" data-linktype=\"2\"></a><a href=\"https://mp.weixin.qq.com/s/ZCK58Qbo_vqgS7ynL-9BZA\" target=\"_blank\">https://mp.weixin.qq.com/s/ZCK58Qbo_vqgS7ynL-9BZA</a></span></span></p>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">移动端优先设计存在的三大缺点被揭示，强调在以移动为核心的设计路径中，往往可能牺牲信息完整性、可用性深度与跨端一致性，需要在响应式布局、信息层级与多端协调之间寻求平衡。</span></span></p>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\" nodeleaf=\"\"><img data-imgfileid=\"501968397\" class=\"rich_pages wxw-img\" data-ratio=\"1.25\" data-type=\"other\" data-w=\"1080\" width=\"1080\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=7e40338c&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_jpg%2Fg0kpxARkI2SuH9A1kc0JN9uMIiceCB0rVhibvDMhykhQnL4WiasoldL63VxGXtG9DvDjXArbd0uFO5bQ6fVoEkiaQA%2F640%3Fwx_fmt%3Dother%26from%3Dappmsg\"></p>\n  <h2 style=\"-webkit-text-stroke-width:0px;padding:0px;font-variant-caps:normal;margin:24px 8px 8px;white-space:normal;font-weight:400;letter-spacing:normal;font-size:17px;text-decoration-style:initial;line-height:2em;font-style:normal;text-decoration-thickness:initial;text-transform:none;word-spacing:0px;text-indent:0px;font-family:mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;text-decoration-color:initial;font-variant-ligatures:normal;text-align:left;\"><span leaf=\"\" style=\"font-family: mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style: normal;font-variant-ligatures: normal;font-variant-caps: normal;letter-spacing: normal;text-indent: 0px;text-transform: none;white-space: normal;word-spacing: 0px;-webkit-text-stroke-width: 0px;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;line-height: 2em;text-align: left;color: rgb(1, 194, 96);font-weight: bold;margin-top: 0px;margin-bottom: 0px;padding: 0px;font-size: 18px;\">▌策略产品权重设计方法连载（四）：CRITIC，优序图法，AHP，熵值法，独立性权重，信息量权重，主观成分分析法，因子分析法</span></h2>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">链接：</span></span><span style=\"font-size: 14px;\"><span leaf=\"\"><a class=\"normal_text_link\" target=\"_blank\" style=\"\" href=\"https://mp.weixin.qq.com/s?__biz=MzA3Mjg1MjQ4Mg==&amp;mid=2452455459&amp;idx=1&amp;sn=4c8f8cbb8b4d3fb076835d2c97dce6aa&amp;scene=21#wechat_redirect\" textvalue=\"\" linktype=\"text\" data-linktype=\"2\"></a><a href=\"https://mp.weixin.qq.com/s/cSQQOD8Z99WORfojXIOyvQ\" target=\"_blank\">https://mp.weixin.qq.com/s/cSQQOD8Z99WORfojXIOyvQ</a></span></span></p>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">CRITIC权重法在客观赋权方法中通过同时考虑对比强度与冲突性，能够在特征存在相关性的情境下，精准衡量每个特征的独特信息贡献，从而解决信息重叠导致的权重偏差，并给出归一化后的权重以反映特征的重要性。</span></span></p>\n  <h2 style=\"-webkit-text-stroke-width:0px;padding:0px;font-variant-caps:normal;margin:24px 8px 8px;white-space:normal;font-weight:400;letter-spacing:normal;font-size:17px;text-decoration-style:initial;line-height:2em;font-style:normal;text-decoration-thickness:initial;text-transform:none;word-spacing:0px;text-indent:0px;font-family:mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;text-decoration-color:initial;font-variant-ligatures:normal;text-align:left;\"><span leaf=\"\" style=\"font-family: mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style: normal;font-variant-ligatures: normal;font-variant-caps: normal;letter-spacing: normal;text-indent: 0px;text-transform: none;white-space: normal;word-spacing: 0px;-webkit-text-stroke-width: 0px;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;line-height: 2em;text-align: left;color: rgb(1, 194, 96);font-weight: bold;margin-top: 0px;margin-bottom: 0px;padding: 0px;font-size: 18px;\">▌设计不是改界面，而是读懂情绪</span></h2>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">链接：</span></span><span style=\"font-size: 14px;\"><span leaf=\"\"><a class=\"normal_text_link\" target=\"_blank\" style=\"\" href=\"https://mp.weixin.qq.com/s?__biz=Mzg2OTYzMTI1Ng==&amp;mid=2247497458&amp;idx=1&amp;sn=8658d45922f469a994d09fa034a625fe&amp;scene=21#wechat_redirect\" textvalue=\"\" linktype=\"text\" data-linktype=\"2\"></a><a href=\"https://mp.weixin.qq.com/s/UTJ75bB1SZpR26Qrfm2W4g\" target=\"_blank\">https://mp.weixin.qq.com/s/UTJ75bB1SZpR26Qrfm2W4g</a></span></span></p>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">本文从“情绪驱动”出发，重新设计航班状态页，提出三个以用户情绪为核心的设计决策：通过风险等级可视化降低不确定感、在高压场景中提供最短决策路径的入口、以及在后续阶段通过“关怀”功能实现情绪外溢的正向传递，强调设计不仅是界面美化，更是进入并回应用户情绪的过程。</span></span></p>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\" nodeleaf=\"\"><img data-imgfileid=\"501968400\" class=\"rich_pages wxw-img\" data-ratio=\"0.75\" data-type=\"other\" data-w=\"1080\" width=\"1080\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=342c05f7&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_jpg%2Fg0kpxARkI2SuH9A1kc0JN9uMIiceCB0rViajz2ib32UD4bzd6l8PETtBmibLglVqAicgXW82rkCF5PfxxYrMOmUibpPQ%2F640%3Fwx_fmt%3Dother%26from%3Dappmsg\"></p>\n  <h2 style=\"-webkit-text-stroke-width:0px;padding:0px;font-variant-caps:normal;margin:24px 8px 8px;white-space:normal;font-weight:400;letter-spacing:normal;font-size:17px;text-decoration-style:initial;line-height:2em;font-style:normal;text-decoration-thickness:initial;text-transform:none;word-spacing:0px;text-indent:0px;font-family:mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;text-decoration-color:initial;font-variant-ligatures:normal;text-align:left;\"><span leaf=\"\" style=\"font-family: mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style: normal;font-variant-ligatures: normal;font-variant-caps: normal;letter-spacing: normal;text-indent: 0px;text-transform: none;white-space: normal;word-spacing: 0px;-webkit-text-stroke-width: 0px;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;line-height: 2em;text-align: left;color: rgb(1, 194, 96);font-weight: bold;margin-top: 0px;margin-bottom: 0px;padding: 0px;font-size: 18px;\">▌稳定币向西，人民币向东</span></h2>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">链接：</span></span><span style=\"font-size: 14px;\"><span leaf=\"\"><a class=\"normal_text_link\" target=\"_blank\" style=\"\" href=\"https://mp.weixin.qq.com/s?__biz=MjM5MDIwNjAxMA==&amp;mid=2247489285&amp;idx=1&amp;sn=e7341d72925455084530e921f878a318&amp;scene=21#wechat_redirect\" textvalue=\"\" linktype=\"text\" data-linktype=\"2\"></a><a href=\"https://mp.weixin.qq.com/s/_tDTh2gI4_FlRkmxfgGvIg\" target=\"_blank\">https://mp.weixin.qq.com/s/_tDTh2gI4_FlRkmxfgGvIg</a></span></span></p>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">本文章围绕央行及多部委就虚拟货币与稳定币的整治提出的明确信号展开，强调全面禁止稳定币、推动信息与资金流的联动监管以及通过数字人民币推动人民币国际化与中国在 WEB3 领域的发展，最终提出数字货币将引导全球金融基础设施向双轮驱动的方向演进。</span></span></p>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\" nodeleaf=\"\"><img data-imgfileid=\"501968398\" class=\"rich_pages wxw-img\" data-ratio=\"0.7725856697819314\" data-type=\"other\" data-w=\"321\" width=\"321\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=8873cfa5&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_jpg%2Fg0kpxARkI2SuH9A1kc0JN9uMIiceCB0rVFuP0el8pfy5U1icZnzDbqDPo5udU26RUfhZJic8fPhbes0MdKjUZWDxw%2F640%3Fwx_fmt%3Dother%26from%3Dappmsg\"></p>\n  <h2 style=\"-webkit-text-stroke-width:0px;padding:0px;font-variant-caps:normal;margin:24px 8px 8px;white-space:normal;font-weight:400;letter-spacing:normal;font-size:17px;text-decoration-style:initial;line-height:2em;font-style:normal;text-decoration-thickness:initial;text-transform:none;word-spacing:0px;text-indent:0px;font-family:mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;text-decoration-color:initial;font-variant-ligatures:normal;text-align:left;\"><span leaf=\"\" style=\"font-family: mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style: normal;font-variant-ligatures: normal;font-variant-caps: normal;letter-spacing: normal;text-indent: 0px;text-transform: none;white-space: normal;word-spacing: 0px;-webkit-text-stroke-width: 0px;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;line-height: 2em;text-align: left;color: rgb(1, 194, 96);font-weight: bold;margin-top: 0px;margin-bottom: 0px;padding: 0px;font-size: 18px;\">▌她是小公司B端产品经理，去抖音做搜索</span></h2>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">链接：</span></span><span style=\"font-size: 14px;\"><span leaf=\"\"><a class=\"normal_text_link\" target=\"_blank\" style=\"\" href=\"https://mp.weixin.qq.com/s?__biz=MzA3Mjg1MjQ4Mg==&amp;mid=2452455442&amp;idx=1&amp;sn=4e1771d5cef8ff84e36475ebfc1905f5&amp;scene=21#wechat_redirect\" textvalue=\"\" linktype=\"text\" data-linktype=\"2\"></a><a href=\"https://mp.weixin.qq.com/s/lgrxrhPXN0UxH5-ilznaoA\" target=\"_blank\">https://mp.weixin.qq.com/s/lgrxrhPXN0UxH5-ilznaoA</a></span></span></p>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">本文讲述了一个传统行业B端产品经理转向策略产品经理的求职与成长路径。通过QN的经历，展示了策略产品相较于功能产品在技能门槛、职业稳定性和薪资水平方面的优势，以及系统化学习与面试准备在转行中的关键性作用。同时，强调在训练营的系统培训下，求职者能够建立全局视角、提升面试表达能力，并分享了转行过程中的常见坑与应对策略。</span></span></p>\n  <h2 style=\"-webkit-text-stroke-width:0px;padding:0px;font-variant-caps:normal;margin:24px 8px 8px;white-space:normal;font-weight:400;letter-spacing:normal;font-size:17px;text-decoration-style:initial;line-height:2em;font-style:normal;text-decoration-thickness:initial;text-transform:none;word-spacing:0px;text-indent:0px;font-family:mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;text-decoration-color:initial;font-variant-ligatures:normal;text-align:left;\"><span leaf=\"\" style=\"font-family: mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style: normal;font-variant-ligatures: normal;font-variant-caps: normal;letter-spacing: normal;text-indent: 0px;text-transform: none;white-space: normal;word-spacing: 0px;-webkit-text-stroke-width: 0px;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;line-height: 2em;text-align: left;color: rgb(1, 194, 96);font-weight: bold;margin-top: 0px;margin-bottom: 0px;padding: 0px;font-size: 18px;\">▌银行的产品设计请停止乱造新词</span></h2>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">链接：</span></span><span style=\"font-size: 14px;\"><span leaf=\"\"><a class=\"normal_text_link\" target=\"_blank\" style=\"\" href=\"https://mp.weixin.qq.com/s?__biz=MzU4ODgyMjI1NQ==&amp;mid=2247483871&amp;idx=1&amp;sn=2372ce56dccfb75d5011f3635194d312&amp;scene=21#wechat_redirect\" textvalue=\"\" linktype=\"text\" data-linktype=\"2\"></a><a href=\"https://mp.weixin.qq.com/s/dQocqJHeXX9uouAG2fbIhQ\" target=\"_blank\">https://mp.weixin.qq.com/s/dQocqJHeXX9uouAG2fbIhQ</a></span></span></p>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">银行在产品设计中频繁造新词，导致用户无法快速理解核心信息，削弱信任与体验。文章通过分析三大误区（将晦涩当专业、将造词当创新、把合规当挡箭牌），提出以用户为中心的改进路径：直给核心信息的命名、将术语翻译成大白话、以用户需求为导向的营销表达，倡导回归简单、透明、易懂的金融产品设计。</span></span></p>\n  <h2 style=\"-webkit-text-stroke-width:0px;padding:0px;font-variant-caps:normal;margin:24px 8px 8px;white-space:normal;font-weight:400;letter-spacing:normal;font-size:17px;text-decoration-style:initial;line-height:2em;font-style:normal;text-decoration-thickness:initial;text-transform:none;word-spacing:0px;text-indent:0px;font-family:mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;text-decoration-color:initial;font-variant-ligatures:normal;text-align:left;\"><span leaf=\"\" style=\"font-family: mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style: normal;font-variant-ligatures: normal;font-variant-caps: normal;letter-spacing: normal;text-indent: 0px;text-transform: none;white-space: normal;word-spacing: 0px;-webkit-text-stroke-width: 0px;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;line-height: 2em;text-align: left;color: rgb(1, 194, 96);font-weight: bold;margin-top: 0px;margin-bottom: 0px;padding: 0px;font-size: 18px;\">▌大星辰-广告素材智能分析与生成平台</span></h2>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">链接：</span></span><span style=\"font-size: 14px;\"><span leaf=\"\"><a class=\"normal_text_link\" target=\"_blank\" style=\"\" href=\"https://mp.weixin.qq.com/s?__biz=MzI0MjczMjM2NA==&amp;mid=2247499171&amp;idx=1&amp;sn=17dab30365e32771f21c4dcd4a95a7ee&amp;scene=21#wechat_redirect\" textvalue=\"\" linktype=\"text\" data-linktype=\"2\"></a><a href=\"https://mp.weixin.qq.com/s/A_n0MeEv-7AM9pwe1YL2_Q\" target=\"_blank\">https://mp.weixin.qq.com/s/A_n0MeEv-7AM9pwe1YL2_Q</a></span></span></p>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">本报告介绍“大星辰”平台在广告素材智能分析与生成领域的应用与发展，聚焦通过多模态生成式AI能力提升广告素材的质量、多样性与生产效率，解决素材质量与效率、同质化、长尾场景覆盖不足等痛点，并以产出自动化、跨尺寸适配和全链路提效为目标，推动广告收入的持续增长与创意边界扩展。</span></span></p>\n  <h2 style=\"-webkit-text-stroke-width:0px;padding:0px;font-variant-caps:normal;margin:24px 8px 8px;white-space:normal;font-weight:400;letter-spacing:normal;font-size:17px;text-decoration-style:initial;line-height:2em;font-style:normal;text-decoration-thickness:initial;text-transform:none;word-spacing:0px;text-indent:0px;font-family:mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;text-decoration-color:initial;font-variant-ligatures:normal;text-align:left;\"><span leaf=\"\" style=\"font-family: mp-quote, -apple-system-font, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style: normal;font-variant-ligatures: normal;font-variant-caps: normal;letter-spacing: normal;text-indent: 0px;text-transform: none;white-space: normal;word-spacing: 0px;-webkit-text-stroke-width: 0px;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;line-height: 2em;text-align: left;color: rgb(1, 194, 96);font-weight: bold;margin-top: 0px;margin-bottom: 0px;padding: 0px;font-size: 18px;\">▌设计师必备！Lovart用设计Agent，打破AI设计效率天花板</span></h2>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">链接：</span></span><span style=\"font-size: 14px;\"><span leaf=\"\"><a class=\"normal_text_link\" target=\"_blank\" style=\"\" href=\"https://mp.weixin.qq.com/s?__biz=MzI5Nzc3MzkyNw==&amp;mid=2247495911&amp;idx=1&amp;sn=fa0b154d0cfebe99aea4fdff6e45d40f&amp;scene=21#wechat_redirect\" textvalue=\"\" linktype=\"text\" data-linktype=\"2\"></a><a href=\"https://mp.weixin.qq.com/s/8AtalfxGsfcbJqKt34xBzg\" target=\"_blank\">https://mp.weixin.qq.com/s/8AtalfxGsfcbJqKt34xBzg</a></span></span></p>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\"><span style=\"font-size: 14px;\"><span leaf=\"\">Lovart 以“设计Agent”为核心，结合四大独家功能，显著提升设计效率与成品落地能力，使AI设计从初稿阶段直接过渡到可编辑、可落地的成品，且通过与 Nanobanana Pro 的深度整合实现高精度的场景拟合与图层管理，彻底改善了文字编辑、精准修改、分层拆解与一键Mockup等常见痛点。</span></span></p>\n  <p style=\"margin: 0px 8px;padding: 0px;min-height: 24px;\" nodeleaf=\"\"><img data-imgfileid=\"501968399\" class=\"rich_pages wxw-img\" data-ratio=\"0.375\" data-type=\"other\" data-w=\"1080\" width=\"1080\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=f7ae1b10&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_jpg%2Fg0kpxARkI2SuH9A1kc0JN9uMIiceCB0rV95HxXEGMGp8auXhcSnTY3eAO5vibKaJLETgdW9S1HAHGHH1t5n78WLw%2F640%3Fwx_fmt%3Dother%26from%3Dappmsg\"></p>\n  <div>\n   <h2 data-node-type=\"block\" data-block-type=\"text\" style=\"margin: 24px 8px;white-space: normal;line-height: 2em;\">\n    <p style=\"margin: 48px 8px 24px;text-align: center;\