" data-id=\"88402\" style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;line-height: 27.2px;widows: 1;visibility: visible;\">\n    <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;letter-spacing: 0.544px;line-height: 27.2px;visibility: visible;\">\n     <section data-style=\"line-height: 1.8; text-align: justify; font-size: 15px; letter-spacing: 0px; color: rgb(117, 114, 114);white-space: normal;\" style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n      <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n       <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n        <hr style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 17px;letter-spacing: 0.544px;visibility: visible;\">\n        <p style=\"margin: -1.2em 8px 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;clear: both;min-height: 1em;font-size: 17px;letter-spacing: 0.544px;line-height: 1.75em;visibility: visible;\"><br style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\"></p>\n        <p style=\"margin: -1.2em 8px 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;clear: both;min-height: 1em;font-size: 17px;letter-spacing: 0.544px;text-align: center;line-height: 1.75em;visibility: visible;\"><span style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;letter-spacing: 1px;visibility: visible;\"><strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-family: inherit;font-size: 1em;text-decoration: inherit;visibility: visible;\"><span style=\"padding:0px;margin:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;box-sizing:border-box !important;overflow-wrap:break-word !important;background-color:rgb(127, 127, 127);outline:0px;max-width:100%;font-family:inherit;\">&nbsp;&nbsp;</span></strong><strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 1em;font-family: inherit;text-decoration: inherit;visibility: visible;\"><span style=\"padding:0px;margin:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;box-sizing:border-box !important;overflow-wrap:break-word !important;background-color:rgb(127, 127, 127);outline:0px;max-width:100%;font-family:inherit;\">新智元报道&nbsp;&nbsp;</span></strong></span></p>\n       </section>\n      </section>\n     </section>\n    </section>\n   </section></h3>\n  <section style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;outline:0px;word-spacing:0px;text-indent:0px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:center;-webkit-text-stroke-width:0px;padding:0px;margin:0px 8px;visibility:visible;letter-spacing:0.544px;text-decoration-style:initial;line-height:1.75em;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n   <span style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 12px;color: rgb(136, 136, 136);font-family: &quot;Helvetica Neue&quot;, Helvetica, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;letter-spacing: 1px;visibility: visible;\">编辑：英智</span>\n  </section>\n  <section powered-by=\"xiumi.us\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;outline:0px;word-spacing:0px;text-indent:0px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:0px;visibility:visible;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n   <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n    <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n     <h5 style=\"padding:10px;margin:10px 8px 0px;visibility:visible;font-weight:400;letter-spacing:0.544px;font-size:14px;line-height:1.75em;box-sizing:border-box !important;overflow-wrap:break-word !important;border-radius:3px;outline:0px;word-spacing:1px !important;max-width:100%;word-break:break-all !important;font-family:Arial, Helvetica, sans-serif;\"><span style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;letter-spacing: 1px;font-size: 15px;visibility: visible;\"><strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">【新智元导读】</strong>英伟达巧妙地将DeepSeek-R1与推理时扩展相结合，构建了全新工作流程，自动优化生成GPU内核，取得了令人瞩目的成果。</span></h5>\n    </section>\n   </section>\n  </section>\n  <p style=\"margin:0px 8px 24px;max-width:100%;white-space:normal;letter-spacing:0.544px;min-height:1em;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;box-sizing:border-box !important;text-align:justify;overflow-wrap:break-word !important;\"><span style=\"font-size: 15px;letter-spacing: 1px;font-family: mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;\">本周英伟达的一篇技术博客引发了业界震动！</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">英伟达的团队尝试利用DeepSeek-R1和推理时扩展实现GPU内核生成自动化，效果极佳。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">随着AI模型的扩展，推理时扩展（inference-time scaling），也叫测试时扩展（test-time scaling）正闪亮登场。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">推理时扩展就像是给AI模型配备了一个「智慧锦囊」。当模型进行推理时，它会额外分配计算资源，让模型有能力评估多种可能的结果，然后从中挑选出最优解。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">通过这种方式，AI可以像人类一样，有条不紊地剖析复杂问题，找到最佳解决方案。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"172\" data-backw=\"562\" data-height=\"498\" data-imgfileid=\"505081595\" data-ratio=\"0.30648148148148147\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/adcb6834-4319-454b-8781-9f16efa0c600/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1623\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/adcb6834-4319-454b-8781-9f16efa0c600/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">为了充分发挥DeepSeek-R1的优势，同时克服其在生成优化GPU内核时遇到的困难，英伟达的工程师们想出了一个创新的方法——将推理时扩展技术与DeepSeek-R1相结合，构建了一种全新的工作流程。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">他们使用DeepSeek-R1，在推理过程中借助额外的计算能力来解决一个复杂问题：旨在自动生成数值正确且针对不同类型注意力机制进行优化的GPU注意力内核，整个过程无需任何显式编程。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在某些情况下，R1生成的内核甚至比娴熟的工程师开发出来的还要出色！</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">对此，网友评价道：「英伟达是在毁掉自己的护城河吗？」</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"220\" data-backw=\"562\" data-height=\"438\" data-imgfileid=\"505081599\" data-ratio=\"0.39166666666666666\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/55ba2b3f-a7c6-405b-699a-251ccca48700/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1118\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/55ba2b3f-a7c6-405b-699a-251ccca48700/public\"></p>\n  <section autoid=\"1895\" data-style-type=\"0\" style=\"max-width:100%;white-space:normal;letter-spacing:0.544px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box !important;margin-bottom:0px;overflow-wrap:break-word !important;\">\n   <section style=\"padding: 8px;max-width: 100%;box-sizing: border-box;border-left: 6px solid rgb(255, 202, 0);font-size: 18px;line-height: 1.4;font-family: inherit;font-weight: bold;text-decoration: inherit;border-top-color: rgb(255, 202, 0);border-right-color: rgb(255, 202, 0);border-bottom-color: rgb(255, 202, 0);overflow-wrap: break-word !important;\">\n    <p style=\"line-height: 1.75em;margin-bottom: 0px;\"><span style=\"letter-spacing: 1px;\"></span>优化注意力内核的挑战</p>\n   </section>\n  </section>\n  <h2 style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\"></span></h2>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">深入了解推理时扩展技术如何发挥作用之前，先要认识一个LLM中至关重要的概念——注意力机制。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">注意力机制就像是「聚光灯」，能让AI模型在处理任务时，有选择地聚焦在输入信息中最相关的部分，快速找到关键语句，做出更准确的预测，发现数据中的隐藏模式。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">但是，注意力操作的计算复杂度与输入序列长度的平方成正比。输入的文本越长，模型处理起来就会越吃力，不仅计算量大幅增加，还可能出现运行时错误，比如内存不足的情况。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">为了避免这些问题，提高计算效率，开发优化的底层实现，也就是GPU内核，十分必要。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">另外，注意力机制有多种不同的变体，像因果注意力、相对位置嵌入、alibi等。工程师们在面对不同的任务时，往往需要把这些变体组合起来使用。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在多模态模型，比如视觉Transformer中，需要专门的注意力机制，像空间邻域注意力（Spatial Neighborhood Attention），来处理计算机视觉、视频生成模型中常见的时空信息。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"167\" data-backw=\"562\" data-height=\"542\" data-imgfileid=\"505081597\" data-ratio=\"0.2962962962962963\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/3e95498c-699f-48f8-e7ae-d8dd295e8b00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1827\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/3e95498c-699f-48f8-e7ae-d8dd295e8b00/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">开发一个优化的GPU注意力内核，对经验丰富的软件工程师来说，也是一项艰巨的任务，费时费力。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">尽管像DeepSeek-R1这样的模型在代码生成任务中展现出了很大的潜力，但它们在第一次尝试生成优化代码时，还是会遇到不少挑战。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">这使得在推理时必须使用其他策略来生成优化代码。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">以下是为相对位置嵌入注意力内核输入的示例用户提示。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"248\" data-backw=\"562\" data-height=\"643\" data-imgfileid=\"505081596\" data-ratio=\"0.44074074074074077\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/021141b2-2c63-4bf4-d763-0b4b5772b900/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1458\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/021141b2-2c63-4bf4-d763-0b4b5772b900/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">模型有时会产生幻觉，生成一些「不靠谱」的代码，要么在语法上有错误，要么把不同语言或框架的语法混在一起，导致无法运行或效率低下。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">计算最优的GPU线程映射也不是一件容易的事，通常需要反复调整优化，才能得到一个正确又高效的内核。</span></p>\n  <section autoid=\"1895\" data-style-type=\"0\" style=\"max-width:100%;white-space:normal;letter-spacing:0.544px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box !important;margin-bottom:0px;overflow-wrap:break-word !important;\">\n   <section style=\"padding: 8px;max-width: 100%;box-sizing: border-box;border-left: 6px solid rgb(255, 202, 0);font-size: 18px;line-height: 1.4;font-family: inherit;font-weight: bold;text-decoration: inherit;border-top-color: rgb(255, 202, 0);border-right-color: rgb(255, 202, 0);border-bottom-color: rgb(255, 202, 0);overflow-wrap: break-word !important;\">\n    <p style=\"line-height: 1.75em;margin-bottom: 0px;\"><span style=\"letter-spacing: 1px;\"></span>DeepSeek R1与推理时扩展「强强联合」</p>\n   </section>\n  </section>\n  <h2 style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\"></span></h2>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">为了攻克优化GPU注意力内核这个难题，英伟达的工程师们想出了一个巧妙的办法，他们把DeepSeek-R1模型和推理时扩展技术结合起来，创造了一种新的工作流程。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"188\" data-backw=\"562\" data-height=\"578\" data-imgfileid=\"505081598\" data-ratio=\"0.3351851851851852\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/8a0b5a2b-6676-483f-62b5-d4ea02fd7400/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1726\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/8a0b5a2b-6676-483f-62b5-d4ea02fd7400/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">一开始，工程师会手动输入一个提示。然后，DeepSeek-R1会根据这个提示，在第一次遍历中生成GPU代码，也就是内核代码。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">生成的代码会交给一个特殊的验证器，这个验证器运行在英伟达H100 GPU上，仔细分析生成的内核代码。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">如果发现代码有不足的地方，验证器就会生成新的提示，再把这些提示作为输入，反馈给DeepSeek-R1。模型根据新的提示，对代码进行改进，如此循环往复。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">工程师们发现，这个过程持续15分钟，就能得到一个性能更好的注意力内核。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"343\" data-backw=\"562\" data-height=\"1053\" data-imgfileid=\"505081601\" data-ratio=\"0.6101851851851852\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/c6df0867-32d2-42d5-cf0a-4df8761b8e00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1727\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/c6df0867-32d2-42d5-cf0a-4df8761b8e00/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">根据斯坦福大学的KernelBench基准测试，它生成的内核在处理Level-1问题时，在数值上100%是正确的。在处理Level-2问题时，正确率也能达到96% 。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">KernelBench Level-1问题解决率，是用来评估LLM为特定计算任务生成高效GPU内核能力的数值正确指标，它是一系列测试LLM GPU编程能力挑战的一部分。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">推理时间预算对生成正确内核的影响也很明显。从测试结果来看，在Level-1问题中，如果每个问题分配的推理时间超过10分钟，就能为100个问题中的大多数生成数值正确的代码。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">这也意味着，给模型足够的「思考时间」，它真的能给出更好的答案。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"365\" data-backw=\"562\" data-height=\"995\" data-imgfileid=\"505081600\" data-ratio=\"0.649074074074074\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/56f0546b-0e49-45df-58f2-1202bce98600/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1532\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/56f0546b-0e49-45df-58f2-1202bce98600/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">利用DeepSeek-R1模型，通过在推理时投入更多计算资源，可以生成比一些熟练工程师开发的优化内核还要好的结果，这为GPU内核的自动化生成开辟了一条新的道路。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">目前这项技术还处于早期研究阶段，虽然已经取得了一些令人振奋的成果，但要想让它能稳定地产生更好的结果，还有很多工作要做。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">研究者对DeepSeek-R1的最新进展及潜力感到兴奋。</span></p>\n  <section style=\"white-space:normal;letter-spacing:0.544px;min-height:1em;line-height:1.75em;box-sizing:border-box !important;margin-right:8px;overflow-wrap:break-word !important;margin-left:8px;max-width:100%;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\">参考资料：</span>\n  </section>\n  <section style=\"white-space:normal;letter-spacing:0.544px;min-height:1em;line-height:1.75em;box-sizing:border-box !important;margin-right:8px;overflow-wrap:break-word !important;margin-left:8px;max-width:100%;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\">https://x.com/anneouyang/status/1889770178487132384</span>\n  </section>\n  <section style=\"white-space:normal;letter-spacing:0.544px;min-height:1em;line-height:1.75em;box-sizing:border-box !important;margin-right:8px;overflow-wrap:break-word !important;margin-left:8px;max-width:100%;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\">https://developer.nvidia.com/blog/automating-gpu-kernel-generation-with-deepseek-r1-and-inference-time-scaling/</span></section>\n  <p style=\"display: none;\"><mp-style-type data-value=\"3\"></mp-style-type></p>\n \n",
  "aiSummary": "英伟达利用 DeepSeek R1 模型结合推理时扩展技术，实现了 GPU 内核的自动优化生成，部分性能超越人工，降低了对人工优化的依赖。",
  "oneSentenceSummary": "英伟达利用 DeepSeek R1 模型结合推理时扩展技术，实现了 GPU 内核的自动优化生成，部分性能超越人工，降低了对人工优化的依赖。",
  "summary": "英伟达的研究团队探索了使用 DeepSeek R1 模型和推理时扩展技术来自动生成优化的 GPU 内核。通过将 DeepSeek R1 与推理时扩展相结合，构建了一个全新的工作流程，该流程通过迭代优化，生成在数值上正确且针对不同类型注意力机制进行优化的 GPU 注意力内核，无需人工显式编程。在某些情况下，生成的内核甚至优于经验丰富的工程师开发的内核。文章还探讨了 DeepSeek R1 在代码生成时面临的挑战，如生成不靠谱代码和计算最优 GPU 线程映射的困难，并阐述了英伟达如何通过推理时扩展来解决这些问题。该技术通过验证器在 H100 GPU 上分析生成的内核代码，并根据发现的不足之处生成新的提示，反馈给 DeepSeek R1 模型进行改进。实验结果表明，该方法在 KernelBench 基准测试中表现出色，尤其是在为模型分配足够的“思考时间”的情况下。",
