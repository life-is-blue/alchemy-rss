data-backh=\"247\" data-backw=\"578\" data-cropselx1=\"0\" data-cropselx2=\"578\" data-cropsely1=\"0\" data-cropsely2=\"248\" data-imgfileid=\"505082743\" data-ratio=\"0.42777777777777776\" data-s=\"300,640\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/0eee439f-fd7f-4a19-e194-3c12be02d100/public\" data-type=\"png\" data-w=\"1080\" style=\"font-variant-caps:normal;color:rgb(51, 51, 51);white-space:normal;font-weight:400;font-size:16px;text-decoration-thickness:initial;word-spacing:0px;text-indent:0px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;height:auto;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:0px;letter-spacing:0.544px;vertical-align:bottom;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;width:100%;font-variant-ligatures:normal;widows:1;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/0eee439f-fd7f-4a19-e194-3c12be02d100/public\">\n       </section>\n      </section>\n     </section>\n    </section>\n   </section></h3>\n  <h3 style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:16px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;outline:0px;word-spacing:0px;text-indent:0px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:0px;visibility:visible;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n   <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;line-height: 27.2px;widows: 1;visibility: visible;\">\n    <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;letter-spacing: 0.544px;line-height: 27.2px;visibility: visible;\">\n     <section data-style=\"line-height: 1.8; text-align: justify; font-size: 15px; letter-spacing: 0px; color: rgb(117, 114, 114);white-space: normal;\" style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n      <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n       <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n        <hr style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 17px;letter-spacing: 0.544px;visibility: visible;\">\n        <p style=\"margin: -1.2em 8px 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;clear: both;min-height: 1em;font-size: 17px;letter-spacing: 0.544px;line-height: 1.75em;visibility: visible;\"><br style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\"></p>\n        <p style=\"margin: -1.2em 8px 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;clear: both;min-height: 1em;font-size: 17px;letter-spacing: 0.544px;text-align: center;line-height: 1.75em;visibility: visible;\"><span style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;letter-spacing: 1px;visibility: visible;\"><strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-family: inherit;font-size: 1em;text-decoration: inherit;visibility: visible;\"><span style=\"padding:0px;margin:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;box-sizing:border-box !important;overflow-wrap:break-word !important;background-color:rgb(127, 127, 127);outline:0px;max-width:100%;font-family:inherit;\">&nbsp;&nbsp;</span></strong><strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 1em;font-family: inherit;text-decoration: inherit;visibility: visible;\"><span style=\"padding:0px;margin:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;box-sizing:border-box !important;overflow-wrap:break-word !important;background-color:rgb(127, 127, 127);outline:0px;max-width:100%;font-family:inherit;\">新智元报道&nbsp;&nbsp;</span></strong></span></p>\n       </section>\n      </section>\n     </section>\n    </section>\n   </section></h3>\n  <section style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;outline:0px;word-spacing:0px;text-indent:0px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:center;-webkit-text-stroke-width:0px;padding:0px;margin:0px 8px;visibility:visible;letter-spacing:0.544px;text-decoration-style:initial;line-height:1.75em;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n   <span style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 12px;color: rgb(136, 136, 136);font-family: &quot;Helvetica Neue&quot;, Helvetica, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;letter-spacing: 1px;visibility: visible;\">编辑：桃子 英智</span>\n  </section>\n  <section powered-by=\"xiumi.us\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;outline:0px;word-spacing:0px;text-indent:0px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:0px;visibility:visible;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n   <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n    <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n     <h5 style=\"padding:10px;margin:10px 8px 0px;visibility:visible;font-weight:400;letter-spacing:0.544px;font-size:14px;line-height:1.75em;box-sizing:border-box !important;overflow-wrap:break-word !important;border-radius:3px;outline:0px;word-spacing:1px !important;max-width:100%;word-break:break-all !important;font-family:Arial, Helvetica, sans-serif;\"><span style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;letter-spacing: 1px;font-size: 15px;visibility: visible;\"><strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">【新智元导读】</strong>你能想象判别模型也能成为强大的图像合成高手吗？「直接上升合成」（DAS）做到了！它突破传统认知，借助多分辨率优化等创新技术，在图像生成的多个关键任务中表现出色。<strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\"></strong></span></h5>\n    </section>\n   </section>\n  </section>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">判别模型与生成模型长期以来彼此独立，前者专注于分类和识别，后者用于数据生成。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">最近一项名为「直接上升合成」（Direct Ascent Synthesis，DAS）的独立研究，颠覆了这一传统观念，揭示出判别模型中隐藏着令人惊叹的生成能力。</span></p>\n  <section style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px;line-height: 1.75em;\">\n   <img class=\"rich_pages wxw-img\" data-backh=\"139\" data-backw=\"562\" data-height=\"440\" data-imgfileid=\"505082747\" data-ratio=\"0.24722222222222223\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/a1b92ffa-68b5-4b33-0389-829a369b0d00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1783\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/a1b92ffa-68b5-4b33-0389-829a369b0d00/public\">\n  </section>\n  <p style=\"letter-spacing: 0.578px;text-align: left;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"letter-spacing: 1px;font-size: 14px;color: rgb(136, 136, 136);\">论文链接：https://arxiv.org/abs/2502.07753</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">DAS的核心观点挑战了人们对判别模型和生成模型的传统认知。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">研究人员发现，判别模型并非只能用于判别任务，其内部实际上蕴含着丰富的生成知识。通过合适的优化技术，判别模型可以突破传统角色，成为强大的图像合成工具。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"187\" data-backw=\"562\" data-height=\"509\" data-imgfileid=\"505082749\" data-ratio=\"0.3333333333333333\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/9fc5eca7-5e26-4d7e-c9d9-2fe727193900/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1526\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/9fc5eca7-5e26-4d7e-c9d9-2fe727193900/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">以CLIP模型为例，它能够将图像映射到嵌入向量，这些嵌入向量不仅包含了图像的语义信息，还捕捉到了自然图像的结构特征。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">然而，传统的反向映射尝试，即将嵌入向量转换回图像时，往往会遇到问题。以往的方法通常会产生退化的结果，生成的图像在数学上与目标嵌入向量匹配度很高，但在人类观察者眼中却像是毫无意义的噪声。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">这种现象在对抗样本的研究中尤为明显，也揭示了表示匹配与感知质量之间的矛盾。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">DAS的研究者们却从中获得了灵感，他们认为这种看似的限制实际上是一个机会。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\"><img class=\"rich_pages wxw-img\" data-backh=\"557\" data-backw=\"562\" data-height=\"954\" data-imgfileid=\"505082773\" data-ratio=\"0.9906542056074766\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/a4b1ac75-2310-48e4-c3df-453d64093900/public\" data-type=\"png\" data-w=\"963\" data-width=\"963\" style=\"letter-spacing: 0.578px;width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/a4b1ac75-2310-48e4-c3df-453d64093900/public\"></span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在可能的反向映射空间中，既存在自然图像，也存在对抗模式。通过精心设计的优化方法，就有可能引导模型生成自然且有意义的图像，从而挖掘出判别模型中隐藏的生成能力。</span></p>\n  <section autoid=\"1895\" data-style-type=\"0\" style=\"max-width:100%;white-space:normal;letter-spacing:0.544px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box !important;margin-bottom:0px;overflow-wrap:break-word !important;\">\n   <section style=\"padding: 8px;max-width: 100%;box-sizing: border-box;border-left: 6px solid rgb(255, 202, 0);font-size: 18px;line-height: 1.4;font-family: inherit;font-weight: bold;text-decoration: inherit;border-top-color: rgb(255, 202, 0);border-right-color: rgb(255, 202, 0);border-bottom-color: rgb(255, 202, 0);overflow-wrap: break-word !important;\">\n    <p style=\"line-height: 1.75em;margin-bottom: 0px;\"><span style=\"letter-spacing: 1px;\"></span>关键创新：多分辨率优化</p>\n   </section>\n  </section>\n  <section style=\"letter-spacing: 0.578px;text-align: justify;margin: 24px 8px;line-height: 1.75em;\">\n   <span style=\"font-size: 15px;letter-spacing: 1px;\">DAS的关键创新在于多分辨率优化。它打破了传统优化直接在像素层面操作的局限，将图像分解为多个不同分辨率的组件进行同时优化：</span>\n  </section>\n  <p style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-height=\"220\" data-imgfileid=\"505082748\" data-ratio=\"0.26410564225690275\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/d0752c49-fb60-486d-a2aa-0a43f9479300/public\" data-type=\"png\" data-w=\"833\" data-width=\"833\" style=\"width: 293px;height: 77px;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/d0752c49-fb60-486d-a2aa-0a43f9479300/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">其中，</span><img class=\"rich_pages wxw-img\" data-height=\"84\" data-imgfileid=\"505082746\" data-ratio=\"0.2028985507246377\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/c96cc11b-d504-47d5-183b-1b9e9b11ab00/public\" data-type=\"png\" data-w=\"414\" data-width=\"414\" style=\"letter-spacing: 0.578px;font-size: var(--articleFontsize);width: 113px;height: 23px;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/c96cc11b-d504-47d5-183b-1b9e9b11ab00/public\"><span style=\"font-size: 15px;letter-spacing: 1px;\">表示分</span><span style=\"font-size: 15px;letter-spacing: 1px;\">辨率为r的图像组件，图像被表示为从1×1到224×224分辨率的一系列组件之和。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">从正则化角度来看，多分辨率分解提供了一种自然的正则化方式。它通过强制不同分辨率之间的一致性，避免了优化过程中出现退化的高频解决方案，而这些高频噪声往往是传统对抗优化产生无意义图像的原因。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">同时，不同分辨率的组件能够在合适的尺度上捕捉语义信息，比如低分辨率组件可以把握图像的整体结构，高分辨率组件则专注于细节，从而使生成的图像在语义上更加连贯。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在优化目标的设定上，DAS通过衡量生成图像与目标描述（如文本描述对应的嵌入向量）的CLIP嵌入相似度来进行优化：</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-height=\"256\" data-imgfileid=\"505082751\" data-ratio=\"0.19074074074074074\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/ce097ba7-c4f7-448f-b05b-f4df1c34a400/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1343\" style=\"width: 344px;height: 66px;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/ce097ba7-c4f7-448f-b05b-f4df1c34a400/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">其中，i对多个CLIP模型进行索引，j对增强操作进行索引。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">公式具有几个关键特性：1）所有分辨率的组件同时进行优化；2）梯度根据各尺度的重要性自然地分布；3）通过尺度分解抑制高频对抗模式。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"190\" data-backw=\"562\" data-height=\"686\" data-imgfileid=\"505082752\" data-ratio=\"0.337037037037037\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/4e6f414c-ee05-41b9-5099-20cffbcad700/public\" data-type=\"png\" data-w=\"1080\" data-width=\"2033\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/4e6f414c-ee05-41b9-5099-20cffbcad700/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">梯度会根据不同分辨率组件的重要性自然地分布，进一步促进了生成过程朝着符合自然图像统计结构的方向发展。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">最终生成图像的功率谱遵循1/f²分布，这正是自然图像的典型特征，证明了多分辨率优化生成图像的有效性。</span></p>\n  <section autoid=\"1895\" data-style-type=\"0\" style=\"max-width:100%;white-space:normal;letter-spacing:0.544px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box !important;margin-bottom:0px;overflow-wrap:break-word !important;\">\n   <section style=\"padding: 8px;max-width: 100%;box-sizing: border-box;border-left: 6px solid rgb(255, 202, 0);font-size: 18px;line-height: 1.4;font-family: inherit;font-weight: bold;text-decoration: inherit;border-top-color: rgb(255, 202, 0);border-right-color: rgb(255, 202, 0);border-bottom-color: rgb(255, 202, 0);overflow-wrap: break-word !important;\">\n    <p style=\"line-height: 1.75em;margin-bottom: 0px;\"><span style=\"letter-spacing: 1px;\"></span>DAS实现细节</p>\n   </section>\n  </section>\n  <h2 style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\"></span></h2>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"736\" data-backw=\"562\" data-height=\"1013\" data-imgfileid=\"505082753\" data-ratio=\"1.3087855297157622\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/64a674ff-3db3-4d39-0776-a5698f568200/public\" data-type=\"png\" data-w=\"774\" data-width=\"774\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/64a674ff-3db3-4d39-0776-a5698f568200/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">研究者采用了几种技术来确保稳定且高质量的生成：</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);letter-spacing: 1px;font-size: 16px;\">数据增强</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">研究发现，随机的x-y位移和像素噪声这两种简单的数据增强方式，与多分辨率先验协同工作，能够显著提升生成的稳定性和图像质量。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">单独使用其中任何一种增强方式效果都有限，但两者结合，就能为模型在优化过程中提供更多的变化和稳定性，使得生成的图像更加多样化且自然。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">更复杂的数据增强方式可能会进一步提高生成质量，这为后续研究留下了探索空间。</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);letter-spacing: 1px;font-size: 16px;\">位移处理</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在处理图像位移时，DAS采用了一种独特的策略。与传统的填充方法不同，它在生成图像时，会将图像尺寸扩大为(H+2s)×(W+2s)，其中s是最大位移量。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">这样在进行位移增强时，图像就有了足够的缓冲空间，避免了因位移导致的边界问题。最后，再将生成的图像中心裁剪为所需的H×W尺寸，确保图像的完整性和一致性。</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);letter-spacing: 1px;font-size: 16px;\">模型集成</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">为了进一步提高生成质量，DAS采用了模型集成的方法。它平均了三个CLIP模型（OpenAI ViT-B/32 和两个 OpenCLIP ViT-B/32 变体，分别在不同数据集上训练）的梯度。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">虽然单个模型也能实现图像生成，但通过模型集成，能够在一定程度上提升生成图像的质量和稳定性。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">不过，研究人员也发现，部分CLIP模型在转换为生成器时表现不佳，目前还没有明确的原因，有待后续研究。</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);letter-spacing: 1px;font-size: 16px;\">框架扩展</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">DAS的框架具有很强的扩展性，在多目标向量方面，生成过程可以由多个加权目标引导，通过不同提示的组合，实现对生成图像的精细控制。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在风格迁移和重建任务中，目标嵌入可以来自文本，也可以来自参考图像。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"222\" data-backw=\"562\" data-height=\"807\" data-imgfileid=\"505082754\" data-ratio=\"0.39537037037037037\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/98112f9b-1d16-4370-d3b9-996a1078fe00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"2042\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/98112f9b-1d16-4370-d3b9-996a1078fe00/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">基于CLIP模型强大的表示能力，即使经过大幅度的维度压缩，DAS仍然能够在重建过程中保留图像的语义内容和风格元素。</span></p>\n  <section autoid=\"1895\" data-style-type=\"0\" style=\"max-width:100%;white-space:normal;letter-spacing:0.544px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box !important;margin-bottom:0px;overflow-wrap:break-word !important;\">\n   <section style=\"padding: 8px;max-width: 100%;box-sizing: border-box;border-left: 6px solid rgb(255, 202, 0);font-size: 18px;line-height: 1.4;font-family: inherit;font-weight: bold;text-decoration: inherit;border-top-color: rgb(255, 202, 0);border-right-color: rgb(255, 202, 0);border-bottom-color: rgb(255, 202, 0);overflow-wrap: break-word !important;\">\n    <p style=\"line-height: 1.75em;margin-bottom: 0px;\"><span style=\"letter-spacing: 1px;\"></span>实验结果与分析</p>\n   </section>\n  </section>\n  <h2 style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\"></span></h2>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">研究人员对DAS进行了全面的实验，从多个角度验证了其性能和优势。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">实验聚焦在四个关键方面：生成一致性、可控修改、重建保真度以及在不同应用中的通用性。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">研究者采用3个CLIP模型进行集成：OpenAI ViT-B/32、两个OpenCLIP ViT-B/32变体。上述模型均基于ViT架构，但也验证了非ViT模型同样可以取得类似的生成效果。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"287\" data-backw=\"562\" data-height=\"928\" data-imgfileid=\"505082755\" data-ratio=\"0.5111111111111111\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/ae37078c-cb49-4f26-964a-cb4dcc745d00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1817\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/ae37078c-cb49-4f26-964a-cb4dcc745d00/public\"></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);letter-spacing: 1px;font-size: 16px;\">生成质量与一致性</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在生成质量和一致性实验中，研究人员选择了两个具有挑战性的提示：火山爆发和冬夜的剑桥。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">多次运行DAS生成图像的结果显示，它在生成过程中表现出了高度的可靠性。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"145\" data-backw=\"562\" data-height=\"470\" data-imgfileid=\"505082757\" data-ratio=\"0.25833333333333336\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/e6bda94e-8bc2-4ffe-c290-50a1f0be1600/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1821\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/e6bda94e-8bc2-4ffe-c290-50a1f0be1600/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在语义一致性方面，每次生成的图像都能保持一致的高级特征，比如火山场景中的火山灰柱结构和景观融合，剑桥场景中的建筑主题和冬夜氛围都非常稳定。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在构图理解上，生成的图像展现出了复杂而合理的构图，即使没有经过专门的构图训练，也能自然地平衡前景和背景，体现出对场景结构的理解。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">此外，不同运行结果之间的差异呈现出自然图像的特征，如光照变化、视角微调等，而非对抗模式，这表明多分辨率先验成功地将优化过程限制在了自然图像流形内。</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);letter-spacing: 1px;font-size: 16px;\">可控修改</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在可控修改实验中，研究人员以一张原始图像为基础，根据不同的文本提示对图像进行修改。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">结果表明，DAS能够实现精确的局部调整和全局场景转换。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"776\" data-backw=\"562\" data-height=\"977\" data-imgfileid=\"505082756\" data-ratio=\"1.3799435028248588\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/ff154354-a6a9-477a-1068-e1cd3f6a2100/public\" data-type=\"png\" data-w=\"708\" data-width=\"708\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/ff154354-a6a9-477a-1068-e1cd3f6a2100/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在结构保存方面，图像的核心几何结构和空间关系在修改过程中得以保留，比如道路场景中，道路的基本形状和位置不会因为修改提示而被破坏。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">语义控制上，图像的修改能够准确响应文本提示，并且保持物理上的合理性，像下雪的道路场景中，雪会自然地堆积在路面上。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在多尺度协调方面，新添加的元素能够在不同空间尺度上无缝融合，火山爆发场景中，不仅有大规模的地形变化，还有局部的大气效果，两者协调一致。</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);letter-spacing: 1px;font-size: 16px;\">嵌入引导的重建</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">从CLIP嵌入中重建图像是对DAS的一项严格测试，因为这需要从高度压缩的表示（从150,528维压缩到512维）中恢复高维图像结构。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">实验结果令人惊喜，DAS 能够恢复出大量的语义和风格信息。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"722\" data-backw=\"562\" data-height=\"949\" data-imgfileid=\"505082759\" data-ratio=\"1.284167794316644\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/98947a8b-a185-4449-2f06-848ed0670b00/public\" data-type=\"png\" data-w=\"739\" data-width=\"739\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/98947a8b-a185-4449-2f06-848ed0670b00/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在语义保留上，主要的场景元素及其关系被一致地恢复出来。风格保留方面，颜色方案、光照条件和艺术特质都能有效地转移。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">构图保真度上，整体的布局和空间组织保持完整。同时，在细节上还能呈现出自然的变化，使得重建图像既保留了原始图像的主要特征，又具有一定的多样性。</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);letter-spacing: 1px;font-size: 16px;\">专业应用</span></strong></span></h3>\n  <section style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\">\n   <span style=\"font-size: 15px;letter-spacing: 1px;\">在生成国旗的任务中，DAS能够处理精确的几何图案和象征元素，虽然生成的国旗并不完美，但已经能够清晰地识别出各个国家的国旗特征，像瑞士国旗的精确比例和巴西国旗复杂的星星图案都能得到较好的呈现。</span>\n  </section>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"336\" data-backw=\"562\" data-height=\"817\" data-imgfileid=\"505082758\" data-ratio=\"0.5972222222222222\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/8b114ae8-e410-40d1-ff29-fac9bd880800/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1367\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/8b114ae8-e410-40d1-ff29-fac9bd880800/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在图像修复任务中，DAS可以根据给定的提示（如「夜晚的城市天际线」）生成与现有图像上下文无缝融合的内容，展示出其在处理边界条件和结构连续性方面的优势。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"361\" data-backw=\"562\" data-height=\"879\" data-imgfileid=\"505082760\" data-ratio=\"0.6425925925925926\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/1ef036a0-c126-4259-82d4-30f528ed9400/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1368\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/1ef036a0-c126-4259-82d4-30f528ed9400/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">这表明，DAS能够在多种复杂任务中发挥作用，且不需要针对特定任务进行专门的训练或架构修改。</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);letter-spacing: 1px;font-size: 16px;\">风格迁移</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在风格迁移方面，DAS 同样表现出色。通过将起始图像向风格图像的嵌入方向优化，DAS能有效地实现风格迁移。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"261\" data-backw=\"562\" data-height=\"585\" data-imgfileid=\"505082761\" data-ratio=\"0.4648148148148148\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/8c8e297c-20f1-41d1-cb50-845d28cf5f00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1258\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/8c8e297c-20f1-41d1-cb50-845d28cf5f00/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">与传统的基于像素空间优化的风格迁移方法相比，DAS生成的结果更加自然，高频伪影更少，而且所需的优化步骤也更少。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">这使得DAS成为了传统风格迁移技术的有力替代方案，为用户带来更加流畅和高质量的风格迁移体验。</span></p>\n  <section style=\"white-space:normal;letter-spacing:0.544px;min-height:1em;line-height:1.75em;box-sizing:border-box !important;margin-right:8px;overflow-wrap:break-word !important;margin-left:8px;max-width:100%;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\">参考资料：</span>\n  </section>\n  <section style=\"white-space:normal;letter-spacing:0.544px;min-height:1em;line-height:1.75em;box-sizing:border-box !important;margin-right:8px;overflow-wrap:break-word !important;margin-left:8px;max-width:100%;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\">https://x.com/stanislavfort/status/1890724291752100265</span>\n  </section>\n  <section style=\"white-space:normal;letter-spacing:0.544px;min-height:1em;line-height:1.75em;box-sizing:border-box !important;margin-right:8px;overflow-wrap:break-word !important;margin-left:8px;max-width:100%;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\">https://arxiv.org/abs/2502.07753</span></section>\n  <p style=\"display: none;\"><mp-style-type data-value=\"3\"></mp-style-type></p>\n \n",
  "aiSummary": "DAS 通过多分辨率优化，使现有判别模型在无需 GAN 或扩散模型的情况下，实现高质量图像生成、编辑和风格迁移，开辟了 AI 生图的新路径。",
  "oneSentenceSummary": "DAS 通过多分辨率优化，使现有判别模型在无需 GAN 或扩散模型的情况下，实现高质量图像生成、编辑和风格迁移，开辟了 AI 生图的新路径。",
  "summary": "文章介绍了“直接上升合成”（DAS）这一突破性技术，它颠覆了判别模型只能用于分类和识别的传统认知，揭示了其强大的图像生成能力。DAS 的核心创新在于多分辨率优化，通过将图像分解为不同分辨率的组件进行同步优化，有效避免了生成过程中的高频噪声，并能更好捕捉图像的整体结构和细节。实验结果表明，DAS 在图像生成质量、可控修改、嵌入引导的重建以及风格迁移等方面均表现出色，无需 GAN 或扩散模型，也无需针对特定任务进行专门的训练或架构修改，为 AI 图像生成提供了一种全新的方法。此外，DAS 框架具有很强的扩展性，可以用于多目标引导或结合参考图像。",
  "mainPoints": [
    {
      "point": "DAS 打破了判别模型与生成模型的界限",
      "explanation": "通过优化技术，判别模型也能实现高质量的图像合成，为 AI 图像生成提供了新思路。"
    },
    {
      "point": "多分辨率优化是 DAS 的关键创新",
      "explanation": "它能有效避免高频噪声，在不同尺度上捕捉语义信息，生成更自然连贯的图像。"
    },
    {
      "point": "DAS 在图像生成、编辑、重建和风格迁移等任务中表现出色，且无需针对特定任务进行专门训练或架构修改",
      "explanation": "DAS 在多个图像生成任务中表现出色"
    }
  ],
  "keyQuotes": [
    "判别模型并非只能用于判别任务，其内部实际上蕴含着丰富的生成知识。",
    "通过精心设计的优化方法，就有可能引导模型生成自然且有意义的图像，从而挖掘出判别模型中隐藏的生成能力。",
    "梯度会根据不同分辨率组件的重要性自然地分布，进一步促进了生成过程朝着符合自然图像统计结构的方向发展。"
  ],
