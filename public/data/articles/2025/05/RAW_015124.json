m:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n    <section style=\"-webkit-tap-highlight-color:transparent;padding:0px;margin:0px;outline:0px;max-width:100%;font-weight:400;font-size:20px;font-family:Avenir, -apple-system-font, 微软雅黑, sans-serif;box-sizing:border-box;overflow-wrap:break-word !important;text-align:center;\">\n     <span data-cacheurl=\"\" data-remoteid=\"\" data-lazy-bgimg=\"https://mmbiz.qpic.cn/sz_mmbiz_jpg/YriaiaJPb26VNgAV7QEDBn31mDCzcLmnyIgnyqSqPDQ0mJffezjyicxr9XVVBE1vHmVY8vICspHICUQOJ8j9PWJ4A/640?wx_fmt=jpeg&amp;from=appmsg\" data-fail=\"0\" style=\"-webkit-tap-highlight-color: transparent;margin: 38px 0px 10px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;height: 57px;line-height: 62px;color: rgb(0, 179, 138);font-weight: 500;border-bottom: 2px solid rgb(0, 179, 139);background: url(&quot;https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/b9a42157-a1d2-4cc1-0abb-78e5b6598d00/public&quot;) 50% 50% / 55px no-repeat;display: inline-block;\"><span leaf=\"\" style=\"-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;\">今日好文推荐</span></span>\n    </section>\n   </section>\n   <section style=\"font-variant-caps:normal;white-space:pre-line;font-weight:400;font-size:16px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:Avenir, -apple-system-font, 微软雅黑, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:23px 8px 0px;margin:0px;visibility:visible;letter-spacing:0.544px;text-decoration-style:initial;line-height:27px;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n    <span leaf=\"\" style=\"-webkit-tap-highlig