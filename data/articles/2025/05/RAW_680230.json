zing: border-box !important;overflow-wrap: break-word !important;&quot;,&quot;data-pm-slice&quot;:&quot;0 0 []&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;}]\"><span style=\"-webkit-tap-highlight-color: transparent;margin-top: 0px;margin-bottom: 0px;padding: 0px;outline: 0px;max-width: 100%;font-family: PingFangSC-Light;letter-spacing: 0.5px;font-size: 36px;box-sizing: border-box !important;overflow-wrap: break-word !important;\"><span leaf=\"\" data-pm-slice=\"1 1 [&quot;para&quot;,{&quot;tagName&quot;:&quot;section&quot;,&quot;attributes&quot;:{&quot;style&quot;:&quot;-webkit-tap-highlight-color: transparent;margin-bottom: 16px;outline: 0px;font-family: \\&quot;PingFang SC\\&quot;, system-ui, -apple-system, \\&quot;system-ui\\&quot;, \\&quot;Helvetica Neue\\&quot;, \\&quot;Hiragino Sans GB\\&quot;, \\&quot;Microsoft YaHei UI\\&quot;, \\&quot;Microsoft YaHei\\&quot;, Arial, sans-serif;letter-spacing: 0.544px;background-color: rgb(255, 255, 255);visibility: visible;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;},&quot;para&quot;,{&quot;tagName&quot;:&quot;section&quot;,&quot;attributes&quot;:{},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;},&quot;para&quot;,{&quot;tagName&quot;:&quot;section&quot;,&quot;attributes&quot;:{},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;},&quot;node&quot;,{&quot;tagName&quot;:&quot;span&quot;,&quot;attributes&quot;:{&quot;style&quot;:&quot;-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;color: rgb(75, 110, 245);&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;},&quot;node&quot;,{&quot;tagName&quot;:&quot;strong&quot;,&quot;attributes&quot;:{&quot;style&quot;:&quot;-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;},&quot;node&quot;,{&quot;tagName&quot;:&quot;span&quot;,&quot;attributes&quot;:{&quot;style&quot;:&quot;-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-family: PingFangSC-Light;letter-spacing: 0.5px;font-size: 36px;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;}]\" style=\"-webkit-tap-highlight-color: transparent;margin-top: 0px;margin-bottom: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;\">02&nbsp;</span></span>\n     <p data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:16px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:16px 0px;letter-spacing:0.544px;clear:both;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><strong><span leaf=\"\" style=\"font-variant-caps:normal;color:rgb(75, 110, 245);font-weight:bold;font-size:20px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;margin-top:0px;font-family:PingFangSC-Light;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;visibility:visible;letter-spacing:0.5px;clear:both;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">推出企业级 AI 功能：</span></strong></p>\n     <p data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:16px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:16px 0px;letter-spacing:0.544px;clear:both;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><strong><span leaf=\"\" style=\"font-variant-caps:normal;color:rgb(75, 110, 245);font-weight:bold;font-size:20px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;margin-top:0px;font-family:PingFangSC-Light;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;visibility:visible;letter-spacing:0.5px;clear:both;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">搜索、研究与集成</span></strong></p></strong></span>\n  </section>\n  <section style=\"margin-bottom: 24px;\">\n   <p style=\"margin: 1em 0px 24px;line-height: 1.6em;\"><span style=\"display: block;font-size: 16px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">而除了 AI 会议笔记外，此次 Notion 还发布了 Notion AI for Work 和 Research Mode，也就是把 Glean 的企业 AI 搜索和 ChatGPT 的深度研究功能都做了，只不过它主要还是针对企业级需求这块，特别是基于 Notion 以及与 Notion 打通的各个其他 SAAS 里的数据。</span></span></span></p>\n   <section style=\"text-align: center;line-height: 1.6em;margin-bottom: 24px;\" nodeleaf=\"\">\n    <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/cbed6e06-b8fd-47a7-01cb-dfa1a390a600/public\" class=\"rich_pages wxw-img js_insertlocalimg\" data-ratio=\"0.584375\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1280\" type=\"block\" data-imgfileid=\"308372764\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/cbed6e06-b8fd-47a7-01cb-dfa1a390a600/public\">\n   </section>\n   <p style=\"margin: 1em 0px 24px;line-height: 1.6em;\"><span style=\"display: block;font-size: 16px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">Notion 创始人 Ivan Zhao 说，现在 Notion 已经有 10 个集成，比方说 Slack、Google Drive、Jira 以及 Zendesk 等，很快将再添加 20 多个集成。通过深度研究功能，它会将所有数据研究后形成一份 PDF 报告或者是一个网页的形式来展示给团队，这和 Manus 每次研究完后会通过网页或者 PDF 报告等方式展现出来比较类似。</span></span></span></p>\n   <p style=\"margin: 1em 0px 24px;line-height: 1.6em;\"><span style=\"display: block;font-size: 16px;\"><span leaf=\"\"><br></span></span></p><span style=\"font-variant-caps:normal;color:rgb(75, 110, 245);font-weight:400;font-size:17px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;margin-top:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;margin-bottom:0px;font-variant-ligatures:normal;widows:2;\" data-pm-slice=\"0 0 []\"><strong style=\