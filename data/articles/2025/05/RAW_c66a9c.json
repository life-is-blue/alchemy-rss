ext-stroke-width:0px;padding:0px;visibility:visible;letter-spacing:0.544px;clear:both;text-decoration-style:initial;font-style:normal;margin-right:0px;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><span leaf=\"\" style=\"-webkit-tap-highlight-color: transparent;margin-right: 0px;margin-left: 0px;padding: 0px;outline: 0px;max-width: 100%;visibility: visible;box-sizing: border-box !important;overflow-wrap: break-word !important;\"><br></span></em></p>\n   <p style=\"margin: 0px 8px;\"><em style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:15px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;margin-left:0px;word-spacing:0px;outline:0px;text-indent:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;visibility:visible;letter-spacing:0.544px;clear:both;text-decoration-style:initial;font-style:normal;margin-right:0px;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><span leaf=\"\" style=\"-webkit-tap-highlight-color: transparent;margin-right: 0px;margin-left: 0px;padding: 0px;outline: 0px;max-width: 100%;visibility: visible;box-sizing: border-box !important;overflow-wrap: break-word !important;\"><span textstyle=\"\" style=\"font-size: 13px;color: rgb(0, 128, 255);font-style: italic;\">https://github.com/stepfun-ai/Step1X-3D</span></span></em></p>\n   <p style=\"margin: 0px 8px;\"><span leaf=\"\" style=\"font-variant-caps:normal;font-weight:400;font-size:15px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transpare