640\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/f715866c-0144-47cb-19df-1d70e2442d00/public\" data-type=\"jpeg\" data-w=\"1080\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/f715866c-0144-47cb-19df-1d70e2442d00/public\">\n       </section>\n      </section>\n     </section>\n    </section>\n   </section></h3>\n  <h3 style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:16px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;outline:0px;word-spacing:0px;text-indent:0px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:0px;visibility:visible;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n   <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;line-height: 27.2px;widows: 1;visibility: visible;\">\n    <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;letter-spacing: 0.544px;line-height: 27.2px;visibility: visible;\">\n     <section data-style=\"line-height: 1.8; text-align: justify; font-size: 15px; letter-spacing: 0px; color: rgb(117, 114, 114);white-space: normal;\" style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n      <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n       <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n        <hr style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 17px;letter-spacing: 0.544px;visibility: visible;\">\n        <p style=\"margin: -1.2em 8px 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;clear: both;min-height: 1em;font-size: 17px;letter-spacing: 0.544px;line-height: 1.75em;visibility: visible;\"><br style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\"></p>\n        <p style=\"margin: -1.2em 8px 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;clear: both;min-height: 1em;font-size: 17px;letter-spacing: 0.544px;text-align: center;line-height: 1.75em;visibility: visible;\"><span style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;letter-spacing: 1px;visibility: visible;\"><strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-family: inherit;font-size: 1em;text-decoration: inherit;visibility: visible;\"><span style=\"padding:0px;margin:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;box-sizing:border-box !important;overflow-wrap:break-word !important;background-color:rgb(127, 127, 127);outline:0px;max-width:100%;font-family:inherit;\">&nbsp;&nbsp;</span></strong><strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 1em;font-family: inherit;text-decoration: inherit;visibility: visible;\"><span style=\"padding:0px;margin:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;box-sizing:border-box !important;overflow-wrap:break-word !important;background-color:rgb(127, 127, 127);outline:0px;max-width:100%;font-family:inherit;\">新智元报道&nbsp;&nbsp;</span></strong></span></p>\n       </section>\n      </section>\n     </section>\n    </section>\n   </section></h3>\n  <section style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;outline:0px;word-spacing:0px;text-indent:0px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:center;-webkit-text-stroke-width:0px;padding:0px;margin:0px 8px;visibility:visible;letter-spacing:0.544px;text-decoration-style:initial;line-height:1.75em;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n   <span style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 12px;color: rgb(136, 136, 136);font-family: &quot;Helvetica Neue&quot;, Helvetica, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;letter-spacing: 1px;visibility: visible;\">编辑：LRST</span>\n  </section>\n  <section powered-by=\"xiumi.us\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;outline:0px;word-spacing:0px;text-indent:0px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:0px;visibility:visible;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n   <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n    <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n     <h5 style=\"padding:10px;margin:10px 8px 0px;visibility:visible;font-weight:400;letter-spacing:0.544px;font-size:14px;line-height:1.75em;box-sizing:border-box !important;overflow-wrap:break-word !important;border-radius:3px;outline:0px;word-spacing:1px !important;max-width:100%;word-break:break-all !important;font-family:Arial, Helvetica, sans-serif;\"><span style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;letter-spacing: 1px;font-size: 15px;visibility: visible;\"><strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">【新智元导读】</strong>DiffRhythm是一款新型AI音乐生成模型，能在10秒内生成长达4分45秒的完整歌曲，包含人声和伴奏。它采用简单高效的全diffusion架构，仅需歌词和风格提示即可创作，还支持本地部署，最低只需8G显存。<strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\"></strong></span></h5>\n    </section>\n   </section>\n  </section>\n  <section style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-top: 24px;\">\n   <span style=\"font-size: 15px;letter-spacing: 1px;\">音乐创作，尤其是完整歌曲的生成，一直是人工智能领域的一大挑战。</span>\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">Suno、Udio等商用音乐生成大模型展现出惊人的音乐生成能力。但现有开源的音乐生成模型要么只能生成人声或伴奏，要么依赖复杂的多阶段架构，难以扩展到长音频生成。</span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">而现在，AI音乐破局时刻到了！</span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">近日，西北工业大学音频语音与语言处理实验室（ASLP@NPU）和香港中文大学（深圳）的研究团队提出了一种名为DiffRhythm（中文名：谛韵）的新型音乐生成AI模型，全diffusion架构，它能够在短短10秒内生成长达4分45秒的不同风格完整双轨高保真歌曲，包含人声和伴奏！</span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">最低仅需8G显存，可本地部署到消费级显卡！</span></p>\n  <section style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-bottom: 0px;\">\n   <img class=\"rich_pages wxw-img\" data-backh=\"172\" data-backw=\"562\" data-height=\"320\" data-imgfileid=\"505090494\" data-ratio=\"0.3065134099616858\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/02bd7c55-a625-4e27-185e-06ad9dbaa800/public\" data-type=\"png\" data-w=\"1044\" data-width=\"1044\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/02bd7c55-a625-4e27-185e-06ad9dbaa800/public\">\n  </section>\n  <section style=\"text-align: left;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-bottom: 0px;\">\n   <span style=\"letter-spacing: 1px;font-size: 14px;color: rgb(136, 136, 136);\">在线Demo: </span><span style=\"letter-spacing: 1px;font-size: 14px;color: rgb(136, 136, 136);\">https://huggingface.co/spaces/ASLP-lab/DiffRhythm</span>\n  </section>\n  <section style=\"text-align: left;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-bottom: 0px;\">\n   <span style=\"letter-spacing: 1px;font-size: 14px;color: rgb(136, 136, 136);\">Paper: https://arxiv.org/abs/2503.01183</span>\n  </section>\n  <section style=\"text-align: left;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-bottom: 0px;\">\n   <span style=\"letter-spacing: 1px;font-size: 14px;color: rgb(136, 136, 136);\">Github: </span><span style=\"letter-spacing: 1px;font-size: 14px;color: rgb(136, 136, 136);\">https://github.com/ASLP-lab/DiffRhythm</span>\n  </section>\n  <p style=\"text-align: left;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span style=\"letter-spacing: 1px;font-size: 14px;color: rgb(136, 136, 136);\">Hugging Face: https://huggingface.co/ASLP-lab/DiffRhythm-base</span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">这一成果不仅刷新了音乐生成的速度，还大大简化了生成流程，让音乐创作变得更加高效和便捷。模型完全采用华为昇腾910B训练，同时支持N卡。</span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">目前模型和推理代码全部开源。开源短短几天位列Hugging Face Space趋势榜第一和总榜第五，受到众多网友和音乐爱好者广泛好评。</span></p>\n  <p style=\"text-align: center;\"><img class=\"rich_pages wxw-img\" data-galleryid=\"\" data-imgfileid=\"505090900\" data-ratio=\"0.9268518518518518\" data-s=\"300,640\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/f9d14cab-b7e6-4fde-3c30-e5a06dd92d00/public\" data-type=\"png\" data-w=\"1080\" style=\"\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/f9d14cab-b7e6-4fde-3c30-e5a06dd92d00/public\"></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"235\" data-backw=\"562\" data-height=\"1042\" data-imgfileid=\"505090496\" data-ratio=\"0.41759259259259257\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/bf9c9a49-216f-47ff-df9d-bffa29665d00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"2498\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/bf9c9a49-216f-47ff-df9d-bffa29665d00/public\"></p>\n  <section>\n   <iframe class=\"video_iframe rich_pages\" data-vidtype=\"2\" data-mpvid=\"wxv_3892862243209166849\" data-cover=\"http%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_jpg%2FUicQ7HgWiaUb10jYGo0FHUTox5yWhfoNjiahXhrIx0geCedOazKQqQqLdx0q0VJuuwYDictKiclUoTpRTZOice5w4h7w%2F0%3Fwx_fmt%3Djpeg\" allowfullscreen=\"\" frameborder=\"0\" data-ratio=\"2.0083333333333333\" data-w=\"964\" data-src=\"https://mp.weixin.qq.com/mp/readtemplate?t=pages/video_player_tmpl&amp;action=mpvideo&amp;auto=0&amp;vid=wxv_3892862243209166849\"></iframe>\n  </section>\n  <section>\n   <iframe class=\"video_iframe rich_pages\" data-vidtype=\"2\" data-mpvid=\"wxv_3892859061829779457\" data-cover=\"http%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_jpg%2FUicQ7HgWiaUb10jYGo0FHUTox5yWhfoNjiaBgWzFiaOc7KiaPiaZMM3T6sRBOwR8xbdHbrGEPGKHiccBGoVd35ViaWHTbw%2F0%3Fwx_fmt%3Djpeg\" allowfullscreen=\"\" frameborder=\"0\" data-ratio=\"1.7777777777777777\" data-w=\"1920\" data-src=\"https://mp.weixin.qq.com/mp/readtemplate?t=pages/video_player_tmpl&amp;action=mpvideo&amp;auto=0&amp;vid=wxv_3892859061829779457\"></iframe>\n  </section>\n  <section>\n   <mp-common-mpaudio class=\"js_editor_audio res_iframe js_uneditable custom_select_card\" src=\"/cgi-bin/readtemplate?t=tmpl/audio_tmpl&amp;name=Hotel-California-as-performed-by-DiffRhythm&amp;play_length=1%E5%88%86%E9%92%9F\" cover=\"https://wx.qlogo.cn/mmopen/Q3auHgzwzM6OG6oS3F1hpuCibDtCYOR5ECj0GibxO5VSPeLT6yyhurAas9nS2NMErQ5QatlP08iaEJz8n0Wd6vdQsqt135Zkic5esWc6OjDcBJU/0\" isaac2=\"1\" low_size=\"183.54\" source_size=\"183.5\" high_size=\"743.31\" name=\"Hotel-California-as-performed-by-DiffRhythm\" play_length=\"95000\" author=\"新智元\" data-topic_id=\"\" data-topic_name=\"\" data-pluginname=\"insertaudio\" data-trans_state=\"1\" data-verify_state=\"3\" voice_encode_fileid=\"MzI3MTA0MTk1MF8yNjUyNTc0NjMy\"></mp-common-mpaudio>\n  </section>\n  <section autoid=\"1895\" data-style-type=\"0\" style=\"max-width:100%;white-space:normal;letter-spacing:0.544px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box !important;margin-bottom:0px;overflow-wrap:break-word !important;\">\n   <section style=\"padding: 8px;max-width: 100%;box-sizing: border-box;border-left: 6px solid rgb(255, 202, 0);font-size: 18px;line-height: 1.4;font-family: inherit;font-weight: bold;text-decoration: inherit;border-top-color: rgb(255, 202, 0);border-right-color: rgb(255, 202, 0);border-bottom-color: rgb(255, 202, 0);overflow-wrap: break-word !important;\">\n    <p>DiffRhythm：简单、快速、高质量<span style=\"letter-spacing: 1px;\"></span></p>\n   </section>\n  </section>\n  <section style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-top: 24px;\">\n   <span style=\"font-size: 15px;letter-spacing: 1px;\">DiffRhythm 的核心优势在于它的简洁性和高效性。在模型方面它摒弃了复杂的多阶段架构，采用了一个简单的基于LLaMA的DiT，只需要歌词和风格提示即可生成歌曲。</span>\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">这种非自回归结构确保了快速的推理速度，相比现有的语言模型方法，DiffRhythm的速度提升显著，更适合实时应用和用户交互。在数据方面，仅需音频与对应歌词，无需复杂数据处理标注流程，易于scale up到大数据。</span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"168\" data-backw=\"562\" data-height=\"667\" data-imgfileid=\"505090498\" data-ratio=\"0.29907407407407405\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/a8a070e4-ce64-488e-f18b-9882010f1a00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"2230\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/a8a070e4-ce64-488e-f18b-9882010f1a00/public\"></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">DiffRhythm以歌词和风格提示输入，生成44.1kHz采样率全长立体声音乐作品（最长4分45秒）。</span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">DiffRhythm由两个顺序训练的模型组成：1) 变分自编码器 (VAE)，学习音频波形的紧凑潜在表示，使得分钟级长音频建模成为可能；2) DiT 建模 VAE 的潜在空间，通过迭代去噪生成歌曲。</span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"220\" data-backw=\"562\" data-height=\"701\" data-imgfileid=\"505090495\" data-ratio=\"0.3907407407407407\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/1ead839e-e38c-4376-4aba-4817a8455b00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1793\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/1ead839e-e38c-4376-4aba-4817a8455b00/public\"></p>\n  <h3 style=\"text-align: center;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-bottom: 24px;\"><span style=\"font-size: 16px;color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);font-size: 16px;letter-spacing: 1px;\">句级歌词对齐</span></strong></span></h3>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在歌曲生成中，歌词与歌声的对齐是一个极具挑战性的问题，可以概括为以下两个方面：</span></p>\n  <ol start=\"1\" class=\"list-paddingleft-1\" style=\"margin-left: 8px;margin-right: 8px;\">\n   <li style=\"font-size: 15px;letter-spacing: 1px;\">\n    <p style=\"text-align: justify;line-height: 1.75em;margin-bottom: 24px;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">时间上的不连续性：歌词中的句子之间往往存在较长的间隔，这些间隔可能是纯音乐部分，导致歌词与歌声之间的时间对应关系不连续。</span></p></li>\n   <li style=\"font-size: 15px;letter-spacing: 1px;\">\n    <section style=\"text-align: justify;line-height: 1.75em;\">\n     <span style=\"font-size: 15px;letter-spacing: 1px;\">伴奏的干扰：相同的一个字，在不同歌曲中的伴奏不同，唱法也不同，这使得歌声的对齐更加复杂。</span>\n    </section>\n    <section style=\"text-align: justify;line-height: 1.75em;\">\n     <span style=\"font-size: 15px;letter-spacing: 1px;\"></span>\n    </section></li>\n  </ol>\n  <section style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\">\n   <span style=\"font-size: 15px;letter-spacing: 1px;\">为了解决这些问题，DiffRhythm 提出了一种句子级对齐机制。具体来说，该机制仅依赖于句子起始时间的标注，通过以下步骤实现歌词与歌声的对齐：</span>\n  </section>\n  <ol start=\"1\" class=\"list-paddingleft-1\" style=\"margin-left: 8px;margin-right: 8px;\">\n   <li style=\"font-size: 15px;letter-spacing: 1px;\">\n    <section style=\"text-align: justify;line-height: 1.75em;margin-bottom: 24px;\">\n     <span style=\"font-size: 15px;letter-spacing: 1px;\">句子分割与音素转换：首先，将歌词按照句子分割，并通过 Grapheme-to-Phoneme (G2P) 转换将每个句子转换为音素序列。</span>\n    </section></li>\n   <li style=\"font-size: 15px;letter-spacing: 1px;\">\n    <p style=\"text-align: justify;line-height: 1.75em;margin-bottom: 24px;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">初始化潜在序列：创建一个与潜在表示长度相同的序列，并用填充符号（&lt;pad&gt;）初始化。</span></p></li>\n   <li style=\"font-size: 15px;letter-spacing: 1px;\">\n    <p style=\"text-align: justify;line-height: 1.75em;margin-bottom: 24px;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">对齐音素与潜在表示：根据歌词句子的起始时间戳，将音素序列映射到潜在表示的对应位置。例如，如果一个句子的起始时间是 10 秒，那么对应的音素序列将被放置在潜在表示的第 10 秒位置。</span></p></li>\n  </ol>\n  <section style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\">\n   <span style=\"font-size: 15px;letter-spacing: 1px;\">通过这种方式，DiffRhythm 只需要句子起始时间的标注，即可实现歌词与歌声的对齐。</span>\n  </section>\n  <section autoid=\"1895\" data-style-type=\"0\" style=\"max-width:100%;white-space:normal;letter-spacing:0.544px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box !important;margin-bottom:0px;overflow-wrap:break-word !important;\">\n   <section style=\"padding: 8px;max-width: 100%;box-sizing: border-box;border-left: 6px solid rgb(255, 202, 0);font-size: 18px;line-height: 1.4;font-family: inherit;font-weight: bold;text-decoration: inherit;border-top-color: rgb(255, 202, 0);border-right-color: rgb(255, 202, 0);border-bottom-color: rgb(255, 202, 0);overflow-wrap: break-word !important;\">\n    <p>压缩鲁棒VAE<span style=\"letter-spacing: 1px;\"></span></p>\n   </section>\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-top: 24px;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">考虑到大量歌曲数据都以压缩后的MP3格式存在，而高频细节在压缩过程中会受到损害，我们采用数据增强来赋予VAE修复功能。</span></p>\n  <section style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\">\n   <span style=\"font-size: 15px;letter-spacing: 1px;\">具体来说，VAE以无损FLAC格式数据进行训练，其中输入经过MP3压缩，而重建目标仍然是原始无损数据。通过这种有损到无损的重建过程，VAE学会将从有损压缩数据中得出的潜在表示解码回无损音频信号。</span>\n  </section>\n  <section autoid=\"1895\" data-style-type=\"0\" style=\"max-width:100%;white-space:normal;letter-spacing:0.544px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box !important;margin-bottom:0px;overflow-wrap:break-word !important;\">\n   <section style=\"padding: 8px;max-width: 100%;box-sizing: border-box;border-left: 6px solid rgb(255, 202, 0);font-size: 18px;line-height: 1.4;font-family: inherit;font-weight: bold;text-decoration: inherit;border-top-color: rgb(255, 202, 0);border-right-color: rgb(255, 202, 0);border-bottom-color: rgb(255, 202, 0);overflow-wrap: break-word !important;\">\n    <p>📊 实验结果<span style=\"letter-spacing: 1px;\"></span></p>\n   </section>\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-top: 24px;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">DiffRhythm的表现令人印象深刻。在音频重建方面，它在无损和有损压缩条件下都优于现有的基线模型。</span></p>\n  <section style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\">\n   <img class=\"rich_pages wxw-img\" data-height=\"240\" data-imgfileid=\"505090501\" data-ratio=\"0.17777777777777778\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/1bfc5119-d2d4-4731-8341-101ed12bd500/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1347\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/1bfc5119-d2d4-4731-8341-101ed12bd500/public\">\n  </section>\n  <section style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\">\n   <span style=\"font-size: 15px;letter-spacing: 1px;\">在可视化分析中，可以看到DiffRhythm VAE可以有效修复MP3压缩损失</span>\n  </section>\n  <section style=\"text-align: center;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\">\n   <img class=\"rich_pages wxw-img\" data-height=\"1004\" data-imgfileid=\"505090500\" data-ratio=\"1.5166163141993958\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/5b8008a8-627c-499b-abfa-1faee1e61200/public\" data-type=\"png\" data-w=\"662\" data-width=\"662\" style=\"width: 302px;height: 458px;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/5b8008a8-627c-499b-abfa-1faee1e61200/public\">\n  </section>\n  <section style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\">\n   <span style=\"font-size: 15px;letter-spacing: 1px;\">在歌曲生成方面，DiffRhythm的生成歌曲在音质、音乐性和歌词可理解性上都表现出色，与现有的SongLM模型相比，DiffRhythm的歌词清晰度更高，推理速度更快。</span>\n  </section>\n  <section style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\">\n   <img class=\"rich_pages wxw-img\" data-height=\"261\" data-imgfileid=\"505090499\" data-ratio=\"0.1935185185185185\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/f16fd459-a678-4d07-8cdf-caa21f53bf00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1347\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/f16fd459-a678-4d07-8cdf-caa21f53bf00/public\">\n  </section>\n  <section autoid=\"1895\" data-style-type=\"0\" style=\"max-width:100%;white-space:normal;letter-spacing:0.544px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box !important;margin-bottom:0px;overflow-wrap:break-word !important;\">\n   <section style=\"padding: 8px;max-width: 100%;box-sizing: border-box;border-left: 6px solid rgb(255, 202, 0);font-size: 18px;line-height: 1.4;font-family: inherit;font-weight: bold;text-decoration: inherit;border-top-color: rgb(255, 202, 0);border-right-color: rgb(255, 202, 0);border-bottom-color: rgb(255, 202, 0);overflow-wrap: break-word !important;\">\n    <p>未来展望<span style=\"letter-spacing: 1px;\"></span></p>\n   </section>\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;margin-top: 24px;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">尽管DiffRhythm已经可以快速生成整首歌曲，但仍有进一步优化的空间。例如，未来可能会通过在训练中引入随机掩码来支持对生成歌曲的特定片段进行编辑。</span></p>\n  <section style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\">\n   <span style=\"font-size: 15px;letter-spacing: 1px;\">此外，DiffRhythm 未来可能会引入自然语言条件机制，以实现更精细的风格控制，从而无需依赖音频参考。</span>\n  </section>\n  <section style=\"white-space:normal;letter-spacing:0.544px;min-height:1em;line-height:1.75em;box-sizing:border-box !important;margin-right:8px;overflow-wrap:break-word !important;margin-left:8px;max-width:100%;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\">参考资料：</span>\n  </section>\n  <section style=\"white-space:normal;letter-spacing:0.544px;min-height:1em;line-height:1.75em;box-sizing:border-box !important;margin-right:8px;overflow-wrap:break-word !important;margin-left:8px;max-width:100%;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\"><span style=\"color: rgb(136, 136, 136);font-size: 14px;letter-spacing: 1px;\">https://arxiv.org/abs/2503.01183</span></span></section>\n  <p style=\"display: none;\"><mp-style-type data-value=\"3\"></mp-style-type></p>\n \n",
  "aiSummary": "DiffRhythm 是一款开源 AI 音乐生成模型，采用 diffusion 架构，仅需歌词和风格提示即可快速生成音乐，在 Hugging Face 上广受欢迎。",
  "oneSentenceSummary": "DiffRhythm 是一款开源 AI 音乐生成模型，采用 diffusion 架构，仅需歌词和风格提示即可快速生成音乐，在 Hugging Face 上广受欢迎。",
  "summary": "DiffRhythm 是由西北工业大学和香港中文大学（深圳）的研究团队提出的一种新型 AI 音乐生成模型。该模型采用全 diffusion 架构，能在 10 秒内生成包含人声和伴奏的完整歌曲，最长可达 4 分 45 秒。DiffRhythm 具有简单、快速、高质量的特点，相比现有模型速度更快、部署更简单，最低仅需 8GB 显存，支持本地部署。模型由变分自编码器 (VAE) 和 DiT 组成，通过句级歌词对齐机制解决歌词与歌声的对齐问题。模型和推理代码全部开源，在 Hugging Face 广受欢迎。",
  "mainPoints": [
    {
      "point": "DiffRhythm 采用全 diffusion 架构，简化了音乐生成流程。",
      "explanation": "该模型摒弃了复杂的多阶段架构，使用基于 LLaMA 的 DiT，仅需歌词和风格提示即可生成歌曲，提高了生成速度和效率。"
    },
    {
      "point": "DiffRhythm 提出了一种句子级对齐机制，解决了歌词与歌声的对齐问题。",
      "explanation": "该机制仅依赖于句子起始时间的标注，通过音素转换和潜在表示对齐，实现了歌词与歌声的准确同步。"
    },
    {
      "point": "DiffRhythm 通过数据增强，赋予 VAE 修复 MP3 压缩损失的能力。",
      "explanation": "VAE 以无损 FLAC 格式数据进行训练，输入经过 MP3 压缩，重建目标为原始无损数据，从而学会从有损压缩数据中恢复音频信号。"
    },
    {
      "point": "DiffRhythm 模型完全采用华为昇腾 910B 训练，同时支持 N 卡",
      "explanation": "该模型在硬件上具有良好的兼容性，并支持国产硬件，降低了部署和使用门槛。"
    }
  ],
  "keyQuotes": [
    "DiffRhythm 的核心优势在于它的简洁性和高效性。",
    "DiffRhythm 以歌词和风格提示输入，生成 44.1kHz 采样率全长立体声音乐作品（最长 4 分 45 秒）。",
    "DiffRhythm 只需要句子起始时间的标注，即可实现歌词与歌声的对齐。",
    "模型和推理代码全部开源，受到众多网友和音乐爱好者广泛好评。"
  ],
