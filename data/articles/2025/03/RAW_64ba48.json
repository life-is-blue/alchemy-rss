data-backh=\"241\" data-backw=\"562\" data-cropselx1=\"0\" data-cropselx2=\"578\" data-cropsely1=\"0\" data-cropsely2=\"248\" data-imgfileid=\"505086414\" data-ratio=\"0.42777777777777776\" data-s=\"300,640\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/22c577b8-d370-43bd-55fe-162bed539a00/public\" data-type=\"png\" data-w=\"1080\" style=\"font-variant-caps:normal;color:rgb(51, 51, 51);white-space:normal;font-weight:400;font-size:16px;text-decoration-thickness:initial;word-spacing:0px;text-indent:0px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;height:248px;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:0px;letter-spacing:0.544px;vertical-align:bottom;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;width:578px;font-variant-ligatures:normal;widows:1;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/22c577b8-d370-43bd-55fe-162bed539a00/public\">\n       </section>\n      </section>\n     </section>\n    </section>\n   </section></h3>\n  <h3 style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:16px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;outline:0px;word-spacing:0px;text-indent:0px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:0px;visibility:visible;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n   <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;line-height: 27.2px;widows: 1;visibility: visible;\">\n    <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;letter-spacing: 0.544px;line-height: 27.2px;visibility: visible;\">\n     <section data-style=\"line-height: 1.8; text-align: justify; font-size: 15px; letter-spacing: 0px; color: rgb(117, 114, 114);white-space: normal;\" style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n      <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n       <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n        <hr style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 17px;letter-spacing: 0.544px;visibility: visible;\">\n        <p style=\"margin: -1.2em 8px 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;clear: both;min-height: 1em;font-size: 17px;letter-spacing: 0.544px;line-height: 1.75em;visibility: visible;\"><br style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\"></p>\n        <p style=\"margin: -1.2em 8px 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;clear: both;min-height: 1em;font-size: 17px;letter-spacing: 0.544px;text-align: center;line-height: 1.75em;visibility: visible;\"><span style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;letter-spacing: 1px;visibility: visible;\"><strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-family: inherit;font-size: 1em;text-decoration: inherit;visibility: visible;\"><span style=\"padding:0px;margin:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;box-sizing:border-box !important;overflow-wrap:break-word !important;background-color:rgb(127, 127, 127);outline:0px;max-width:100%;font-family:inherit;\">&nbsp;&nbsp;</span></strong><strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 1em;font-family: inherit;text-decoration: inherit;visibility: visible;\"><span style=\"padding:0px;margin:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;box-sizing:border-box !important;overflow-wrap:break-word !important;background-color:rgb(127, 127, 127);outline:0px;max-width:100%;font-family:inherit;\">新智元报道&nbsp;&nbsp;</span></strong></span></p>\n       </section>\n      </section>\n     </section>\n    </section>\n   </section></h3>\n  <section style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;outline:0px;word-spacing:0px;text-indent:0px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:center;-webkit-text-stroke-width:0px;padding:0px;margin:0px 8px;visibility:visible;letter-spacing:0.544px;text-decoration-style:initial;line-height:1.75em;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n   <span style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 12px;color: rgb(136, 136, 136);font-family: &quot;Helvetica Neue&quot;, Helvetica, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;letter-spacing: 1px;visibility: visible;\">编辑：英智</span>\n  </section>\n  <section powered-by=\"xiumi.us\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;outline:0px;word-spacing:0px;text-indent:0px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:0px;visibility:visible;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n   <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n    <section style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n     <h5 style=\"padding:10px;margin:10px 8px 0px;visibility:visible;font-weight:400;letter-spacing:0.544px;font-size:14px;line-height:1.75em;box-sizing:border-box !important;overflow-wrap:break-word !important;border-radius:3px;outline:0px;word-spacing:1px !important;max-width:100%;word-break:break-all !important;font-family:Arial, Helvetica, sans-serif;\"><span style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;letter-spacing: 1px;font-size: 15px;visibility: visible;\"><strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">【新智元导读】</strong>LMM在人类反馈下表现如何？新加坡国立大学华人团队提出InterFeedback框架，结果显示，最先进的LMM通过人类反馈纠正结果的比例不到50%！<strong style=\"margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\"></strong></span></h5>\n    </section>\n   </section>\n  </section>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">大规模多模态模型（Large Multimodal Models，LMM）在人类反馈下的表现如何？</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">这一问题对于利用LMM开发通用AI助手至关重要，现有的基准测试并未针对LMM与人类的交互智能进行测试。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">来自新加坡国立大学的华人团队提出了InterFeedback，一个可应用任何LMM和数据集的交互式框架。</span></p>\n  <section style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px;line-height: 1.75em;\">\n   <img class=\"rich_pages wxw-img\" data-backh=\"219\" data-backw=\"562\" data-height=\"562\" data-imgfileid=\"505086418\" data-ratio=\"0.38981481481481484\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/671f9f9f-bd2d-4656-5f2b-b26ff880c100/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1442\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/671f9f9f-bd2d-4656-5f2b-b26ff880c100/public\">\n  </section>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"letter-spacing: 1px;font-size: 14px;color: rgb(136, 136, 136);\">论文链接：https://arxiv.org/abs/2502.15027</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在此基础上，团队引入了InterFeedback-Bench，用两个具有代表性的数据集（MMMU-Pro和MathVerse）来评估交互智能，并对10种不同的LMM进行测试。</span></p>\n  <section style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px;line-height: 1.75em;\">\n   <span style=\"font-size: 15px;letter-spacing: 1px;\">InterFeedback-Bench旨在全面评估LMM：</span>\n  </section>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">1）交互式解决问题的能力；</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">2）解释反馈以提升自身的能力。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">评估结果表明，最先进的LMM通过人类反馈纠正结果的比例不到50%！</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">交互式过程可提升大多数LMM解决难题的性能，现有LMM在解释和整合反馈方面表现欠佳。进行额外迭代不一定能得出正确的解决方案，高质量反馈至关重要。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">人类在解决问题时，具有很强的适应性，能够从反馈中不断学习完善。同样，先进的LMM也应该能从反馈中学习，提高解决问题的能力。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"429\" data-backw=\"562\" data-height=\"1100\" data-imgfileid=\"505086422\" data-ratio=\"0.7638888888888888\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/2a8eb183-bbcc-4619-aaef-464a4303d700/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1440\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/2a8eb183-bbcc-4619-aaef-464a4303d700/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">评估LMM交互智能的关键挑战在于自动模型测试，不同模型对相同查询的响应不同，需要人类在每个对话轮次中提供定制化反馈。</span></p>\n  <section autoid=\"1895\" data-style-type=\"0\" style=\"max-width:100%;white-space:normal;letter-spacing:0.544px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box !important;margin-bottom:0px;overflow-wrap:break-word !important;\">\n   <section style=\"padding: 8px;max-width: 100%;box-sizing: border-box;border-left: 6px solid rgb(255, 202, 0);font-size: 18px;line-height: 1.4;font-family: inherit;font-weight: bold;text-decoration: inherit;border-top-color: rgb(255, 202, 0);border-right-color: rgb(255, 202, 0);border-bottom-color: rgb(255, 202, 0);overflow-wrap: break-word !important;\">\n    <p style=\"line-height: 1.75em;margin-bottom: 0px;\"><span style=\"letter-spacing: 1px;\"></span>InterFeedback框架设计原理</p>\n   </section>\n  </section>\n  <section style=\"letter-spacing: 0.578px;text-align: justify;margin: 24px 8px;line-height: 1.75em;\">\n   <span style=\"font-size: 15px;letter-spacing: 1px;\">研究人员提出了InterFeedback，这是一个基于交互式问题解决的框架，通过GPT-4o等模型模拟人类反馈，让LMM在动态的交互环境中进行测试和学习。</span>\n  </section>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">InterFeedback-Bench将带有反馈的交互式问题解决过程，变成了一种数学模型，叫部分可观测马尔可夫决策过程（POMDP）。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">通过状态空间、观测值、动作空间、转移函数和奖励函数等要素，精确地描述模型在交互过程中的行为和决策。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在实际应用中，当给定自然语言问题和输入图像时，模型基于当前状态获取观测值，生成自然语言回复。奖励函数通过精确匹配的方式判断任务的正确性，为模型提供反馈信号。</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);letter-spacing: 1px;font-size: 16px;\">数据集构建</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">InterFeedback-Bench采用了两个有挑战性的数据集：MathVerse和MMMU-Pro。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">MathVerse是一个视觉数学问题数据集，其中包含了各种需要结合图像和数学知识才能解决的问题。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">MMMU-Pro则是综合性的多模态基准测试，涵盖了多个领域的专家级问题，包括科学、技术、工程和数学等。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"268\" data-backw=\"562\" data-height=\"841\" data-imgfileid=\"505086420\" data-ratio=\"0.47685185185185186\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/a955fefd-6300-4bc1-93b4-20222eecf300/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1762\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/a955fefd-6300-4bc1-93b4-20222eecf300/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">通过巧妙地利用LMM（例如GPT-4o）来模拟人机交互，构建出具有针对性的测试数据集。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">具体而言，通过选择反馈提供模型M_p答对，而反馈接收模型M_r答错的交集，确保反馈的相关性和可靠性。</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);letter-spacing: 1px;font-size: 16px;\">InterFeedback框架</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">InterFeedback框架有两个角色：反馈接收者M_r和反馈提供者M_p。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">M_r是准备接受基准测试的LMM，如Qwen2-VL，M_p是当前最优的LMM，如GPT-4o，用于在每个时间步代替人类提供反馈。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"382\" data-backw=\"562\" data-height=\"1069\" data-imgfileid=\"505086421\" data-ratio=\"0.6796296296296296\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/b75d6e7a-affd-447b-6653-c3f554612e00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1573\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/b75d6e7a-affd-447b-6653-c3f554612e00/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">当M_r模型生成输出后，M_p会根据映射策略提供反馈，模型则根据反馈进行改进，如此循环，直到得到正确答案或达到预设的迭代次数。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在这个过程中，M_r根据当前的状态和观测信息，生成相应的动作。M_p则根据模型的回答，提供反馈信息，帮助模型改进自己的回答。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">基于InterFeedback框架，团队构建了InterFeedback-Bench基准测试。这个基准测试旨在全面评估LMM交互式问题解决和反馈学习的能力。</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);letter-spacing: 1px;font-size: 16px;\">人类评估基准测试</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">除了自动基准测试，研究团队还收集了InterFeedback-Human数据集，用于人工评估闭源模型。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">与自动基准测试不同，InterFeedback-Human数据集的评估过程更注重人类的参与和反馈。用户根据模型的回答，提供详细的反馈信息，包括问题的分析、正确的思路和答案等。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">通过这种方式，可以更深入地了解模型在实际人机交互中的表现，以及它们理解和处理人类反馈的能力。</span></p>\n  <section autoid=\"1895\" data-style-type=\"0\" style=\"max-width:100%;white-space:normal;letter-spacing:0.544px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box !important;margin-bottom:0px;overflow-wrap:break-word !important;\">\n   <section style=\"padding: 8px;max-width: 100%;box-sizing: border-box;border-left: 6px solid rgb(255, 202, 0);font-size: 18px;line-height: 1.4;font-family: inherit;font-weight: bold;text-decoration: inherit;border-top-color: rgb(255, 202, 0);border-right-color: rgb(255, 202, 0);border-bottom-color: rgb(255, 202, 0);overflow-wrap: break-word !important;\">\n    <p style=\"line-height: 1.75em;margin-bottom: 0px;\"><span style=\"letter-spacing: 1px;\"></span>实验结果与分析</p>\n   </section>\n  </section>\n  <section style=\"letter-spacing: 0.578px;text-align: justify;margin: 24px 8px;line-height: 1.75em;\">\n   <span style=\"font-size: 15px;letter-spacing: 1px;\">研究人员设计了一系列实验，在MathVerse和MMMU-Pro两个具有代表性的数据集上，对多个开源LMM进行了全面评估。</span>\n  </section>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">用准确率和纠错率来评估结果，纠错率定义为所有错误样本中被纠正答案的样本所占的百分比。N表示样本总数，N_e表示错误样本的数量，N_c表示已被纠正的样本数量。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">准确率和纠错率可以用以下公式表示：</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"58\" data-backw=\"562\" data-height=\"110\" data-imgfileid=\"505086419\" data-ratio=\"0.10328638497652583\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/b4588c02-2b44-498b-4b68-a6c2b40c2700/public\" data-type=\"png\" data-w=\"1065\" data-width=\"1065\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/b4588c02-2b44-498b-4b68-a6c2b40c2700/public\"></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 16px;color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);font-size: 16px;letter-spacing: 1px;\">交互过程能提高性能</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">实验结果表明，交互式过程对大多数LMM的性能提升有显著的促进作用。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">InterFeedback框架能使大多数模型从GPT-4o和Claude-3.5-Sonnet等提供的反馈中受益。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">例如，即使是性能较弱的Fuyu-8B模型，通过GPT-4o的反馈也能纠正24.1%的错误样本。这表明交互过程可以有效提高大多数LMM解决问题的能力。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"js_asyningdom rich_pages wxw-img\" data-backh=\"250\" data-backw=\"562\" data-height=\"877\" data-imgfileid=\"505086424\" data-ratio=\"0.44537037037037036\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/5f7de97e-8dcc-4f7e-2d8e-fc6f499ddd00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1968\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/5f7de97e-8dcc-4f7e-2d8e-fc6f499ddd00/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"250\" data-backw=\"562\" data-height=\"726\" data-imgfileid=\"505086423\" data-ratio=\"0.4444444444444444\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/534a92da-7a9c-4dd4-f165-f6374015df00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1635\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/534a92da-7a9c-4dd4-f165-f6374015df00/public\"></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 16px;color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);font-size: 16px;letter-spacing: 1px;\">难以通过反馈提升性能</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">尽管有先进模型提供的反馈，但大多数LMM仍难以纠正所有错误样本。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">以Qwen2-VL-7B和Molmo为例，Qwen2-VL-7B在MathVerse数据集上使用GPT-4o的反馈时，纠错率为66.8%，但在MMMU-Pro数据集上仅为50.4%。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">Molmo-7B在MathVerse和MMMU-Pro数据集上的纠错率分别为55.1%和51.7%，其余模型的纠错率普遍低于50%。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">即使有LMM提供的反馈，当前的模型在通过反馈提升自身性能方面仍存在较大困难。</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 16px;color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);font-size: 16px;letter-spacing: 1px;\">准确率可能无法反映模型能力</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">实验发现，准确率可能无法真实、全面地反映模型的实际能力。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"js_asyningdom rich_pages wxw-img\" data-backh=\"250\" data-backw=\"562\" data-height=\"877\" data-imgfileid=\"505086425\" data-ratio=\"0.44537037037037036\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/5f7de97e-8dcc-4f7e-2d8e-fc6f499ddd00/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1968\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/5f7de97e-8dcc-4f7e-2d8e-fc6f499ddd00/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">例如，InternVL2-8B的准确率较高（38.1%），但其纠错率仅为49.6%。而准确率较低（22.5%）的Qwen2-VL-7B在使用GPT-4o的反馈时，却达到了最高的纠错率66.8%。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在MMMU-Pro数据集上也有类似情况，LLaVA-OneVision-7B的准确率排名第二（47.1%），但其纠错率仅为 31.7%，低于几个准确率较低的模型。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">这表明仅通过准确率评估模型，可能无法全面体现其真实能力。</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 16px;color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);font-size: 16px;letter-spacing: 1px;\">反馈质量至关重要</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">令人惊讶的是，所有模型都能从简单的二元（0/1）反馈中受益。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">同时，研究发现反馈质量至关重要，低质量反馈对性能的损害比简单的二元反馈更大。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在MathVerse数据集上，对于一些模型，使用次优模型（Gemini-1.5-Flash）提供的简单二元反馈，其效果优于LMM生成的详细反馈。</span></p>\n  <h3 style=\"letter-spacing: 0.578px;text-align: center;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 16px;color: rgb(255, 104, 39);\"><strong><span style=\"color: rgb(255, 104, 39);font-size: 16px;letter-spacing: 1px;\">人工基准测试的分析</span></strong></span></h3>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">在对OpenAI-o1、GPT-4o、Gemini-2.0和Claude-3.5-Sonnet等闭源模型的人工评估中，Claude-3.5的平均准确率最高，达到了48.3%。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"js_asyningdom rich_pages wxw-img\" data-backh=\"363\" data-backw=\"562\" data-height=\"993\" data-imgfileid=\"505086427\" data-ratio=\"0.6462962962962963\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/b6137013-901f-4946-559c-da8bf92b1900/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1537\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/b6137013-901f-4946-559c-da8bf92b1900/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">从纠正率结果分析来看，不同模型从人类反馈中获益的轮次和程度存在明显差异。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">GPT-4o在第一轮反馈中能够纠正41.9%的错误样本，显示出其对人类反馈的快速响应和学习能力。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">Claude-3.5则在第二轮反馈中展现出强大的纠正性能，成功纠正了30.6%的错误样本。在第三轮，由于提供了真实答案，所有LMM都能够给出选择正确答案的推理步骤。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"rich_pages wxw-img\" data-backh=\"170\" data-backw=\"562\" data-height=\"554\" data-imgfileid=\"505086426\" data-ratio=\"0.30277777777777776\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/3670a9e4-2f17-41c8-59dc-e05eedd4c300/public\" data-type=\"png\" data-w=\"1080\" data-width=\"1831\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/3670a9e4-2f17-41c8-59dc-e05eedd4c300/public\"></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">此外，不同任务类别中被纠正样本的分布也有所不同。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">视觉逻辑任务大多在前两轮就能够得到有效解决，而纯文本数学任务和MMMU-Pro任务在前两轮的纠正相对较少。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><span style=\"font-size: 15px;letter-spacing: 1px;\">相比之下，纯文本编码任务和MathVerse任务在前两轮也出现了一定比例的纠正，说明模型在这些领域具有一定的学习和改进能力。</span></p>\n  <p style=\"letter-spacing: 0.578px;text-align: justify;margin: 0px 8px 24px;line-height: 1.75em;\"><img class=\"js_asyningdom rich_pages wxw-img\" data-backh=\"414\" data-backw=\"562\" data-height=\"729\" data-imgfileid=\"505086428\" data-ratio=\"0.737108190091001\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/9c8e2f69-bd16-4dd2-5e05-6ab1caa71d00/public\" data-type=\"png\" data-w=\"989\" data-width=\"989\" style=\"width: 100%;height: auto;\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/9c8e2f69-bd16-4dd2-5e05-6ab1caa71d00/public\"></p>\n  <section style=\"white-space:normal;letter-spacing:0.544px;min-height:1em;line-height:1.75em;box-sizing:border-box !important;margin-right:8px;overflow-wrap:break-word !important;margin-left:8px;max-width:100%;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\">参考资料：</span>\n  </section>\n  <section style=\"white-space:normal;letter-spacing:0.544px;min-height:1em;line-height:1.75em;box-sizing:border-box !important;margin-right:8px;overflow-wrap:break-word !important;margin-left:8px;max-width:100%;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\">https://huggingface.co/papers/2502.15027</span>\n  </section>\n  <section style=\"white-space:normal;letter-spacing:0.544px;min-height:1em;line-height:1.75em;box-sizing:border-box !important;margin-right:8px;overflow-wrap:break-word !important;margin-left:8px;max-width:100%;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\">https://arxiv.org/pdf/2502.15027</span></section>\n  <p style=\"display: none;\"><mp-style-type data-value=\"3\"></mp-style-type></p>\n \n",
  "aiSummary": "新加坡国立大学华人团队提出 InterFeedback 框架，评估发现即使是最先进的 LMM，在人类反馈下的修正率也低于 50%，揭示了现有 LMM 在反馈学习方面的不足。",
  "oneSentenceSummary": "新加坡国立大学华人团队提出 InterFeedback 框架，评估发现即使是最先进的 LMM，在人类反馈下的修正率也低于 50%，揭示了现有 LMM 在反馈学习方面的不足。",
  "summary": "文章介绍了新加坡国立大学华人团队提出的 InterFeedback 框架，用于自动化评估大规模多模态模型（LMM）的交互智能。该团队构建了 InterFeedback-Bench 基准测试，使用了 MMMU-Pro 和 MathVerse 两个数据集对 10 种不同的 LMM 进行测试。实验还发现，交互式过程可以提高 LMM 解决难题的性能。研究结果表明，即使是最先进的 LMM，通过人类反馈纠正错误结果的比例也低于 50%。现有 LMM 在解释和整合反馈方面表现不佳，高质量的反馈至关重要。此外，文章还探讨了准确率作为评估指标的局限性，以及人工评估基准测试的结果，强调了模型从人类反馈中获益的程度存在差异。",
  "mainPoints": [
    {
      "point": "LMM 在人类反馈下的纠错率不足 50%，表明现有模型在理解和整合反馈方面存在根本性挑战。",
      "explanation": "实验结果表明，即使是最先进的 LMM，通过人类反馈纠正结果的比例仍然较低，表明 LMM 在理解和整合反馈方面存在挑战。"
    },
    {
      "point": "交互式过程能有效提高 LMM 解决问题的能力，但反馈质量至关重要。",
      "explanation": "交互式反馈可以帮助 LMM 从错误中学习和改进，但低质量的反馈甚至可能损害模型性能，高质量反馈是关键。"
    },
    {
      "point": "高质量反馈是提升 LMM 性能的关键，但获取有效反馈仍然面临挑战。",
      "explanation": "研究表明，反馈质量对 LMM 的性能提升至关重要，但如何设计更有效的反馈机制，以及如何获取高质量的反馈数据，仍然是当前面临的挑战。"
    },
    {
      "point": "准确率可能无法全面反映 LMM 的真实能力，需结合纠错率等指标综合评估。",
      "explanation": "实验表明，高准确率的模型可能纠错能力较弱，因此需要综合考虑准确率和纠错率等指标，才能更全面地评估模型性能。"
    }
  ],
