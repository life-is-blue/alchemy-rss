woshipm.com/view/woshipm_api_def_20230531102333_9683.jpeg?imageView2/1/w/72/h/72/q/100\" alt=\"\" height=\"36\" width=\"36\" class=\"avatar\"></a>\n            </div>\n            <div class=\"comment-section\">\n             <div class=\"comment-info\">\n              <div class=\"comment-meta\">\n               <div class=\"comment-author\" itemprop=\"author\">\n                <a href=\"https://www.woshipm.com/u/1034466\" target=\"_blank\">七姑娘</a> <el-tooltip class=\"newusertagIcon u-cursorPointer\" effect=\"dark\" content=\"实名认证\" placement=\"top\"><img src=\"https://static.woshipm.com/tag/1601_1@2x.png \" width=\"16\" @click=\"goVip({parentCode: 1600})\"></el-tooltip><el-tooltip class=\"newusertagIcon u-cursorPointer\" effect=\"dark\" content=\"普通作者\" placement=\"top\"><img src=\"https://static.woshipm.com/tag/1101_1@2x.png \" width=\"16\" @click=\"goVip({parentCode: 1100})\"></el-tooltip><span class=\"post-c-a\" title=\"文章作者\">作者</span> <span class=\"color-noraml\">回复</span><a href=\"#comment-588227\">方正泓</a>\n               </div>\n              </div>\n             </div>\n             <div class=\"comment-content\" itemprop=\"description\">\n              <p>IT咨询公司和IT服务公司都没有产品经理的岗位。产品公司大部分都将工作合并在产品经理这里， 也有的会拆开。但我觉得叫什么不重要，重要的是学会需求分析、产品设计和指导落地能力。</p>\n             </div>\n             <div class=\"comment-bottom\">\n              <span class=\"comment-time\" itemprop=\"datePublished\" datetime=\"2025-02-14T14:53:34+08:00\">最近</span> <span class=\"comment-reply\">来自陕西</span> <span @click=\"moveForm\" data-id=\"588229\" class=\"comment-reply\">回复</span> <span class=\"js-report-content\" @click=\"showReport(588229)\"> <img src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/b0504319-e7a9-4ea7-3f46-52f9506dd600/public\" width=\"16\"> </span>\n             </div>\n            </div>\n           </div>\n          </li>\n          <!-- #comment-## -->\n         </ol>\n         <!-- .children -->\n        </li>\n        <!-- #comment-## -->\n       </ol>\n       <