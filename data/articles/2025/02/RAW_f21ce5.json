648384-35.478528-12.50304-55.53152-20.606976-57.255936-23.138304-114.526208-51.75296-168.23808-86.290432C100.463616 698.655744 4.096 567.63392 4.096 404.086784 4.096 88.11008 368.360448-26.631168 553.612288 264.40704l-75.334656 0.48128z\" fill=\"#ffffff\" p-id=\"3818\"></path>\n         </svg><span class=\"default\">点赞</span><span class=\"active\">已赞</span><span class=\"count\" v-if=\"!!postmeta.bookmark\">{{ postmeta.postlike }}</span></button>\n       </div>\n      </div>\n      <section class=\"pm-adTitle trackRead\">\n       更多精彩内容，请关注人人都是产品经理微信公众号或下载App\n      </section>\n      <div class=\"article--actions\">\n       <div class=\"taglist\" data-dts-event-location=\"tag_items\">\n        <a href=\"https://www.woshipm.com/tag/%e4%b8%9c%e5%8d%97%e4%ba%9a\" rel=\"tag\">东南亚</a><a href=\"https://www.woshipm.com/tag/%e5%87%ba%e6%b5%b7\" rel=\"tag\">出海</a><a href=\"https://www.woshipm.com/tag/%e7%91%9e%e5%b9%b8\" rel=\"tag\">瑞幸</a><a href=\"https://www.woshipm.com/tag/%e8%a1%8c%e4%b8%9a%e8%a7%82%e5%af%9f\" rel=\"tag\">行业观察</a>\n       </div>\n       <div class=\"article--actions__right\">\n        <share-button link=\"https://www.woshipm.com/it/6181995.html\" title=\"没有微信，不打价格战，瑞幸如何出海东南亚\" image=\"https://image.woshipm.com/2023/04/20/f087e29a-df4a-11ed-946e-00163e0b5ff3.jpg\"></share-button>\n       </div>\n      </div>\n     </div>\n     <div class=\"postFooterInfo u-marginTop20 u-backgroundColorWhite u-rounded u-shadowed\">\n      <div class=\"u-flex\">\n       <div class=\"u-flex0\">\n        <a href=\"https://www.woshipm.com/u/1521537\" target=\"_blank\"><img src=\"https://static.woshipm.com/view/woshipm_api_def_20230601112921_4944.png?imageView2/1/w/150/h/150/q/100\" alt=\"\" height=\"75\" width=\"75\" class=\"avatar\"></a>\n       </div>\n       <div class=\"u-flex1 u-paddingLeft15 u-overflowHidden\">\n        <div class=\"authorCard--content\">\n         <span class=\"authorCard--title u-flex\"> <a href=\"https://www.woshipm.com/u/1521537\" target=\"_blank\">窄播