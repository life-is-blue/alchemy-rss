>\n     <div class=\"postFooterInfo u-marginTop20 u-backgroundColorWhite u-rounded u-shadowed\">\n      <div class=\"u-flex\">\n       <div class=\"u-flex0\">\n        <a href=\"https://www.woshipm.com/u/285936\" target=\"_blank\"><img src=\"https://static.woshipm.com/view/woshipm_api_def_20250117141911_4838.jpg?imageView2/1/w/150/h/150/q/100\" alt=\"\" height=\"75\" width=\"75\" class=\"avatar\"></a>\n       </div>\n       <div class=\"u-flex1 u-paddingLeft15 u-overflowHidden\">\n        <div class=\"authorCard--content\">\n         <span class=\"authorCard--title u-flex\"> <a href=\"https://www.woshipm.com/u/285936\" target=\"_blank\">化文龙</a> <el-tooltip class=\"newusertagIcon\" effect=\"dark\" content=\"实名认证\" placement=\"top\"><img src=\"https://static.woshipm.com/tag/1601_1@2x.png \" class=\"icon-height20\" @click=\"goVip({parentCode: 1600})\"></el-tooltip><el-tooltip class=\"newusertagIcon\" effect=\"dark\" content=\"普通作者\" placement=\"top\"><img src=\"https://static.woshipm.com/tag/1101_1@2x.png \" class=\"icon-height20\" @click=\"goVip({parentCode: 1100})\"></el-tooltip> <sub-button :author=\"285936\" :status=\"isFollowing\" @subauthorchild=\"subauthor\"> </sub-button></span>\n        </div>\n        <div class=\"authorCard--description\">聚焦服务管理！</div>\n        <div class=\"authorCard--meta\">\n         <span class=\"authorInfo-item\">62篇作品</span> <span class=\"dot\"></span> <span class=\"authorInfo-item\">131744总阅读量</span>\n        </div>\n       </div>\n      </div>\n     </div>\n     <div class=\"relate-text u-shadowed u-rounded\">\n      <nav class=\"stream-video--title\">\n       <span class=\"title\">为你推荐</span>\n      </nav>\n      <div class=\"relate-text__list\" data-dts-event-location=\"recom_article_module\">\n       <div class=\"relate-text__item\">\n        <div class=\"content\">\n         <div class=\"title\">\n          <a href=\"https://www.woshipm.com/it/5805469.html\" target=\"_blank\" title=\"团餐如何“互联网化”？\">团餐如何“互联网化”？</a>\n         </div>