  "content": "<html>\n <head></head>\n <body>\n  <div data-tool=\"mdnice编辑器\" data-website=\"https://www.mdnice.com\" style=\"background-size:auto;background-attachment:scroll;padding-left:0px;font-size:16px;overflow-wrap:break-word;background-color:rgba(0, 0, 0, 0);margin-left:0px;background-repeat:no-repeat;word-spacing:0em;background-position-x:0%;background-position-y:0%;word-break:break-word;font-family:'Microsoft YaHei';margin-top:0px;background-image:none;text-align:left;padding-top:0px;letter-spacing:0em;padding-bottom:0px;line-height:1.5em;margin-right:0px;background-clip:border-box;width:auto;background-origin:padding-box;margin-bottom:0px;padding-right:0px;\" data-pm-slice=\"0 0 []\">\n   <h2 data-tool=\"mdnice编辑器\" style=\"padding-top: 0px;padding-bottom: 0px;padding-left: 10px;padding-right: 0px;display: block;color: rgb(0, 150, 136);margin-top: 0.2rem;margin-right: auto;margin-bottom: 0.2rem;margin-left: auto;border-left-width: 3px;border-left-style: solid;border-left-color: rgb(0, 150, 136);\"><span style=\"font-weight:bold;letter-spacing:0em;display:block;font-size:22px;line-height:1.5em;text-align:left;\"><span leaf=\"\">nanobrowser/nanobrowser</span><span style=\"font-size: 0.58em;font-weight: normal;font-style: italic;color: graytext;display: block;text-decoration: underline;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;\"><span leaf=\"\"><a href=\"https://github.com/nanobrowser/nanobrowser\" target=\"_blank\">https://github.com/nanobrowser/nanobrowser</a></span></span></span></h2>\n   <p data-tool=\"mdnice编辑器\" style=\"padding-top:3px;letter-spacing:0em;padding-left:0px;font-size:16px;padding-bottom:3px;line-height:1.5em;margin-right:0px;margin-left:0px;text-indent:0em;margin-top:0px;margin-bottom:0px;text-align:justify;padding-right:0px;\"><span leaf=\"\">Stars:&nbsp;</span><code style=\"font-size: 14px;line-height: 1.2em;letter-spacing: 0em;background-attachment: scroll;background-clip: border-