-radius: 4px;border-top-right-radius: 4px;border-bottom-right-radius: 4px;border-bottom-left-radius: 4px;overflow-wrap: break-word;font-family: Consolas, Monaco, Menlo, monospace;word-break: break-all;color: rgb(0, 150, 136);\"><span leaf=\"\">NOASSERTION</span></code></p>\n   <p data-tool=\"mdnice编辑器\" style=\"padding-top:3px;letter-spacing:0em;padding-left:0px;font-size:16px;padding-bottom:3px;line-height:1.5em;margin-right:0px;margin-left:0px;text-indent:0em;margin-top:0px;margin-bottom:0px;text-align:justify;padding-right:0px;\"><span leaf=\"\">system_prompts_leaks 是一个收集来自流行聊天机器人（如 ChatGPT、Claude 和 Gemini）系统提示语的项目。</span></p>\n   <ul style=\"margin-left:0px;padding-top:0px;list-style-type:disc;padding-left:1rem;padding-bottom:0px;margin-top:8px;margin-bottom:8px;margin-right:0px;padding-right:0px;\" class=\"list-paddingleft-1\">\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">汇总了多种公开部署聊天机器人的系统消息指令</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">提供了对不同模型内部提示设计的洞察</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">方便研究者和开发者了解和比较各大聊天机器人的系统设置</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">项目持续更新，包含最新版本如 OpenAI 的 gpt-5-thinking.md 文件</span></p>\n    </li>\n   </ul>\n   <h2 data-tool=\"mdnice编辑器\" style=\"padding-top: 0px;padding-bottom: 0px;padding-left: 10px;padding-right: 0px;display: block;color: rgb(0, 150, 136);margin-top: 0.2rem;margin-right: auto;margin-bottom: 0.2rem;margin-left: auto;border-left-width: 3px;border-left-style: solid;b