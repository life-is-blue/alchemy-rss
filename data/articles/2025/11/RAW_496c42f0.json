, 0, 0);border-bottom-color: rgba(0, 0, 0, 0.4);border-left-color: rgba(0, 0, 0, 0.4);border-right-color: rgba(0, 0, 0, 0.4);border-top-left-radius: 4px;border-top-right-radius: 4px;border-bottom-right-radius: 4px;border-bottom-left-radius: 4px;overflow-wrap: break-word;font-family: Consolas, Monaco, Menlo, monospace;word-break: break-all;color: rgb(0, 150, 136);\"><span leaf=\"\">1.3k</span></code><span leaf=\"\">&nbsp; License:&nbsp;</span><code style=\"font-size: 14px;line-height: 1.2em;letter-spacing: 0em;background-attachment: scroll;background-clip: border-box;background-color: rgba(27, 31, 35, 0.05);background-image: none;background-origin: padding-box;background-position-x: 0%;background-position-y: 0%;background-repeat: no-repeat;background-size: auto;width: auto;height: auto;margin-top: 0px;margin-bottom: 0px;margin-left: 2px;margin-right: 2px;padding-top: 2px;padding-bottom: 2px;padding-left: 4px;padding-right: 4px;border-top-style: none;border-bottom-style: none;border-left-style: none;border-right-style: none;border-top-width: 3px;border-bottom-width: 3px;border-left-width: 3px;border-right-width: 3px;border-top-color: rgb(0, 0, 0);border-bottom-color: rgba(0, 0, 0, 0.4);border-left-color: rgba(0, 0, 0, 0.4);border-right-color: rgba(0, 0, 0, 0.4);border-top-left-radius: 4px;border-top-right-radius: 4px;border-bottom-right-radius: 4px;border-bottom-left-radius: 4px;overflow-wrap: break-word;font-family: Consolas, Monaco, Menlo, monospace;word-break: break-all;color: rgb(0, 150, 136);\"><span leaf=\"\">AGPL-3.0</span></code></p>\n   <p data-tool=\"mdnice编辑器\" style=\"padding-top:3px;letter-spacing:0em;padding-left:0px;font-size:16px;padding-bottom:3px;line-height:1.5em;margin-right:0px;margin-left:0px;text-indent:0em;margin-top:0px;margin-bottom:0px;text-align:justify;padding-right:0px;\"><span leaf=\"\">buttercup 是一个由 Trail of Bits 开发的网络推理系统（Cyber Reasoning System），用于自动发现并修复开源代码库中的软件漏洞。</span></p>\n   <ul style=\"margin-left:0px;padding-top:0px;list-style-type:disc;padding-left:1rem;padding-bottom:0px;margin-top:8px;margin-bottom:8px;margin-right:0px;padding-right:0px;\" class=\"list-paddingleft-1\">\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">通过 AI/ML 辅助的模糊测试（基于 oss-fuzz）进行漏洞挖掘</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">多智能体 AI 驱动的补丁生成与应用，实现自动化漏洞修复</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">系统组件包括任务协调器、种子生成器、模糊测试器、程序模型分析和补丁工具</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">支持 Linux x86_64 和部分 ARM64 平台，兼容 OSS-Fuzz 的 C 和 Java 代码库</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">提供本地部署脚本及 Web GUI，方便监控任务状态和查看补丁结果</span></p>\n    </li>\n    <li>\n     <p style=\"font-weight:normal;letter-spacing:0em;font-size:16px;margin-top:5px;line-height:1.5em;margin-bottom:5px;text-align:left;\"><span leaf=\"\">集成 SigNoz 用于日志追踪和性能监控，提高系统可观测性</span></p>\n    </li>\n   </ul>\n  </div>\n  <p></p>\n </body>\n</html>",
  "aiSummary": "本文汇总了多个热门开源项目，涵盖聊天机器人系统提示语、AI 代理工具、数据时间轴、3D 动画和网络安全推理系统，为技术从业者提供最新工具和洞察。",
  "oneSentenceSummary": "本文汇总了多个热门开源项目，涵盖聊天机器人系统提示语、AI 代理工具、数据时间轴、3D 动画和网络安全推理系统，为技术从业者提供最新工具和洞察。",
  "summary": "本期开源日报精选了五个热门开源项目，旨在为技术从业者提供前沿工具和洞察。其中，`system_prompts_leaks`项目汇集了主流聊天机器人如 ChatGPT、Claude 和 Gemini 的系统提示语，揭示了模型内部设计，对研究者和开发者理解和比较大模型有重要价值。`klavis`则是一个多通道平台集成层，赋能 AI 代理可靠使用工具并实现大规模扩展，支持超过 50 种生产级服务集成。此外，日报还介绍了`timelinize`（将多源数据整合到统一时间轴）、`mesh2motion-app`（网页版 3D 模型动画工具）和`buttercup`（AI 辅助网络推理系统，用于自动发现并修复开源代码漏洞），覆盖了从个人数据管理到 AI 安全分析的多个领域，体现了开源社区的活力和创新。",
