  "id": "RAW_07bac7",
  "title": "Anthropic 限制加码：中国控股 50%以上的公司，立即断供",
  "url": "https://mp.weixin.qq.com/s?__biz=MzkzNDQxOTU2MQ==&mid=2247505177&idx=1&sn=67bc66cb595c8e903c3a493e8a183149",
  "date": "2025-09-05 04:37:00",
