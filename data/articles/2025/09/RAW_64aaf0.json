>6,830,273.97<span class=\"hljs-tag\">&lt;/<span class=\"hljs-name\">td</span>&gt;</span>&nbsp;&nbsp;<span class=\"hljs-tag\">&lt;/<span class=\"hljs-name\">tr</span>&gt;</span>\r\n&nbsp; &nbsp; &nbsp; &nbsp;&nbsp;<span class=\"hljs-tag\">&lt;<span class=\"hljs-name\">tr</span>&gt;</span>&nbsp;&nbsp;<span class=\"hljs-tag\">&lt;<span class=\"hljs-name\">td</span>&gt;</span>衍生金融资产<span class=\"hljs-tag\">&lt;/<span class=\"hljs-name\">td</span>&gt;</span>&nbsp;<span class=\"hljs-tag\">&lt;<span class=\"hljs-name\">td</span>&gt;</span><span class=\"hljs-tag\">&lt;/<span class=\"hljs-name\">td</span>&gt;</span>&nbsp;<span class=\"hljs-tag\">&lt;<span class=\"hljs-name\">td</span>&gt;</span><span class=\"hljs-tag\">&lt;/<span class=\"hljs-name\">td</span>&gt;</span>&nbsp;&nbsp;<span class=\"hljs-tag\">&lt;/<span class=\"hljs-name\">tr</span>&gt;</span>\r\n&nbsp; &nbsp; &nbsp; &nbsp;&nbsp;<span class=\"hljs-tag\">&lt;<span class=\"hljs-name\">tr</span>&gt;</span>&nbsp;&nbsp;<span class=\"hljs-tag\">&lt;<span class=\"hljs-name\">td</span>&gt;</span>应收票据<span class=\"hljs-tag\">&lt;/<span class=\"hljs-name\">td</span>&gt;</span>&nbsp;<span class=\"hljs-tag\">&lt;<span class=\"hljs-name\">td</span>&gt;</span>1,010,636.94<span class=\"hljs-tag\">&lt;/<span class=\"hljs-name\">td</span>&gt;</span>&nbsp;<span class=\"hljs-tag\">&lt;<span class=\"hljs-name\">td</span>&gt;</span>888,800.00<span class=\"hljs-tag\">&lt;/<span class=\"hljs-name\">td</span>&gt;</span>&nbsp;&nbsp;<span class=\"hljs-tag\">&lt;/<span class=\"hljs-name\">tr</span>&gt;</span>\r\n&nbsp; &nbsp; &nbsp; &nbsp;&nbsp;<span class=\"hljs-tag\">&lt;<span class=\"hljs-name\">tr</span>&gt;</span>&nbsp;&nbsp;<span class=\"hljs-tag\">&lt;<span class=\"hljs-name\">td</span>&gt;</span>应收账款<span class=\"hljs-tag\">&lt;/<span class=\"hljs-name\">td</span>&gt;</span>&nbsp;<span class=\"hljs-tag\">&lt;<span class=\"hljs-name\">td</span>&gt;</span>389,409,537.65<span class=\"hljs-tag\">&lt;/<span class=\"hljs-name\">td</spa