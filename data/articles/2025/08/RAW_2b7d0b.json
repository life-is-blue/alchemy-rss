1\">\n       <div class=\"f-ui-05 ml-8 mt-2 inline-flex h-full items-center\">\n        <time class=\"f-ui-05 inline-flex w-36 items-center\">00:00</time>&nbsp;/&nbsp;<time class=\"f-ui-05 text-light inline-flex items-center\">00:00</time>\n       </div>\n      </div>\n      <div class=\"flex items-center gap-x-8\">\n       <button class=\"inline-flex items-center justify-center whitespace-nowrap rounded-full effect-color disabled:cursor-not-allowed bg-transparent text-default hover:text-lighter effect-focus data-[state=active]:bg-default w-24 h-24 f-ui-03\" aria-label=\"Mute\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" fill=\"none\" class=\"color-white\">\n         <path fill=\"currentColor\" stroke=\"currentColor\" d=\"M16 17.659a6.002 6.002 0 0 0 0-11.317V5.29a7.003 7.003 0 0 1 0 13.42v-1.05Z\"></path><path stroke=\"currentColor\" stroke-width=\"2\" d=\"m7.284 8.398.216-.03.184-.119L13 4.832v14.336l-5.316-3.417-.184-.118-.216-.031-2.855-.408A.5.5 0 0 1 4 14.699V9.301a.5.5 0 0 1 .43-.495z\"></path>\n        </svg></button><span dir=\"ltr\" data-orientation=\"horizontal\" aria-disabled=\"false\" class=\"relative flex touch-none select-none items-center w-60\" style=\"--radix-slider-thumb-transform:translateX(-50%)\"><span data-orientation=\"horizontal\" class=\"bg-darker relative h-4 w-full grow overflow-hidden rounded-full\"><span data-orientation=\"horizontal\" class=\"bg-inverse absolute h-full\" style=\"left:0%;right:40%\"></span></span><span style=\"transform:var(--radix-slider-thumb-transform);left:calc(0% + 0px);\"></span></span>\n      </div>\n     </div>\n    </div>\n   </div>\n  </div>\n  <div class=\"block-el block-el-rich-text px-16 md:px-32\">\n   <div class=\"rich-text-blog whitespace-pre-line font-inter grid-col-span-12 lg:grid-col-span-6 lg:grid-col-start-4\">\n    <p><strong>Obsidian</strong></p>\n    <p>Prompt: “Extremely dark, tense and powerful, cinematic sound design, electronic hybrid, trailer music, evil, braam, braam horns, impacts, boom, rising tension, completely instrumental.”</p>\n   </div>\n  </div>\n  <div class=\"block-el block-el-asset block-el-asset-audio\">\n   <div aria-label=\"Audio Player \" class=\"flex items-center gap-20 rounded-sm border p-12 lg:p-20\" role=\"region\">\n    <div class=\"flex-1 space-y-12 lg:space-y-20\">\n     <div class=\"gap-8 flex grow items-center justify-between\">\n      <button class=\"inline-flex items-center justify-center whitespace-nowrap rounded-full effect-color disabled:cursor-not-allowed bg-transparent text-default hover:text-lighter effect-focus data-[state=active]:bg-default w-24 h-24 f-ui-03\" aria-label=\"Play\">\n       <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" fill=\"none\" class=\"color-white\">\n        <path fill=\"currentColor\" d=\"M24 12 6 22.392V1.608z\"></path>\n       </svg></button>\n      <div class=\"items-center mr-auto flex flex-1\">\n       <div class=\"f-ui-05 ml-8 mt-2 inline-flex h-full items-center\">\n        <time class=\"f-ui-05 inline-flex w-36 items-center\">00:00</time>&nbsp;/&nbsp;<time class=\"f-ui-05 text-light inline-flex items-center\">00:00</time>\n       </div>\n      </div>\n      <div class=\"flex items-center gap-x-8\">\n       <button class=\"inline-flex items-center justify-center whitespace-nowrap rounded-full effect-color disabled:cursor-not-allowed bg-transparent text-default hover:text-lighter effect-focus data-[state=active]:bg-default w-24 h-24 f-ui-03\" aria-label=\"Mute\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" fill=\"none\" class=\"color-white\">\n         <path fill=\"currentColor\" stroke=\"currentColor\" d=\"M16 17.659a6.002 6.002 0 0 0 0-11.317V5.29a7.003 7.003 0 0 1 0 13.42v-1.05Z\"></path><path stroke=\"currentColor\" stroke-width=\"2\" d=\"m7.284 8.398.216-.03.184-.119L13 4.832v14.336l-5.316-3.417-.184-.118-.216-.031-2.855-.408A.5.5 0 0 1 4 14.699V9.301a.5.5 0 0 1 .43-.495z\"></path>\n        </svg></button><span dir=\"ltr\" data-orientation=\"horizontal\" aria-disabled=\"false\" class=\"relative flex touch-none select-none items-center w-60\" style=\"--radix-slider-thumb-transform:translateX(-50%)\"><span data-orientation=\"horizontal\" class=\"bg-darker relative h-4 w-full grow overflow-hidden rounded-full\"><span data-orientation=\"horizontal\" class=\"bg-inverse absolute h-full\" style=\"left:0%;right:40%\"></span></span><span style=\"transform:var(--radix-slider-thumb-transform);left:calc(0% + 0px);\"></span></span>\n      </div>\n     </div>\n    </div>\n   </div>\n  </div>\n  <div class=\"block-el block-el-rich-text px-16 md:px-32\">\n   <div class=\"rich-text-blog whitespace-pre-line font-inter grid-col-span-12 lg:grid-col-span-6 lg:grid-col-start-4\">\n    <p><strong>Wanderer of the Moor</strong></p>\n    <p>Prompt: “A young english girl singing an old english folk song, stunning, lonely, thoughtful and almost haunting, fiddle and english folk instrumentation, reverb, short song.”</p>\n   </div>\n  </div>\n  <div class=\"block-el block-el-asset block-el-asset-audio\">\n   <div aria-label=\"Audio Player \" class=\"flex items-center gap-20 rounded-sm border p-12 lg:p-20\" role=\"region\">\n    <div class=\"flex-1 space-y-12 lg:space-y-20\">\n     <div class=\"gap-8 flex grow items-center justify-between\">\n      <button class=\"inline-flex items-center justify-center whitespace-nowrap rounded-full effect-color disabled:cursor-not-allowed bg-transparent text-default hover:text-lighter effect-focus data-[state=active]:bg-default w-24 h-24 f-ui-03\" aria-label=\"Play\">\n       <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" fill=\"none\" class=\"color-white\">\n        <path fill=\"currentColor\" d=\"M24 12 6 22.392V1.608z\"></path>\n       </svg></button>\n      <div class=\"items-center mr-auto flex flex-1\">\n       <div class=\"f-ui-05 ml-8 mt-2 inline-flex h-full items-center\">\n        <time class=\"f-ui-05 inline-flex w-36 items-center\">00:00</time>&nbsp;/&nbsp;<time class=\"f-ui-05 text-light inline-flex items-center\">00:00</time>\n       </div>\n      </div>\n      <div class=\"flex items-center gap-x-8\">\n       <button class=\"inline-flex items-center justify-center whitespace-nowrap rounded-full effect-color disabled:cursor-not-allowed bg-transparent text-default hover:text-lighter effect-focus data-[state=active]:bg-default w-24 h-24 f-ui-03\" aria-label=\"Mute\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" fill=\"none\" class=\"color-white\">\n         <path fill=\"currentColor\" stroke=\"currentColor\" d=\"M16 17.659a6.002 6.002 0 0 0 0-11.317V5.29a7.003 7.003 0 0 1 0 13.42v-1.05Z\"></path><path stroke=\"currentColor\" stroke-width=\"2\" d=\"m7.284 8.398.216-.03.184-.119L13 4.832v14.336l-5.316-3.417-.184-.118-.216-.031-2.855-.408A.5.5 0 0 1 4 14.699V9.301a.5.5 0 0 1 .43-.495z\"></path>\n        </svg></button><span dir=\"ltr\" data-orientation=\"horizontal\" aria-disabled=\"false\" class=\"relative flex touch-none select-none items-center w-60\" style=\"--radix-slider-thumb-transform:translateX(-50%)\"><span data-orientation=\"horizontal\" class=\"bg-darker relative h-4 w-full grow overflow-hidden rounded-full\"><span data-orientation=\"horizontal\" class=\"bg-inverse absolute h-full\" style=\"left:0%;right:40%\"></span></span><span style=\"transform:var(--radix-slider-thumb-transform);left:calc(0% + 0px);\"></span></span>\n      </div>\n     </div>\n    </div>\n   </div>\n  </div>\n  <div class=\"block-el block-el-rich-text px-16 md:px-32\">\n   <div class=\"rich-text-blog whitespace-pre-line font-inter grid-col-span-12 lg:grid-col-span-6 lg:grid-col-start-4\">\n    <p><strong>Yellow Bus Jam</strong></p>\n    <p>Jam band song about driving through new york city in a big yellow school bus with 2 long guitar solos and lots of harmonizing</p>\n   </div>\n  </div>\n  <div class=\"block-el block-el-asset block-el-asset-audio\">\n   <div aria-label=\"Audio Player \" class=\"flex items-center gap-20 rounded-sm border p-12 lg:p-20\" role=\"region\">\n    <div class=\"flex-1 space-y-12 lg:space-y-20\">\n     <div class=\"gap-8 flex grow items-center justify-between\">\n      <button class=\"inline-flex items-center justify-center whitespace-nowrap rounded-full effect-color disabled:cursor-not-allowed bg-transparent text-default hover:text-lighter effect-focus data-[state=active]:bg-default w-24 h-24 f-ui-03\" aria-label=\"Play\">\n       <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" fill=\"none\" class=\"color-white\">\n        <path fill=\"currentColor\" d=\"M24 12 6 22.392V1.608z\"></path>\n       </svg></button>\n      <div class=\"items-center mr-auto flex flex-1\">\n       <div class=\"f-ui-05 ml-8 mt-2 inline-flex h-full items-center\">\n        <time class=\"f-ui-05 inline-flex w-36 items-center\">00:00</time>&nbsp;/&nbsp;<time class=\"f-ui-05 text-light inline-flex items-center\">00:00</time>\n       </div>\n      </div>\n      <div class=\"flex items-center gap-x-8\">\n       <button class=\"inline-flex items-center justify-center whitespace-nowrap rounded-full effect-color disabled:cursor-not-allowed bg-transparent text-default hover:text-lighter effect-focus data-[state=active]:bg-default w-24 h-24 f-ui-03\" aria-label=\"Mute\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" fill=\"none\" class=\"color-white\">\n         <path fill=\"currentColor\" stroke=\"currentColor\" d=\"M16 17.659a6.002 6.002 0 0 0 0-11.317V5.29a7.003 7.003 0 0 1 0 13.42v-1.05Z\"></path><path stroke=\"currentColor\" stroke-width=\"2\" d=\"m7.284 8.398.216-.03.184-.119L13 4.832v14.336l-5.316-3.417-.184-.118-.216-.031-2.855-.408A.5.5 0 0 1 4 14.699V9.301a.5.5 0 0 1 .43-.495z\"></path>\n        </svg></button><span dir=\"ltr\" data-orientation=\"horizontal\" aria-disabled=\"false\" class=\"relative flex touch-none select-none items-center w-60\" style=\"--radix-slider-thumb-transform:translateX(-50%)\"><span data-orientation=\"horizontal\" class=\"bg-darker relative h-4 w-full grow overflow-hidden rounded-full\"><span data-orientation=\"horizontal\" class=\"bg-inverse absolute h-full\" style=\"left:0%;right:40%\"></span></span><span style=\"transform:var(--radix-slider-thumb-transform);left:calc(0% + 0px);\"></span></span>\n      </div>\n     </div>\n    </div>\n   </div>\n  </div>\n  <div class=\"block-el block-el-rich-text px-16 md:px-32\">\n   <div class=\"rich-text-blog whitespace-pre-line font-inter grid-col-span-12 lg:grid-col-span-6 lg:grid-col-start-4\">\n    <p>We can’t wait to see what you create.</p>\n    <h3 id=\"12-commercial-use\">Commercial use&nbsp;</h3>\n    <p>Created in collaboration with labels, publishers, and artists, Eleven Music is cleared for nearly all commercial uses, from film and television to podcasts and social media videos, and from advertisements to gaming. For more information on supported usage across our different plans, <span style=\"text-decoration: underline\">head here.</span></p>\n    <p>Eleven Music is available today on our website, with public API access and integration into our Conversational AI platform coming soon. Check out our <a href=\"https://elevenlabs.io/docs/best-practices/prompting/eleven-music\"><span style=\"text-decoration: underline\">prompt engineering guide</span></a> to help you master the full range of the model’s capabilities.</p>\n   </div>\n  </div>\n </body>\n</html>",
  "aiSummary": "ElevenLabs 推出 Eleven Music，一个 AI 音频平台，使用户能够通过自然语言提示生成录音棚级别、多语言的音乐，并具有广泛的创作控制。",
  "oneSentenceSummary": "ElevenLabs 推出 Eleven Music，一个 AI 音频平台，使用户能够通过自然语言提示生成录音棚级别、多语言的音乐，并具有广泛的创作控制。",
  "summary": "文章宣布 ElevenLabs 正式推出 Eleven Music，将其定位为构建综合性 AI 音频平台的重要一步。它强调了该平台的核心能力：通过自然语言提示生成录音棚级别的音乐。重点强调的关键功能包括对流派、风格和结构的精细控制，乐器或声乐曲目的选项（包括英语、西班牙语、德语、日语等多种语言的声乐），以及编辑特定部分或整首歌曲的能力。文章展示了由 ElevenLabs 团队生成的几个不同的音乐样本。至关重要的是，Eleven Music 被声明几乎可以用于所有商业应用，它是与唱片公司、出版商和艺术家合作开发的。目前可通过 ElevenLabs 网站访问，计划在不久的将来提供公共 API 访问权限并集成到其对话式 AI 平台中。",
  "mainPoints": [
    {
      "point": "Eleven Music 为 AI 驱动的音乐生成提供了广泛的控制。",
      "explanation": "用户可以通过自然语言提示生成录音棚级别的音乐，可以对流派、风格、结构以及人声（多语言）的包含进行细粒度控制，从而实现高度定制的音频创作。"
    },
    {
      "point": "该平台通过行业合作支持广泛的商业应用。",
      "explanation": "Eleven Music 与唱片公司和艺术家合作开发，已获准在电影、电视、播客和游戏等领域进行各种商业应用，从而大大提高了其对专业人士的实用性。"
    },
    {
      "point": "未来的 API 集成旨在扩大可访问性和开发。",
      "explanation": "虽然目前是基于 Web 的，但即将推出的公共 API 访问和集成到 ElevenLabs 的对话式 AI 平台将使开发人员能够更广泛地嵌入和利用其功能。"
    }
  ],
  "keyQuotes": [
    "借助 Eleven Music，企业、创作者、艺术家以及我们的每一位用户都可以通过自然语言提示生成录音棚级别的音乐。",
    "完全控制流派、风格和结构",
    "多语言，包括英语、西班牙语、德语、日语等",
    "Eleven Music 与唱片公司、出版商和艺术家合作创作，几乎可以用于所有商业应用，从电影和电视到播客和社交媒体视频，以及从广告到游戏。",
    "Eleven Music 今天已在我们的网站上提供，公共 API 访问和集成到我们的对话式 AI 平台即将推出。"
  ],
