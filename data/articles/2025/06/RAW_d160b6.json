></span><span leaf=\"\">:&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"^20\"</span></span><span leaf=\"\">,</span><span leaf=\"\"><br></span><span leaf=\"\">&nbsp; &nbsp;&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"@types/react\"</span></span><span leaf=\"\">:&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"^19\"</span></span><span leaf=\"\">,</span><span leaf=\"\"><br></span><span leaf=\"\">&nbsp; &nbsp;&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"@types/react-dom\"</span></span><span leaf=\"\">:&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"^19\"</span></span><span leaf=\"\">,</span><span leaf=\"\"><br></span><span leaf=\"\">&nbsp; &nbsp;&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"@tailwindcss/postcss\"</span></span><span leaf=\"\">:&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"^4\"</span></span><span leaf=\"\">,</span><span leaf=\"\"><br></span><span leaf=\"\">&nbsp; &nbsp;&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"tailwindcss\"</span></span><span leaf=\"\">:&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"^4\"</span></span><span leaf=\"\">,</span><span leaf=\"\"><br></span><span leaf=\"\">&nbsp; &nbsp;&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"eslint\"</span></span><span leaf=\"\">:&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"^9\"</span></span><span leaf=\"\">,</span><span leaf=\"\"><br></span><span leaf=\"\">&nbsp; &nbsp;&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"eslint-config-next\"</span></span><span leaf=\"\">:&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"15.3.3\"</span></span><span leaf=\"\">,</span><span leaf=\"\"><br></span><span leaf=\"\">&nbsp; &nbsp;&nbsp;</span><span style=\"line-height:26px;\"><span leaf=\"\">\"@eslint/eslintrc\"</span></span><span leaf=\"\">:&nbsp;</span><span style=\"line-height:26p