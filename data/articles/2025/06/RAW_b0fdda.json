ne: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-family: PingFangSC-Light;letter-spacing: 0.5px;font-size: 36px;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;}]\" style=\"-webkit-tap-highlight-color: transparent;margin-top: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;\">02</span><span leaf=\"\" data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;color:rgb(75, 110, 245);font-weight:bold;font-size:20px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;margin-top:0px;font-family:PingFangSC-Light;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;visibility:visible;letter-spacing:0.5px;clear:both;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><br></span></span></strong></span>\n  </section>\n  <p data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:16px 0px;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><strong><span leaf=\"\" style=\"font-variant-caps:normal;color:rgb(75, 110, 245);font-weight:bold;font-size:20px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;margin-top:0px;font-family:PingFangSC-Light;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;visibility:visible;letter-spacing:0.5px;clear:both;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">成本持续下降，</span></strong></p>\n  <p data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:16px 0px 24px;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><strong><span leaf=\"\" style=\"font-variant-caps:normal;color:rgb(75, 110, 245);font-weight:bold;font-size:20px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;margin-top:0px;font-family:PingFangSC-Light;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;visibility:visible;letter-spacing:0.5px;clear:both;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">信任成为「顶层」并逐渐变得稀缺</span></strong></p>\n  <p data-pm-slice=\"0 0 []\" style=\"line-height: 1.6em;margin-bottom: 24px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">但分发呢？软件公司不是还有庞大的销售和营销团队吗？确实，就像报社也曾经拥有送报线路和发行量一样。当免费分发与免费分发竞争，付费分发一败涂地。</span></span></p>\n  <p style=\"line-height: 1.6em;margin-bottom: 24px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">起初，这些模型会依赖传统训练集决定的默认环境和技术栈。但默认值会变。随着选择激增，代码在何处、以何种方式运行将由算法决定。</span></span></p>\n  <p style=\"line-height: 1.6em;margin-bottom: 24px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">这种逻辑我们早已习惯。TikTok 决定我们看到什么，Spotify 决定我们听到什么。系统并不透明，但结果还不错——所以我们继续刷。</span></span></p>\n  <p style=\"line-height: 1.6em;margin-bottom: 24px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">代码的洪流真正到来时，我们不会追问解释——</span></span><strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">我们会奖励速度</span></span></strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">。便利会胜过透明。那些能以最快速度回应我们的系统，将取代操作系统，成为新的权力中心。</span></span></p>\n  <p style=\"line-height: 1.6em;margin-bottom: 24px;\"><strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">当成本持续下降，我们的注意力会向上游寻找「稀缺」。</span></span></strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">最底层是算力，它依然主要集中在中心化的数据中心，但已经开始向边缘渗透，本地模型开始在笔记本和手机上落地部署。再往上是「上下文」：我们的习惯、偏好、历史记录，让模型比任何公开语料都更了解我们。最上层是信任——这是时间累积起来的信誉，决定了某个代理是否有权代表我们做决定。</span></span></p>\n  <p style=\"line-height: 1.6em;margin-bottom: 24px;\"><strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">而一旦信任完全建立，主动选择反而成了一种负担。</span></span></strong></p>\n  <section>\n   <span data-lark-record-format=\"docx/record\"></span>\n  </section>\n  <p style=\"margin-left: 0px;margin-right: 0px;line-height: 1.5em;margin-bottom: 24px;\"><span leaf=\"\"><br></span></p>\n  <section data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;box-sizing:border-box