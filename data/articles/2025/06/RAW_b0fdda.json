ow-wrap: break-word !important;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;},&quot;node&quot;,{&quot;tagName&quot;:&quot;strong&quot;,&quot;attributes&quot;:{&quot;style&quot;:&quot;-webkit-tap-highlight-color: transparent;margin-top: 0px;margin-right: 0px;margin-left: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;}]\" style=\"-webkit-tap-highlight-color: transparent;margin-top: 0px;margin-bottom: 0px;padding: 0px;outline: 0px;max-width: 100%;font-family: PingFangSC-Light;letter-spacing: 0.5px;font-size: 36px;box-sizing: border-box !important;overflow-wrap: break-word !important;\"><span leaf=\"\" data-pm-slice=\"1 1 [&quot;para&quot;,{&quot;tagName&quot;:&quot;section&quot;,&quot;attributes&quot;:{&quot;style&quot;:&quot;-webkit-tap-highlight-color: transparent;margin-bottom: 16px;outline: 0px;font-family: \\&quot;PingFang SC\\&quot;, system-ui, -apple-system, \\&quot;system-ui\\&quot;, \\&quot;Helvetica Neue\\&quot;, \\&quot;Hiragino Sans GB\\&quot;, \\&quot;Microsoft YaHei UI\\&quot;, \\&quot;Microsoft YaHei\\&quot;, Arial, sans-serif;letter-spacing: 0.544px;background-color: rgb(255, 255, 255);visibility: visible;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;},&quot;para&quot;,{&quot;tagName&quot;:&quot;section&quot;,&quot;attributes&quot;:{},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;},&quot;para&quot;,{&quot;tagName&quot;:&quot;section&quot;,&quot;attributes&quot;:{},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;},&quot;node&quot;,{&quot;tagName&quot;:&quot;span&quot;,&quot;attributes&quot;:{&quot;style&quot;:&quot;-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;color: rgb(75, 110, 245);&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;},&quot;node&quot;,{&quot;tagName&quot;:&quot;strong&quot;,&quot;attributes&quot;:{&quot;style&quot;:&quot;-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;},&quot;node&quot;,{&quot;tagName&quot;:&quot;span&quot;,&quot;attributes&quot;:{&quot;style&quot;:&quot;-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-family: PingFangSC-Light;letter-spacing: 0.5px;font-size: 36px;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;}]\" style=\"-webkit-tap-highlight-color: transparent;margin-top: 0px;margin-bottom: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;\">01&nbsp;</span><span leaf=\"\" data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;color:rgb(75, 110, 245);font-weight:bold;font-size:20px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;margin-top:0px;font-family:PingFangSC-Light;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;visibility:visible;letter-spacing:0.5px;clear:both;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;margin-bottom:0px;font-variant-ligatures:normal;widows:2;\"><br></span></span></strong></span>\n  </section>\n  <p data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:16px 0px;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><span leaf=\"\" style=\"font-variant-caps:normal;color:rgb(75, 110, 245);font-weight:bold;font-size:20px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;margin-top:0px;font-family:PingFangSC-Light;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;visibility:visible;letter-spacing:0.5px;clear:both;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">从「上传」到「描述」，</span></p>\n  <p data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:16px 0px 24px;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><span leaf=\"\" style=\"font-variant-caps:normal;color:rgb(75, 110, 245);font-weight:bold;font-size:20px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;margin-top:0px;font-family:PingFangSC-Light;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;visibility:visible;letter-spacing:0.5px;clear:both;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">现在只需要一个提示词就能生成</span></p>\n  <p data-pm-slice=\"0 0 []\" style=\"line-height: 1.6em;margin-bottom: 24px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">2005 年，圣马特奥（ San Mateo ）：三个创始人在一间弥漫着意大利辣香肠味道的办公室里，给他们的小破视频网站加上了一个「上传」按钮。</span></span></p>\n  <p style=\"line-height: 1.6em;margin-bottom: 24px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">2025 年，世界任何角落：一个人输入想法，按下回车，一群智能代理便开始编译、测试、执行。</span></span></p>\n  <p style=\"line-height: 1.6em;margin-bottom: 24px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">在</span><a class=\"normal_text_link\" target=\"_blank\" style=\"\" href=\"https://mp.weixin.qq.com/s?__biz=Mzg5NTc0MjgwMw==&amp;mid=2247499209&amp;idx=2&amp;sn=af37004b3431e9fe835ae4fb1124a29d&amp;scene=21#wechat_redirect\" textvalue=\"《软件的终结》\" data-itemshowtype=\"0\" linktype=\"text\" data-linktype=\"2\">《软件的终结》</a><span textstyle=\"\" style=\"font-size: 16px;\">那篇文章里，我提出一个观点：</span></span><strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">大语言模型将把软件的边际成本压至趋近于零</span></span></strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">，就像互联网对「内容」做的那样。一年过去，这一预测正在应验。代码的生成早已不值一提，问题在于我们如何应对即将到来的洪流。</span></span></p>\n  <p style=\"line-height: 1.6em;margin-bottom: 24px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">延伸阅读：</span><a class=\"normal_text_link\" target=\"_blank\" style=\"\" href=\"https://mp.weixin.qq.com/s?__biz=MzU4MzY1MDg5NQ==&amp;mid=2247487272&amp;idx=1&amp;sn=a165897d2346804a9a3b7d31ca7fbd0e&amp;scene=21#wechat_redirect\" textvalue=\"\" linktype=\"text\" data-linktype=\"2\"><span textstyle=\"\" style=\"font-size: 16px;\">AI 在把传统软件当早餐吃掉</span></a></span></p>\n  <p style=\"line-height: 1.6em;margin-bottom: 24px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">这个模式我们并不陌生。2005 年 YouTube 上线时，第一条视频「我在动物园」看起来微不足道。这就是要颠覆整个媒体行业的前兆？但这正是重点——它证明内容的生产已廉价到无法计量。如今，这个大坝在「写代码」上也决堤了。过去需要一个团队、一个冲刺周期才能完成的原型，现在只需一个提示词就能生成。就像当年在卧室里直播改变世界一样，</span></span><strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">现在任何人都能把自己的想法变成产品。</span></span></strong></p>\n  <p style=\"line-height: 1.6em;margin-bottom: 24px;\"><strong><span leaf=\"\"><img class=\"rich_pages wxw-img js_insertlocalimg\" data-imgfileid=\"100005290\" data-ratio=\"0.7284427284427284\" data-s=\"300,640\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/bcce1534-e8ca-4aee-9250-747c853e6700/public\" data-type=\"png\" data-w=\"777\" type=\"block\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/bcce1534-e8ca-4aee-9250-747c853e6700/public\"></span></strong></p>\n  <section style=\"line-height: 1.6em;margin-bottom: 24px;\" nodeleaf=\"\">\n   <img class=\"rich_pages wxw-img\" data-height=\"220\" data-imgfileid=\"100032933\" data-ratio=\"0.3240058910162003\" data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/b85406a9-6834-4217-307b-fe11b4b52a00/public\" data-type=\"png\" data-w=\"679\" data-width=\"679\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/b85406a9-6834-4217-307b-fe11b4b52a00/public\">\n  </section>\n  <p style=\"line-height: 1.6em;margin-bottom: 24px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">Web 2.0 给了所有人一个动词：「上传」，它一举颠覆了各大新闻编辑部。</span></span><strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">AI</span></span></strong><strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">&nbsp;给了我们一个新动词：描述，</span></span></strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">于是那些拥有五百人专攻单一功能的公司瞬间蒸发。工作的重点从「怎么写」变成「想要什么」。我们不再逐行写代码，而是描述需求，由模型来决定实现方式。</span></span></p>\n  <section>\n   <span data-lark-record-format=\"docx/record\"></span>\n  </section>\n  <p style=\"margin-left: 0px;margin-right: 0px;line-height: 1.5em;margin-bottom: 24px;\"><span leaf=\"\"><br></span></p>\n  <section data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:16px 0px;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\">\n   <span data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;color:rgb(75, 110, 245);font-weight:400;font-size:17px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;margin-top:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;fon