  "content": "\n \n \n  <h3 data-mpa-powered-by=\"yiban.io\" style=\"outline:0px;visibility:visible;letter-spacing:0.544px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;\">\n   <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"outline: 0px;line-height: 27.2px;widows: 1;visibility: visible;\">\n    <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"outline: 0px;letter-spacing: 0.544px;line-height: 27.2px;visibility: visible;\">\n     <section data-style=\"line-height: 1.8; text-align: justify; font-size: 15px; letter-spacing: 0px; color: rgb(117, 114, 114);white-space: normal;\" style=\"outline: 0px;visibility: visible;\">\n      <section style=\"outline: 0px;visibility: visible;\">\n       <section style=\"margin-bottom: 8px;text-align: center;\">\n        <span leaf=\"\"><img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/ba394544-001b-4ed2-f2d5-ebfbe59d2400/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.42578125\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1280\" style=\"width:100%;\" data-croporisrc=\"https://mmbiz.qpic.cn/sz_mmbiz_jpg/UicQ7HgWiaUb1wbMVjW5XBeWsmGMhbLXedXLUPIN8vzANfIjDnRdf4KaNosxjdtWd0Wrtcry6WbEugoDX8aH8FRg/0?wx_fmt=jpeg&amp;from=appmsg\" data-cropselx2=\"578\" data-cropsely2=\"247\" data-backw=\"578\" data-backh=\"246\" data-imgfileid=\"505102085\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/ba394544-001b-4ed2-f2d5-ebfbe59d2400/public\"></span>\n       </section>\n      </section>\n     </section>\n    </section>\n   </section></h3>\n  <h3 style=\"outline:0px;visibility:visible;letter-spacing:0.544px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;\">\n   <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"outline: 0px;line-height: 27.2px;widows: 1;visibility: visible;\">\n    <section data-tools=\"135编辑器\" data-id=\"88402\" style=\"outline: 0px;letter-spacing: 0.544px;line-height: 27.2px;visibility: visible;\">\n     <section data-style=\"line-height: 1.8; text-align: justify; font-size: 15px; letter-spacing: 0px; color: rgb(117, 114, 114);white-space: normal;\" style=\"outline: 0px;visibility: visible;\">\n      <section style=\"outline: 0px;visibility: visible;\">\n       <section style=\"outline: 0px;visibility: visible;\">\n        <hr style=\"outline: 0px;font-size: 17px;letter-spacing: 0.544px;visibility: visible;\">\n        <p style=\"margin-top: -1.2em;margin-right: 8px;margin-left: 8px;outline: 0px;font-size: 17px;letter-spacing: 0.544px;line-height: 1.75em;visibility: visible;\"><span leaf=\"\"><br></span></p>\n        <p style=\"margin-top: -1.2em;margin-right: 8px;margin-left: 8px;outline: 0px;font-size: 17px;letter-spacing: 0.544px;text-align: center;line-height: 1.75em;visibility: visible;\"><span style=\"outline: 0px;letter-spacing: 1px;visibility: visible;\"><strong style=\"outline: 0px;font-family: inherit;font-size: 1em;text-decoration: inherit;visibility: visible;\"><span style=\"background-color:rgb(127, 127, 127);outline:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;font-family:inherit;\"><span leaf=\"\">&nbsp;&nbsp;</span></span></strong><strong style=\"outline: 0px;font-size: 1em;font-family: inherit;text-decoration: inherit;visibility: visible;\"><span style=\"background-color:rgb(127, 127, 127);outline:0px;visibility:visible;font-weight:inherit;text-decoration:inherit;font-size:18px;line-height:1.4;font-family:inherit;\"><span leaf=\"\">新智元报道 &nbsp;</span></span></strong></span></p>\n       </section>\n      </section>\n     </section>\n    </section>\n   </section></h3>\n  <section style=\"margin-left:8px;outline:0px;visibility:visible;letter-spacing:0.544px;min-height:1em;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;margin-bottom:0px;margin-right:8px;text-align:center;\">\n   <span style=\"outline: 0px;font-size: 12px;color: rgb(136, 136, 136);font-family: &quot;Helvetica Neue&quot;, Helvetica, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;letter-spacing: 1px;visibility: visible;\"><span leaf=\"\">编辑：犀牛 定慧</span></span>\n  </section>\n  <section powered-by=\"xiumi.us\" style=\"outline:0px;visibility:visible;letter-spacing:0.544px;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;margin-bottom:0px;\">\n   <section style=\"outline: 0px;visibility: visible;\">\n    <section style=\"outline: 0px;visibility: visible;\">\n     <h5 style=\"padding:10px;visibility:visible;letter-spacing:0.544px;font-size:14px;line-height:1.75em;margin-right:8px;margin-left:8px;border-radius:3px;outline:0px;word-spacing:1px !important;word-break:break-all !important;margin-top:10px;font-family:Arial, Helvetica, sans-serif;\"><span style=\"outline: 0px;letter-spacing: 1px;font-size: 15px;visibility: visible;\"><strong style=\"outline: 0px;visibility: visible;\"><span leaf=\"\">【新智元导读】</span><span leaf=\"\"><span textstyle=\"\" style=\"font-weight: normal;\">Anthropic推出Claude两大重磅功能：Research与Google Workspace集成！Research功能让Claude快速检索网络与内部文件，精准回答复杂问题；而与Google Workspace的深度整合，则让用户能无缝调用Gmail、日历和文档信息，轻松完成从行程规划到报告撰写的任务。</span></span></strong></span></h5>\n    </section>\n   </section>\n  </section>\n  <p data-pm-slice=\"0 0 []\" style=\"text-align: justify;margin-left: 8px;margin-right: 8px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.6;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">今天凌晨，Anthropic官方推出了两个重磅新功能：Research以及与Google Workspace集成。</span></span></p>\n  <section nodeleaf=\"\" style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;text-align:justify;margin-right:8px;\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/9a9c8538-7e02-4afb-01d0-d124f60c9600/public\" class=\"rich_pages wxw-img\" data-ratio=\"1.051207729468599\" data-type=\"png\" data-w=\"1035\" style=\"width:100%;\" data-width=\"1035\" data-height=\"1088\" data-backw=\"562\" data-backh=\"591\" data-imgfileid=\"505102071\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/9a9c8538-7e02-4afb-01d0-d124f60c9600/public\">\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">Anthropic称Research功能是与Claude合作的新方式。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">它能从多个角度分析问题，自动搜索信息，几分钟之内给出答案。在深度与速度中找到一个恰当的平衡。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">另一个更新是Claude现在可以连接到你的Gmail、Google日历和文档。它可以理解其中的上下文，并能从需要的地方提取信息。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">Anthropic表示，他们为此精心设计了提示建议，可以快速地帮用户从整个Google Workspace中获取有用的信息。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">例如，可以尝试问它：「假设我100岁时回顾现在，请对我的日程进行反思。」</span></span></p>\n  <section nodeleaf=\"\" style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;text-align:justify;margin-right:8px;\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/923b9143-4b9e-4bc8-947f-27536bbefb00/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.5625\" data-type=\"png\" data-w=\"1200\" style=\"width:100%;\" data-width=\"1200\" data-height=\"675\" data-backw=\"562\" data-backh=\"316\" data-imgfileid=\"505102072\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/923b9143-4b9e-4bc8-947f-27536bbefb00/public\">\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">Research功能在美国、日本、巴西三国的Max、Team和企业计划中可用。Google Workspace集成则对所有付费用户开放。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">Anthropic还为这两个新功能做了一个演示，视频中用户要求根据自己的邮件、日历和文档信息起草一份外出计划，并搜索出网络条件良好的地方以方便与同事联系。</span></span></p>\n  <section nodeleaf=\"\" style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;text-align:justify;margin-right:8px;\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/03836756-b3dc-49f5-6808-7edd6232ab00/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.5625579240037072\" data-type=\"gif\" data-w=\"1079\" style=\"width:100%;\" data-width=\"1138\" data-height=\"640\" data-backw=\"562\" data-backh=\"316\" data-imgfileid=\"505102073\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/03836756-b3dc-49f5-6808-7edd6232ab00/public\">\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">点击Research按钮后，Claude便开始搜寻用户的邮件、日历、文档以及联网搜索必要的信息。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">综合处理完这些信息后给出了一份完整的出行计划报告。</span></span></p>\n  <section style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;text-align:justify;margin-right:8px;\" nodeleaf=\"\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/03836756-b3dc-49f5-6808-7edd6232ab00/public\" class=\"rich_pages wxw-img js_insertlocalimg\" data-ratio=\"0.562390158172232\" data-s=\"300,640\" data-type=\"gif\" data-w=\"1138\" style=\"width:100%;\" type=\"block\" data-backw=\"562\" data-backh=\"316\" data-imgfileid=\"505102083\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/03836756-b3dc-49f5-6808-7edd6232ab00/public\">\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">不仅如此，Claude还可以将报告一键同步到邮箱发送给好友。</span></span></p>\n  <section style=\"text-align: center;margin-bottom: 48px;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/b7cb9bfb-afb4-4c2b-1f41-1f7a0f188500/public\" class=\"rich_pages wxw-img js_insertlocalimg\" data-ratio=\"0.5625579240037072\" data-s=\"300,640\" data-type=\"gif\" data-w=\"1079\" style=\"width: 100%;\" type=\"block\" data-backw=\"578\" data-backh=\"325\" data-imgfileid=\"505102084\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/b7cb9bfb-afb4-4c2b-1f41-1f7a0f188500/public\">\n  </section>\n  <section>\n   <span data-lark-record-format=\"docx/record\"></span>\n  </section>\n  <section style=\"text-align: center;margin-top: 0px;margin-bottom: 0px;\">\n   <span leaf=\"\"><img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/47efb6c6-e260-4865-e30a-092b5639f000/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.5267857142857143\" data-s=\"300,640\" data-type=\"png\" data-w=\"112\" style=\"width: 85px;height: 40px;\" data-imgfileid=\"505095291\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/47efb6c6-e260-4865-e30a-092b5639f000/public\"></span>\n  </section>\n  <section style=\"text-align: center;margin-bottom: 24px;margin-top: 8px;line-height: 1.75em;\">\n   <span style=\"letter-spacing:1px;font-size:19px;\"><strong><span leaf=\"\">接入谷歌全家桶，工作效率提10倍</span></strong></span>\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">没想到率先接入Google的是Claude。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">Claude引入了两个新功能，一个是与Google Workspace集成，另一个则是已经「落后」ChatGPT和Gemini的Research功能。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">先说Research，Claude通过这个功能可以检索内部文件和网络，比如Claude一次性可以检索信息、日历、云盘和互联网等。</span></span></p>\n  <section nodeleaf=\"\" style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;text-align:justify;margin-right:8px;\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/9b17f3cb-bc58-4a1b-3b89-67a1036cfa00/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.6478102189781022\" data-type=\"png\" data-w=\"1096\" style=\"width:100%;\" data-width=\"1096\" data-height=\"710\" data-backw=\"562\" data-backh=\"364\" data-imgfileid=\"505102075\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/9b17f3cb-bc58-4a1b-3b89-67a1036cfa00/public\">\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">而与Google Workspace的集成，可以快速访问Gmail、日历和Google文档。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">通过官方演示可以看到，在完成Research工作后，可以直接调用Google邮箱，完成发布。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">Claude还提供了更多的使用场景示例：</span></span></p>\n  <ul style=\"list-style-type: disc;margin-left: 8px;margin-right: 8px;\" class=\"list-paddingleft-1\">\n   <li style=\"font-size: 15px;\">\n    <p style=\"text-align: justify;line-height: 1.75em;margin-bottom: 16px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">营销团队可以通过从网络上收集竞争情报，同时提取相关的产品规格、定位和战略文档，来更快地创建全面的产品发布计划。</span></span></p></li>\n   <li style=\"font-size: 15px;\">\n    <p style=\"text-align: justify;line-height: 1.75em;margin-bottom: 16px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">销售团队可以搜索通信历史、带会议记录的日历邀请以及关于潜在客户公司的最新更新，从而更有效地为客户会议做准备，以创建详细的简报文档。</span></span></p></li>\n   <li style=\"font-size: 15px;\">\n    <p style=\"text-align: justify;line-height: 1.75em;margin-bottom: 16px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">工程师可以分析设计文档、系统规范以及外部 API 文档、实现模式和安全最佳实践，来创建与现有系统集成的技术解决方案。</span></span></p></li>\n   <li style=\"font-size: 15px;\">\n    <p style=\"text-align: justify;line-height: 1.75em;margin-bottom: 16px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">大学学生可以与Claude合作分析学习材料和过去课程的笔记，同时搜索最新的学术研究、互动学习资源和专家解释，来创建个性化的学习计划。</span></span></p></li>\n   <li style=\"font-size: 15px;\">\n    <p style=\"text-align: justify;line-height: 1.75em;margin-bottom: 16px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">父母可以让Claude扫描电子邮件和日历事件来突出重要承诺，同时搜索网络以获取更新的学校日历、当地社区事件和天气预报。</span></span></p></li>\n  </ul>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">除了Research和Google Workspace集成，Claude Enterprise的管理员可以启用目录编制（Google Docs cataloging）功能。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">一旦目录编制启用，Claude会利用组织文档的专用索引来查找所需信息——即使这些信息隐藏在冗长文档中或分布在多个文件中。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">相当于加入一个「人工监督」，这样查找文档的准确率大大的提高。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">Research功能现已在美国的Max、Team和Enterprise计划中进入早期测试版，只需在聊天中启用Research设置。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">Google Workspace 集成版现已处于测试阶段，可供所有付费用户在个人资料设置中启用。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">功能发布后，网友们进行了实测。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">Claude的一位负责人Alex Albert表示，</span></span><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" data-pm-slice=\"1 1 [&quot;para&quot;,{&quot;tagName&quot;:&quot;p&quot;,&quot;attributes&quot;:{&quot;style&quot;:&quot;text-align: justify; margin-left: 8px; margin-right: 8px; line-height: 1.75em;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;}]\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">Claude的这两个新功能「让我工作效率提升了10倍！」。</span></span></p>\n  <section style=\"text-align: center;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/ae8ab86b-81f3-48c6-2668-c1cc46493100/public\" class=\"rich_pages wxw-img js_insertlocalimg\" data-ratio=\"0.32407407407407407\" data-s=\"300,640\" data-type=\"png\" data-w=\"1080\" style=\"width:100%;\" type=\"block\" data-backw=\"562\" data-backh=\"182\" data-imgfileid=\"505102089\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/ae8ab86b-81f3-48c6-2668-c1cc46493100/public\">\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" data-pm-slice=\"1 1 [&quot;para&quot;,{&quot;tagName&quot;:&quot;p&quot;,&quot;attributes&quot;:{&quot;style&quot;:&quot;text-align: justify; margin-left: 8px; margin-right: 8px; line-height: 1.75em;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;}]\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">同时他也表示，很快</span></span><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" data-pm-slice=\"1 1 [&quot;para&quot;,{&quot;tagName&quot;:&quot;p&quot;,&quot;attributes&quot;:{&quot;style&quot;:&quot;text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;}]\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">Research功能将扩展到专家级别的深入报告，成为一个更加强大全面的工具。</span></span></p>\n  <section style=\"text-align: center;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/e414a2a9-1aff-4409-d669-4e90869d5300/public\" class=\"rich_pages wxw-img js_insertlocalimg\" data-ratio=\"0.5633333333333334\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1200\" style=\"width:100%;\" type=\"block\" data-backw=\"562\" data-backh=\"316\" data-imgfileid=\"505102088\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/e414a2a9-1aff-4409-d669-4e90869d5300/public\">\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">有人在使用中「发现了自己数据中意想不到的联系」。</span></span></p>\n  <section style=\"text-align: center;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/99629be1-6c92-41bc-cc37-e39946996f00/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.37415540540540543\" data-s=\"300,640\" data-type=\"png\" data-w=\"1184\" style=\"width: 100%;\" type=\"block\" data-backw=\"578\" data-backh=\"216\" data-imgfileid=\"505102091\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/99629be1-6c92-41bc-cc37-e39946996f00/public\">\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">有人发现Claude可以整合之前的所有聊天记录（非常像OpenAI刚刚推出的记忆功能）。</span></span></p>\n  <section nodeleaf=\"\" style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;text-align:justify;margin-right:8px;\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/1b3df7f7-33f7-4ed2-c57a-323795d2ca00/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.5516666666666666\" data-type=\"png\" data-w=\"1200\" height=\"449\" style=\"width:100%;\" width=\"1072\" data-width=\"1200\" data-height=\"662\" data-backw=\"562\" data-backh=\"239\" data-imgfileid=\"505102076\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/1b3df7f7-33f7-4ed2-c57a-323795d2ca00/public\">\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">但也有人担心——虽然Claude强调了它们使用更高的安全机制——Claude这样直接访问Gmail邮箱是不是安全。</span></span></p>\n  <section nodeleaf=\"\" style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;font-style:normal;text-align:justify;margin-right:8px;\">\n   <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/9c63deb4-c5ff-4b2b-6776-2a59e7dbf700/public\" class=\"rich_pages wxw-img\" data-ratio=\"1.2470588235294118\" data-type=\"png\" data-w=\"1190\" height=\"1347\" width=\"1073\" data-width=\"1190\" data-height=\"1484\" data-imgfileid=\"505102078\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/9c63deb4-c5ff-4b2b-6776-2a59e7dbf700/public\">\n  </section>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">作为最早提出MCP的大模型，Claude推出Research的时间点似乎有点晚。</span></span></p>\n  <p style=\"text-align: justify;margin-left: 8px;margin-right: 8px;line-height: 1.75em;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\"><span textstyle=\"\" style=\"font-size: 15px;letter-spacing: 1px;\">但作为把AI安全性作为最大卖点的Anthropic公司，似乎这才是它们的合理时间——足够充分的测试和市场反馈。</span></span></p>\n  <section style=\"margin-left:8px;letter-spacing:0.544px;min-height:1em;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;margin-bottom:0px;margin-right:8px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\"><span leaf=\"\">参考资料：</span><span leaf=\"\"><br></span></span>\n  </section>\n  <section style=\"margin-left:8px;letter-spacing:0.544px;min-height:1em;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;margin-bottom:0px;margin-right:8px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\"><span leaf=\"\">https://www.anthropic.com/news/research</span></span>\n  </section>\n  <section style=\"margin-left:8px;letter-spacing:0.544px;min-height:1em;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:1.75em;margin-bottom:0px;margin-right:8px;text-align:left;\">\n   <span style=\"font-size: 14px;color: rgb(136, 136, 136);letter-spacing: 1px;\"><span leaf=\"\">https://x.com/AnthropicAI/status/1912192384588271771</span></span>\n  </section>\n  <section style=\"margin-left:8px;letter-spacing:0.544px;min-height:1em;font-family:-apple-system-font, system-ui, &quot;Helvetica Neue&quot;, &quot;PingFang SC&qu