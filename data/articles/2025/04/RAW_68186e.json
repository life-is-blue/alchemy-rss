peg\" data-w=\"1080\" style=\"width: 100%;height: auto;\" data-backw=\"568\" data-backh=\"344\" data-imgfileid=\"100146708\" src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/21e3202e-097b-4e94-ecd7-d15b2cbf0800/public\">\n        </section>\n        <section style=\"line-height: 1.75em;\">\n         <section style=\"margin-top: 10px;margin-bottom: 10px;display:flex;\">\n          <section style=\"width: 0.6em;display: inline-block;vertical-align: middle;\">\n           <span style=\"background-color:rgb(0, 176, 240);display:block;width:0.6em;margin-top:2px;opacity:0.6;margin-bottom:2px;height:0.6em;\" data-bgopacity=\"25%\"></span><span style=\"background-color:rgb(19, 139, 222);display:block;width:0.6em;opacity:1;height:0.6em;\"></span>\n          </section>\n          <section style=\"display: inline-block;vertical-align: middle;font-size: 16px;padding-left: 10px;\">\n           <section data-brushtype=\"text\">\n            <span style=\"color: #138bde;\"><strong><span leaf=\"\">3、可灰度(灰度切量读)</span></strong></span>\n           </section>\n          </section>\n         </section>\n        </section>\n        <section style=\"line-height: 1.75em;\">\n         <span style=\"font-size: 15px;color: #3e3e3e;letter-spacing: normal;line-height: 1.6em;font-family: &quot;Helvetica Neue&quot;, Helvetica, &quot;Hiragino Sans GB&quot;, &quot;Apple Color Emoji&quot;, &quot;Emoji Symbols Font&quot;, &quot;Segoe UI Symbol&quot;, Arial, sans-serif;\"><span leaf=\"\">读切流，按照供应商和采销白名单+百分比来切流</span></span>\n        </section>\n        <section style=\"text-align: center;line-height: 1.75em;\" nodeleaf=\"\">\n         <img data-src=\"https://imagedelivery.net/qGOFcc1O8XwTZW3W1JAHHg/058be5ac-8961-4353-148b-bf335f5d3e00/public\" class=\"rich_pages wxw-img\" data-ratio=\"0.7052740434332989\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"967\" style=\"width: 100%;height: auto;\" data-backw=\"568\" data-backh=\"401\" data-imgfileid=\"100146709\" src=\"https://imagedelivery.net/qGOFc