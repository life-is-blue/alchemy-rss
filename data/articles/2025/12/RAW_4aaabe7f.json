Fmmbiz.qpic.cn%2Fsz_mmbiz_png%2FePw3ZeGRruwPz6GHDCOGsYNoWXVibVKTj3GK3G4A4h97aveEeNvSJaploECtNZiaM2iblN2TO0fWVBhqJRvmPPGgQ%2F640%3Fwx_fmt%3Dpng%26from%3Dappmsg\"></p>\n  <h3 style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:16px;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:0px;visibility:visible;letter-spacing:0.544px;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\" data-pm-slice=\"0 0 []\">\n   <ms-cmark-node style=\"-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">\n    <p class=\"js_darkmode__0\" data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:32px 8px 0px;visibility:visible;letter-spacing:0.544px;clear:both;text-decoration-style:initial;line-height:2em;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><span style=\"-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;color: rgb(255, 104, 39);font-family: Futura-Medium;font-size: 32px;font-weight: 700;letter-spacing: 1px;visibility: visible;\"><span leaf=\"\" style=\"-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">01</span></span></p>\n    <p class=\"js_darkmode__1\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:justify;-webkit-text-stroke-width:0px;padding:0px;margin:0px 8px 16px;visibility:visible;letter-spacing:0.544px;clear:both;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><strong class=\"js_darkmode__2\" style=\"-webkit-tap-highlight-color:transparent;padding:0px;margin:0px;outline:0px;max-width:100%;visibility:visible;letter-spacing:0.544px;font-size:17px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box !important;overflow-wrap:break-word !important;\"><span style=\"-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;font-size: 16px;visibility: visible;\"><span leaf=\"\" style=\"-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\">开源项目简介</span></span></strong></p>\n   </ms-cmark-node>\n  </h3>\n  <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:14px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"miq251fdg1d\">在传统的网页自动化 RPA 开发中，最让人头疼的莫过于<span textstyle=\"\" style=\"font-weight: bold;\">页面结构变了</span>。</span></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:14px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"miq251fd1c5h\">如果你写过 Selenium 或 Puppeteer 脚本，一定经历过因为网站开发者修改了一个 CSS 类名或调整了按钮位置，<span textstyle=\"\" style=\"font-weight: bold;\">导致整套脚本报错失效</span>的崩溃瞬间。</span></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:14px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"miq251fdy7b\">为了维护这些脚本，开发者往往需要花费大量时间去修补 XPath 或 CSS 选择器。Skyvern 这个开源项目试图用大模型和计算机视觉彻底解决这个问题。</span></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:14px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"miq251fdepj\">它不再依赖死板的代码选择器，而是<span textstyle=\"\" style=\"font-weight: bold;\">像人类一样看懂网页，从而进行自动化操作。</span></span></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><span leaf=\"\"><img class=\"rich_pages wxw-img\" data-imgfileid=\"100045693\" data-ratio=\"0.412962962962963\" data-s=\"300,640\" type=\"block\" data-type=\"png\" data-w=\"1080\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=1d04bdbb&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_png%2FePw3ZeGRruxdEzCx4tnIERa38lCEt8VCT4sBv4SyHxwBCpm3RrT08iafLibnapRcb16U6GokicezlqfDNZgvDw7zw%2F640%3Fwx_fmt%3Dpng%26from%3Dappmsg\"></span><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:14px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"miq251fdepj\"> \n    <br> \n   </span></p>\n  <mpcpc class=\"js_cpc_area res_iframe cpc_iframe\" data-category_id_list=\"17|21|41|43|48|5|59|6\" js_editor_cpcad=\"\" src=\"/cgi-bin/readtemplate?t=tmpl/cpc_tmpl#1764769704749\" data-id=\"1764769704749\"></mpcpc>\n  <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:14px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"miq251fdepj\">堪称Token 消耗神器<img style=\"display: inline-block;width: 20px;vertical-align: middle;background-size: cover;\" class=\"rich_pages wxw-img\" data-ratio=\"1\" data-w=\"20\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=7478ac68&amp;u=https%3A%2F%2Fres.wx.qq.com%2Ft%2Fwx_fed%2Fwe-emoji%2Fres%2Fassets%2Fnewemoji%2FYellowdog.png\">&nbsp;<img class=\"rich_pages wxw-img\" data-src=\"\"></span></p>\n  <p nodeleaf=\"\" style=\"margin-left:8px;font-weight:normal;letter-spacing:0.034em;font-size:17px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;line-height:2em;font-style:normal;margin-bottom:16px;margin-right:8px;\"></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><span mpa-font-style=\"miq251fd11xv\" style=\"font-size: 14px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\">下面这张图就是开源项目&nbsp;</span><span leaf=\"\" data-pm-slice=\"1 1 [&quot;para&quot;,{&quot;tagName&quot;:&quot;p&quot;,&quot;attributes&quot;:{},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;}]\" style=\"font-weight:normal;letter-spacing:0.034em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\">Skyvern 的核心原理：</span></span></p>\n  <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><span leaf=\"\" data-pm-slice=\"1 1 [&quot;para&quot;,{&quot;tagName&quot;:&quot;p&quot;,&quot;attributes&quot;:{},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;}]\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:14px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"miq251fd21ml\"><span textstyle=\"\" style=\"color: rgb(178, 178, 178);font-style: italic;text-decoration: underline;\">拿 AI 在亚马逊（Amazon.com）上完成购物任务的详细工作流举例。</span></span></p>\n  <ms-text-chunk data-pm-slice=\"0 0 []\">\n   <ms-cmark-node>\n    <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><ms-cmark-node><span mpa-font-style=\"miq251fd1ziq\" style=\"font-size: 14px;\"><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\">整个系统分为三个主要模块：</span><strong><ms-cmark-node><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\">Planner（规划器）</span></ms-cmark-node></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\">、</span><strong><ms-cmark-node><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\">Task（任务执行器）</span></ms-cmark-node></strong></span><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-size:14px;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\" mpa-font-style=\"miq251fdc09\">和</span><span mpa-font-style=\"miq251fd2fn\" style=\"font-size: 14px;\"><strong><ms-cmark-node><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\">Validator（验证器）</span></ms-cmark-node></strong><span leaf=\"\" style=\"font-weight:normal;letter-spacing:0.034em;font-family:mp-quote, &quot;PingFang SC&quot;, system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-style:normal;\">。</span></span></ms-cmark-node></p>\n    <p style=\"margin-left: 8px;margin-right: 8px;line-height: 2em;margin-bottom: 16px;\"><ms-cmark-node data-pm-slice=\"2 2 [&quot;node&quot;,{&quot;tagName&quot;:&quot;MS-TEXT-CHUNK&quot;,&quot;attributes&quot;:{&quot;data-pm-slice&quot;:&quot;0 0 []&quot;},&quot;namespaceURI&quot;:&