56182V9.25V10H11.999V9.25V5C11.999 4.44772 11.5512 4 10.999 4H6.75011Z\" fill=\"currentColor\" />\n      </svg> \n     </span></a></li>\n   <li>CVE-2025-55184 (DoS): <a href=\"https://www.cve.org/CVERecord?id=CVE-2025-55184\" rel=\"noopener noreferrer nofollow\" target=\"_blank\">React<span class=\"inline-flex not-prose\"> \n      <svg data-testid=\"geist-icon\" height=\"16\" stroke-linejoin=\"round\" style=\"color:currentColor\" viewBox=\"0 0 16 16\" width=\"16\">\n       <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M6.75011 4H6.00011V5.5H6.75011H9.43945L5.46978 9.46967L4.93945 10L6.00011 11.0607L6.53044 10.5303L10.499 6.56182V9.25V10H11.999V9.25V5C11.999 4.44772 11.5512 4 10.999 4H6.75011Z\" fill=\"currentColor\" />\n      </svg> \n     </span></a>, <a href=\"https://github.com/vercel/next.js/security/advisories/GHSA-mwv6-3258-q52c\" rel=\"noopener noreferrer\" target=\"_blank\">Next.js<span class=\"inline-flex not-prose\"> \n      <svg data-testid=\"geist-icon\" height=\"16\" stroke-linejoin=\"round\" style=\"color:currentColor\" viewBox=\"0 0 16 16\" width=\"16\">\n       <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M6.75011 4H6.00011V5.5H6.75011H9.43945L5.46978 9.46967L4.93945 10L6.00011 11.0607L6.53044 10.5303L10.499 6.56182V9.25V10H11.999V9.25V5C11.999 4.44772 11.5512 4 10.999 4H6.75011Z\" fill=\"currentColor\" />\n      </svg> \n     </span></a></li>\n   <li>CVE-2025-55183 (Source Code Exposure): <a href=\"https://www.cve.org/CVERecord?id=CVE-2025-55183\" rel=\"noopener noreferrer nofollow\" target=\"_blank\">React<span class=\"inline-flex not-prose\"> \n      <svg data-testid=\"geist-icon\" height=\"16\" stroke-linejoin=\"round\" style=\"color:currentColor\" viewBox=\"0 0 16 16\" width=\"16\">\n       <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M6.75011 4H6.00011V5.5H6.75011H9.43945L5.46978 9.46967L4.93945 10L6.00011 11.0607L6.53044 10.5303L10.499 6.56182V9.25V10H11.999V9.25V5C11.999 4.44772 11.5512 4 10.999 4H6.75011Z\" fill=\"currentColor\" />\n      </svg> \n     </span></a>, <a href=\"https://github.com/vercel/next.js/security/advisories/GHSA-w37m-7fhw-fmv9\" rel=\"noopener noreferrer\" target=\"_blank\">Next.js<span class=\"inline-flex not-prose\"> \n      <svg data-testid=\"geist-icon\" height=\"16\" stroke-linejoin=\"round\" style=\"color:currentColor\" viewBox=\"0 0 16 16\" width=\"16\">\n       <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M6.75011 4H6.00011V5.5H6.75011H9.43945L5.46978 9.46967L4.93945 10L6.00011 11.0607L6.53044 10.5303L10.499 6.56182V9.25V10H11.999V9.25V5C11.999 4.44772 11.5512 4 10.999 4H6.75011Z\" fill=\"currentColor\" />\n      </svg> \n     </span></a></li>\n   <li><a href=\"https://react.dev/blog/2025/12/11/denial-of-service-and-source-code-exposure-in-react-server-components\" rel=\"noopener noreferrer nofollow\" target=\"_blank\">React blog: Denial of Service and Source Code Exposure in React Server Components<span class=\"inline-flex not-prose\"> \n      <svg data-testid=\"geist-icon\" height=\"16\" stroke-linejoin=\"round\" style=\"color:currentColor\" viewBox=\"0 0 16 16\" width=\"16\">\n       <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M6.75011 4H6.00011V5.5H6.75011H9.43945L5.46978 9.46967L4.93945 10L6.00011 11.0607L6.53044 10.5303L10.499 6.56182V9.25V10H11.999V9.25V5C11.999 4.44772 11.5512 4 10.999 4H6.75011Z\" fill=\"currentColor\" />\n      </svg> \n     </span></a></li>\n   <li><a href=\"https://nextjs.org/blog/CVE-2025-66478\">Previous Security Advisory: CVE-2025-66478</a></li>\n  </ul>\n  <h2>Discovery</h2>\n  <p>Thank you to <a href=\"https://ryotak.net\" rel=\"noopener noreferrer nofollow\" target=\"_blank\">RyotaK<span class=\"inline-flex not-prose\"> \n     <svg data-testid=\"geist-icon\" height=\"16\" stroke-linejoin=\"round\" style=\"color:currentColor\" viewBox=\"0 0 16 16\" width=\"16\">\n      <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M6.75011 4H6.00011V5.5H6.75011H9.43945L5.46978 9.46967L4.93945 10L6.00011 11.0607L6.53044 10.5303L10.499 6.56182V9.25V10H11.999V9.25V5C11.999 4.44772 11.5512 4 10.999 4H6.75011Z\" fill=\"currentColor\" />\n     </svg> \n    </span></a> from GMO Flatt Security Inc. and <a href=\"https://github.com/AndrewMohawk\" rel=\"noopener noreferrer nofollow\" target=\"_blank\">Andrew MacPherson<span class=\"inline-flex not-prose\"> \n     <svg data-testid=\"geist-icon\" height=\"16\" stroke-linejoin=\"round\" style=\"color:currentColor\" viewBox=\"0 0 16 16\" width=\"16\">\n      <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M6.75011 4H6.00011V5.5H6.75011H9.43945L5.46978 9.46967L4.93945 10L6.00011 11.0607L6.53044 10.5303L10.499 6.56182V9.25V10H11.999V9.25V5C11.999 4.44772 11.5512 4 10.999 4H6.75011Z\" fill=\"currentColor\" />\n     </svg> \n    </span></a> for discovering and responsibly disclosing these vulnerabilities. We are intentionally limiting technical detail in this advisory to protect developers who have not yet upgraded.</p>\n </body>\n</html>",
  "aiSummary": "Next.js 发布安全更新，解决了 App Router 应用程序中 React 服务器组件的两个高危漏洞（拒绝服务和源代码暴露），用户需立即采取处理措施。",
  "oneSentenceSummary": "Next.js 发布安全更新，解决了 App Router 应用程序中 React 服务器组件的两个高危漏洞（拒绝服务和源代码暴露），用户需立即采取处理措施。",
  "summary": "Next.js 发布了一项紧急安全更新，内容涉及在 App Router 应用程序中，利用上游 React 实现的 React 服务器组件 (RSC) 中发现的两个新漏洞。其中包括一个高危拒绝服务 (DoS) 漏洞（CVE-2025-55184 和完整修复 CVE-2025-67779），该漏洞可能由于特制的 HTTP 请求导致服务器进程无限期挂起；以及一个中危源代码暴露漏洞 (CVE-2025-55183)，该漏洞可能泄露已编译的服务端函数代码，从而可能暴露业务逻辑或硬编码密钥。需要特别注意的是，DoS 漏洞的初始修复是不完整的，因此之前已更新的用户需要进行第二次升级。这些漏洞不允许远程代码执行。文章提供了受影响的 Next.js 版本的详细列表和精确的升级说明，强调没有权宜之计，所有受影响的用户都必须立即升级到已打补丁的版本。",
  "mainPoints": [
    {
      "point": "Next.js 发布了一项紧急安全更新，针对源自 React 的 RSC 协议的两个漏洞，这些漏洞影响 App Router 应用程序。",
      "explanation": "这些是高危拒绝服务 (DoS) 和中危源代码暴露漏洞，要求使用 App Router 的 Next.js 应用程序立即关注并升级。"
    },
    {
      "point": "拒绝服务漏洞可能导致服务器进程崩溃，其修复需要额外更新。",
      "explanation": "特制的 HTTP 请求可能导致无限循环并使服务器挂起。最初的补丁是不完整的，这意味着已经升级过一次的用户需要再次升级到最新的打补丁版本。"
