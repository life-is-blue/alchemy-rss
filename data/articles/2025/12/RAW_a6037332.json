rtlocalimg\" data-ratio=\"1.413888888888889\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1080\" type=\"block\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=c094468c&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_jpg%2FnW2ZPfuYqSIiba4ic1cLO5fFUxW5f6LApOE5iar22HpbO1hrfOOpm4jp5RekIE44xjyggFibjK5wfGvb5qYU78ib1gA%2F640%3Fwx_fmt%3Djpeg%26from%3Dappmsg\"></p>\n  <p style=\"text-align: center;\" nodeleaf=\"\"><img data-imgfileid=\"502966867\" class=\"rich_pages wxw-img js_insertlocalimg\" data-ratio=\"1.413888888888889\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1080\" type=\"block\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=3ddee23b&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_jpg%2FnW2ZPfuYqSIiba4ic1cLO5fFUxW5f6LApOjUKrxrrDdytIagOwAbiajSEvPRT1kraSYCTnZvL6jsbCicjiaSXbNub7g%2F640%3Fwx_fmt%3Djpeg%26from%3Dappmsg\"></p>\n  <p style=\"text-align: center;\" nodeleaf=\"\"><img data-imgfileid=\"502966869\" class=\"rich_pages wxw-img js_insertlocalimg\" data-ratio=\"1.413888888888889\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1080\" type=\"block\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=d3f5b561&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_jpg%2FnW2ZPfuYqSIiba4ic1cLO5fFUxW5f6LApOjiaLMBIUOOkECL7I5R9gR2xpRyU9Fd6YZ9DCO8kv2KGGicAE39LRTa4g%2F640%3Fwx_fmt%3Djpeg%26from%3Dappmsg\"></p>\n  <p style=\"text-align: center;\" nodeleaf=\"\"><img data-imgfileid=\"502966868\" class=\"rich_pages wxw-img js_insertlocalimg\" data-ratio=\"1.413888888888889\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1080\" type=\"block\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=9bec549e&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fsz_mmbiz_jpg%2FnW2ZPfuYqSIiba4ic1cLO5fFUxW5f6LApONlLTMRm31Wg95Nxc0CkjWUPHS1MmTRW8SZNRn3qy9J4f2WH6tO87jg%2F640%3Fwx_fmt%3Djpeg%26from%3Dappmsg\"></p>\n  <div>\n   <p data-start=\"1979\" data-end=\"2076\" data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word !important;-webkit-tap-highlight-color:transparent;outline:0px;word-spacing:0px;text-indent:0px;font-family:&quot;PingFang SC&quot;, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Helvetica Neue&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;orphans:2;text-decoration-color:initial;text-align:left;-webkit-text-stroke-width:0px;padding:0px;margin:0px 8px;visibility:visible;letter-spacing:0.544px;clear:both;text-decoration-style:initial;font-style:normal;text-transform:none;max-width:100%;font-variant-ligatures:normal;widows:2;\"><strong data-start=\"1979\" data-end=\"2074\" style=\"-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;\"><span data-pm-slice=\"0 0 []\" style=\"-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;\"><span leaf=\"\" style=\"-webkit-tap-highlight-color: transparent;margin: 0px;padding: 0px;outline: 0px;max-width: 100%;box-sizing: border-box !important;overflow-wrap: break-word !important;visibility: visible;\" data-pm-slice=\"1 1 [&quot;para&quot;,{&quot;tagName&quot;:&quot;p&quot;,&quot;attributes&quot;:{&quot;data-start&quot;:&quot;1979&quot;,&quot;data-end&quot;:&quot;2076&quot;,&quot;data-pm-slice&quot;:&quot;0 0 []&quot;,&quot;style&quot;:&quot;-webkit-tap-highlight-color: transparent; margin: 0px 8px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; clear: both; min-height: 1em; color: rgba(0, 0, 0, 0.9); font-family: \\&quot;PingFang SC\\&quot;, system-ui, -apple-system, \\&quot;system-ui\\&quot;, \\&quot;Helvetica Neue\\&quot;, \\&quot;Hiragino Sans GB\\&quot;, \\&quot;Microsoft YaHei UI\\&quot;, \\&quot;Microsoft YaHei\\&quot;, Arial, sans-serif; font-size: 17px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: 0.544px; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; background-color: rgb(255, 255, 255); text-align: left; visibility: visible;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;},&quot;node&quot;,{&quot;tagName&quot;:&quot;strong&quot;,&quot;attributes&quot;:{&quot;data-start&quot;:&quot;1979&quot;,&quot;data-end&quot;:&quot;2074&quot;,&quot;style&quot;:&quot;-webkit-tap-highlight-color: transparent; margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;},&quot;node&quot;,{&quot;tagName&quot;:&quot;span&quot;,&quot;attributes&quot;:{&quot;data-pm-slice&quot;:&quot;0 0 []&quot;,&quot;style&quot;:&quot;-webkit-tap-highlight-color: transparent; margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;&quot;},&quot;namespaceURI&quot;:&quot;http://www.w3.org/1999/xhtml&quot;}]\"><span textstyle=\"\" style=\"font-size: 16px;font-weight: normal;\">感兴趣的朋友可以关注AINLP公众号回复'mimov2'获取该技术报告pdf全文</span></span></span></strong></p>\n  </div>\n </body>\n</html>",
  "aiSummary": "小米发布 MiMo-V2-Flash，一款针对 Agent 和长上下文任务优化的 MoE 大模型，通过架构创新和训练范式提升推理效率与性能。",
  "oneSentenceSummary": "小米发布 MiMo-V2-Flash，一款针对 Agent 和长上下文任务优化的 MoE 大模型，通过架构创新和训练范式提升推理效率与性能。",
  "summary": "文章介绍了小米推出的 MiMo-V2-Flash 大模型，它是一款拥有 309B 总参数但每 token 仅激活 15B 的 MoE 模型，专注于推理效率和 Agent 能力。该模型通过 Hybrid Sliding Window Attention 解决了长上下文问题，大幅降低了 KV Cache 和计算复杂度。Multi-Token Prediction（MTP）技术则在训练和推理阶段加速解码，特别适用于 RL rollout 和 Agent 推理。此外，创新的 MOPD（Multi-Teacher On-Policy Distillation）训练范式，利用多个领域专精教师模型提供密集奖励，有效避免了传统多任务训练的跷跷板问题，使其在数学、代码和 Agent 任务上表现突出。MiMo-V2-Flash 在 SWE-Bench Verified 上达到 73.4%，且模型和 MTP 权重全部开源。文章最后附带了技术报告的英中对照版获取方式。",
  "mainPoints": [
    {
      "point": "MiMo-V2-Flash 通过 MoE 架构实现高效推理和 Agent 能力。",
      "explanation": "模型总参数达 309B，但每 token 仅激活 15B，极大降低了推理成本，并专注于提升 Agent 和长上下文处理能力，对标顶级大模型。"
    },
    {
      "point": "Hybrid Sliding Window Attention 显著优化长上下文处理和计算效率。",
