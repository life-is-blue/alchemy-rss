{
  "id": "RAW_a6037332",
  "title": "小米 MiMo-V2-Flash 技术报告英中对照版.pdf",
  "url": "https://mp.weixin.qq.com/s?__biz=MjM5ODkzMzMwMQ==&mid=2650450520&idx=1&sn=5a67a366fd058ec836afc21050ae57ba",
  "date": "2025-12-18 12:31:00",
  "author": "AINLP",
  "siteName": "AINLP",
  "content": "<html>\n <head></head>\n <body>\n  <p><strong data-start=\"90\" data-end=\"193\" style=\"background-color: inherit; font-size: 1rem;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 17px;\">小米MiMo-V2-Flash 是一个“极度强调效率”的超大 MoE 推理与 Agent 模型：用更少的激活参数，在长上下文、复杂推理和代码代理任务上，做到接近甚至追平顶级大模型，并显著加速推理。</span></span></strong></p>\n  <p data-start=\"90\" data-end=\"231\" data-pm-slice=\"0 0 []\"><strong data-start=\"90\" data-end=\"193\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 17px;\">🔑 核心要点</span></span></strong></p>\n  <h3 data-start=\"255\" data-end=\"270\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">1️⃣ 模型规模与定位</span></span></h3>\n  <ul class=\"list-paddingleft-1\">\n   <li>\n    <p data-start=\"273\" data-end=\"307\"><strong data-start=\"273\" data-end=\"307\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">309B 总参数，但每 token 只激活 15B（MoE）</span></span></strong></p>\n   </li>\n   <li>\n    <p data-start=\"310\" data-end=\"347\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">目标不是“参数最大”，而是&nbsp;</span></span><strong data-start=\"324\" data-end=\"347\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">推理强 + Agent 强 + 成本低</span></span></strong></p>\n   </li>\n   <li>\n    <p data-start=\"350\" data-end=\"427\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">对标：DeepSeek-V3.2、Kimi-K2、Claude、GPT-5 等</span></span></p>\n   </li>\n  </ul>\n  <p data-start=\"350\" data-end=\"427\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">2️⃣ 关键架构创新：Hybrid Sliding Window Attention</span></span></p>\n  <ul class=\"list-paddingleft-1\">\n   <li>\n    <p data-start=\"483\" data-end=\"515\"><strong data-start=\"483\" data-end=\"515\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">5:1 的滑窗注意力（SWA）+ 全局注意力（GA）混合</span></span></strong></p>\n   </li>\n   <li>\n    <p data-start=\"518\" data-end=\"536\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">窗口仅&nbsp;</span></span><strong data-start=\"522\" data-end=\"536\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">128 tokens</span></span></strong></p>\n   </li>\n   <li>\n    <p data-start=\"539\" data-end=\"564\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">显著降低 KV Cache 和计算复杂度（≈6×）</span></span></p>\n   </li>\n   <li>\n    <p data-start=\"567\" data-end=\"605\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">通过&nbsp;</span></span><strong data-start=\"570\" data-end=\"593\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">Attention Sink Bias</span></span></strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">，避免小窗口导致性能退化</span></span></p>\n   </li>\n   <li>\n    <p data-start=\"608\" data-end=\"673\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">在 32K–256K 长上下文下保持几乎满分检索成功率&nbsp;</span></span></p>\n   </li>\n  </ul>\n  <p data-start=\"608\" data-end=\"673\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">3️⃣ Multi-Token Prediction（MTP）= 训练 + 推理双加速</span></span></p>\n  <ul class=\"list-paddingleft-1\">\n   <li>\n    <p data-start=\"730\" data-end=\"741\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">训练阶段：提升学习效率</span></span></p>\n   </li>\n   <li>\n    <p data-start=\"744\" data-end=\"781\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">推理阶段：作为&nbsp;</span></span><strong data-start=\"752\" data-end=\"781\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">Speculative Decoding 草稿模型</span></span></strong></p>\n   </li>\n   <li>\n    <p data-start=\"784\" data-end=\"792\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">3 层 MTP：</span></span></p>\n   </li>\n   <ul class=\"list-paddingleft-1\">\n    <li>\n     <p data-start=\"797\" data-end=\"813\"><strong data-start=\"797\" data-end=\"813\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">最高 2.6× 解码加速</span></span></strong></p>\n    </li>\n    <li>\n     <p data-start=\"818\" data-end=\"835\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">接受长度可达 3.6 tokens</span></span></p>\n    </li>\n   </ul>\n   <li>\n    <p data-start=\"838\" data-end=\"906\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">特别适合&nbsp;</span></span><strong data-start=\"843\" data-end=\"868\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">RL rollout / Agent 推理</span></span></strong></p>\n   </li>\n  </ul>\n  <p><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">4️⃣ 关键训练范式：MOPD（Multi-Teacher On-Policy Distillation）</span></span></p>\n  <ul class=\"list-paddingleft-1\">\n   <li>\n    <p data-start=\"973\" data-end=\"987\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">创新点不是单一 RL，而是：</span></span></p>\n   </li>\n   <ul class=\"list-paddingleft-1\">\n    <li>\n     <p data-start=\"992\" data-end=\"1007\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">多个&nbsp;</span></span><strong data-start=\"995\" data-end=\"1007\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">领域专精教师模型</span></span></strong></p>\n    </li>\n    <li>\n     <p data-start=\"1012\" data-end=\"1035\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">提供&nbsp;</span></span><strong data-start=\"1015\" data-end=\"1035\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">token-level 密集奖励</span></span></strong></p>\n    </li>\n   </ul>\n   <li>\n    <p data-start=\"1038\" data-end=\"1074\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">学生模型在&nbsp;</span></span><strong data-start=\"1044\" data-end=\"1060\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">on-policy RL</span></span></strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">&nbsp;中吸收各教师的“峰值能力”</span></span></p>\n   </li>\n   <li>\n    <p data-start=\"1077\" data-end=\"1101\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">有效避免传统多任务训练的&nbsp;</span></span><strong data-start=\"1090\" data-end=\"1101\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">能力跷跷板问题</span></span></strong></p>\n   </li>\n   <li>\n    <p data-start=\"1104\" data-end=\"1168\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">在数学、代码、Agent 任务上可逼近或追平最强教师&nbsp;</span></span></p>\n   </li>\n  </ul>\n  <p><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">5️⃣ 实际效果与定位</span></span></p>\n  <ul class=\"list-paddingleft-1\">\n   <li>\n    <p data-start=\"1193\" data-end=\"1229\"><strong data-start=\"1193\" data-end=\"1229\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">SWE-Bench Verified：73.4%（开源第一梯队）</span></span></strong></p>\n   </li>\n   <li>\n    <p data-start=\"1232\" data-end=\"1254\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">长上下文、代码 Agent、数学推理非常突出</span></span></p>\n   </li>\n   <li>\n    <p data-start=\"1257\" data-end=\"1290\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">用&nbsp;</span></span><strong data-start=\"1259\" data-end=\"1276\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">1/2～1/3 的参数规模</span></span></strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">，对标当前最强开源/闭源模型</span></span></p>\n   </li>\n   <li>\n    <p data-start=\"1293\" data-end=\"1359\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">模型与 MTP 权重&nbsp;</span></span><strong data-start=\"1304\" data-end=\"1312\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">全部开源</span></span></strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 16px;\">，强调工程可复现性&nbsp;</span></span></p>\n   </li>\n  </ul>\n  <p data-start=\"1979\" data-end=\"2076\" data-pm-slice=\"0 0 []\" style=\"font-variant-caps:normal;white-space:normal;font-weight:400;font-size:17px;min-height:1em;box-sizing:border-box !important;text-decoration-thickness:initial;overflow-wrap:break-word