  "title": "五年，终于等来 Transformers v5",
  "url": "https://mp.weixin.qq.com/s?__biz=MzA3MzI4MjgzMw==&mid=2651005150&idx=2&sn=adf53249c20f389072439602596ca904",
  "date": "2025-12-02 06:47:00",
