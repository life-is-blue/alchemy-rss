{
  "id": "RAW_ab0dd611",
  "title": "吃了 15 年麦当劳，我用 Banana2 给鸡块搓了条 AI 商业广告",
  "url": "https://mp.weixin.qq.com/s?__biz=Mzg3MTk3NzYzNw==&mid=2247503160&idx=1&sn=32db9b42f696a5584f92b9910513023c",
  "date": "2025-12-11 12:56:00",
