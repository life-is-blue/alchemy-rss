465e560fb4a_1206x409.png 848w, https://image.jido.dev/20260518192453_f715ea7a-acc7-4185-b24e-8465e560fb4a_1206x409.png 1272w, https://image.jido.dev/20260518192453_f715ea7a-acc7-4185-b24e-8465e560fb4a_1206x409.png 1456w\" sizes=\"100vw\" fetchpriority=\"high\" class=\"sizing-normal\"></picture>\n       <div class=\"image-link-expand\">\n        <div class=\"pencraft pc-display-flex pc-gap-8 pc-reset\">\n         <button tabindex=\"0\" type=\"button\" class=\"pencraft pc-reset pencraft icon-container restack-image\">\n          <svg role=\"img\" width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" stroke-width=\"1.5\" stroke=\"var(--color-fg-primary)\" stroke-linecap=\"round\" stroke-linejoin=\"round\" xmlns=\"http://www.w3.org/2000/svg\">\n           <g>\n            <title></title><path d=\"M2.53001 7.81595C3.49179 4.73911 6.43281 2.5 9.91173 2.5C13.1684 2.5 15.9537 4.46214 17.0852 7.23684L17.6179 8.67647M17.6179 8.67647L18.5002 4.26471M17.6179 8.67647L13.6473 6.91176M17.4995 12.1841C16.5378 15.2609 13.5967 17.5 10.1178 17.5C6.86118 17.5 4.07589 15.5379 2.94432 12.7632L2.41165 11.3235M2.41165 11.3235L1.5293 15.7353M2.41165 11.3235L6.38224 13.0882\"></path>\n           </g>\n          </svg>\n         </button>\n         <button tabindex=\"0\" type=\"button\" class=\"pencraft pc-reset pencraft icon-container view-image\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-maximize2 lucide-maximize-2\">\n           <polyline points=\"15 3 21 3 21 9\"></polyline><polyline points=\"9 21 3 21 3 15\"></polyline><line x1=\"21\" x2=\"14\" y1=\"3\" y2=\"10\"></line><line x1=\"3\" x2=\"10\" y1=\"21\" y2=\"14\"></line>\n          </svg>\n         </button>\n        </div>\n       </div>\n      </div> \n     </a>\n    </figure>\n   </div>\n   <p>The AI trial of the century has just ended with a procedural whimper rather a bang; the jury agreed that Musk was too late but never weighed in on the questions of whether OpenAI did was legitimate.</p>\n   <p>We will never know what the world might be like had OpenAI been forced to fully follow its original mission (as reprinted below).</p>\n   <div class=\"captioned-image-container\">\n    <figure>\n     <a target=\"_blank\" href=\"https://image.jido.dev/20260518192453_45a286df-bfdc-4e76-89e9-88114aca3ee7_1169x898.jpeg\" data-component-name=\"Image2ToDOM\" class=\"image-link image2 is-viewable-img can-restack\"> \n      <div class=\"image2-inset\">\n       <picture><source type=\"image/webp\" srcset=\"https://image.jido.dev/20260518192453_45a286df-bfdc-4e76-89e9-88114aca3ee7_1169x898.jpeg 424w, https://image.jido.dev/20260518192453_45a286df-bfdc-4e76-89e9-88114aca3ee7_1169x898.jpeg 848w, https://image.jido.dev/20260518192455_45a286df-bfdc-4e76-89e9-88114aca3ee7_1169x898.jpeg 1272w, https://image.jido.dev/20260518192453_45a286df-bfdc-4e76-89e9-88114aca3ee7_1169x898.jpeg 1456w\" sizes=\"100vw\"><img src=\"https://image.jido.dev/20260518192453_45a286df-bfdc-4e76-89e9-88114aca3ee7_1169x898.jpeg\" data-attrs=\"{&quot;src&quot;:&quot;https://substack-post-media.s3.amazonaws.com/public/images/45a286df-bfdc-4e76-89e9-88114aca3ee7_1169x898.jpeg&quot;,&quot;srcNoWatermark&quot;:null,&quot;fullscreen&quot;:null,&quot;imageSize&quot;:null,&quot;height&quot;:898,&quot;width&quot;:1169,&quot;resizeWidth&quot;:null,&quot;bytes&quot;:267023,&quot;alt&quot;:null,&quot;title&quot;:null,&quot;type&quot;:&quot;image/jpeg&quot;,&quot;href&quot;:null,&quot;belowTheFold&quot;:false,&quot;topImage&quot;:false,&quot;internalRedirect&quot;:&quot;https://garymarcus.substack.com/i/198302776?img=https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F45a286df-bfdc-4e76-89e9-88114aca3ee7_1169x898.jpeg&quot;,&quot;isProcessing&quot;:false,&quot;align&quot;:null,&quot;offset&quot;:false}\" alt srcset=\"https://image.jido.dev/20260518192454_45a286df-bfdc-4e76-89e9-88114aca3ee7_1169x898.jpeg 424w, https://image.jido.dev/20260518192453_45a286df-bfdc-4e76-89e9-88114aca3ee7_1169x898.jpeg 848w, https://image.jido.dev/20260518192454_45a286df-bfdc-4e76-89e9-88114aca3ee7_1169x898.jpeg 1272w, https://image.jido.dev/20260518192453_45a286df-bfdc-4e76-89e9-88114aca3ee7_1169x898.jpeg 1456w\" sizes=\"100vw\" class=\"sizing-normal\"></picture>\n       <div class=\"image-link-expand\">\n        <div class=\"pencraft pc-display-flex pc-gap-8 pc-reset\">\n         <button tabindex=\"0\" type=\"button\" class=\"pencraft pc-reset pencraft icon-container restack-image\">\n          <svg role=\"img\" width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" stroke-width=\"1.5\" stroke=\"var(--color-fg-primary)\" stroke-linecap=\"round\" stroke-linejoin=\"round\" xmlns=\"http://www.w3.org/2000/svg\">\n           <g>\n            <title></title><path d=\"M2.53001 7.81595C3.49179 4.73911 6.43281 2.5 9.91173 2.5C13.1684 2.5 15.9537 4.46214 17.0852 7.23684L17.6179 8.67647M17.6179 8.67647L18.5002 4.26471M17.6179 8.67647L13.6473 6.91176M17.4995 12.1841C16.5378 15.2609 13.5967 17.5 10.1178 17.5C6.86118 17.5 4.07589 15.5379 2.94432 12.7632L2.41165 11.3235M2.41165 11.3235L1.5293 15.7353M2.41165 11.3235L6.38224 13.0882\"></path>\n           </g>\n          </svg>\n         </button>\n         <button tabindex=\"0\" type=\"button\" class=\"pencraft pc-reset pencraft icon-container view-image\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-maximize2 lucide-maximize-2\">\n           <polyline points=\"15 3 21 3 21 9\"></polyline><polyline points=\"9 21 3 21 3 15\"></polyline><line x1=\"21\" x2=\"14\" y1=\"3\" y2=\"10\"></line><line x1=\"3\" x2=\"10\" y1=\"21\" y2=\"14\"></line>\n          </svg>\n         </button>\n        </div>\n       </div>\n      </div> \n     </a>\n    </figure>\n   </div>\n   <p></p>\n   <p></p>\n   <p></p>\n   <p></p>\n   <p></p>\n   <p></p>\n  </div>\n </body>\n</html>",
  "aiSummary": "世纪 AI 审判——马斯克诉 OpenAI 案，因程序性技术问题而终结，未能触及 OpenAI 是否违反其最初非营利使命的核心问题。",
  "oneSentenceSummary": "世纪 AI 审判——马斯克诉 OpenAI 案，因程序性技术问题而终结，未能触及 OpenAI 是否违反其最初非营利使命的核心问题。",
  "summary": "加里·马库斯对马斯克与 OpenAI 之间备受瞩目的法律案件结局进行了反思。该审判并非就 OpenAI 行为的合法性做出实质性裁决，而是基于程序性裁定，认为马斯克的诉讼提起过晚。马库斯感叹，陪审团从未就 OpenAI 从最初的非营利、开源使命转向营利性、封闭模式是否合法这一根本性问题做出裁决。文章强调，这是一次错失的机会，未能为一家领先 AI 公司的发展方向提供法律上的明确性，使得公众对此问题仍无定论。",
  "mainPoints": [
    {
      "point": "马斯克诉 OpenAI 案以程序性技术问题告终，而非实质性裁决。",
      "explanation": "陪审团一致认为马斯克的诉讼提起过晚，从而避免了对 OpenAI 是否违反其最初非营利使命这一核心问题做出裁决。"
    },
    {
      "point": "这一结果使得关于 AI 治理的一个关键问题悬而未决。",
      "explanation": "公众将无从得知 OpenAI 从开放的非营利实体转变为营利性、封闭模式在法律上是否合法，这标志着一次错失法律明确性的机会。"
    }
  ],
  "keyQuotes": [
    "这场世纪 AI 审判以程序性的呜咽而非巨响收场",
    "我们永远不会知道，如果 OpenAI 被迫完全遵循其最初使命，世界将会是怎样一番景象"
  ],
