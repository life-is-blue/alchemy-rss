  "content": "<html>\n <head></head>\n <body>\n  <div class=\"loader-mask\"></div>\n  <main id=\"jump-content\" class=\"site-content\" tabindex=\"-1\">\n   <div class=\"uni-layout-page uni-component-spacing short-post-page\">\n    <div class=\"short-post-page__grid\">\n     <div class=\"short-post-page__breadcrumb\">\n      <div class=\"breadcrumb__container\" data-component=\"uni-breadcrumb\" data-component-initialized=\"true\">\n       <button class=\"breadcrumb__prev-btn hide\" aria-label=\"Previous\"></button>\n       <button class=\"breadcrumb__next-btn hide\" aria-label=\"Next\"></button>\n      </div>\n     </div>\n     <div class=\"short-post-page__post\">\n      <uni-short-post data-title=\"Fitbit’s personal health coach is expanding to reach 37 countries and 32 languages.\" author=\"\" author-job-title=\"\" author-url=\"\" date=\"Apr 09, 2026\" url=\"https://blog.google/products-and-platforms/devices/fitbit/fitbit-personal-health-coach-expansion/\">\n       <!---->\n       <div class=\"short-post\">\n        <div class=\"short-post__header\">\n         <div class=\"uni-body--small short-post__date\">\n          <!--?lit$628820316$-->\n          Apr 09, 2026\n         </div>\n         <button tooltip=\"Copied\" aria-label=\"Copy to clipboard\" class=\"short-post__copy-link\"><uni-icon-component icon-id=\"social-link\"><!----></uni-icon-component></button>\n        </div>\n        <!--?lit$628820316$-->\n        <!--?lit$628820316$-->\n        <!--?lit$628820316$-->\n        <!--?-->\n        <!--?-->\n        <p class=\"short-post__description\" data-analytics-module=\"{&quot;module_name&quot;:&quot;Paragraph&quot;,&quot;section_header&quot;:&quot;Fitbit’s personal health coach is expanding to reach 37 countries and 32 languages.&quot;}\"><!--?lit$628820316$--></p>\n        <div slot=\"uni-short-post-description-slot\" style=\"display: block;\">\n         <div class=\"rich-text\">\n          <p data-block-key=\"l6ezq\">We’re continuing to expand the <a href=\"https://blog.google/products-and-platforms/devices/fitbit/personal-health-coach-public-preview/\">Fitbit personal health coach Public Preview</a> experience to more people and languages around the world (for iOS &amp; Android users in free and Premium).</p>\n          <p data-block-key=\"9i6k3\">Starting today, the personal health coach will start rolling out in public preview in: Austria, Belgium, Brazil, Czech Republic, Denmark, Estonia, Finland, France, Germany, Hungary, India, Indonesia, Ireland, Italy, Japan, Latvia, Lithuania, Malaysia, Mexico, Netherlands, Norway, Poland, Portugal, Romania, Slovakia, Slovenia, South Korea, Spain, Sweden, Switzerland and Taiwan.</p>\n          <p data-block-key=\"4voau\">We’re also expanding to new languages, including Brazilian Portuguese, Canadian French, Czech, Danish, Dutch, Estonian, Finnish, French, German, Hindi, Hungarian, Indonesian, Italian, Japanese, Korean, Latin American Spanish, Latvian, Lithuanian, Malay, Norwegian, Polish, Portuguese, Romanian, Slovak, Slovenian, Spanish, Swedish and Chinese (Traditional).</p>\n          <p data-block-key=\"fshle\">Eligible users in these countries will see the update in their Fitbit app over the coming weeks.</p>\n          <p data-block-key=\"e61ao\">This update will also bring VO2Max (formerly Cardio Fitness Score) into the Public Preview experience so your cardio performance will integrate with the coach.</p>\n          <p data-block-key=\"c2f4r\">For more details on all updates we’ve introduced in public preview, visit our <a href=\"https://community.fitbit.com/t5/Personal-Health-Coach-Public-Preview/Current-Feature-Status-in-Preview/td-p/5788669\" rel=\"noopener\" target=\"_blank\">community page</a>.</p>\n         </div>\n        </div>\n        <p></p>\n        <!--?lit$628820316$-->\n       </div>\n      </uni-short-post>\n     </div>\n     <div class=\"short-post-page__related-articles\">\n      <h2 class=\"uni-headline-5 short-post-page__related-articles-title\">Related stories</h2>\n      <ul class=\"short-post-page__related-articles-list\">\n       <li>\n        <uni-short-related-post authors=\"The Keyword Team\" index=\"0\" primary-tag=\"Topics - AI\" summary=\"Here are Google’s latest AI updates from March 2026\" title=\"The latest AI news we announced in March 2026\" url=\"https://blog.google/innovation-and-ai/technology/ai/google-ai-updates-march-2026/\" ga4-context=\"{\n                  &quot;module_name&quot;: &quot;Short Post Related articles&quot;,\n                  &quot;section_header&quot;: &quot;Related stories&quot;,\n                  &quot;content_type&quot;: &quot;article page&quot;\n                }\">\n         <!---->\n         <div class=\"short-post-page__related-article short-post-page__related-article--underline\">\n          <a class=\"short-post-page__related-article-link\" href=\"https://blog.google/innovation-and-ai/technology/ai/google-ai-updates-march-2026/\"> \n           <h3 class=\"uni-title-2 short-post-page__related-article-title\"><!--?lit$628820316$-->The latest AI news we announced in March 2026</h3> \n           <!--?lit$628820316$--> \n           <p class=\"uni-body--small short-post-page__related-article-body\"><!--?lit$628820316$-->Here are Google’s latest AI updates from March 2026</p> \n          </a>\n         </div>\n        </uni-short-related-post>\n       </li>\n       <li>\n        <uni-short-related-post authors=\"\" index=\"1\" primary-tag=\"Products - Fitbit\" summary=\"Fitbit adds cycle, mental wellbeing &amp; nutrition tools in Public Preview. Now available for those without a Premium membership.\" title=\"New personal health coach features are coming to Fitbit.\" url=\"https://blog.google/products-and-platforms/devices/fitbit/fitbit-personal-health-coach-new-features/\" ga4-context=\"{\n                  &quot;module_name&quot;: &quot;Short Post Related articles&quot;,\n                  &quot;section_header&quot;: &quot;Related stories&quot;,\n                  &quot;content_type&quot;: &quot;Short Post&quot;\n                }\">\n         <!---->\n         <div class=\"short-post-page__related-article short-post-page__related-article--underline\">\n          <a class=\"short-post-page__related-article-link\" href=\"https://blog.google/products-and-platforms/devices/fitbit/fitbit-personal-health-coach-new-features/\"> \n           <h3 class=\"uni-title-2 short-post-page__related-article-title\"><!--?lit$628820316$-->New personal health coach features are coming to Fitbit.</h3> \n           <!--?lit$628820316$--> \n          </a>\n         </div>\n        </uni-short-related-post>\n       </li>\n       <li>\n        <uni-short-related-post authors=\"Florence Thng\" index=\"2\" primary-tag=\"Products - Fitbit\" summary=\"Learn how Fitbit is helping people take control of their health by linking medical records, improving sleep tracking accuracy and adva…\" title=\"Get a fuller picture with Fitbit's personal health coach\" url=\"https://blog.google/products-and-platforms/devices/fitbit/fitbit-personal-health-coach-updates-2026/\" ga4-context=\"{\n                  &quot;module_name&quot;: &quot;Short Post Related articles&quot;,\n                  &quot;section_header&quot;: &quot;Related stories&quot;,\n                  &quot;content_type&quot;: &quot;article page&quot;\n                }\">\n         <!---->\n         <div class=\"short-post-page__related-article short-post-page__related-article--underline\">\n          <a class=\"short-post-page__related-article-link\" href=\"https://blog.google/products-and-platforms/devices/fitbit/fitbit-personal-health-coach-updates-2026/\"> \n           <h3 class=\"uni-title-2 short-post-page__related-article-title\"><!--?lit$628820316$-->Get a fuller picture with Fitbit's personal health coach</h3> \n           <!--?lit$628820316$--> \n          </a>\n         </div>\n        </uni-short-related-post>\n       </li>\n       <li>\n        <uni-short-related-post authors=\"\" index=\"3\" primary-tag=\"Products - Fitbit\" summary=\"Fitbit’s personal health coach experience is expanding to more people around the world.Starting today and over the next few weeks, the…\" title=\"Fitbit’s personal health coach is expanding to more people in public preview.\" url=\"https://blog.google/products-and-platforms/devices/fitbit/personal-health-coach-expansion/\" ga4-context=\"{\n                  &quot;module_name&quot;: &quot;Short Post Related articles&quot;,\n                  &quot;section_header&quot;: &quot;Related stories&quot;,\n                  &quot;content_type&quot;: &quot;Short Post&quot;\n                }\">\n         <!---->\n         <div class=\"short-post-page__related-article\">\n          <a class=\"short-post-page__related-article-link\" href=\"https://blog.google/products-and-platforms/devices/fitbit/personal-health-coach-expansion/\"> \n           <h3 class=\"uni-title-2 short-post-page__related-article-title\"><!--?lit$628820316$-->Fitbit’s personal health coach is expanding to more people in public preview.</h3> \n           <!--?lit$628820316$--> \n          </a>\n         </div>\n        </uni-short-related-post>\n       </li>\n      </ul>\n     </div>\n    </div>\n   </div>\n  </main>\n  <div class=\"uni-newsletter-toast\" data-component=\"uni-newsletter-toast\" data-component-initialized=\"true\" style=\"bottom: -63.0938px;\">\n   <div class=\"h-c-page\">\n    <div class=\"uni-newsletter-toast--container h-c-grid\">\n     <div class=\"uni-newsletter-toast__info h-c-grid__col h-c-grid__col--12  h-c-grid__col-l--9 h-c-grid__col--align-middle\">\n      <div class=\"uni-newsletter-toast__img\">\n       <img src=\"https://blog.google/static/blogv2/images/newsletter_toast.svg?version=pr20260319-1641\" alt=\"\">\n      </div>\n      <p class=\"uni-newsletter-toast__text\">Let’s stay in touch. Get the latest news from Google in your inbox.</p>\n     </div>\n     <div class=\"uni-newsletter-toast__buttons h-c-grid__col h-c-grid__col--8 h-c-grid__col-l--3\">\n      <a class=\"uni-newsletter-toast__cta uni-newsletter-toast__cta--sub\" href=\"https://blog.google/newsletter-subscribe/\" tabindex=\"0\" aria-label=\"Newsletter subscribe\" data-content-type=\"blogv2 | Short Post\">Subscribe</a>\n      <button class=\"uni-newsletter-toast__cta uni-newsletter-toast__cta--no\" tabindex=\"0\" data-content-type=\"blogv2 | Short Post\">No thanks</button>\n     </div>\n    </div>\n   </div>\n  </div>\n </body>\n</html>",
  "aiSummary": "Google 正在将 Fitbit 个人健康教练功能的公开预览版扩展至 37 个国家和 32 种语言，并将 VO2Max 指标整合到教练体验中。",
  "oneSentenceSummary": "Google 正在将 Fitbit 个人健康教练功能的公开预览版扩展至 37 个国家和 32 种语言，并将 VO2Max 指标整合到教练体验中。",
  "summary": "Google 宣布对其 Fitbit 个人健康教练功能的公开预览版进行重大全球扩展，现已覆盖 iOS 和 Android 平台上的 37 个国家并支持 32 种语言。此次更新旨在为更广泛的国际用户群体提供更本地化的健康指导。此外，该更新还将 VO2Max 指标（前身为有氧健身评分）直接整合到教练体验中，从而实现更全面的心血管表现追踪和个性化的健康洞察。",
  "mainPoints": [
    {
      "point": "AI 驱动的健康教练功能实现广泛的国际化推广。",
      "explanation": "Fitbit 个人健康教练功能正在将其公开预览版扩展至 37 个国家，显著提升了全球 iOS 和 Android 用户的使用便利性。"
    },
    {
      "point": "广泛的语言支持以实现本地化的用户体验。",
      "explanation": "通过增加对 32 种语言（包括多种区域方言）的支持，Google 降低了非英语用户获取 AI 健康洞察的门槛。"
    },
    {
      "point": "将生理指标整合到教练反馈循环中。",
      "explanation": "将 VO2Max 数据纳入教练预览版，使 AI 能够根据用户的实时表现提供更准确、基于数据的心血管健康建议。"
    }
  ],
  "keyQuotes": [
    "我们正在继续将 Fitbit 个人健康教练的公开预览体验扩展到全球更多的人群和语言中。",
    "此次更新还将把 VO2Max（前身为有氧健身评分）引入到公开预览体验中，以便您的有氧运动表现能与教练功能相结合。"
  ],
