  "content": "<!--$-->\n<!--/$-->\n<!--$-->\n<!--/$-->\n<html>\n <head></head>\n <body>\n  <a class=\"skip-nav-link-module__uw4zXa__skipLink\" href=\"#geist-skip-nav\" tabindex=\"0\">Skip to content</a>\n  <div class=\"flex min-w-0\">\n   <div class=\"@container flex-1 min-w-0\">\n    <div class=\"stack-module__UbbKhW__stack stack geist-soft-reset grid-module__4pDFEa__page page-module__qbCsVG__page px-4 lg:first:pt-[calc(var(--banner-min-height))] lg:first:has-[&gt;[data-slot=banner]]:pt-0 stack-module__UbbKhW__padding\" data-version=\"v1\" style=\"--stack-flex:initial;--stack-direction:column;--stack-align:stretch;--stack-justify:flex-start;--sm-stack-padding:16px 0px;--md-stack-padding:32px 0px;--lg-stack-padding:90px 0px;--xl-stack-padding:90px 0px;--stack-gap:0px\">\n     <div class=\"grid-module__4pDFEa__unstable_gridSystemWrapper\">\n      <div class=\"grid-module__4pDFEa__gridSystem mx-auto\">\n       <section class=\"grid-module__4pDFEa__grid\" data-grid=\"\" style=\"--grid-rows:3;--sm-grid-columns:2;--lg-grid-columns:3;--sm-height:fit-content;border-bottom:none\">\n        <div class=\"grid-module__4pDFEa__cross\" data-grid-cross=\"\" style=\"--cross-row:1;--cross-column:1\"></div>\n        <div class=\"grid-module__4pDFEa__block hero-module__0CIgbq__cell hero-module__0CIgbq__categoryCell\" data-grid-cell=\"\" style=\"--sm-grid-row:1 / span 1;--sm-grid-column:1/-1;--sm-cell-rows:1;--sm-cell-columns:-2;padding:0\">\n         <div class=\"flex flex-col items-center justify-center flex-initial\">\n          <p class=\"text-copy-14 text-gray-900 hero-module__0CIgbq__category\"><a data-zone=\"same\" class=\"link-module__Q1NRQq__link no-underline inline-flex leading-none\" href=\"https://vercel.com/blog\">Blog</a> <!-- -->/<!-- --> <span><a data-zone=\"same\" class=\"link-module__Q1NRQq__link no-underline\" href=\"https://vercel.com/changelog\">Changelog</a></span></p>\n         </div>\n        </div>\n        <div class=\"grid-module__4pDFEa__block hero-module__0CIgbq__cell hero-module__0CIgbq__titleCell\" data-grid-cell=\"\" style=\"--sm-grid-row:2 / span 1;--sm-grid-column:1/-1;--sm-cell-rows:1;--sm-cell-columns:-2;padding:0\">\n         <div class=\"flex flex-col items-center justify-center flex-initial\"></div>\n        </div>\n        <div class=\"grid-module__4pDFEa__block hero-module__0CIgbq__cell hero-module__0CIgbq__authorCell\" data-grid-cell=\"\" style=\"--sm-grid-row:3 / span 1;--sm-grid-column:1/-1;--sm-cell-rows:1;--sm-cell-columns:-2;padding:0\">\n         <div class=\"flex flex-col items-center w-full relative\">\n          <div class=\"flex flex-col items-center justify-center flex-initial\">\n           <div class=\"flex flex-col items-stretch justify-start gap-2 flex-initial hero-module__0CIgbq__fewAuthorsContainer\">\n            <a href=\"https://twitter.com/tomlienard\" rel=\"author\" target=\"_blank\" data-zone=\"null\" class=\"link-module__Q1NRQq__link no-underline hero-module__0CIgbq__author\"> \n             <div class=\"flex flex-row items-stretch justify-start gap-2 flex-initial hero-module__0CIgbq__authorStack\">\n              <span class=\"text-[14px] leading-[20px] font-medium text-gray-1000 hero-module__0CIgbq__name\">Tom Lienard</span><span class=\"text-copy-14 text-gray-900 hero-module__0CIgbq__role\">Software Engineer, Infrastructure</span>\n             </div> \n            </a><a href=\"https://twitter.com/SheardLuke\" rel=\"author\" target=\"_blank\" data-zone=\"null\" class=\"link-module__Q1NRQq__link no-underline hero-module__0CIgbq__author\"> \n             <div class=\"flex flex-row items-stretch justify-start gap-2 flex-initial hero-module__0CIgbq__authorStack\">\n              <span class=\"text-[14px] leading-[20px] font-medium text-gray-1000 hero-module__0CIgbq__name\">Luke Phillips-Sheard</span><span class=\"text-copy-14 text-gray-900 hero-module__0CIgbq__role\">Engineering Manager, Infrastructure</span>\n             </div> \n            </a>\n           </div>\n          </div>\n         </div>\n        </div>\n       </section>\n       <div class=\"grid-module__4pDFEa__grid article-module__XJFYTq__topGap\" data-grid=\"\" style=\"--grid-rows:1;--sm-grid-columns:2;--lg-grid-columns:3;--sm-height:var(--grid-divider-gap);border-bottom:none\"></div>\n       <main class=\"grid-module__4pDFEa__grid\" data-grid=\"\" style=\"--sm-grid-rows:2;--lg-grid-rows:1;--sm-grid-columns:2;--lg-grid-columns:3;--sm-height:fit-content;border-bottom:none\">\n        <article class=\"grid-module__4pDFEa__block article-module__XJFYTq__articleContent\" data-grid-cell=\"\" style=\"--sm-grid-row:1 / span 1;--sm-grid-column:1/3;--lg-grid-column:1/4;--sm-cell-rows:1;--sm-cell-columns:2;--lg-cell-columns:3\">\n         <div data-customer-story=\"false\" class=\"flex flex-col items-center justify-start gap-6 flex-initial article-module__XJFYTq__content\">\n          <div class=\"flex flex-row items-center justify-between flex-initial w-full gap-4 pt-2\">\n           <div class=\"flex flex-row items-center justify-start gap-1.5 flex-initial\">\n            <p class=\"text-copy-14 text-gray-900\">1<!-- --> min <!-- -->read</p>\n           </div>\n           <div class=\"flex items-center gap-x-2 sm:gap-x-6 flex-1 justify-start\"></div>\n           <time class=\"text-copy-14 text-gray-900 order-2 md:order-3\" datetime=\"2026-04-08T00:00-07:00\">Apr 8, 2026</time>\n          </div>\n          <p class=\"text-copy-16 lg:text-copy-18 text-module__qZtYrq__paragraph\">Vercel Sandbox now supports creating sandboxes with up to 32 vCPUs and 64 GB of RAM for Enterprise customers. This enables running large, resource-intensive applications that are CPU-bound or require a large amount of memory.</p>\n          <p class=\"text-copy-16 lg:text-copy-18 text-module__qZtYrq__paragraph\">Get started by setting the <code>resources.vcpus</code> option in the <a href=\"https://vercel.com/docs/vercel-sandbox/sdk-reference#sandbox.create\" target=\"_blank\" data-track=\"true\" data-track-click-name=\"article_link\" data-track-click-value=\"/docs/vercel-sandbox/sdk-reference#sandbox.create\" data-zone=\"667155\" class=\"link-module__Q1NRQq__link no-underline link-module__Q1NRQq__highlight [&amp;_u]:no-underline\">SDK</a>:</p>\n          <div class=\"flex flex-col items-stretch justify-start gap-4 flex-initial blog-code-block-module__TEKDOa__wrapper\">\n           <div class=\"relative code-block-module__NOThwW__wrapper blog-code-block-module__TEKDOa__codeBlock\" data-geist-code-block=\"\">\n            <button aria-label=\"Copy code\" class=\"code-block-module__NOThwW__copyButton code-block-module__NOThwW__copyFloatingButton\" type=\"button\"></button>\n            <pre class=\"prism-code language-typescript code-block-module__NOThwW__pre blog-code-block-module__TEKDOa__maxHeight\"><code class=\"code-block-module__NOThwW__code\" data-geist-code-block=\"true\"><div class=\"line\" data-geist-code-block-line=\"true\" id=\"C46ca89e3-L1\" data-highlighted=\"false\" style=\"font-feature-settings:&quot;liga&quot; off\"><div class=\"token-line\"><span class=\"token keyword\">import</span><span class=\"token plain\"> </span><span class=\"token punctuation\">{</span><span class=\"token plain\"> Sandbox </span><span class=\"token punctuation\">}</span><span class=\"token plain\"> </span><span class=\"token keyword\">from</span><span class=\"token plain\"> </span><span class=\"token string\">\"@vercel/sandbox\"</span><span class=\"token punctuation\">;</span><span class=\"token plain\"></span></div></div><div class=\"line\" data-geist-code-block-line=\"true\" id=\"C46ca89e3-L2\" data-highlighted=\"false\" style=\"font-feature-settings:&quot;liga&quot; off\"><div class=\"token-line\"><span class=\"token plain\" style=\"display:inline-block\">\n</span></div></div><div class=\"line\" data-geist-code-block-line=\"true\" id=\"C46ca89e3-L3\" data-highlighted=\"false\" style=\"font-feature-settings:&quot;liga&quot; off\"><div class=\"token-line\"><span class=\"token plain\"></span><span class=\"token keyword\">const</span><span class=\"token plain\"> sandbox </span><span class=\"token operator\">=</span><span class=\"token plain\"> </span><span class=\"token keyword\">await</span><span class=\"token plain\"> Sandbox</span><span class=\"token punctuation\">.</span><span class=\"token function\">create</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">{</span><span class=\"token plain\"></span></div></div><div class=\"line\" data-geist-code-block-line=\"true\" id=\"C46ca89e3-L4\" data-highlighted=\"true\" style=\"font-feature-settings:&quot;liga&quot; off\"><div class=\"token-line\"><span class=\"token plain\">  resources</span><span class=\"token operator\">:</span><span class=\"token plain\"> </span><span class=\"token punctuation\">{</span><span class=\"token plain\"> vcpus</span><span class=\"token operator\">:</span><span class=\"token plain\"> </span><span class=\"token number\">32</span><span class=\"token plain\"> </span><span class=\"token punctuation\">}</span><span class=\"token punctuation\">,</span><span class=\"token plain\"></span></div></div><div class=\"line\" data-geist-code-block-line=\"true\" id=\"C46ca89e3-L5\" data-highlighted=\"false\" style=\"font-feature-settings:&quot;liga&quot; off\"><div class=\"token-line\"><span class=\"token plain\"></span><span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span></div></div></code></pre>\n           </div>\n           <p class=\"text-center text-copy-14 text-gray-900\"></p>\n          </div>\n          <p class=\"text-copy-16 lg:text-copy-18 text-module__qZtYrq__paragraph\">Or using the <code>--vcpus</code> option in the <a href=\"https://vercel.com/docs/vercel-sandbox/cli-reference#sandbox-create\" target=\"_blank\" data-track=\"true\" data-track-click-name=\"article_link\" data-track-click-value=\"/docs/vercel-sandbox/cli-reference#sandbox-create\" data-zone=\"667155\" class=\"link-module__Q1NRQq__link no-underline link-module__Q1NRQq__highlight [&amp;_u]:no-underline\">CLI</a>:</p>\n          <div class=\"flex flex-col items-stretch justify-start gap-4 flex-initial blog-code-block-module__TEKDOa__wrapper\">\n           <div class=\"relative code-block-module__NOThwW__wrapper code-block-module__NOThwW__hideLineNumbers blog-code-block-module__TEKDOa__codeBlock\" data-geist-code-block=\"\">\n            <button aria-label=\"Copy code\" class=\"code-block-module__NOThwW__copyButton code-block-module__NOThwW__copyFloatingButton\" type=\"button\"></button>\n            <pre class=\"prism-code language-bash code-block-module__NOThwW__pre blog-code-block-module__TEKDOa__maxHeight\"><code class=\"code-block-module__NOThwW__code\" data-geist-code-block=\"true\"><div class=\"line\" data-geist-code-block-line=\"true\" id=\"C3fd93c9f-L1\" style=\"font-feature-settings:&quot;liga&quot; off\"><div class=\"token-line\"><span class=\"token plain\">sandbox create </span><span class=\"token parameter variable\">--connect</span><span class=\"token plain\"> </span><span class=\"token parameter variable\">--vcpus</span><span class=\"token plain\"> </span><span class=\"token number\">32</span></div></div></code></pre>\n           </div>\n           <p class=\"text-center text-copy-14 text-gray-900\"></p>\n          </div>\n          <p class=\"text-copy-16 lg:text-copy-18 text-module__qZtYrq__paragraph\">Learn more about Sandbox in the <a href=\"https://vercel.com/docs/vercel-sandbox\" target=\"_blank\" data-track=\"true\" data-track-click-name=\"article_link\" data-track-click-value=\"/docs/vercel-sandbox\" data-zone=\"667155\" class=\"link-module__Q1NRQq__link no-underline link-module__Q1NRQq__highlight [&amp;_u]:no-underline\">docs</a>.</p>\n         </div>\n        </article>\n       </main>\n       <div class=\"grid-module__4pDFEa__grid\" data-grid=\"\" style=\"--grid-rows:1;--sm-grid-columns:2;--lg-grid-columns:3;--sm-height:var(--grid-divider-gap)\"></div>\n       <section class=\"grid-module__4pDFEa__grid grid-module__4pDFEa__useContainer\" data-grid=\"\" style=\"--sm-grid-rows:2;--lg-grid-rows:1;--sm-grid-columns:2;--lg-grid-columns:3;--sm-height:fit-content\">\n        <div class=\"grid-module__4pDFEa__block footer-module__QGSwJW__primaryCell\" data-grid-cell=\"\" style=\"--sm-grid-row:1 / span 1;--sm-grid-column:1/3;--sm-cell-rows:1;--sm-cell-columns:2\">\n         <div class=\"flex flex-col items-center lg:items-start justify-center gap-6 flex-initial\">\n          <div class=\"footer-module__QGSwJW__primaryDescription\">\n           <p><b>Ready to deploy? </b>Start building with a free account. Speak to an expert for your <i>Pro</i> or <u>Enterprise</u> needs.</p>\n          </div>\n          <div class=\"flex flex-row items-stretch justify-start gap-4 flex-initial undefined\">\n           <a role=\"link\" href=\"https://vercel.com/new\" type=\"submit\" tabindex=\"0\" data-react-aria-pressable=\"true\" data-track=\"true\" data-track-intent=\"Get Started\" data-zone=\"2d9dc9\" class=\"button-module__QyrFCa__base reset-module__ylizOa__reset button-module__QyrFCa__button reset-module__ylizOa__reset geist-new-themed geist-new-default geist-new-default-fill button-module__QyrFCa__rounded button-module__QyrFCa__invert\" data-geist-button=\"\" data-prefix=\"false\" data-suffix=\"false\" data-version=\"v1\" style=\"--geist-icon-size:16px\"><span class=\"button-module__QyrFCa__content\"> \n             <div class=\"flex flex-row items-center justify-start gap-2 flex-initial\">Start Deploying</div> \n            </span></a><a role=\"link\" type=\"submit\" tabindex=\"0\" data-react-aria-pressable=\"true\" data-track=\"true\" data-track-intent=\"Contact Sales\" data-zone=\"same\" class=\"button-module__QyrFCa__base reset-module__ylizOa__reset button-module__QyrFCa__button reset-module__ylizOa__reset button-module__QyrFCa__secondary button-module__QyrFCa__rounded button-module__QyrFCa__shadow button-module__QyrFCa__invert\" data-geist-button=\"\" data-prefix=\"false\" data-suffix=\"false\" data-version=\"v1\" style=\"--geist-icon-size:16px\" href=\"https://vercel.com/contact/sales\"><span class=\"button-module__QyrFCa__content\"> \n             <div class=\"flex flex-row items-center justify-start gap-2 flex-initial\">Talk to an Expert</div> \n            </span></a>\n          </div>\n         </div>\n        </div>\n        <div class=\"grid-module__4pDFEa__block footer-module__QGSwJW__secondaryCell footer-module__QGSwJW__secondaryCellRenderingCTAAsButton\" data-grid-cell=\"\" style=\"--sm-grid-row:2 / span 1;--lg-grid-row:1 / span 1;--sm-grid-column:1/3;--lg-grid-column:3/4;--sm-cell-rows:1;--sm-cell-columns:2;--lg-cell-columns:1;overflow:visible\">\n         <div class=\"flex flex-col lg:flex-col items-center lg:items-start justify-center gap-4 lg:gap-6 flex-initial\">\n          <div class=\"footer-module__QGSwJW__secondaryDescription\">\n           <p><b>Explore Vercel Enterprise</b> with an interactive product tour, trial, or a personalized demo.</p>\n          </div>\n          <div class=\"flex flex-row items-center justify-center lg:justify-between gap-6 lg:gap-2 flex-initial\">\n           <a role=\"link\" type=\"submit\" tabindex=\"0\" data-react-aria-pressable=\"true\" data-track=\"true\" data-track-intent=\"Contact Sales\" data-zone=\"same\" class=\"button-module__QyrFCa__base reset-module__ylizOa__reset button-module__QyrFCa__button reset-module__ylizOa__reset button-module__QyrFCa__secondary button-module__QyrFCa__rounded button-module__QyrFCa__shadow button-module__QyrFCa__invert\" data-geist-button=\"\" data-prefix=\"false\" data-suffix=\"false\" data-version=\"v1\" style=\"--geist-icon-size:16px\" href=\"https://vercel.com/try-enterprise\"><span class=\"button-module__QyrFCa__content\"> \n             <div class=\"flex flex-row items-center justify-start gap-2 flex-initial\">Explore Enterprise</div> \n            </span></a>\n          </div>\n         </div>\n        </div>\n        <div class=\"grid-module__4pDFEa__cross\" data-grid-cross=\"\" style=\"--cross-row:1;--cross-column:1\"></div>\n        <div class=\"grid-module__4pDFEa__cross\" data-grid-cross=\"\" style=\"transform:translateY(1px);--sm-cross-row:3;--lg-cross-row:2;--cross-column:-1\"></div>\n       </section>\n      </div>\n     </div>\n    </div>\n    <!--$-->\n    <!--/$-->\n   </div>\n  </div>\n  <!--$-->\n  <!--/$-->\n  <!--$-->\n  <!--$-->\n  <!--/$-->\n  <!--$-->\n  <!--/$-->\n  <!--/$-->\n  <!--$-->\n  <!--/$-->\n  <!--$-->\n  <!--/$-->\n  <!--$-->\n  <!--/$-->\n </body>\n</html>",
  "aiSummary": "Vercel 已升级其 Sandbox 环境，为企业级客户提供最高 32 vCPU 和 64 GB RAM 的高性能配置支持。",
  "oneSentenceSummary": "Vercel 已升级其 Sandbox 环境，为企业级客户提供最高 32 vCPU 和 64 GB RAM 的高性能配置支持。",
  "summary": "Vercel 宣布对其 Sandbox 环境进行重大资源升级，专门面向企业级用户。开发者现在可以配置最高 32 vCPU 和 64 GB RAM 的沙盒，从而能够运行资源密集型、受 CPU 限制或需要大量内存的应用。此次更新通过 Vercel Sandbox SDK 和 CLI 全面支持这些配置。",
  "mainPoints": [
    {
      "point": "Vercel Sandbox 资源大幅扩展。",
      "explanation": "企业级客户现在可以使用最高 32 vCPU 和 64 GB RAM，这对于在隔离环境中运行繁重工作负载是一次重大飞跃。"
    },
    {
      "point": "通过 SDK 和 CLI 实现可编程资源分配。",
      "explanation": "通过 `@vercel/sandbox` SDK 或在创建沙盒时使用简单的 CLI 标志，即可轻松实现这些新配置。"
    }
  ],
  "keyQuotes": [
    "Vercel Sandbox 现已支持企业级客户创建最高 32 vCPU 和 64 GB RAM 的沙盒。",
    "这使得运行大型、资源密集型、受 CPU 限制或需要大量内存的应用成为可能。"
  ],
