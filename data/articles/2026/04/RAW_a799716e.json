  "id": "RAW_a799716e",
  "title": "GLM-5.1 开源：支持 8 小时独立工作的长程任务模型",
  "url": "https://mp.weixin.qq.com/s?__biz=MzkyMzI3NzQ0Mg==&mid=2247493695&idx=1&sn=3c096efd1739c7e0266befeef6ebcd4d",
  "date": "2026-04-08 02:41:00",
