{
  "id": "RAW_0054771f",
  "title": "千问 APP 给未来的 AI 应用打了个样",
  "url": "https://mp.weixin.qq.com/s?__biz=MzU2Njg0OTEyNQ==&mid=2247490707&idx=1&sn=c5178aab359d16dc0702af4dc304ca8d",
  "date": "2026-01-15 03:39:00",
  "author": "AI异类弗兰克",
