229, 229, 229);line-height:2;box-sizing:border-box;word-break:break-all;border-width:0px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;border-style:solid;opacity:0.9;text-align:justify;\"><strong style=\"box-sizing: border-box;border-width: 0px;border-style: solid;border-color: rgb(229, 229, 229);font-weight: bold;text-align: left;line-height: 1.75;font-family: -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-size: inherit;color: rgb(198, 110, 73);margin: 24px 0px 8px;\"><span leaf=\"\">建模</span></strong><span leaf=\"\"> \n     <br> \n    </span><span leaf=\"\">从零建三张表，或者往现有模板填数据</span></p>\n   <p style=\"margin:24px 8px 8px;letter-spacing:0.1em;font-size:16px;border-color:rgb(229, 229, 229);line-height:2;box-sizing:border-box;word-break:break-all;border-width:0px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;border-style:solid;opacity:0.9;text-align:justify;\"><span leaf=\"\">支持 .xlsx 和 .xlsm。这次更新加了多文件拖拽、避免覆盖现有单元格、长会话自动压缩</span></p>\n   <h2 style=\"box-sizing: border-box;border-width: 0px;border-style: solid;border-color: rgb(229, 229, 229);font-size: 19.5px;font-weight: bold;margin: 4em auto 2em;text-align: center;line-height: 1.75;font-family: -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;display: table;padding: 0.3em 1em;background: rgb(198, 110, 73);border-radius: 8px;box-shadow: rgba(0, 0, 0, 0.1) 0px 4px 6px;color: white !important;\"><span leaf=\"\">几个限制</span></h2>\n   <p style=\"margin:24px 8px 8px;letter-spacing:0.1em;font-size:16px;border-color:rgb(229, 229, 229);line-height:2;box-sizing:border-box;word-break:break-all;border-width:0px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;border-style:solid;opacity:0.9;text-align:justify;\"><span leaf=\"\">当前不支持：条件格式、数据验证、宏、VBA</span></p>\n   <p style=\"margin:24px 8px 8px;letter-spacing:0.1em;font-size:16px;border-color:rgb(229, 229, 229);line-height:2;box-sizing:border-box;word-break:break-all;border-width:0px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;border-style:solid;opacity:0.9;text-align:justify;\"><span leaf=\"\">聊天记录不保存，每次打开是新会话</span></p>\n   <p style=\"margin:24px 8px 8px;letter-spacing:0.1em;font-size:16px;border-color:rgb(229, 229, 229);line-height:2;box-sizing:border-box;word-break:break-all;border-width:0px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;border-style:solid;opacity:0.9;text-align:justify;\"><span leaf=\"\">Beta 阶段官方不建议用于没人工审核的客户交付物、需要审计的关键计算</span></p>\n   <h2 style=\"box-sizing: border-box;border-width: 0px;border-style: solid;border-color: rgb(229, 229, 229);font-size: 19.5px;font-weight: bold;margin: 4em auto 2em;text-align: center;line-height: 1.75;font-family: -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;display: table;padding: 0.3em 1em;background: rgb(198, 110, 73);border-radius: 8px;box-shadow: rgba(0, 0, 0, 0.1) 0px 4px 6px;color: white !important;\"><span leaf=\"\">一个风险提醒</span></h2>\n   <p style=\"margin:24px 8px 8px;letter-spacing:0.1em;font-size:16px;border-color:rgb(229, 229, 229);line-height:2;box-sizing:border-box;word-break:break-all;border-width:0px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;border-style:solid;opacity:0.9;text-align:justify;\"><span leaf=\"\">Anthropic 有一份说明文档，专门写了 prompt injection 风险</span></p>\n   <figure style=\"margin:1.5em 8px;font-size:15px;border-width:0px;border-color:rgb(229, 229, 229);line-height:1.75;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;box-sizing:border-box;border-style:solid;text-align:left;\">\n    <span leaf=\"\"><img class=\"rich_pages wxw-img\" data-aistatus=\"1\" data-backh=\"368\" data-backw=\"546\" data-croporisrc=\"https://mmbiz.qpic.cn/mmbiz_png/2icSMc1VBIYqeZudY6IXgccJx5BtQCvNU4boQ5Xl27no1NpumwXLicDtctjxWsmFyE6OthwrB0UkJk0rc8B0MwQw/0?wx_fmt=png&amp;from=appmsg\" data-cropselx2=\"546\" data-cropsely2=\"269\" data-imgfileid=\"100028008\" data-ratio=\"0.6739345887016849\" data-s=\"300,640\" style=\"box-sizing:border-box;border-width:0px;border-style:solid;border-color:rgb(229, 229, 229);display:block;vertical-align:middle;max-width:100%;text-align:left;line-height:1.75;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-size:15px;margin:0.1em auto 0.5em;border-radius:8px;box-shadow:rgba(0, 0, 0, 0.1) 0px 4px 8px;width:100%;\" data-type=\"png\" data-w=\"2018\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=3cb616cc&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fmmbiz_png%2F2icSMc1VBIYqeZudY6IXgccJx5BtQCvNU4boQ5Xl27no1NpumwXLicDtctjxWsmFyE6OthwrB0UkJk0rc8B0MwQw%2F640%3Fwx_fmt%3Dpng%26from%3Dappmsg\"></span>\n    <figcaption style=\"box-sizing: border-box;border-width: 0px;border-style: solid;border-color: rgb(229, 229, 229);text-align: center;line-height: 1.75;font-family: -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-size: 0.8em;color: rgb(136, 136, 136);\">\n     <span leaf=\"\"><a href=\"https://support.claude.com/en/articles/12650343-claude-in-excel\" target=\"_blank\">https://support.claude.com/en/articles/12650343-claude-in-excel</a></span>\n    </figcaption>\n   </figure>\n   <p style=\"margin:24px 8px 8px;letter-spacing:0.1em;font-size:16px;border-color:rgb(229, 229, 229);line-height:2;box-sizing:border-box;word-break:break-all;border-width:0px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;border-style:solid;opacity:0.9;text-align:justify;\"><span leaf=\"\">攻击方式是在 Excel 文件里藏恶意指令。看起来正常的模板，可能包含\"把数据导出到某个 URL\"这种隐藏内容</span></p>\n   <p style=\"margin:24px 8px 8px;letter-spacing:0.1em;font-size:16px;border-color:rgb(229, 229, 229);line-height:2;box-sizing:border-box;word-break:break-all;border-width:0px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;border-style:solid;opacity:0.9;text-align:justify;\"><span leaf=\"\">官方建议：</span><strong style=\"box-sizing: border-box;border-width: 0px;border-style: solid;border-color: rgb(229, 229, 229);font-weight: bold;text-align: left;line-height: 1.75;font-family: -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;font-size: inherit;color: rgb(198, 110, 73);margin: 24px 0px 8px;\"><span leaf=\"\">只用可信来源的 Excel 文件</span></strong><span leaf=\"\">。下载的模板、供应商发的文件、外部数据导入，都要小心</span></p>\n   <p style=\"margin:24px 8px 8px;letter-spacing:0.1em;font-size:16px;border-color:rgb(229, 229, 229);line-height:2;box-sizing:border-box;word-break:break-all;border-width:0px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;border-style:solid;opacity:0.9;text-align:justify;\"><span leaf=\"\">触发高危函数（</span><code style=\"padding:3px 5px;color:rgb(17, 114, 221);font-size:14.4px;border-color:rgb(229, 229, 229);line-height:1.75;box-sizing:border-box;font-variation-settings:normal;border-radius:4px;font-feature-settings:normal;border-width:0px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;border-style:solid;opacity:0.9;text-align:left;\"><span leaf=\"\">WEBSERVICE</span></code><span leaf=\"\">、</span><code style=\"padding:3px 5px;color:rgb(17, 114, 221);font-size:14.4px;border-color:rgb(229, 229, 229);line-height:1.75;box-sizing:border-box;font-variation-settings:normal;border-radius:4px;font-feature-settings:normal;border-width:0px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;border-style:solid;opacity:0.9;text-align:left;\"><span leaf=\"\">INDIRECT</span></code><span leaf=\"\">、</span><code style=\"padding:3px 5px;color:rgb(17, 114, 221);font-size:14.4px;border-color:rgb(229, 229, 229);line-height:1.75;box-sizing:border-box;font-variation-settings:normal;border-radius:4px;font-feature-settings:normal;border-width:0px;font-family:-apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;border-style:solid;opacity:0.9;text-align:left;\"><span leaf=\"\">FOPEN</span></code><span leaf=\"\">&nbsp;这些）会弹确认框，记得看一眼再点</span></p>\n  </div>\n </body>\n</html>",
  "aiSummary": "本文实测了 Claude 官方推出的 Excel 插件，展示了其联网搜索、自动建表、公式调试及数据建模等办公自动化能力，并提醒了潜在的安全风险。",
  "oneSentenceSummary": "本文实测了 Claude 官方推出的 Excel 插件，展示了其联网搜索、自动建表、公式调试及数据建模等办公自动化能力，并提醒了潜在的安全风险。",
  "summary": "文章详细介绍了 Anthropic 官方推出的 Claude in Excel 插件的功能与实操体验。该插件支持 Pro、Team 等订阅用户，集成了 Claude 3.5/4.5 等模型能力。实测显示，用户只需输入自然语言指令，Claude 即可完成联网信息收集、数据清洗并自动填充至 Excel 表格，甚至能生成透视表。此外，插件在理解单元格逻辑、追踪公式错误（如 #REF!）、执行假设分析以及跨表建模方面表现出色。文章最后也指出了该工具目前的局限性，如不支持宏和 VBA，并特别强调了针对 Excel 模板中可能存在的提示词注入（Prompt Injection）风险，建议用户仅处理可信来源的文件。",
