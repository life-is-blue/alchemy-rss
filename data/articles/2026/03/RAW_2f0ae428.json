  "id": "RAW_2f0ae428",
  "title": "一周 1300 多个 PR，揭秘 Stripe 内部 AI 工程最佳实践",
  "url": "https://mp.weixin.qq.com/s?__biz=Mzg3NDc2MjQxMg==&mid=2247494116&idx=1&sn=1a3927f31d3cac416fcd74acdfb2e6fc",
