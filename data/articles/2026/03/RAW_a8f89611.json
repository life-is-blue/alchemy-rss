F7gdhICh6mN4fuAH3sUPb9cr8FReCMgKzMcU9cCVMjXzydbXTQFAkXCkiaoNkic2Q/0?wx_fmt=png&amp;from=appmsg\" data-cropselx2=\"578\" data-cropsely2=\"39\" data-imgfileid=\"101296330\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=a727f33a&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fmmbiz_png%2FQicyPhNHD5vYs92nHCpdbueQF7gdhICh6mN4fuAH3sUPb9cr8FReCMgKzMcU9cCVMjXzydbXTQFAkXCkiaoNkic2Q%2F640%3Fwx_fmt%3Dpng%26from%3Dappmsg\"></span></p>\n  <p class=\"mp_profile_iframe_wrp\" style=\"margin-bottom: 24px;\" nodeleaf=\"\"><mp-common-profile class=\"js_uneditable custom_select_card mp_profile_iframe\" data-pluginname=\"mpprofile\" data-nickname=\"36氪汽车\" data-alias=\"EV36kr\" data-from=\"0\" data-headimg=\"http://mmbiz.qpic.cn/sz_mmbiz_png/MKAWBa6icicPW2icCicf1nkCBVGrVP96ESQ4e8ev2vXV7GfjSGibXTorKOr4amoKydAYQibGKUaGofIb31JN8KwlGSiaQ/0?wx_fmt=png\" data-signature=\"看懂汽车产业新百年。36氪旗下智能电动车产业报道公号。\" data-id=\"Mzg3Nzg1MDk2MA==\" data-is_biz_ban=\"0\" data-service_type=\"1\" data-verify_status=\"2\"></mp-common-profile></p>\n  <p style=\"margin-bottom: 8px;letter-spacing: 0.578px;text-align: center;\"><span leaf=\"\"><img data-aistatus=\"1\" class=\"rich_pages wxw-img js_insertlocalimg\" data-ratio=\"0.4166666666666667\" data-s=\"300,640\" data-type=\"gif\" data-w=\"1080\" style=\"height: 241px;width: 578px;\" data-cropselx1=\"0\" data-cropselx2=\"578\" data-cropsely1=\"0\" data-cropsely2=\"241\" data-imgfileid=\"101307435\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=87b607f5&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fmmbiz_gif%2FQicyPhNHD5vagBvpJSWBnNYW2D0LereibpbkBWeO9ZkPaT3HA1GmlmABENQmcfuVicLhA8MJnBVLEPpRmwlY5n0HA%2F640%3Fwx_fmt%3Dgif%26from%3Dappmsg\"></span></p>\n  <p style=\"margin-bottom: 8px;letter-spacing: 0.578px;text-align: center;\"><span leaf=\"\"><img data-aistatus=\"1\" class=\"rich_pages wxw-img\" data-ratio=\"0.2828507795100223\" data-type=\"gif\" data-w=\"898\" style=\"height: 163px;width: 578px;\" data-cropselx1=\"0\" data-cropselx2=\"578\" data-cropsely1=\"0\" data-cropsely2=\"163\" data-imgfileid=\"101307434\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=cedb1d4d&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fmmbiz_gif%2FQicyPhNHD5vagBvpJSWBnNYW2D0Lereibph6S4cD1udwTvHO1f1TGc38MPePRKKvibuBqd6BCmY7buGgDxiaoUxgWA%2F640%3Fwx_fmt%3Dgif%26from%3Dappmsg\"></span></p>\n  <p style=\"margin-bottom: 0px;letter-spacing: 0.578px;text-align: center;\"><span leaf=\"\"><img data-aistatus=\"1\" class=\"rich_pages wxw-img\" data-ratio=\"0.14444444444444443\" data-s=\"300,640\" data-type=\"png\" data-w=\"1080\" style=\"height: 84px;width: 578px;\" data-cropselx1=\"0\" data-cropselx2=\"578\" data-cropsely1=\"0\" data-cropsely2=\"81\" data-imgfileid=\"101307433\" src=\"https://wechat2rss.bestblogs.dev/img-proxy/?k=419a6fb5&amp;u=https%3A%2F%2Fmmbiz.qpic.cn%2Fmmbiz_png%2FQicyPhNHD5vagBvpJSWBnNYW2D0LereibpVtBKUEjKhlcnTamERSCcPu00rbtswUB7cpAibmAe1GzGWa8vDh5zvRw%2F640%3Fwx_fmt%3Dpng%26from%3Dappmsg\"></span></p>\n  <p style=\"display: none;\"><mp-style-type data-value=\"10000\"></mp-style-type></p>\n  <p><a href=\"https://wechat2rss.bestblogs.dev/link-proxy/?k=61378751&amp;r=1&amp;u=https%3A%2F%2Fmp.weixin.qq.com%2Fs%3F__biz%3DMzI2NDk5NzA0Mw%3D%3D%26mid%3D2248882428%26idx%3D2%26sn%3D828a063a5d1911e008189e30b271076f\">跳转微信打开</a></p>\n </body>\n</html>",
  "aiSummary": "蔚来将芯片业务拆分为“神玑科技”并与爱芯元智成立合资公司，通过技术外供和联合研发模式，旨在实现研发成本分摊与商业变现，同时填补国产高阶辅助驾驶芯片的市场空白。",
  "oneSentenceSummary": "蔚来将芯片业务拆分为“神玑科技”并与爱芯元智成立合资公司，通过技术外供和联合研发模式，旨在实现研发成本分摊与商业变现，同时填补国产高阶辅助驾驶芯片的市场空白。",
  "summary": "本文深度解析了蔚来汽车芯片业务的战略调整。在面临巨大财务压力背景下，蔚来将芯片业务独立为“神玑科技”，并与爱芯元智、豪威集成电路成立合资公司“重庆创元智航”。这种合作模式突破了传统的 IP 授权或直接采购，采用了联合研发与流片的复杂模式。文章指出，此举不仅能为蔚来带来数亿元的技术授权费，还能通过爱芯元智的成熟渠道触达零跑、吉利等车企，实现研发投入的有效分摊。同时，文章分析了国产大算力芯片在当前汽车市场中的替代机遇与挑战，探讨了蔚来在追求商业回报与保持全栈自研技术优势之间的平衡难题。",
