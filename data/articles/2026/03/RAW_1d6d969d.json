splay: inline-block;line-height: 0;box-sizing: border-box;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\"><img data-aistatus=\"1\" class=\"rich_pages wxw-img\" data-ratio=\"0.5625\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1280\" style=\"vertical-align: middle;max-width: 100%;width: 100%;box-sizing: border-box;\" data-croporisrc=\"https://mmbiz.qpic.cn/mmbiz_jpg/UqLjwjsK1PeUlSzxiaMurQT47dMMbbXDba7CZqn3bO17td3Ovd97lXV5aId56ibZsXYaHQs8vcNEfqsRc5mYQnWMtsGsUVZSGiaFFjaJwvPicrA/0?wx_fmt=jpeg&amp;from=appmsg\" data-cropselx2=\"578\" data-cropsely2=\"414\" data-imgfileid=\"100004466\" src=\"https://image.jido.dev/20260318225159_255ffd5.jpeg\"></p>\n      </div>\n      <div style=\"margin: 0px 0%;line-height: 0;box-sizing: border-box;\">\n       <p style=\"max-width: 100%;vertical-align: middle;display: inline-block;line-height: 0;box-sizing: border-box;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\"><img data-aistatus=\"1\" class=\"rich_pages wxw-img\" data-ratio=\"0.5625\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1280\" style=\"vertical-align: middle;max-width: 100%;width: 100%;box-sizing: border-box;\" data-croporisrc=\"https://mmbiz.qpic.cn/mmbiz_jpg/UqLjwjsK1PdvWiaeicb0ic0biaqQJvLFibS0WNLibT2zAvABgULnw8R7oxESbyz9m89ObBO4PAMJBRicdD0rRkhgf9VNXAFetdkGicuvyibOtFibpia1WQ/0?wx_fmt=jpeg&amp;from=appmsg\" data-cropselx2=\"578\" data-cropsely2=\"414\" data-imgfileid=\"100004464\" src=\"https://image.jido.dev/20260318225159_2e9be1b.jpeg\"></p>\n      </div>\n      <div style=\"margin: 0px 0%;line-height: 0;box-sizing: border-box;\">\n       <p style=\"max-width: 100%;vertical-align: middle;display: inline-block;line-height: 0;box-sizing: border-box;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\"><img data-aistatus=\"1\" class=\"rich_pages wxw-img\" data-ratio=\"0.5625\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1280\" style=\"vertical-align: middle;max-width: 100%;width: 100%;box-sizing: border-box;\" data-croporisrc=\"https://mmbiz.qpic.cn/sz_mmbiz_jpg/UqLjwjsK1PcywtibVFM6HkKuvbYmJaEFxeZT0heJbHlztcz91E0sljdQx3zeR21zFCMFAhYCiagbP3GKM7gCRZVWed57HvZiaAcn6ibicV8RWyUA/0?wx_fmt=jpeg&amp;from=appmsg\" data-cropselx2=\"578\" data-cropsely2=\"414\" data-imgfileid=\"100004465\" src=\"https://image.jido.dev/20260318225159_2464eaf.jpeg\"></p>\n      </div>\n      <div style=\"margin: 0px 0%;line-height: 0;box-sizing: border-box;\">\n       <p style=\"max-width: 100%;vertical-align: middle;display: inline-block;line-height: 0;box-sizing: border-box;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\"><img data-aistatus=\"1\" class=\"rich_pages wxw-img\" data-ratio=\"0.5599603567888999\" data-s=\"300,640\" data-type=\"png\" data-w=\"2018\" style=\"vertical-align: middle;max-width: 100%;width: 100%;box-sizing: border-box;\" data-croporisrc=\"https://mmbiz.qpic.cn/sz_mmbiz_png/UqLjwjsK1Pc3CjCTpAwccwBet441DeruqltwYTOKIVy2WiblR9aYmxmh2ArqlqR5jnOk1Z7ZAVhYd9w1xWHMMe4vZXppsGDoNB5hPVC4lYFA/0?wx_fmt=png&amp;from=appmsg\" data-cropselx2=\"578\" data-cropsely2=\"414\" data-imgfileid=\"100004470\" src=\"https://image.jido.dev/20260318225159_9820600.png\"></p>\n      </div>\n     </div>\n    </div>\n   </div>\n   <div style=\"display: flex;flex-flow: row;isolation: isolate;margin: 0px 0% 10px;text-align: left;justify-content: flex-start;box-sizing: border-box;\">\n    <div style=\"display: inline-block;vertical-align: middle;width: auto;flex: 100 100 0%;align-self: center;height: auto;box-sizing: border-box;\">\n     <div style=\"color: rgb(231, 35, 18);padding: 0px 11px;box-sizing: border-box;\">\n      <p style=\"margin: 0px 8px 8px;padding: 0px;box-sizing: border-box;text-align: center;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 14px;color: rgb(136, 136, 136);font-weight: bold;\">① PPT 报告演示（可上下滑动）</span></span></p>\n      <div style=\"font-weight:400;font-size:16px;font-style:normal;box-sizing:border-box;text-align:justify;\" data-pm-slice=\"0 0 []\">\n       <div style=\"text-align: center;margin: 10px 0% 0px;box-sizing: border-box;\">\n        <div style=\"display: inline-block;width: 100%;height: 240px;vertical-align: top;overflow-y: auto;box-sizing: border-box;\">\n         <div style=\"overflow: hidden;box-sizing: border-box;\">\n          <div style=\"margin: 0px 0%;line-height: 0;box-sizing: border-box;\">\n           <p style=\"max-width: 100%;vertical-align: middle;display: inline-block;line-height: 0;box-sizing: border-box;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\"><img data-aistatus=\"1\" class=\"rich_pages wxw-img\" data-ratio=\"1.4140625\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1280\" style=\"vertical-align: middle;max-width: 100%;width: 100%;box-sizing: border-box;\" data-croporisrc=\"https://mmbiz.qpic.cn/mmbiz_jpg/UqLjwjsK1PcXtDliaZvsf2IJtdMiaWdzmJLialt7oxrWScYzWLIxw3NVu6jfiaJbUa0QNqjg642Iwn9fPGvWGb7w6dDOS7BWCEz9lb8jOKKfGD4/0?wx_fmt=jpeg&amp;from=appmsg\" data-cropselx2=\"556\" data-cropsely2=\"398\" data-imgfileid=\"100004480\" src=\"https://image.jido.dev/20260318225159_c8d75ea.jpeg\"></p>\n          </div>\n          <div style=\"margin: 0px 0%;line-height: 0;box-sizing: border-box;\">\n           <p style=\"max-width: 100%;vertical-align: middle;display: inline-block;line-height: 0;box-sizing: border-box;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\"><img data-aistatus=\"1\" class=\"rich_pages wxw-img\" data-ratio=\"1.4140625\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1280\" style=\"vertical-align: middle;max-width: 100%;width: 100%;box-sizing: border-box;\" data-croporisrc=\"https://mmbiz.qpic.cn/mmbiz_jpg/UqLjwjsK1Pd3dNvtzvl5Md85hSmMvEIK5eW1U3TaNJtsYibHRV1vvavfUXFZvSSSIvoPwliaJ71j8vdFTvwibGlGooV6cJianOxB8xN8FBwH7xE/0?wx_fmt=jpeg&amp;from=appmsg\" data-cropselx2=\"556\" data-cropsely2=\"398\" data-imgfileid=\"100004481\" src=\"https://image.jido.dev/20260318225200_97670fe.jpeg\"></p>\n          </div>\n          <div style=\"margin: 0px 0%;line-height: 0;box-sizing: border-box;\">\n           <p style=\"max-width: 100%;vertical-align: middle;display: inline-block;line-height: 0;box-sizing: border-box;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\"><img data-aistatus=\"1\" class=\"rich_pages wxw-img\" data-ratio=\"1.4140625\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1280\" style=\"vertical-align: middle;max-width: 100%;width: 100%;box-sizing: border-box;\" data-croporisrc=\"https://mmbiz.qpic.cn/mmbiz_jpg/UqLjwjsK1Pf0IKBzaXeenXmhoS3aicJXzLOsNMbLNgicbExFhtI8dcmA3rh2YxSvhLib564Uicc1VcrEgzx6OoEDe5NjyOlgSjgAJUkrWzzr8cU/0?wx_fmt=jpeg&amp;from=appmsg\" data-cropselx2=\"556\" data-cropsely2=\"398\" data-imgfileid=\"100004482\" src=\"https://image.jido.dev/20260318225159_b523246.jpeg\"></p>\n          </div>\n          <div style=\"margin: 0px 0%;line-height: 0;box-sizing: border-box;\">\n           <p style=\"max-width: 100%;vertical-align: middle;display: inline-block;line-height: 0;box-sizing: border-box;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\"><img data-aistatus=\"1\" class=\"rich_pages wxw-img\" data-ratio=\"1.4140625\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1280\" style=\"vertical-align: middle;max-width: 100%;width: 100%;box-sizing: border-box;\" data-croporisrc=\"https://mmbiz.qpic.cn/sz_mmbiz_jpg/UqLjwjsK1PfhGDibUegU9l6VTDm2O2vayNAmbf1rn2Mmj5x5HcGsCPHS228pCQKpongScHAkWS7xKfHWjdBsCx9A6qhfuc6gotFheSbSibxy8/0?wx_fmt=jpeg&amp;from=appmsg\" data-cropselx2=\"556\" data-cropsely2=\"398\" data-imgfileid=\"100004483\" src=\"https://image.jido.dev/20260318225159_45ff3ed.jpeg\"></p>\n          </div>\n          <div style=\"margin: 0px 0%;line-height: 0;box-sizing: border-box;\">\n           <p style=\"max-width: 100%;vertical-align: middle;display: inline-block;line-height: 0;box-sizing: border-box;margin-left: 8px;margin-right: 8px;\" nodeleaf=\"\"><img data-aistatus=\"1\" class=\"rich_pages wxw-img\" data-ratio=\"1.4140625\" data-s=\"300,640\" data-type=\"jpeg\" data-w=\"1280\" style=\"vertical-align: middle;max-width: 100%;width: 100%;box-sizing: border-box;\" data-cropori