  "id": "RAW_f7697e4f",
  "title": "第一个同时为人类和 Agent 设计的 AI 视频产品，它叫，LibTV。",
  "url": "https://mp.weixin.qq.com/s?__biz=MzIyMzA5NjEyMA==&mid=2647680707&idx=1&sn=75cc952e1e4827cfe0a1e2a1ca8269ed",
  "date": "2026-03-18 03:00:00",
