 100%;box-sizing: border-box;margin-bottom: 0px;overflow-wrap: break-word !important;\">\n      <p style=\"max-width: 100%;box-sizing: border-box;display: inline-block;overflow-wrap: break-word !important;\"><span style=\"padding: 0.3em 0.5em;max-width: 100%;box-sizing: border-box;display: block;border-radius: 0.8em 0.8em 0px 0px;color: rgb(255, 255, 255);background-color: rgb(95, 156, 239);font-size: 16px;overflow-wrap: break-word !important;\"></span></p>\n      <p style=\"max-width: 100%;box-sizing: border-box;overflow-wrap: break-word !important;\"><span style=\"max-width: 100%;font-size: 15px;box-sizing: border-box !important;overflow-wrap: break-word !important;\"><span leaf=\"\">推荐阅读</span></span></p>\n      <p></p>\n     </div>\n     <div style=\"padding: 10px;max-width: 100%;box-sizing: border-box;border-width: 1px;border-style: solid;border-color: rgb(95, 156, 239);border-radius: 0px 0px 0.8em 0.8em;overflow-wrap: break-word !important;\">\n      <div powered-by=\"xiumi.us\" style=\"max-width: 100%;box-sizing: border-box;overflow-wrap: break-word !important;\">\n       <p style=\"max-width: 100%;box-sizing: border-box;overflow-wrap: break-word !important;\"></p>\n       <h2 style=\"margin-bottom: 14px;padding-bottom: 10px;font-size: 24px;font-family: -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;letter-spacing: 0.544px;outline: 0px;background-color: rgb(255, 255, 255);color: rgb(34, 34, 34);caret-color: rgba(0, 0, 0, 0);line-height: 1.4;border-bottom: 1px solid rgb(231, 231, 235);\"><span leaf=\"\"><a class=\"normal_text_link\" target=\"_blank\" style=\"color: rgb(0, 122, 170);\" href=\"https://mp.weixin.qq.com/s?__biz=MzA3NTQ4NjczNw==&amp;mid=2650678248&amp;idx=1&amp;sn=b713f18f2d6e850cabf69033432d62bd&amp;scene=21#wechat_redirect\" textvalue=\"这些国家，有自己的「ChatGPT」\" data-itemshowtype=\"0\" linktype=\"text\" data-linktype=\"2\"><span textstyle=\"\" style=\"font-size: 12px;color: rgb(0, 122, 170);text-decoration: underline;\">这些国家，有自己的「ChatGPT」</span></a></span></h2>\n       <p></p>\n       <p style=\"max-width: 100%;box-sizing: border-box;overflow-wrap: break-word !important;\"></p>\n       <h2 style=\"margin-bottom: 14px;padding-bottom: 10px;font-size: 24px;font-family: -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;letter-spacing: 0.544px;outline: 0px;background-color: rgb(255, 255, 255);color: rgb(34, 34, 34);caret-color: rgba(0, 0, 0, 0);line-height: 1.4;border-bottom: 1px solid rgb(231, 231, 235);\"><span leaf=\"\"><a class=\"normal_text_link\" target=\"_blank\" style=\"color: rgb(0, 122, 170);\" href=\"https://mp.weixin.qq.com/s?__biz=MzA3NTQ4NjczNw==&amp;mid=2650678190&amp;idx=1&amp;sn=31c829727e1d5164002b933073d81805&amp;scene=21#wechat_redirect\" textvalue=\"把拆卡“打包”成App，冲上美国总榜\" data-itemshowtype=\"0\" linktype=\"text\" data-linktype=\"2\"><span textstyle=\"\" style=\"font-size: 12px;color: rgb(0, 122, 170);text-decoration: underline;\">把拆卡“打包”成App，冲上美国总榜</span></a></span></h2>\n       <p></p>\n       <p style=\"max-width: 100%;box-sizing: border-box;overflow-wrap: break-word !important;\"></p>\n       <h2 style=\"margin-bottom: 14px;padding-bottom: 10px;font-size: 24px;font-family: -apple-system-font, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif;letter-spacing: 0.544px;outline: 0px;background-color: rgb(255, 255, 255);color: rgb(34, 34, 34);caret-color: rgba(0, 0, 0, 0);line-height: 1.4;border-bottom: 1px solid rgb(231, 231, 235);\"><span leaf=\"\"><a class=\"normal_text_link\" target=\"_blank\" style=\"color: rgb(0, 122, 170);\" href=\"https://mp.weixin.qq.com/s?__biz