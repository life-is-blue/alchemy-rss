  "content": "<html>\n <head></head>\n <body>\n  <div class=\"page-lead-media\">\n   <figure class=\"figure m-0\">\n    <picture> <source type=\"image/webp\" srcset=\"https://ca-times.brightspotcdn.com/dims4/default/f4c7873/2147483647/strip/true/crop/2000x1333+0+0/resize/320x213!/format/webp/quality/75/?url=https%3A%2F%2Fcalifornia-times-brightspot.s3.amazonaws.com%2F11%2F09%2F4b4c1577705669093972a66782bb%2F1x-1.jpg 320w, https://ca-times.brightspotcdn.com/dims4/default/bf53de0/2147483647/strip/true/crop/2000x1333+0+0/resize/568x379!/format/webp/quality/75/?url=https%3A%2F%2Fcalifornia-times-brightspot.s3.amazonaws.com%2F11%2F09%2F4b4c1577705669093972a66782bb%2F1x-1.jpg 568w, https://ca-times.brightspotcdn.com/dims4/default/5742c2e/2147483647/strip/true/crop/2000x1333+0+0/resize/768x512!/format/webp/quality/75/?url=https%3A%2F%2Fcalifornia-times-brightspot.s3.amazonaws.com%2F11%2F09%2F4b4c1577705669093972a66782bb%2F1x-1.jpg 768w, https://ca-times.brightspotcdn.com/dims4/default/642a988/2147483647/strip/true/crop/2000x1333+0+0/resize/1024x683!/format/webp/quality/75/?url=https%3A%2F%2Fcalifornia-times-brightspot.s3.amazonaws.com%2F11%2F09%2F4b4c1577705669093972a66782bb%2F1x-1.jpg 1024w, https://ca-times.brightspotcdn.com/dims4/default/623cc55/2147483647/strip/true/crop/2000x1333+0+0/resize/1200x800!/format/webp/quality/75/?url=https%3A%2F%2Fcalifornia-times-brightspot.s3.amazonaws.com%2F11%2F09%2F4b4c1577705669093972a66782bb%2F1x-1.jpg 1200w\" sizes=\"100vw\"> <img class=\"image\" alt=\"Mike Nusinkis and Jack Nekhala at the Bed Scrunchie offices in Staten Island.\" srcset=\"https://ca-times.brightspotcdn.com/dims4/default/f2030ff/2147483647/strip/true/crop/2000x1333+0+0/resize/320x213!/quality/75/?url=https%3A%2F%2Fcalifornia-times-brightspot.s3.amazonaws.com%2F11%2F09%2F4b4c1577705669093972a66782bb%2F1x-1.jpg 320w, https://ca-times.brightspotcdn.com/dims4/default/81f203f/2147483647/strip/true/crop/2000x1333+0+0/resize/568x379!/quality/75/?url=https%3A%2F%2Fcalifornia-times-brightspot.s3.amazonaws.com%2F11%2F09%2F4b4c1577705669093972a66782bb%2F1x-1.jpg 568w, https://ca-times.brightspotcdn.com/dims4/default/48dfc43/2147483647/strip/true/crop/2000x1333+0+0/resize/768x512!/quality/75/?url=https%3A%2F%2Fcalifornia-times-brightspot.s3.amazonaws.com%2F11%2F09%2F4b4c1577705669093972a66782bb%2F1x-1.jpg 768w, https://ca-times.brightspotcdn.com/dims4/default/4015a1e/2147483647/strip/true/crop/2000x1333+0+0/resize/1024x683!/quality/75/?url=https%3A%2F%2Fcalifornia-times-brightspot.s3.amazonaws.com%2F11%2F09%2F4b4c1577705669093972a66782bb%2F1x-1.jpg 1024w, https://ca-times.brightspotcdn.com/dims4/default/1cef7ae/2147483647/strip/true/crop/2000x1333+0+0/resize/1200x800!/quality/75/?url=https%3A%2F%2Fcalifornia-times-brightspot.s3.amazonaws.com%2F11%2F09%2F4b4c1577705669093972a66782bb%2F1x-1.jpg 1200w\" sizes=\"100vw\" src=\"https://ca-times.brightspotcdn.com/dims4/default/1cef7ae/2147483647/strip/true/crop/2000x1333+0+0/resize/1200x800!/quality/75/?url=https%3A%2F%2Fcalifornia-times-brightspot.s3.amazonaws.com%2F11%2F09%2F4b4c1577705669093972a66782bb%2F1x-1.jpg\" decoding=\"async\" fetchpriority=\"high\"> </picture>\n    <div class=\"figure-content\">\n     <div class=\"figure-credit\">(Emil T. Lippe/Bloomberg)</div>\n    </div>\n   </figure>\n  </div>\n  <div class=\"byline\">\n   <div class=\"authors\">\n    <div class=\"author-name\">\n     <span class=\"byline-prefix\">By</span> <span class=\"link\">Spencer Soper</span>\n    </div>\n   </div>\n   <time datetime=\"2026-06-30T15:29:06.924Z\" class=\"published-date\"><span class=\"published-date-day\">June 30, 2026 </span><span class=\"published-time\">8:29 AM PT </span></time>\n  </div>\n  <div class=\"page-actions\">\n   <ps-actionbar data-element=\"action-bar\" class=\"block font-cms-font-service-text \">\n    <ul data-element=\"action-bar-menu\" class=\"flex gap-2 list-none \">\n     <li>\n      <button data-element=\"action-link\" class=\"flex items-center h-7 px-1.25 font-cms-font-se