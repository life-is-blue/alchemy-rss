[{"id":"RAW_077cbcec","title":"OpenClaw + Claude Code 超强教程：一个人就能搭建完整的开发团队！","link":"https://mp.weixin.qq.com/s?__biz=MzIyNjM2MzQyNg==&mid=2247719868&idx=1&sn=c93e0542f8bebb653559315d02841b43","date":"2026-02-25 14:15:00","archive_path":"data/articles/2026/02/RAW_077cbcec.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Datawhale","resourceType":"ARTICLE","readTime":18,"score":92},{"id":"RAW_fa264a88","title":"从上下文到长期记忆：大模型记忆工程的架构设计与实践","link":"https://mp.weixin.qq.com/s?__biz=MjM5MDE0Mjc4MA==&mid=2651276307&idx=2&sn=bc69ed3bd600142d4e67f1a5df1103f4","date":"2026-02-25 07:46:00","archive_path":"data/articles/2026/02/RAW_fa264a88.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"InfoQ 中文","resourceType":"ARTICLE","readTime":38,"score":93},{"id":"RAW_e73edd69","title":"我们如何在一周内用 AI 重构 Next.js","link":"https://blog.cloudflare.com/vinext/","date":"2026-02-24 20:00:00","archive_path":"data/articles/2026/02/RAW_e73edd69.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"The Cloudflare Blog","resourceType":"ARTICLE","readTime":12,"score":92},{"id":"RAW_3879b2af","title":"1500 个 PR、0 人写代码：Codex 驱动的百万行级内部产品实践","link":"https://mp.weixin.qq.com/s?__biz=MjM5MDE0Mjc4MA==&mid=2651276192&idx=2&sn=3cbb6109e944e9fb09f0037d5b5b6172","date":"2026-02-24 10:09:00","archive_path":"data/articles/2026/02/RAW_3879b2af.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"InfoQ 中文","resourceType":"ARTICLE","readTime":26,"score":95},{"id":"RAW_3308e250","title":"智谱 GLM-5 技术全公开！完全适配华为等国产芯片，美国网友酸了","link":"https://www.qbitai.com/2026/02/381712.html","date":"2026-02-23 05:19:44","archive_path":"data/articles/2026/02/RAW_3308e250.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":21,"score":92},{"id":"RAW_a9e947c8","title":"终端大模型操作系统的架构、优化与展望","link":"https://mp.weixin.qq.com/s?__biz=MjM5MDE0Mjc4MA==&mid=2651276357&idx=2&sn=a74eb8bce0c3e2c2d571cd9af9748f79","date":"2026-02-26 05:48:00","archive_path":"data/articles/2026/02/RAW_a9e947c8.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"InfoQ 中文","resourceType":"ARTICLE","readTime":26,"score":92},{"id":"RAW_33b9213a","title":"如何从零开始实现一个 AI Agent 框架（理论+实践）","link":"https://mp.weixin.qq.com/s?__biz=MzI2NDU4OTExOQ==&mid=2247694641&idx=1&sn=dff67991264624bf2e7615bd637f4cf6","date":"2026-02-26 00:46:00","oneSentenceSummary":"本文系统性地梳理了 AI Agent 的核心理论演进，并提供了一个基于 DeepSeek 实现的 279 行极简 Agent 框架实战指南。","summary":"文章分为理论与实践两部分。理论篇回顾了从 ReAct 到 Plan-and-Execute 再到 Reflection 的模式演进，重点探讨了当前业内关于“文件系统作为上下文”及“CodeAct（代码即工具）”的共识，指出上下文工程（Context Engineering）是 Agent 智能的核心。实践篇则通过 Python 实现了一个完整的 Agent Loop，包含 LLM 调用、工具解析与执行（Shell/Python/文件读写）以及上下文管理，展示了如何构建一个具备自主任务解决能力的极简智能体原型。","archive_path":"data/articles/2026/02/RAW_33b9213a.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"腾讯云开发者","resourceType":"ARTICLE","readTime":42,"score":89},{"id":"RAW_d9a48080","title":"AI Agent 系列｜深入解析 Function Calling、MCP 和 Skills 的本质差异与最佳实践","link":"https://mp.weixin.qq.com/s?__biz=MzIzOTU0NTQ0MA==&mid=2247558457&idx=1&sn=088df2d9371481bb54961b09688c6796","date":"2026-02-26 00:31:00","oneSentenceSummary":"本文深入剖析了 AI Agent 的三大核心工具能力——Function Calling、MCP 与 Skills 的技术原理、演进逻辑及竞合关系，并提出了“一切皆函数”的工程实践思路。","summary":"文章从 AI Agent 工具调用的基本流程出发，指出 Function Calling 是实现非结构化需求向结构化指令转换的基础，是所有高级工具能力的底层支撑。针对工具集成成本高的问题，MCP（模型上下文协议）通过标准化协议实现了既有系统与 LLM 的快速接驳；而针对复杂任务流程定义难的问题，Skills 允许用户通过文字（而非代码）定义指令和资源，增强了 Agent 处理不确定性的能力。作者独到地分析了 MCP 与 Skills 之间的竞争关系，即“协议转换+代码逻辑”与“命令行调用+文字流程”的路径之争。最后，作者结合 Lynxe 框架实践，强调了 Agent 结构化输入输出及与复杂业务系统深度集成的必要性。","archive_path":"data/articles/2026/02/RAW_d9a48080.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"阿里云开发者","resourceType":"ARTICLE","readTime":30,"score":91},{"id":"RAW_c5c2092f","title":"开发者指南：构建生产级 AI 智能体","link":"https://cloud.google.com/blog/products/ai-machine-learning/a-devs-guide-to-production-ready-ai-agents/","date":"2026-02-26 00:00:00","oneSentenceSummary":"本指南提供了一个将 AI 智能体从原型转变为生产级系统的全面框架，重点关注架构、互操作协议、上下文工程以及基于轨迹的评估。","summary":"本文探讨了开发者社区从构建 AI 智能体原型向部署生产级系统的关键转变。文章认为，由于智能体能够自主推理和适应，它们需要从根本上背离确定性软件模式。作者概述了生命周期的五大支柱：核心架构（思考-行动-观察循环）、互操作性（利用 MCP 和 A2A 协议）、上下文工程（管理记忆和提示词）、严格评估（关注决策轨迹而非仅是最终输出）以及生产基础设施（会话管理和分阶段发布）。通过将 LLM 视为编排层内的认知引擎，开发者可以构建更可靠、更具扩展性的智能体工作流。","archive_path":"data/articles/2026/02/RAW_c5c2092f.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"Google Cloud Blog","resourceType":"ARTICLE","readTime":4,"score":90},{"id":"RAW_c16f8d46","title":"容器运行时迁移有大坑！Netflix 的 CPU 架构瓶颈排查与修复实践","link":"https://mp.weixin.qq.com/s?__biz=MzkzMjYzNjkzNw==&mid=2247634629&idx=1&sn=cca8c23b8cb9ef41ee85d53e4ca8bf66","date":"2026-02-24 23:16:00","archive_path":"data/articles/2026/02/RAW_c16f8d46.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"dbaplus社群","resourceType":"ARTICLE","readTime":20,"score":90},{"id":"RAW_97909516","title":"知识引导","link":"https://martinfowler.com/articles/reduce-friction-ai/knowledge-priming.html","date":"2026-02-24 14:40:00","archive_path":"data/articles/2026/02/RAW_97909516.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"Martin Fowler","resourceType":"ARTICLE","readTime":10,"score":90},{"id":"RAW_9fbeb19b","title":"2026-02-26 Hacker News Top Stories #","link":"https://supertechfans.com/cn/post/2026-02-26-HackerNews/","date":"2026-02-26 08:17:43","oneSentenceSummary":"本文汇总了 2026 年 2 月 26 日 Hacker News 的热门话题，涵盖了人犬 AI 协作开发、丹麦政府转向开源、Anthropic 放弃安全承诺以及 Cloudflare 用 AI 重构前端框架等前沿动态。","summary":"文章精选了 Hacker News 社区近期备受关注的十大热点话题。在人工智能领域，Anthropic 放弃了其标志性的“安全优先”训练承诺，转向更具竞争导向的应对性安全策略；Cloudflare 工程师展示了利用 AI 在一周内重构 Next.js 替代框架 vinext 的高效实践；同时，一篇深度调查揭露了 Persona 公司为 OpenAI 构建的身份监控系统。在政策与商业方面，丹麦政府推进数字独立计划，逐步以开源软件替代微软产品；加州总检察长对亚马逊发起价格操纵指控；苹果则宣布在休斯顿生产 Mac mini 以推进本土制造。此外，文章还探讨了冷门域名的安全误判风险、极简终端环境 Pi 以及通过排版细节识别社区机器人账号的有趣发现。","archive_path":"data/articles/2026/02/RAW_9fbeb1