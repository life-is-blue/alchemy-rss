link":"https://aws.amazon.com/blogs/machine-learning/reimagine-marketing-at-volkswagen-group-with-generative-ai/","date":"2026-03-30 07:24:17","archive_path":"data/articles/2026/03/RAW_a4eacc5c.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"AWS Machine Learning Blog","resourceType":"ARTICLE","readTime":12,"score":88},{"id":"RAW_1271024e","title":"上海 AI 实验室发布“AGI4S 珠穆朗玛计划”，构建中国科学智能创新中枢","link":"https://www.qbitai.com/2026/03/393344.html","date":"2026-03-30 07:24:15","archive_path":"data/articles/2026/03/RAW_1271024e.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":21,"score":84},{"id":"RAW_eb07bcf2","title":"Claude Code 创始人分享的 15 条最新使用技巧深度解析","link":"https://mp.weixin.qq.com/s?__biz=Mzg2OTA1OTAxNA==&mid=2247489187&idx=1&sn=26ef9393173fdd8f7bd756b541d3a541","date":"2026-03-30 04:44:00","archive_path":"data/articles/2026/03/RAW_eb07bcf2.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"花叔","resourceType":"ARTICLE","readTime":31,"score":89},{"id":"RAW_c30acfae","title":"Nature Index 特刊聚焦天立国际：系统呈现中国教育 AGI 实践探索","link":"https://www.qbitai.com/2026/03/393336.html","date":"2026-03-30 04:08:39","archive_path":"data/articles/2026/03/RAW_c30acfae.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":7,"score":87},{"id":"RAW_54cfc8d0","title":"极佳视界发布具身世界模型 GigaWorld-1：WorldArena 评测登顶全球第一","link":"https://www.qbitai.com/2026/03/393296.html","date":"2026-03-30 03:55:06","archive_path":"data/articles/2026/03/RAW_54cfc8d0.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":16,"score":88},{"id":"RAW_13890a03","title":"60%用户还在乱养虾！9 位大神亮招：OpenClaw AI Agent 实战指南","link":"https://www.qbitai.com/2026/03/393244.html","date":"2026-03-30 03:49:08","archive_path":"data/articles/2026/03/RAW_13890a03.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":19,"score":87},{"id":"RAW_64321a11","title":"DeepSeek 网页版大升级！随后宕机 11 小时崩上热搜，新模型真的来了","link":"https://www.qbitai.com/2026/03/393235.html","date":"2026-03-30 03:33:58","archive_path":"data/articles/2026/03/RAW_64321a11.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":3,"score":86},{"id":"RAW_788348f8","title":"龙虾安全被 3 层硬核架构焊死了！一份面向开发者的硬核生存指南","link":"https://www.qbitai.com/2026/03/393226.html","date":"2026-03-30 02:27:30","archive_path":"data/articles/2026/03/RAW_788348f8.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":23,"score":88},{"id":"RAW_c34d5202","title":"发布：llm-mrchatterbox 0.1","link":"https://simonwillison.net/2026/Mar/30/llm-mrchatterbox-2/#atom-everything","date":"2026-03-30 02:20:46","archive_path":"data/articles/2026/03/RAW_c34d5202.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Simon Willison's Weblog","resourceType":"ARTICLE","readTime":1,"score":82},{"id":"RAW_08a954fd","title":"Echo：预测智能的一小步，通往通用智能的一大步","link":"https://mp.weixin.qq.com/s?__biz=MzA3MzI4MjgzMw==&mid=2651024564&idx=1&sn=6fb075d1ca107111ac46eeb2215716fd","date":"2026-03-30 01:34:00","archive_path":"data/articles/2026/03/RAW_08a954fd.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"机器之心","resourceType":"ARTICLE","readTime":16,"score":86},{"id":"RAW_32ed6943","title":"ICLR 2026 | 让多模态模型学会主动说话：主动交互从训练到评估的完整方案","link":"https://mp.weixin.qq.com/s?__biz=MzA3MzI4MjgzMw==&mid=2651024564&idx=2&sn=35264986836dd290aa3618d110aaeb85","date":"2026-03-30 01:34:00","archive_path":"data/articles/2026/03/RAW_32ed6943.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"机器之心","resourceType":"ARTICLE","readTime":18,"score":89},{"id":"RAW_efc1c96f","title":"单张显卡跑出 15 倍推理速度，aiX-apply-4B 小模型加速企业 AI 研发落地","link":"https://www.qbitai.com/2026/03/392787.html","date":"2026-03-30 00:41:45","archive_path":"data/articles/2026/03/RAW_efc1c96f.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":8,"score":87},{"id":"RAW_2f0ae428","title":"一周 1300 多个 PR，揭秘 Stripe 内部 AI 工程最佳实践","link":"https://mp.weixin.qq.com/s?__biz=Mzg3NDc2MjQxMg==&mid=2247494116&idx=1&sn=1a3927f31d3cac416fcd74acdfb2e6fc","date":"2026-03-30 00:38:00","archive_path":"data/articles/2026/03/RAW_2f0ae428.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"深思圈","resourceType":"ARTICLE","readTime":29,"score":89},{"id":"RAW_4948fa66","title":"推出 Programmable Flow Protection：为 Magic Transit 客户提供自定义 DDoS 防御逻辑","link":"https://blog.cloudflare.com/programmable-flow-protection/","date":"2026-03-31 14:00:01","archive_path":"data/articles/2026/03/RAW_4948fa66.json","topicTag":"devops","category":"Programming_Technology","sourceName":"The Cloudflare Blog","resourceType":"ARTICLE","readTime":8,"score":89},{"id":"RAW_8f465cba","title":"你在不知不觉中做出的隐藏决策","link":"https://www.infoq.com/presentations/culture-systems-teams-careers/?utm_campaign=infoq_content&utm_source=infoq&utm_medium=feed&utm_term=global","date":"2026-03-31 13:58:00","oneSentenceSummary":"本次演讲探讨了那些隐藏的决策——即在平台构建、编码、CI/CD 和所有权方面无意中形成的默认选择，这些选择在潜移默化中塑造了工程文化和技术债务。","summary":"Dan Fike 和 Shawna Martell 讨论了“隐藏决策”这一概念，即那些在未被明确定义的情况下指导工程选择的潜意识原则。他们强调了这些默认选择显现的几个关键领域：当以用户数量衡量成功时，平台工具往往会变得过于复杂；“默认构建”的心态往往忽视了代码作为长期负债的本质；以及缓慢的 CI/CD 流水线如何无意中促使工程师提交庞大且高风险的合并请求（PR）。他们还强调，指标会固化这些行为，往往导致优化方向错误；并将这一视角应用于职业发展，指出“惯性”往往是一种取代了明确方向的隐藏策略。","archive_path":"data/articles/2026/03/RAW_8f465cba.json","topicTag":"other","category":"Programming_Technology","sourceName":"InfoQ","resourceType":"ARTICLE","readTime":32,"score":91},{"id":"RAW_f3dc6894","title":"Kubernetes 自动扩缩容要求超越厂商工具的全新可观测性关注点","link":"https://www.infoq.com/news/2026/03/kubernetes-observability/?utm_campaign=infoq_content&utm_source=infoq&utm_medium=feed&utm_term=global","date":"2026-03-31 12:00:00","oneSentenceSummary":"随着 Karpenter 等 Kubernetes 自动扩缩容工具成为主流，可观测性正从静态的基础设施健康状况转向动态的资源供给智能，重点关注调度延迟和成本效率。","summary":"本文探讨了现代“即时”自动扩缩容工具所带来的 Kubernetes 可观测性演变。CPU 利用率等传统指标正被对资源供给行为的更深入洞察所取代，例如调度队列深度和云 API 延迟。这种转变反映了行业向平台无关、具备成本意识的可观测性发展的更广泛趋势，即通过分析基础设施变更来提升效率和响应能力。通过关联控制平面和云 API 的事件，工程团队可以优化装箱（bin-packing）策略并减少过度配置，从而从被动监控转向主动的、智能驱动的基础设施管理。","archive_path":"data/articles/2026/03/RAW_f3dc6894.json","topicTag":"devops","category":"Programming_Technology","sourceName":"InfoQ","resourceType":"ARTICLE","readTime":3,"score":86},{"id":"RAW_5f58f4fe","title":"TanStack Start 引入导入保护功能，强制执行服务器与客户端边界","link":"https://www.infoq.com/news/2026/03/tanstack-import-protection/?utm_campaign=infoq_content&utm_source=infoq&utm_medium=feed&utm_term=global","date":"2026-03-31 11:52:00","oneSentenceSummary":"TanStack Start 引入了一项基于 Vite 的实验性导入保护功能，旨在自动防止服务端代码泄露，并强制执行全栈 React 应用中的环境边界。","summary":"TanStack Start 作为一个全栈 React 框架，推出了一项新的导入保护机制，以减轻因代码跨越服务器和客户端边界泄露而导致的安全风险和 Bug。该系统作为 Vite 插件运行，通过文件命名约定（例如 `*.server.*`、`*.client.*`）和显式标记（如 `server-only`）来监控导入。在开发过程中，违规行为会触发警告和递归代理，而在生产构建中，系统会严格终止构建并提供详细的诊断信息。此功能提供了与 Next.js 相当的安全保障，但针对 TanStack 的架构进行了定制，为开发者提供了针对敏感服务端逻辑或环境密钥意外暴露的自动化保护。","archive_path":"data/articles/2026/03/RAW_5f58f4fe.json","topicTag":"frontend-fullstack","category":"Programming_Technology","sourceName":"InfoQ","resourceType":"ARTICLE","readTime":3,"score":87},{"id":"RAW_8cd9172b","title":"将故障作为构建弹性软件系统的手段：与 Lorin Hochstein 的对话","link":"https://www.infoq.com/podcasts/failure-means-build-resilient-software-system/?utm_campaign=infoq_content&utm_source=infoq&utm_medium=feed&utm_term=global","date":"2026-03-31 09:00:00","archive_path":"data/articles/2026/03/RAW_8cd9172b.json","topicTag":"other","category":"Programming_Technology","sourceName":"InfoQ","resourceType":"ARTICLE","readTime":41,"score":91},{"id":"RAW_6b28a9c2","title":"云原生银行业的事件驱动模式：经验与教训","link":"https://www.infoq.com/articles/event-driven-banking-architecture/?utm_campaign=infoq_content&utm_source=infoq&utm_medium=feed&utm_term=global","date":"2026-03-31 09:00:00","archive_path":"data/articles/2026/03/RAW_6b28a9c2.json","topicTag":"other","category":"Programming_Technology","sourceName":"InfoQ","resourceType":"ARTICLE","readTime":11,"score":90},{"id":"RAW_099c4a53","title":"Cloudflare 在其边缘网络中增加主动式 API 漏洞扫描功能","link":"https://www.infoq.com/news/2026/03/cloudflare-api-vulnerability/?utm_campaign=infoq_content&utm_source=infoq&utm_medium=feed&utm_term=global","date":"2026-03-31 09:00:00","oneSentenceSummary":"Cloudflare 推出了基于 AI 的主动式 DAST 扫描器（公开测试版），通过分析 API 调用图并集成到 CI/CD 流水线中，专门针对 BOLA 漏洞。","summary":"Cloudflare 宣布其 Web 和 API 漏洞扫描器进入公开测试阶段，这是一款集成在 API Shield 平台中的动态应用安全测试（DAST）工具。首个版本专注于 OWASP API Top 10 中排名第一的威胁——失效的对象级授权（BOLA）。与检测格式错误请求的传统 WAF 不同，该扫描器通过将 API 视为相互关联的调用图，从而识别有效请求中的逻辑缺陷。它利用 Cloudflare Workers AI（特别是 gpt-oss-120b）来映射数据依赖关系并生成合成测试流量，使其适用于预生产环境。后端架构采用 Rust 构建，由 Temporal 进行编排，并使用 HashiCorp Vault 进行端到端凭据加密，以确保安全性。","archive_path":"data/articles/2026/03/RAW_099c4a53.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"InfoQ","resourceType":"ARTICLE","readTime":3,"score":87},{"id":"RAW_6b8bc41e","title":"QCon London 2026：将团队拓扑（Team Topologies）作为 AI 的“智能体基础设施”","link":"https://www.infoq.com/news/2026/03/ai-agency-team-topologies/?utm_campaign=infoq_content&utm_source=infoq&utm_medium=feed&utm_term=global","date":"2026-03-31 08:00:00","archive_path":"data/articles/2026/03/RAW_6b8bc41e.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"InfoQ","resourceType":"ARTICLE","readTime":3,"score":88},{"id":"RAW_60bfaf4c","title":"KubeVirt v1.8 为 Kubernetes 带来多虚拟机管理程序支持和机密计算","link":"https://www.infoq.com/news/2026/03/kubevirt-18-announcement/?utm_campaign=infoq_content&utm_source=infoq&utm_medium=feed&utm_term=global","date":"2026-03-31 07:00:00","oneSentenceSummary":"KubeVirt v1.8 引入了用于多后端支持的虚拟机管理程序抽象层（HAL）、用于机密计算的 Intel TDX，并显著提升了云原生虚拟化的扩展能力。","summary":"KubeVirt v1.8 与 Kubernetes v1.35 对齐，通过引入虚拟机管理程序抽象层（HAL）标志着一个重要的架构里程碑。这种解耦使得该项目能够在保持现有默认设置的同时，支持传统 KVM/QEMU 堆栈之外的虚拟机监视器。此版本通过用于机密计算的 Intel TDX 认证以及针对 AI 和 HPC 工作负载的 PCIe NUMA 拓扑感知，显著增强了企业级就绪能力。运维方面的改进包括无需重启虚拟机即可实时更新网络定义，以及使用变更块跟踪（CBT）的全新存储无关增量备份系统。随着测试规模扩展至 8，000 个虚拟机，该版本巩固了 KubeVirt 作为企业在 Kubernetes 上整合基础设施时，替代专有虚拟化平台的、可行且供应商中立的选择地位。","archive_path":"data/articles/2026/03/RAW_60bfaf4c.json","topicTag":"devops","category":"Programming_Technology","sourceName":"InfoQ","resourceType":"ARTICLE","readTime":4,"score":87},{"id":"RAW_61886a85","title":"OpenClaw 火了之后，企业真正缺的不是更聪明的龙虾，而是一套上岗体系","link":"https://mp.weixin.qq.com/s?__biz=MjM5MDE0Mjc4MA==&mid=2651280528&idx=1&sn=3ace2b4374f323fe50bf2efaf6df93a4","date":"2026-03-31 05:31:00","oneSentenceSummary":"本文探讨了 AI Agent 从工具向「数字员工」转型的趋势，强调企业级落地不仅需要模型能力，更需要涵盖算力底座、安全管控、模型治理及成本控制的完整「上岗体系」。","summary":"文章指出，随着 OpenClaw 等 Agent 工具的热度上升，企业关注点已从单纯的模型能力转向如何在生产环境中部署和管理 Agent。阿里云通过其「虾友会」展示了一套企业级 Agent 落地路径：从 L0 基础设施底座到 L3 商用交付层，构建了包含无影 JVS Crew 运行框架、Agent 安全中心、AI 网关及百炼模型平台的完整生态。文章核心观点认为，安全审计、权限管理、Token 计费及业务技能（Skill）的沉淀才是 Agent 真正成为「数字员工」并实现规模化应用的关键，企业需要的是受控的生态而非野生的工具。","archive_path":"data/articles/2026/03/RAW_61886a85.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"InfoQ 中文","resourceType":"ARTICLE","readTime":19,"score":87},{"id":"RAW_25f2831c","title":"终于不用跟图表死磕了！这个 Skill 让 OpenClaw 直接封神","link":"https://mp.weixin.qq.com/s?__biz=MjM5MDE0Mjc4MA==&mid=2651280528&idx=2&sn=370dee86813e2ff49b207c44de23a7fb","date":"2026-03-31 05:31:00","oneSentenceSummary":"本文介绍了 ChartGen AI 插件正式接入 OpenClaw 框架，通过 Skill 形式补齐了 AI Agent 在数据可视化方面的短板，实现自然语言驱动的专业图表生成。","summary":"文章探讨了当前 AI Agent 生态中「执行」与「表达」脱节的痛点：Agent 虽能高效处理数据，但缺乏将其转化为专业图表的能力，导致自动化流程在汇报环节中断。ChartGen AI 以官方插件（Skill）形式上线 OpenClaw 平台，解决了这一难题。用户现在可以通过简单的自然语言指令，在数秒内获得麦肯锡级别的专业图表。这一更新不仅提升了开发者、运维和产品经理在数据探查与自动化汇报中的效率，更标志着 AI Agent 生态正从单一框架向拥有丰富专业技能的可组合生产力平台演进。","archive_path":"data/articles/2026/03/RAW_25f2831c.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"InfoQ 中文","resourceType":"ARTICLE","readTime":10,"score":84},{"id":"RAW_cf9564a7","title":"Rust 的独特之处不只内存安全：来自自主机器人的启示","link":"https://mp.weixin.qq.com/s?__biz=MjM5MDE0Mjc4MA==&mid=2651280528&idx=3&sn=cd85c2d319c847543ed6df9a0015bb53","date":"2026-03-31 05:31:00","oneSentenceSummary":"本文探讨了 Rust 语言除内存安全外的核心优势，通过自主机器人领域的实践案例，阐述了所有权、枚举、生命周期和类型状态模式如何帮助开发者在编译时构建更健壮、防错的软件系统。","summary":"文章作者结合多年自主移动机器人领域的研发经验，深入剖析了 Rust 语言在内存安全之外的独特价值。核心观点认为，Rust 的设计哲学（如极简内核、强大的枚举、严格的所有权与借用规则）允许开发者将复杂的运行时协议和业务约束直接嵌入类型系统中。通过分析 Option 类型、状态机建模、资源管理（Drop trait）、以及 Mutex 的安全访问，文章展示了 Rust 如何在编译阶段消除整类逻辑错误。此外，作者还介绍了「类型状态」模式（Typestate Pattern）在构建器和状态转换中的应用，证明了 Rust 能显著提升软件的开发效率与质量，使开发者能更轻松地构建高可靠性系统。","archive_path":"data/articles/2026/03/RAW_cf9564a7.json","topicTag":"other","category":"Programming_Technology","sourceName":"InfoQ 中文","resourceType":"ARTICLE","readTime":25,"score":89},{"id":"RAW_1b46967b","title":"JavaScript 2025 状态调查：生态趋于成熟，TypeScript 巩固主导地位","link":"https://mp.weixin.qq.com/s?__biz=MjM5MDE0Mjc4MA==&mid=2651280528&idx=4&sn=2681a4bd83a9d1e1e187323c066f9cc3","date":"2026-03-31 05:31:00","oneSentenceSummary":"2025 年 JavaScript 现状调查显示生态系统趋于稳定，TypeScript 确立统治地位，Vite 凭借极高满意度超越 Webpack，而 AI 开发工具呈现向 Claude 和 Cursor 转移的趋势。","summary":"本文总结了 2025 年 JavaScript 现状调查报告的核心发现。报告指出，JavaScript 生态已从历经多年的快速迭代转向成熟稳定。TypeScript 的完全使用率升至 40%，已成为事实上的行业标准。在构建工具方面，Vite 以 98% 的开发者满意度实质性取代了 Webpack 的地位，而基于 Rust 的工具如 Rolldown 开始崭露头角。前端框架领域 React 虽维持高使用率，但其元框架 Next.js 因复杂度过高引发开发者担忧。此外，AI 开发工具市场发生显著变化，Claude 和 Cursor 的份额大幅增长，反映了开发者对更专业 AI 编程助手的偏好。","archive_path":"data/articles/2026/03/RAW_1b46967b.json","topicTag":"frontend-fullstack","category":"Programming_Technology","sourceName":"InfoQ 中文","resourceType":"ARTICLE","readTime":5,"score":88},{"id":"RAW_a1247165","title":"从特效 SDK 到 AI 动效平台：Neon Vibe Motion 的技术演进之路","link":"https://mp.weixin.qq.com/s?__biz=Mzg3Njc0NTgwMg==&mid=2247504130&idx=1&sn=e16047064d35627ab2d3619c1f763890","date":"2026-03-31 04:05:00","archive_path":"data/articles/2026/03/RAW_a1247165.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"哔哩哔哩技术","resourceType":"ARTICLE","readTime":37,"score":92},{"id":"RAW_67829792","title":"Harness Engineering 来了，SDD 还有意义吗？","link":"https://mp.weixin.qq.com/s?__biz=MzI2NDU4OTExOQ==&mid=2247695017&idx=1&sn=e37650a0f3334a69646fea9959c0297e","date":"2026-03-31 00:46:00","archive_path":"data/articles/2026/03/RAW_67829792.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"腾讯云开发者","resourceType":"ARTICLE","readTime":32,"score":91},{"id":"RAW_5ba4cd12","title":"CoPaw 深度解析：源码架构和功能实践","link":"https://mp.weixin.qq.com/s?__biz=MzIzOTU0NTQ0MA==&mid=2247559269&idx=1&sn=a87c6b0f00c2ccee4a25901df995c65b","date":"2026-03-31 00:30:00","archive_path":"data/articles/2026/03/RAW_5ba4cd12.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"阿里云开发者","resourceType":"ARTICLE","readTime":30,"score":90},{"id":"RAW_5ae30e5a","title":"Discord 开源 Osprey 安全规则引擎，每秒可处理 230 万条规则","link":"https://www.infoq.com/news/2026/03/discord-osprey/?utm_campaign=infoq_content&utm_source=infoq&utm_medium=feed&utm_term=global","date":"2026-03-31 00:11:00","archive_path":"data/articles/2026/03/RAW_5ae30e5a.json","topicTag":"other","category":"Programming_Technology","sourceName":"InfoQ","resourceType":"ARTICLE","readTime":3,"score":90},{"id":"RAW_e1421cf1","title":"Spring 本周动态 - 2026 年 3 月 31 日","link":"https://spring.io/blog/2026/03/31/this-week-in-spring-march-31st-2026","date":"2026-03-31 00:00:00","oneSentenceSummary":"Spring 生态系统周报，涵盖 Spring Boot、Spring AI 和 Spring Modulith 的重大版本更新，以及关键的安全更新和社区资源。","summary":"本期 Spring 本周动态全面更新了 2026 年 3 月下旬 Spring 框架生态系统的最新进展。主要亮点包括 Spring Boot 4.0.5 和 4.1.0 M4、Spring AI 2.0.0 M4 以及 Spring Modulith 的更新。至关重要的是，此次发布还宣布了 Spring Cloud Config 的更新，以解决一个安全漏洞 (CVE-2026-22739)。文章还整理了有价值的社区内容，包括对 Kafka 偏移量提交的深入探讨、MCP 安全指南以及使用 JobRunr 进行碳感知作业调度。","archive_path":"data/articles/2026/03/RAW_e1421cf1.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"Spring Blog","resourceType":"ARTICLE","readTime":2,"score":83},{"id":"RAW_2e6c841d","title":"如何使用 Browser Use 和 Claude API 构建本地 SEO 审计智能体","link":"https://www.freecodecamp.org/news/how-to-build-a-local-seo-audit-agent-with-browser-use-and-claude-api/","date":"2026-03-30 23:37:08","archive_path":"data/articles/2026/03/RAW_2e6c841d.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"freeCodeCamp.org","resourceType":"ARTICLE","readTime":14,"score":91},{"id":"RAW_8b243c19","title":"使用 IndexedStack 在 Flutter 中实现高效的状态管理","link":"https://www.freecodecamp.org/news/efficient-state-management-in-flutter-using-indexedstack/","date":"2026-03-30 23:29:02","oneSentenceSummary":"本文介绍了如何使用 Flutter 的 IndexedStack 组件在标签页导航中保持 UI 状态，包括独立导航栈的实现以及性能权衡。","summary":"本文探讨了 Flutter 开发中一个常见的挑战：由于组件重建，在切换标签页时会导致滚动位置和表单输入等 UI 状态丢失。文章介绍了 IndexedStack 作为一种有效的解决方案，它通过将所有子组件保留在内存中并仅切换其可见性来保持状态。作者提供了基础实现和高级模式的实用代码示例，例如使用嵌套的 Navigator 和 GlobalKey 为每个标签页创建独立的导航栈。此外，文章还讨论了用户体验与内存消耗之间的关键权衡，并根据屏幕的复杂性和数量，为开发者提供了何时使用 IndexedStack 与标准导航的建议。","archive_path":"data/articles/2026/03/RAW_8b243c19.json","topicTag":"other","category":"Programming_Technology","sourceName":"freeCodeCamp.org","resourceType":"ARTICLE","readTime":8,"score":86},{"id":"RAW_86f36b4f","title":"如何在 React 中设计类型安全、懒加载且安全的插件架构","link":"https://www.freecodecamp.org/news/how-to-design-a-type-safe-lazy-and-secure-plugin-architecture-in-react/","date":"2026-03-30 18:06:36","archive_path":"data/articles/2026/03/RAW_86f36b4f.json","topicTag":"frontend-fullstack","category":"Programming_Technology","sourceName":"freeCodeCamp.org","resourceType":"ARTICLE","readTime":13,"score":90},{"id":"RAW_9a024618","title":"杀死那个手工程序员","link":"https://tw93.fun/2026-03-30/kill.html","date":"2026-03-30 17:00:00","archive_path":"data/articles/2026/03/RAW_9a024618.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"Tw93 Blog","resourceType":"ARTICLE","readTime":9,"score":86},{"id":"RAW_0df9b7df","title":"通过智能体、沙盒与人类协作，将 Turborepo 速度