[{"id":"RAW_1a4ea20b","title":"Mistral：Voxtral TTS、Forge、Leanstral 以及 Mistral 4 的未来展望 — 嘉宾：Pavan Kumar Reddy 与 Guillaume Lample","link":"https://www.latent.space/p/voxtral","date":"2026-03-30 19:25:21","archive_path":"data/articles/2026/03/RAW_1a4ea20b.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Latent Space","resourceType":"ARTICLE","readTime":45,"score":92},{"id":"RAW_66d6464a","title":"认知重建之后，步入 Agentic Engineering 的工程革命","link":"https://mp.weixin.qq.com/s?__biz=MjM5ODYwMjI2MA==&mid=2649801026&idx=1&sn=3e12f0888b3c232ed7218caf90df5f0a","date":"2026-03-30 09:37:00","archive_path":"data/articles/2026/03/RAW_66d6464a.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"腾讯技术工程","resourceType":"ARTICLE","readTime":186,"score":93},{"id":"RAW_0a76d16b","title":"从 Vibe Coding 到范式编程：用 Spec 打造淘系交易的 AI 领域专家","link":"https://mp.weixin.qq.com/s?__biz=MzAxNDEwNjk5OQ==&mid=2650543105&idx=1&sn=fec6d68f9c81df650d53981a460b0b11","date":"2026-03-30 07:37:00","archive_path":"data/articles/2026/03/RAW_0a76d16b.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"大淘宝技术","resourceType":"ARTICLE","readTime":74,"score":92},{"id":"RAW_401cc08f","title":"什么时候 Agent 能自己写 skill？","link":"https://mp.weixin.qq.com/s?__biz=Mjc1NjM3MjY2MA==&mid=2691566471&idx=1&sn=b517898fe315865c79bd7a4e4c9e9928","date":"2026-03-30 14:03:00","archive_path":"data/articles/2026/03/RAW_401cc08f.json","topicTag":"ai-llm","category":"Business_Tech","sourceName":"腾讯科技","resourceType":"ARTICLE","readTime":48,"score":92},{"id":"RAW_f08c6c67","title":"[AI 新闻] 科技行业的最后 4 个岗位","link":"https://www.latent.space/p/ainews-the-last-4-jobs-in-tech","date":"2026-03-31 01:04:54","oneSentenceSummary":"本期 AI 新闻探讨了科技行业组织角色的演变、向 Claude Code 和 Hermes 等可组合 AI 智能体“工具链（harness）”的转变，以及本地多模态推理的重大突破。","summary":"本文对 AI 领域进行了高密度的回顾，首先提出了后 AI 时代科技角色的思维模型——坦克（Tank）、治疗（Healer）、输出（DPS）和辅助（Support），类似于 RPG 游戏中的角色定位。文章重点介绍了 Anthropic 的 Claude Code 增加了用于闭环验证的“计算机使用（computer use）”功能，以及“工具链工程（harness engineering）”这一新兴趋势，即编排层变得与模型本身同等重要。开源生态系统随着 Hermes Agent 的更新而激增，正向“智能体操作系统（agent OS）”抽象迈进。在硬件方面，本地推理达到了一个里程碑，llama.cpp 的星标数突破 10 万，Flash-MoE 使 Qwen3.5-397B 等大模型能够在消费级 MacBook 上运行。研究更新包括用于端到端智能体优化的 Meta-Harness，以及用于多智能体软件工程的集中式异步隔离委派（CAID）。Shopify 使用 DSPy 降低 98% 成本等实际案例，凸显了向专业化、小型化模型转变的经济趋势。","archive_path":"data/articles/2026/03/RAW_f08c6c67.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Latent Space","resourceType":"ARTICLE","readTime":7,"score":90},{"id":"RAW_b715a1fc","title":"来自 Georgi Gerganov 的引用","link":"https://simonwillison.net/2026/Mar/30/georgi-gerganov/#atom-everything","date":"2026-03-30 21:31:02","archive_path":"data/articles/2026/03/RAW_b715a1fc.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Simon Willison's Weblog","resourceType":"ARTICLE","readTime":1,"score":83},{"id":"RAW_9e4043cc","title":"发布：datasette-llm 0.1a3","link":"https://simonwillison.net/2026/Mar/30/datasette-llm/#atom-everything","date":"2026-03-30 19:48:43","archive_path":"data/articles/2026/03/RAW_9e4043cc.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Simon Willison's Weblog","resourceType":"ARTICLE","readTime":1,"score":82},{"id":"RAW_3adbb4bb","title":"Mr. Chatterbox 是一个（性能较弱的）维多利亚时代伦理训练模型，你可以在自己的电脑上运行","link":"https://simonwillison.net/2026/Mar/30/mr-chatterbox/#atom-everything","date":"2026-03-30 14:28:34","archive_path":"data/articles/2026/03/RAW_3adbb4bb.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Simon Willison's Weblog","resourceType":"ARTICLE","readTime":3,"score":87},{"id":"RAW_cc80f169","title":"阿里发布 Qwen3.5-Omni，多模态能力超越 Gemini-3.1 Pro","link":"https://www.qbitai.com/2026/03/393460.html","date":"2026-03-30 14:21:45","archive_path":"data/articles/2026/03/RAW_cc80f169.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":2,"score":88},{"id":"RAW_7c6d24d4","title"