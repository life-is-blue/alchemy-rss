[{"id":"RAW_fa1cab53","title":"快速正则搜索：为智能体工具建立文本索引 · Cursor","link":"https://cursor.com/blog/fast-regex-search","date":"2026-03-23 12:00:00","archive_path":"data/articles/2026/03/RAW_fa1cab53.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Cursor Blog","resourceType":"ARTICLE","readTime":19,"score":92},{"id":"RAW_ad7e6094","title":"业务逻辑的“坍塌”：当应用层只剩下胶水代码，在 AI Agent 时代，我们该构建什么","link":"https://mp.weixin.qq.com/s?__biz=MzIzOTU0NTQ0MA==&mid=2247559085&idx=1&sn=088f736a32f31c2b54a534886d492453","date":"2026-03-24 00:32:00","archive_path":"data/articles/2026/03/RAW_ad7e6094.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"阿里云开发者","resourceType":"ARTICLE","readTime":110,"score":92},{"id":"RAW_cd2c701e","title":"TypeScript 6.0 发布公告 - TypeScript","link":"https://devblogs.microsoft.com/typescript/announcing-typescript-6-0","date":"2026-03-23 17:23:48","archive_path":"data/articles/2026/03/RAW_cd2c701e.json","topicTag":"frontend-fullstack","category":"Programming_Technology","sourceName":"Microsoft for Developers","resourceType":"ARTICLE","readTime":24,"score":92},{"id":"RAW_1b7847dd","title":"拒绝重复造轮子！抽象 80% 工作场景，打造可复用的\"AI 助手工厂”","link":"https://mp.weixin.qq.com/s?__biz=MzIzOTU0NTQ0MA==&mid=2247558977&idx=1&sn=dcf5e1258edd06e555cc9bff963f133a","date":"2026-03-23 00:32:00","archive_path":"data/articles/2026/03/RAW_1b7847dd.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"阿里云开发者","resourceType":"ARTICLE","readTime":31,"score":92},{"id":"RAW_d54cd5c4","title":"黄仁勋暴论核弹：AGI 已经实现，Ilya 错了，程序员有 10 亿","link":"https://www.qbitai.com/2026/03/391750.html","date":"2026-03-24 08:54:00","oneSentenceSummary":"黄仁勋在 Lex Fridman 专访中宣布 AGI 已实现，并提出推理即思考、Agentic Scaling 及程序员将扩充至 10 亿等前瞻性观点。","summary":"英伟达 CEO 黄仁勋在与 Lex Fridman 的深度访谈中，对 AI 的现状与未来给出了震撼性判断。他认为 AGI 已经实现，并驳斥了 Scaling Law 触顶的观点，指出 Scaling Law 正在从预训练转向推理时（Test-time）和智能体（Agentic）阶段。黄仁勋强调，计算模式正从「检索式」转向「生成式」，智能将成为按需定价的 Token 商品，而 OpenClaw 则是 Token 时代的 iPhone。针对能源瓶颈，他提出数据中心应具备「优雅降级」能力以利用电网闲置电力。此外，他预测 AI 不会取代程序员，反而会通过降低「规格说明」的门槛，使全球程序员数量从 3000 万激增至 10 亿，让每个人都成为创造者。","archive_path":"data/articles/2026/03/RAW_d54cd5c4.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":61,"score":88},{"id":"RAW_1d9df17b","title":"阿里海外发布企业级 Agent 平台 Accio Work：实测 30 分钟自动化开网店","link":"https://www.qbitai.com/2026/03/391584.html","date":"2026-03-24 05:21:36","oneSentenceSummary":"阿里在海外发布首个企业级 Agent 平台 Accio Work，通过多 Agent 协作实现 30 分钟快速搭建并运营跨境电商网店的全流程自动化。","summary":"本文深度测评了阿里最新在海外上线的企业级 AI Agent 产品 Accio Work。作者通过实测展示了该产品如何通过 Agent 团队协作，在 30 分钟内完成选品、品牌设计、建站、上架及营销推广的全过程。Accio Work 依托阿里 26 年的电商经验，内置多种生意 Skill，支持自定义 Agent 和定时任务，并解决了跨境电商中的信息壁垒、流程复杂和成本高昂等痛点。文章指出，该产品的核心优势在于闭环处理能力和商业级安全性，预示着「一人公司」大航海时代的到来，贸易交互模式正从「人-人」向「Agent-Agent」转变。","archive_path":"data/articles/2026/03/RAW_1d9df17b.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":15,"score":88},{"id":"RAW_4018e9d7","title":"从 SFT 到 PPO：大模型强化学习算法全解","link":"https://mp.weixin.qq.com/s?__biz=MzI1MzEwMzIwOQ==&mid=2247513435&idx=1&sn=54d1c2a1ac1d6490e6634d8b49681f1e","date":"2026-03-24 04:03:00","oneSentenceSummary":"本文系统梳理了从监督微调（SFT）到强化学习（RLHF/PPO）的大模型后训练演进路径，深入解析了拒绝采样、奖励模型、REINFORCE、Actor-Critic 及 PPO 的核心原理与数学逻辑。","summary":"文章详细拆解了大模型后训练（Post-training）的核心技术栈。从基础的 SFT 出发，逐步引入拒绝采样、奖励模型（RM）以解决对齐问题。重点剖析了强化学习在 LLM 中的应用演进：从 REINFORCE 的基础策略梯度，到 Actor-Critic 的价值评估，再到 PPO 的重要性采样与裁剪机制。文章不仅解释了算法背后的数学原理（如 GAE、KL 惩罚），还结合 ChatGPT 的训练流程，探讨了 PPO 的局限性及未来演进方向，是深入理解 LLM 强化学习的优质技术指南。","archive_path":"data/articles/2026/03/RAW_4018e9d7.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"青稞AI","resourceType":"ARTICLE","readTime":64,"score":92},{"id":"RAW_fbe9aca0","title":"OpenClaw 逼出 Claude 最强反击！GUI 操控电脑和真人无差别","link":"https://www.qbitai.com/2026/03/391567.html","date":"2026-03-24 02:20:26","oneSentenceSummary":"Anthropic 升级 Claude Code 的 Computer Use 能力，支持基于 GUI 的全自动电脑操控、远程控制及定时任务，实现了对传统软件的无缝 Agent 化管理。","summary":"本文报道了 Anthropic 对 Claude Code 进行的重大升级，重点增强了 Computer Use 能力。新版本通过实时截图和模拟鼠标键盘操作，使 Claude 能够像真人一样直接操控各类 GUI 软件，无需 API 或 CLI 适配。此外，官方新增了远程控制和定时任务功能，并建立了多层安全机制（如优先调用集成工具、敏感操作确认及 Docker 隔离建议）。目前该功能面向 macOS 的 Claude Pro 和 Max 用户开放预览，标志着 AI Agent 在通用软件操控领域迈出了重要一步。","archive_path":"data/articles/2026/03/RAW_fbe9aca0.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":4,"score":88},{"id":"RAW_08211df9","title":"语音智能体评估新框架 (EVA)","link":"https://huggingface.co/blog/ServiceNow-AI/eva","date":"2026-03-24 02:01:52","archive_path":"data/articles/2026/03/RAW_08211df9.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Hugging Face Blog","resourceType":"ARTICLE","readTime":9,"score":92},{"id":"RAW_f8545491","title":"消融研究：拆解‘多重人格训练’ — LessWrong","link":"https://www.lesswrong.com/posts/5gDjg4oN4kJKMLovs/ablating-split-personality-training","date":"2026-03-23 17:45:38","archive_path":"data/articles/2026/03/RAW_f8545491.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"LessWrong","resourceType":"ARTICLE","readTime":6,"score":87},{"id":"RAW_c852e850","title":"两种不同的智能体授权类型","link":"https://blog.langchain.com/two-different-types-of-agent-authorization/","date":"2026-03-23 17:29:28","archive_path":"data/articles/2026/03/RAW_c852e850.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"LangChain Blog","resourceType":"ARTICLE","readTime":4,"score":89},{"id":"RAW_05b39e90","title":"因果推断正在“吞噬”机器学习","link":"https://towardsdatascience.com/causal-inference-is-eating-machine-learning/","date":"2026-03-23 15:00:00","archive_path":"data/articles/2026/03/RAW_05b39e90.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"Towards Data Science","resourceType":"ARTICLE","readTime":12,"score":89},{"id":"RAW_451d51df","title":"神经符号欺诈检测：在 F1 分数下降前捕获概念漂移（无需标签）","link":"https://towardsdatascience.com/neuro-symbolic-fraud-detection-catching-concept-drift-before-f1-drops-label-free/","date":"2026-03-23 13:30:00","archive_path":"data/articles/2026/03/RAW_451d51df.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Towards Data Science","resourceType":"ARTICLE","readTime":20,"score":88},{"id":"RAW_7a497b4a","title":"UCSD 发布 AIBuildAI 智能体：多智能体协作实现 AI 开发全自动化","link":"https://mp.weixin.qq.com/s?__biz=MzI3MTA0MTk1MA==&mid=2652686074&idx=3&sn=c90acf56dc663db852c883a811b80f50","date":"2026-03-23 12:27:00","oneSentenceSummary":"UCSD 团队推出 AIBuildAI 多智能体系统，通过模拟人类工程师工作流实现模型开发全自动化，并在 OpenAI MLE-Bench 评测中以 63.1% 的获奖率位居榜首。","summary":"加州大学圣地亚哥分校（UCSD）研究团队开发了名为 AIBuildAI 的全自动 AI 模型构建智能体系统。该系统旨在解决 AI 开发中耗时费力的模型设计、编码、训练和调参过程。AIBuildAI 采用多智能体协作架构，包含管理智能体（决策与筛选）、研究员智能体（方案设计与修订）、编码智能体（流水线实现）和调优器智能体（性能提升）。在涵盖 75 个 Kaggle 真实任务的 OpenAI MLE-Bench 基准测试中，AIBuildAI 以 63.1% 的获奖率超越现有方法，排名全球第一，证明了结构化多智能体协作在自动化复杂 AI 工程任务中的巨大潜力。","archive_path":"data/articles/2026/03/RAW_7a497b4a.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"新智元","resourceType":"ARTICLE","readTime":10,"score":87},{"id":"RAW_b28a84fe","title":"MiniMax 定理：压缩即智能","link":"https://mp.weixin.qq.com/s?__biz=MzkzNDQxOTU2MQ==&mid=2247514561&idx=1&sn=29ab67a0d772a047a73c605da8ba9f6e","date":"2026-03-23 10:44:00","archive_path":"data/articles/2026/03/RAW_b28a84fe.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"赛博禅心","resourceType":"ARTICLE","readTime":10,"score":87},{"id":"RAW_79d82b59","title":"陶哲轩访谈：AI 时代的数学研究与科学范式革命","link":"https://www.qbitai.com/2026/03/391515.html","date":"2026-03-23 10:22:44","archive_path":"data/articles/2026/03/RAW_79d82b59.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":74,"score":88},{"id":"RAW_a24896f7","title":"AI 不会减少工程师！Reddit 疯抢应届生：“AI 原生一代”必须毕业就招走","link":"https://mp.weixin.qq.com/s?__biz=MzU1NDA4NjU2MA==&mid=2247659417&idx=1&sn=4df67108502f060e9f7192c426fd6e02","date":"2026-03-23 08:48:00","archive_path":"data/articles/2026/03/RAW_a24896f7.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"AI前线","resourceType":"ARTICLE","readTime":51,"score":87},{"id":"RAW_63f268e9","title":"克服受监管行业中的 LLM 幻觉：Artificial Genius 在 Amazon Nova 上的确定性模型 | Amazon Web Services","link":"https://aws.amazon.com/blogs/machine-learning/overcoming-llm-hallucinations-in-regulated-industries-artificial-geniuss-deterministic-models-on-amazon-nova/","date":"2026-03-23 08:34:37","archive_path":"data/articles/2026/03/RAW_63f268e9.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"AWS Machine Learning Blog","resourceType":"ARTICLE","readTime":15,"score":87},{"id":"RAW_50a7b11a","title":"必看！Sebastian Raschka 新博客盘点了所有主要注意力机制","link":"https://mp.weixin.qq.com/s?__biz=MzA3MzI4MjgzMw==&mid=2651023106&idx=1&sn=cf7819f0a37b38ac328dfa5963e26f8a","date":"2026-03-23 07:07:00","archive_path":"data/articles/2026/03/RAW_50a7b11a.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"机器之心","resourceType":"ARTICLE","readTime":38,"score":90},{"id":"RAW_54a05df9","title":"北大团队提出 SHINE：将任意文本转化为大模型 LoRA，仅需一次前向传播！","link":"https://mp.weixin.qq.com/s?__biz=MzA3MzI4MjgzMw==&mid=2651023106&idx=3&sn=1f34564faacef4e288bd0580245ca742","date":"2026-03-23 07:07:00","archive_path":"data/articles/2026/03/RAW_54a05df9.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"机器之心","resourceType":"ARTICLE","readTime":21,"score":87},{"id":"RAW_bdf1a88b","title":"Yuan3.0 Ultra：万亿参数 MOE 大模型的效率优化与 Agent 实战","link":"https://mp.weixin.qq.com/s?__biz=MjM5ODkzMzMwMQ==&mid=2650451329&idx=1&sn=30fe2df0372bf592a134eb3477aa3808","date":"2026-03-23 06:11:00","archive_path":"data/articles/2026/03/RAW_bdf1a88b.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"AINLP","resourceType":"ARTICLE","readTime":14,"score":88},{"id":"RAW_36dbe343","title":"别人都在卷视觉，这家具身公司偏要卷“手感”","link":"https://www.qbitai.com/2026/03/391314.html","date":"2026-03-23 05:51:28","archive_path":"data/articles/2026/03/RAW_36dbe343.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":20,"score":88},{"id":"RAW_65d56a16","title":"解析 Agent 框架中的上下文管理策略","link":"https://mp.weixin.qq.com/s?__biz=MzI1MzEwMzIwOQ==&mid=2247513403&idx=1&sn=6f38136bfcb8f0acd7f05dfb43b58810","date":"2026-03-23 05:00:00","archive_path":"data/articles/2026/03/RAW_65d56a16.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"青稞AI","resourceType":"ARTICLE","readTime":33,"score":88},{"id":"RAW_eea692a3","title":"从摩擦到流畅：卓越的开发者体验（DevEx）如何成就一切","link":"https://www.infoq.com/presentations/devex-highlights/?utm_campaign=infoq_content&utm_source=infoq&utm_medium=feed&utm_term=global","date":"2026-03-24 09:43:00","oneSentenceSummary":"Nicole Forsgren 博士探讨了如何通过反馈循环、心流状态和降低认知负荷来优化开发者体验（DevEx），这对可持续生产力至关重要，尤其是在 AI 加速代码生成但放大了部署瓶颈的背景下。","summary":"本文基于 Nicole Forsgren 博士的演讲，讨论了开发者体验（DevEx）在现代软件工程中的关键作用。虽然 AI 工具极大地缩短了编写代码的时间，但也暴露并放大了“外循环”（outer loop）中的摩擦，例如缓慢的部署、手动协调和技术债务。Forsgren 引入了一个以三大支柱为核心的框架：快速反馈循环、受保护的心流状态和最小化的认知负荷。她主张使用 DORA 指标来衡量绩效，并为组织改进 DevEx 提供了 7 个战略步骤，从最初的倾听意见到基于经济影响制定数据驱动的商业案例。演讲强调，在 AI 时代，代码行数等传统指标已经过时，重点应转向提示词效率（prompting efficiency）、代码存活率（code survivability）以及人工监督与自动化生成之间的平衡。","archive_path":"data/articles/2026/03/RAW_eea692a3.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"InfoQ","resourceType":"ARTICLE","readTime":24,"score":89},{"id":"RAW_20d1e688","title":"在拥有 5000 万用户的应用中采用 SwiftUI 的经验教训","link":"https://www.infoq.com/articles/adopting-swiftui-at-scale/?utm_campaign=infoq_content&utm_source=infoq&utm_medium=feed&utm_term=global","date":"2026-03-24 09:00:00","oneSentenceSummary":"一份关于在大型生产环境中扩展 SwiftUI 的综合指南，重点关注组织协调、版本控制策略和技术权衡。","summary":"本文深入探讨了在服务于 5000 万用户的庞大 iOS 应用中采用 SwiftUI 所面临的现实挑战。文章指出，主要障碍并非纯粹的技术问题，而是组织和文化层面的挑战，并强调了资深工程师因深耕 UIKit 而产生的抵触情绪。作者主张采取务实的“仅限新功能”采用策略，利用功能开关（feature flags）来管理 iOS 版本碎片化，并指出维护双重设计系统的必要性。在赞扬 SwiftUI 在原型设计速度、状态管理（Observation 框架）和测试易用性方面的进步的同时，作者也坦诚地指出了其在复杂列表和精细滚动控制方面与 UIKit 相比存在的性能差距。","archive_path":"data/articles/2026/03/RAW_20d1e688.json","topicTag":"other","category":"Programming_Technology","sourceName":"InfoQ","resourceType":"ARTICLE","readTime":10,"score":89},{"id":"RAW_701b2f86","title":"硬件成本直降 60%！原生分布式 VS 传统分库分表数据库","link":"https://mp.weixin.qq.com/s?__biz=MjM5MDE0Mjc4MA==&mid=2651279611&idx=2&sn=fc80409f3c2ce7d7b716aca8838b2edf","date":"2026-03-24 05:29:00","oneSentenceSummary":"本文深度对比了原生分布式数据库与传统分库分表架构在硬件资源利用率上的差异，阐述了 OceanBase 如何通过架构创新实现 60% 以上的降本增效。","summary":"在服务器硬件成本持续攀升的背景下，企业 IT 基础设施面临严峻的成本压力。文章指出，传统数据库架构因静态分配和组件冗余，普遍存在资源利用率低（CPU 往往不足 20%）的问题。通过对比分析，原生分布式数据库（以 OceanBase 为例）凭借 Paxos 协议精简组件、自动分片与动态负载均衡、高比例数据压缩（可达 5:1）以及多租户资源共享机制，显著提升了单位硬件的产出效率。河北移动与南京银行的实战案例表明，从传统架构迁移至原生分布式架构，不仅能降低 60% 的硬件投入，还能大幅缩短备份还原时间并提升业务处理性能，为企业提供了绿色可持续的降本方案。","archive_path":"data/articles/2026/03/RAW_701b2f86.json","topicTag":"other","category":"Programming_Technology","sourceName":"InfoQ 中文","resourceType":"ARTICLE","readTime":28,"score":89},{"id":"RAW_5dd117a0","title":"【第 3675 期】别再纠结格式：5 种设计模式，构建真正可靠的 AI Agent","link":"https://mp.weixin.qq.com/s?__biz=MjM5MTA1MjAxMQ==&mid=2651278808&idx=1&sn=cb062b1747e889741fc1ad1e42b7c225","date":"2026-03-24 01:01:00","oneSentenceSummary":"本文介绍了构建可靠 AI Agent 的五种核心设计模式（工具封装器、生成器、审查器、反转模式、流水线），强调通过结构化逻辑而非单纯的提示词工程来提升智能体性能。","summary":"文章指出，随着 Agent 工具（如 Claude Code、Cursor、Gemini CLI）文件布局的逐渐统一，开发者应将重点从 SKILL.md 的格式规范转向内容逻辑设计。基于 Anthropic、Vercel 和 Google 的实践，作者提炼并详细介绍了五种设计模式：1. 工具封装器（动态加载代码库上下文）；2. 生成器（基于模板确保输出一致性）；3. 审查器（模块化评分与审计）；4. 反转模式（Agent 作为采访者主动收集需求）；5. 流水线模式（强制执行带检查点的多步流）。文章还提供了决策指南，建议开发者通过组合这些模式，利用 Google Cloud ADK 等工具构建复杂且稳健的 Agent 工作流，解决提示词脆弱和逻辑混乱的问题。","archive_path":"data/articles/2026/03/RAW_5dd117a0.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"前端早读课","resourceType":"ARTICLE","readTime":19,"score":89},{"id":"RAW_fd69e2a7","title":"如何使用 Codemagic 构建完整的 Flutter CI/CD 流水线：从 PR 质量门禁到自动化应用商店发布","link":"https://www.freecodecamp.org/news/build-a-complete-flutter-ci-cd-pipeline-with-codemagic/","date":"2026-03-24 00:37:14","archive_path":"data/articles/2026/03/RAW_fd69e2a7.json","topicTag":"devops","category":"Programming_Technology","sourceName":"freeCodeCamp.org","resourceType":"ARTICLE","readTime":17,"score":88},{"id":"RAW_d4438ad2","title":"如何停止让 AI 智能体猜测你的需求","link":"https://www.freecodecamp.org/news/how-to-stop-letting-ai-agents-guess-your-requirements/","date":"2026-03-24 00:35:37","archive_path":"data/articles/2026/03/RAW_d4438ad2.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"freeCodeCamp.org","resourceType":"ARTICLE","readTime":10,"score":88},{"id":"RAW_f51863d3","title":"NVIDIA IGX Thor 赋能工业、医疗和机器人边缘 AI 应用","link":"https://developer.nvidia.com/blog/nvidia-igx-thor-powers-industrial-medical-and-robotics-edge-ai-applications/","date":"2026-03-23 20:30:47","archive_path":"data/articles/2026/03/RAW_f51863d3.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"NVIDIA Technical Blog","resourceType":"ARTICLE","readTime":9,"score":87},{"id":"RAW_68d7248e","title":"构建基于代码库的知识助手","link":"https://www.databricks.com/blog/building-knowledge-assistant-over-code","date":"2026-03-23 18:15:00","archive_path":"data/articles/2026/03/RAW_68d7248e.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"Databricks","resourceType":"ARTICLE","readTime":7,"score":90},{"id":"RAW_6d11deae","title":"Docker 容器医生：我是如何构建一个 AI 智能体来监控并修复我的容器的","link":"https://www.freecodecamp.org/news/docker-container-doctor-how-i-built-an-ai-agent-that-monitors-and-fixes-my-containers/","date":"2026-03-23 17:21:11","archive_path":"data/articles/2026/03/RAW_6d11deae.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"freeCodeCamp.org","resourceType":"ARTICLE","readTime":16,"score":88},{"id":"RAW_2f8147a6","title":"Trivy 供应链遭入侵：Docker Hub 用户需知","link":"https://www.docker.com/blog/trivy-supply-chain-compromise-what-docker-hub-users-should-know/","date":"2026-03-23 16:25:16","archive_path":"data/articles/2026/03/RAW_2f8147a6.json","topicTag":"devops","category":"Programming_Technology","sourceName":"Docker","resourceType":"ARTICLE","readTime":5,"score":87},{"id":"RAW_22661f39","title":"Agentic RAG 是如何工作的？","link":"https://blog.bytebytego.com/p/how-agentic-rag-works","date":"2026-03-23 15:31:43","archive_path":"data/articles/2026/03/RAW_22661f39.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"ByteByteGo Newsletter","resourceType":"ARTICLE","readTime":8,"score":88},{"id":"RAW_50e70a7b","title":"在 dotnet/runtime 中使用 Copilot Coding Agent 的十个月 - .NET 博客","link":"https://devblogs.microsoft.com/dotnet/ten-months-with-cca-in-dotnet-runtime","date":"2026-03-23 14:55:00","archive_path":"data/articles/2026/03/RAW_50e70a7b.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"Microsoft for Developers","resourceType":"ARTICLE","readTime":56,"score":89},{"id":"RAW_5a2d213e","title":"发布 Cloudflare 第 13 代服务器：以缓存换核心，实现 2 倍边缘计算性能","link":"https://blog.cloudflare.com/gen13-launch/","date":"2026-03-23 13:00:00","archive_path":"data/articles/2026/03/RAW_5a2d213e.json","topicTag":"devops","category":"Programming_Technology","sourceName":"The Cloudflare Blog","resourceType":"ARTICLE","readTime":7,"score":89},{"id":"RAW_38a5f16f","title":"深入了解 Gen 13：我们如何打造迄今为止最强大的服务器","link":"https://blog.cloudflare.com/gen13-config/","date":"2026-03-23 13:00:00","archive_path":"data/articles/2026/03/RAW_38a5f16f.json","topicTag":"devops","category":"Programming_Technology","sourceName":"The Cloudflare Blog","resourceType":"ARTICLE","readTime":14,"score":91},{"id":"RAW_2cee51c6","title":"巧妙的页眉遮挡技巧 • Josh W. Comeau","link":"https://www.joshwcomeau.com/css/header-blockers/","date":"2026-03-23 12:00:00","archive_path":"data/articles/2026/03/RAW_2cee51c6.json","topicTag":"frontend-fullstack","category":"Programming_Technology","sourceName":"Josh Comeau's blog","resourceType":"ARTICLE","readTime":6,"score":86},{"id":"RAW_dc08e031","title":"Data Mesh 实战：从构思到落地的旅程","link":"https://www.infoq.com/presentations/data-mesh-horse-powertrain/?utm_campaign=infoq_content&utm_source=infoq&utm_medium=feed&utm_term=global","date":"2026-03-23 11:43:00","archive_path":"data/articles/2026/03/RAW_dc08e031.json","topicTag":"devops","category":"Programming_Technology","sourceName":"InfoQ","resourceType":"ARTICLE","readTime":31,"score":89},{"id":"RAW_d222a5d7","title":"Claude Code + OpenSpec 正在加速 AICoding 落地：从模型博弈到工程化的范式转移｜得物技术","link":"https://mp.weixin.qq.com/s?__biz=MzkxNTE3ODU0NA==&mid=2247543887&idx=1&sn=4b040af63cd6575b636c2378f6d1d511","date":"2026-03-23 10:35:00","archive_path":"data/articles/2026/03/RAW_d222a5d7.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"得物技术","resourceType":"ARTICLE","readTime":21,"score":91},{"id":"RAW_bb4b1b78","title":"QCon London 2026：通过在单台服务器中塞入 100 万个沙箱来解决 AI 基础设施扩展问题","link":"https://www.infoq.com/news/2026/03/qcon-million-sandboxes-server/?utm_campaign=infoq_content&utm_source=infoq&utm_medium=feed&utm_term=global","date":"2026-03-23 10:02:00","archive_path":"data/articles/2026/03/RAW_bb4b1b78.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"InfoQ","resourceType":"ARTICLE","readTime":4,"score":89},{"id":"RAW_3b86eb69","title":"让 AI 变成 Super 员工的秘密：高效训练 Skills","link":"https://mp.weixin.qq.com/s?__biz=MjM5ODYwMjI2MA==&mid=2649800926&idx=1&sn=23e36dbedf9052459137075c7ef9733e","date":"2026-03-23 09:37:00","archive_path":"data/articles/2026/03/RAW_3b86eb69.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"腾讯技术工程","resourceType":"ARTICLE","readTime":23,"score":91},{"id":"RAW_b8f0ab61","title":"知识基座：让 AI 越用越懂业务的团队经验实践","link":"https://mp.weixin.qq.com/s?__biz=MzAxNDEwNjk5OQ==&mid=2650543063&idx=1&sn=55bcd079916d096707259d3de8301dbd","date":"2026-03-23 07:39:00","archive_path":"data/articles/2026/03/RAW_b8f0ab61.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"大淘宝技术","resourceType":"ARTICLE","readTime":53,"score":92},{"id":"RAW_2e71c7fe","title":"AI 智能体实践评估：基准、框架与经验总结","link":"https://mp.weixin.qq.com/s?__biz=MjM5MDE0Mjc4MA==&mid=2651279497&idx=3&sn=9c768ffdda153ce916039bb2ff55c58c","date":"2026-03-23 06:31:00","archive_path":"data/articles/2026/03/RAW_2e71c7fe.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"InfoQ 中文","resourceType":"ARTICLE","readTime":35,"score":88},{"id":"RAW_dcd56882","title":"Claude Code 技能实战指南：来自 Anthropic 内部的经验总结","link":"https://mp.weixin.qq.com/s?__biz=MjM5MTA1MjAxMQ==&mid=2651278796&idx=1&sn=ae74d4204ea67ce9a7f9a44df91ec00c","date":"2026-03-23 01:02:00","archive_path":"data/articles/2026/03/RAW_dcd56882.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"前端早读课","resourceType":"ARTICLE","readTime":20,"score":88},{"id":"RAW_0ab1880d","title":"2026-03-24 Hacker News 热点汇总：从极致汇编优化到移动端 400B 模型实测","link":"https://supertechfans.com/cn/post/2026-03-24-HackerNews/","date":"2026-03-24 08:19:08","oneSentenceSummary":"本文汇总了 Hacker News 2026 年 3 月 24 日的热点话题，涵盖隐私迁移实践、汇编级游戏优化、iPhone 运行 400B 模型及 NixOS 声明式系统等前沿技术动态。","summary":"文章精选了 Hacker News 社区近期备受关注的十大技术热点。核心内容包括：一位开发者出于隐私考量将个人网络服务全面迁移至欧盟的详细实践；对《过山车大亨》通过汇编语言和“设计服务于性能”理念实现极致优化的深度剖析；GrapheneOS 宣布与摩托罗拉合作并坚持无隐私采集的原则。在 AI 领域，探讨了利用 SSD 流式传输在 iPhone 上运行 400B 参数模型的技术可行性，以及 OpenClaw AI 代理带来的严重安全隐患。此外，文章还涵盖了 GitHub 可用性下滑的争议、NixOS 在 AI 协作中的优势、POSSE 内容发布策略，以及关于外貌吸引力对学业成绩影响的社会科学研究。","archive_path":"data/articles/2026/03/RAW_0ab1880d.json","topicTag":"ai-llm","category":"Business_Tech","sourceName":"SuperTechFans","resourceType":"ARTICLE","readTime":76,"score":86},{"id":"RAW_d66f741e","title":"谷歌 TPU 能撼动英伟达吗？前 TPU 工程师首次揭秘","link":"https://mp.weixin.qq.com/s?__biz=MzA4NjUwNTI0OA==&mid=2247496925&idx=1&sn=22c467431db23ac56a4cc4764c713910","date":"2026-03-24 06:01:00","oneSentenceSummary":"本文通过前谷歌 TPU 工程师的深度访谈，剖析了 TPU 与 GPU 在架构、成本、供应链及软件生态上的差异，并探讨了 TPU 在大规模部署场景下挑战英伟达的可能性与局限。","summary":"文章以深度访谈形式，邀请前谷歌 TPU 工程师揭秘 TPU 的研发历程与技术哲学。TPU 采用流水线架构，通过软硬件协同优化，在特定的大规模模型训练与推理任务中具备显著的 TCO 优势。然而，TPU 面临 XLA 编译器黑盒化、供应链（HBM、CoWoS）依赖及通用性不足等挑战。文章指出，TPU 与 GPU 将长期并存，TPU 适合大规模稳定部署，而 GPU 在算法迭代快速、通用性要求高的场景下仍具优势。","archive_path":"data/articles/2026/03/RAW_d66f741e.json","topicTag":"ai-llm","category":"Business_Tech","sourceName":"硅谷101","resourceType":"ARTICLE","readTime":54,"score":89},{"id":"RAW_5cba83ff","title":"什么是 DeerFlow 2.0？企业应如何看待这一强大且全新的本地 AI 智能体编排器？","link":"https://venturebeat.com/orchestration/what-is-deerflow-and-what-should-enterprises-know-about-this-new-local-ai","date":"2026-03-24 02:18:51","archive_path":"data/articles/2026/03/RAW_5cba83ff.json","topicTag":"ai-llm","category":"Business_Tech","sourceName":"VentureBeat","resourceType":"ARTICLE","readTime":8,"score":89},{"id":"RAW_2036195789601374705","title":"Claude 推出电脑操作功能","link":"https://x.com/claudeai/status/2036195789601374705","date":"2026-03-23 21:38:01","archive_path":"data/articles/2026/03/RAW_2036195789601374705.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Claude(@claudeai)","resourceType":"TWITTER","readTime":1,"score":93}]
