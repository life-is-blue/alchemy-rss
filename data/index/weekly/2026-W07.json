[{"id":"RAW_ebdbcf7f","title":"全网最详细的 Codex 入门教程，手把手教你玩转 Vibe Coding。","link":"https://mp.weixin.qq.com/s?__biz=MzIyMzA5NjEyMA==&mid=2647679828&idx=1&sn=6e1c0a935c70c566ee765c02a36327a6","date":"2026-02-09 01:29:00","archive_path":"data/articles/2026/02/RAW_ebdbcf7f.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"数字生命卡兹克","resourceType":"ARTICLE","readTime":24,"score":92},{"id":"RAW_dd96812d","title":"Vibe Coding 在代码生成与协作中的实践与思考","link":"https://mp.weixin.qq.com/s?__biz=MjM5MDE0Mjc4MA==&mid=2651275013&idx=2&sn=d696ab8030134d5251ce180ff5dbcd31","date":"2026-02-10 06:05:00","archive_path":"data/articles/2026/02/RAW_dd96812d.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"InfoQ 中文","resourceType":"ARTICLE","readTime":36,"score":87},{"id":"RAW_4ead9a68","title":"Yelp 如何构建 “Yelp Assistant”","link":"https://blog.bytebytego.com/p/how-yelp-built-yelp-assistant","date":"2026-02-09 16:31:03","archive_path":"data/articles/2026/02/RAW_4ead9a68.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"ByteByteGo Newsletter","resourceType":"ARTICLE","readTime":11,"score":92},{"id":"RAW_401505dd","title":"3 年、1 万人，快手技术团队首次系统披露 AI 研发范式升级历程","link":"https://mp.weixin.qq.com/s?__biz=MjM5MDE0Mjc4MA==&mid=2651274822&idx=1&sn=b4b364a2e23df2beda37e877001ea4df","date":"2026-02-09 05:31:00","archive_path":"data/articles/2026/02/RAW_401505dd.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"InfoQ 中文","resourceType":"ARTICLE","readTime":59,"score":92},{"id":"RAW_ea193e97","title":"UML 之父：Dario 大错特错，根本不懂软件工程！软件工程不会死亡！软件已经迎来第三次黄金时代！业界回应：有了 AI，SaaS 只会更加繁荣！","link":"https://mp.weixin.qq.com/s?__biz=MjM5ODI5Njc2MA==&mid=2655936386&idx=1&sn=928acef652aef65bb6dc631b9f620116","date":"2026-02-10 04:29:00","archive_path":"data/articles/2026/02/RAW_ea193e97.json","topicTag":"ai-llm","category":"Business_Tech","sourceName":"51CTO技术栈","resourceType":"ARTICLE","readTime":60,"score":92},{"id":"RAW_722cb045","title":"介绍 Showboat 和 Rodney：让智能体能够演示其构建的成果","link":"https://simonwillison.net/2026/Feb/10/showboat-and-rodney/#atom-everything","date":"2026-02-10 17:45:29","oneSentenceSummary":"Simon Willison 介绍了 Showboat 和 Rodney，这是两款旨在帮助 AI 编程智能体对其构建的软件提供可验证演示和基于浏览器的测试的 CLI 工具。","summary":"本文探讨了 AI 辅助开发中的一个关键挑战：确保编程智能体不仅能编写代码，还能证明代码有效。作者 Simon Willison 介绍了两款新工具：Showboat 允许智能体通过 CLI 命令构建基于 Markdown 的演示文档；Rodney 是一个用于浏览器自动化的 CLI 封装工具，使智能体能够与 Web 界面进行交互。作者认为，虽然测试驱动开发 (TDD) 在引导智能体方面非常有效，但手动或视觉验证仍然必不可少。通过提供具有详尽帮助文本的工具，开发者可以赋能智能体自主记录进度并执行无障碍审计或 UI 测试，最终在增强对 AI 生成产物信心的同时，减轻人工监督的负担。","archive_path":"data/articles/2026/02/RAW_722cb045.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Simon Willison's Weblog","resourceType":"ARTICLE","readTime":7,"score":89},{"id":"RAW_1747a4b4","title":"智能体连接沙箱的两种模式","link":"https://blog.langchain.com/the-two-patterns-by-which-agents-connect-sandboxes/","date":"2026-02-10 16:32:35","oneSentenceSummary":"本文分析了将 AI 智能体与隔离执行沙箱集成的两种架构模式，权衡了安全性、开发者体验和系统耦合度之间的利弊。","summary":"文章探讨了 AI 智能体需要隔离“工作区”（沙箱）以安全执行代码而不损害宿主系统的迫切需求。它正式提出了两种主要的集成模式：“智能体在沙箱内”和“沙箱作为工具”。在模式 1 中，智能体驻留在沙箱内部，提供类似于本地环境的开发体验，但会引入 API Key 泄露和知识产权外泄等风险。在模式 2 中，智能体在外部运行并通过 API 调用沙箱，这有助于更快的迭代、更好的凭据安全性以及推理与执行的清晰分离。文章最后给出了使用 deepagents 框架的实际实现示例，帮助开发者根据对耦合度、安全性和速度的具体需求选择合适的架构。","archive_path":"data/articles/2026/02/RAW_1747a4b4.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"LangChain Blog","resourceType":"ARTICLE","readTime":6,"score":88},{"id":"RAW_20d8a979","title":"达摩院开源 RynnBrain：首个支持移动操作的具身大脑基础模型","link":"https://mp.weixin.qq.com/s?__biz=Mzk3NTc1NTU0Mw==&mid=2247505090&idx=1&sn=b68695b1c7e0b0039cf8a4888d35b391","date":"2026-02-10 13:37:00","oneSentenceSummary":"达摩院开源首个支持移动操作的具身基础模型 RynnBrain，通过时空记忆与文本-空间交错推理范式，显著提升了机器人在物理环境中的泛化与规划能力。","summary":"本文详细介绍了达摩院最新开源的具身基础模型 RynnBrain。该模型基于 Qwen3-VL 架构，采用自研 RynnScale 架构优化训练效率，并推出了高性能的 MoE 版本。其核心突破在于引入了时空记忆能力和“文本-空间交织”的推理策略，通过将离散坐标 Token 与文本描述融合，有效缓解了具身智能中的物理幻觉问题。文章涵盖了从 2000 万规模的预训练数据构建，到利用 GRPO 强化学习和 Dagger 算法进行的后训练优化，展示了该模型在导航、操作规划等 16 项基准测试中超越 Gemini Robotics 等模型的 SOTA 表现，并宣布全系列模型与代码开源。","archive_path":"data/articles/2026/02/RAW_20d8a979.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"魔搭ModelScope社区","resourceType":"ARTICLE","readTime":22,"score":88},{"id":"RAW_12afa83c","title":"中文版 Nano Banana 来了？Qwen-Image-2.0 炸场：1K 长文本硬吃，中文生图彻底不拧巴了","link":"https://www.qbitai.com/2026/02/378338.html","date":"2026-02-10 12:18:01","oneSentenceSummary":"阿里发布 Qwen-Image-2.0 图像模型，支持 1K token 长指令、2K 高清输出及多图编辑，显著提升了中文文本渲染与复杂指令遵循能力。","summary":"本文详细介绍了阿里最新发布的 Qwen-Image-2.0 图像生成及编辑模型。该模型在长文本理解（支持 1K token）、复杂指令遵循、中文文字渲染以及多图编辑四大核心领域实现了显著突破。通过实测展示了其在五宫格漫画、美食分解图、3D 城市景观及微缩摄影等高难度场景下的优异表现。技术上，模型通过 VAE 与生成端同步升级解决了中文小字模糊痛点，并实现了生图与编辑能力的深度融合。目前该模型在国际评测中表现强劲，且具备更轻量化的部署优势，标志着国产图像大模型在实用性与专业化方向迈出了重要一步。","archive_path":"data/articles/2026/02/RAW_12afa83c.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":14,"score":88},{"id":"RAW_9bf11880","title":"Vibe Coding 下半场：四大天王，和想赢的人｜对话朱广翔：百度秒哒产品总经理","link":"https://mp.weixin.qq.com/s?__biz=MzAxMDMxOTI2NA==&mid=2649104495&idx=1&sn=211fbb596b64f493d8484c8eb72838e3","date":"2026-02-10 09:03:00","oneSentenceSummary":"对话百度秒哒总经理朱广翔，深度解析无代码（No-Code）在 Vibe Coding 时代的战略地位、商业模式及技术护城河。","summary":"本文通过对话百度秒哒产品总经理朱广翔，探讨了 AI 辅助编程从 IDE 模式向无代码（No-Code）模式演进的必然性。朱广翔结合其 20 年编程经验与强化学习背景，提出了“15 度夹角理论”以应对模型内化风险，并阐述了以“用户 ARR”为核心的倒金字塔商业模式。文章还对比了全球 AI Coding “四大天王”，介绍了秒哒在后端能力、插件系统及评估体系（MiaoDa Bench）上的技术壁垒，强调了在 AI 时代“业务洞察”优于“代码实现”的核心观点。","archive_path":"data/articles/2026/02/RAW_9bf11880.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"十字路口Crossing","resourceType":"ARTICLE","readTime":61,"score":90},{"id":"RAW_c72c00fd","title":"华为发布业界首个扩散语言模型 Agent，部分场景提速 8 倍！","link":"https://www.qbitai.com/2026/02/378286.html","date":"2026-02-10 07:18:25","archive_path":"data/articles/2026/02/RAW_c72c00fd.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":12,"score":88},{"id":"RAW_574a992c","title":"硅谷豪赌算力烧到停电，中国团队反向出击！这一刀，直接砍碎 Scaling Law","link":"https://mp.weixin.qq.com/s?__biz=MzI3MTA0MTk1MA==&mid=2652673881&idx=1&sn=7722da402c7042499703aef31e80bf48","date":"2026-02-10 05:00:00","oneSentenceSummary":"Yuan 3.0 Flash 通过 RIRM 和 RAPO 机制解决大模型“过度思考”问题，在提升精度的同时将推理 token 消耗最高削减 75%。","summary":"本文介绍了 YuanLab.ai 团队推出的 Yuan 3.0 Flash 模型，该模型针对当前推理大模型普遍存在的“过度思考”（Overthinking）顽疾进行了深度优化。通过采用 40B 总参数的 MoE 架构（仅激活 3.7B），并引入反思抑制奖励机制（RIRM）与反思感知自适应策略优化（RAPO），模型能够精准识别正确答案节点并抑制冗余推理。实验显示，该模型在 MATH-500 等基准测试中不仅提升了准确率，还显著降低了约 75% 的推理 token 消耗，为企业级 AI 应用提供了一种高效率、低成本的实用方案。","archive_path":"data/articles/2026/02/RAW_574a992c.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"新智元","resourceType":"ARTICLE","readTime":19,"score":83},{"id":"RAW_f5285236","title":"首次！AI 智能体破解「纳什均衡」，大模型学会博弈论｜Cell 子刊","link":"https://mp.weixin.qq.com/s?__biz=MzI3MTA0MTk1MA==&mid=2652673881&idx=3&sn=b62f0d4af2b7ab70581dbe0ec8fc8d88","date":"2026-02-10 05:00:00","oneSentenceSummary":"香港中文大学（深圳）等团队开发了 PrimeNash 框架，利用大语言模型智能体实现了纳什均衡闭式解析解的自动推导与形式化验证。","summary":"本文介绍了由香港中文大学（深圳）赵俊华、黄建伟教授团队联合多所顶尖高校研发的 PrimeNash 智能体框架。该框架旨在解决复杂博弈中纳什均衡求解的计算挑战，通过策略生成（SGM）、策略评估（SEM）和均衡证明（EPM）三个核心模块，模拟人类数学家的科研路径。PrimeNash 不仅能处理高维、非凸的静态博弈，在动态博弈中也表现出色，成功率达 70%。研究通过碳排放权交易市场的案例，展示了该框架在提供可证明的闭式解析解及解释市场现象（如“翘尾效应”）方面的强大能力，标志着 AI 在博弈论自动化研究领域迈出了重要一步。","archive_path":"data/articles/2026/02/RAW_f5285236.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"新智元","resourceType":"ARTICLE","readTime":13,"score":83},{"id":"RAW_fd94f2de","title":"想让机器人春晚包饺子？阿里达摩院：别急，先把「大脑」优化一下","link":"https://mp.weixin.qq.com/s?__biz=MzA3MzI4MjgzMw==&mid=2651016237&idx=1&sn=1d0611988c1bde2d83b482fdfb4d2d51","date":"2026-02-10 03:44:00","oneSentenceSummary":"阿里达摩院发布并开源具身智能基础模型 RynnBrain，通过引入时空记忆与物理空间推理，显著提升了机器人在复杂物理环境中的感知、规划与执行能力。","summary":"文章详细介绍了阿里达摩院具身智能团队的最新研究成果 RynnBrain。针对通用大模型在物理世界中缺乏空间感、易产生“物理幻觉”的痛点，RynnBrain 通过将时空记忆和物理空间推理直接融入模型训练，实现了对三维世界的连续理解。其核心创新在于“文本与空间定位交错”的推理策略，强制模型在生成指令时同步预测空间坐标。此外，达摩院开源了包括首个 MoE 具身基础模型在内的 7 个模型及 RynnBrain Bench 评测基准，在 16 项指标上达到 SOTA，为具身智能领域提供了高质量的基础设施。","archive_path":"data/articles/2026/02/RAW_fd94f2de.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"机器之心","resourceType":"ARTICLE","readTime":19,"score":86},{"id":"RAW_96a3fd21","title":"2026 开年关键词：Self-Distillation，大模型真正走向「持续学习」","link":"https://mp.weixin.qq.com/s?__biz=MzA3MzI4MjgzMw==&mid=2651016237&idx=2&sn=a40e285b0b27d5abd99ff5f4ed1ae12d","date":"2026-02-10 03:44:00","oneSentenceSummary":"本文深度解析了 2026 年大模型领域的核心趋势——自蒸馏（Self-Distillation），通过三项前沿研究展示了模型如何利用内生能力实现持续学习与推理进化的闭环。","summary":"文章聚焦于 2026 年初大模型研究的重大转向，即从依赖外部强教师转向利用“自蒸馏”技术实现内生增长。核心内容围绕 MIT、ETH Zurich、Meta 等机构的三项研究展开：首先是 SDFT 方法，通过上下文学习构造临时教师分布，解决了持续学习中的灾难性遗忘；其次是 SDPO 框架，利用环境提供的“富反馈”信息，将稀疏的二值奖励转化为 Token 级的密集监督信号，大幅提升强化学习效率；最后是 OPSD 框架，通过在模型内部构建“信息不对称”，利用特权信息引导学生策略学习深层推理逻辑。这些研究共同预示着大模型正走向自驱动的持续进化阶段。","archive_path":"data/articles/2026/02/RAW_96a3fd21.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"机器之心","resourceType":"ARTICLE","readTime":10,"score":85},{"id":"RAW_68451714","title":"阿里达摩院开源具身大脑基模：3B 激活参数性能超越 72B，转身就忘事的机器人有救了","link":"https://www.qbitai.com/2026/02/378236.html","date":"2026-02-10 03:19:14","archive_path":"data/articles/2026/02/RAW_68451714.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":17,"score":85},{"id":"RAW_cedf4ef1","title":"把电价当量化交易做！这家 AI 公司，一年帮数据中心“赚”出 1000 万","link":"https://mp.weixin.qq.com/s?__biz=MzkyNTY1MjE2OA==&mid=2247493323&idx=1&sn=eef073d7178259a645b49f3659c4ba69","date":"2026-02-09 11:03:00","archive_path":"data/articles/2026/02/RAW_cedf4ef1.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"乌鸦智能说","resourceType":"ARTICLE","readTime":19,"score":85},{"id":"RAW_143cb1eb","title":"今日开源（2026-2-9）：美团 LongCat-Flash-Lite 开源，256k 长上下文+MoE 高效推理，嵌入优化超越等效基线","link":"https://mp.weixin.qq.com/s?__biz=MzkyMzcwMDIyMQ==&mid=2247501588&idx=1&sn=9aade4d280c20d77f9840b0c2de6e9ca","date":"2026-02-09 10:31:00","archive_path":"data/articles/2026/02/RAW_143cb1eb.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"机器之心SOTA模型","resourceType":"ARTICLE","readTime":5,"score":86},{"id":"RAW_41ca7ce7","title":"清华刘知远团队论文：最小化结构改动，短文本到长文本丝滑升级 | ICLR 2026","link":"https://mp.weixin.qq.com/s?__biz=MzA5ODEzMjIyMA==&mid=2247731450&idx=2&sn=3894cd9c6cbb1819597afd469dbf1ce3","date":"2026-02-09 10:04:00","archive_path":"data/articles/2026/02/RAW_41ca7ce7.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"AI科技评论","resourceType":"ARTICLE","readTime":20,"score":88},{"id":"RAW_48ab1cdc","title":"2026 年硅谷书单：18 位硅谷创始人共同推荐的 56 本书","link":"https://mp.weixin.qq.com/s?__biz=MzAxMDMxOTI2NA==&mid=2649104479&idx=1&sn=358e90989ecf328bc6bc47d22be5e315","date":"2026-02-09 09:56:00","archive_path":"data/articles/2026/02/RAW_48ab1cdc.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"十字路口Crossing","resourceType":"ARTICLE","readTime":42,"score":84},{"id":"RAW_ed39a1a3","title":"快手用“对齐”技术，让广告推荐更懂你","link":"https://mp.weixin.qq.com/s?__biz=MjM5ODkzMzMwMQ==&mid=2650450953&idx=1&sn=47ed7abd6a494f4735154972fa1cf2e7","date":"2026-02-09 07:25:00","archive_path":"data/articles/2026/02/RAW_ed39a1a3.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"AINLP","resourceType":"ARTICLE","readTime":21,"score":88},{"id":"RAW_7d30dbd7","title":"警钟敲响！Hinton 最新万字演讲：怒怼乔姆斯基、定义“不朽计算”、揭示人类唯一生路","link":"https://mp.weixin.qq.com/s?__biz=Mzg4NDQwNTI0OQ==&mid=2247588749&idx=1&sn=ba00f3e94e3cfa8387dca5401ee07ce5","date":"2026-02-09 04:01:00","archive_path":"data/articles/2026/02/RAW_7d30dbd7.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"AI科技大本营","resourceType":"ARTICLE","readTime":42,"score":91},{"id":"RAW_b4495599","title":"世界是快的","link":"https://mp.weixin.qq.com/s?__biz=M