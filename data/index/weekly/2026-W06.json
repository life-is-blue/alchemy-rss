[{"id":"RAW_2b1e7283","title":"Claude Code 创始人再次公开：团队的 10 个使用技巧！","link":"https://mp.weixin.qq.com/s?__biz=MzIyNjM2MzQyNg==&mid=2247718904&idx=1&sn=7f77ee06ab57fd11bc44ab6f782cd644","date":"2026-02-03 14:58:00","archive_path":"data/articles/2026/02/RAW_2b1e7283.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Datawhale","resourceType":"ARTICLE","readTime":10,"score":91},{"id":"RAW_f186294d","title":"深度解读：OpenClaw 架构及生态","link":"https://mp.weixin.qq.com/s?__biz=MzIzNjE2NTI3NQ==&mid=2247491455&idx=1&sn=33d58cb6f0d2cd3b9c08c3c84a223e25","date":"2026-02-02 23:05:00","archive_path":"data/articles/2026/02/RAW_f186294d.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"浮之静","resourceType":"ARTICLE","readTime":56,"score":92},{"id":"RAW_eb4ed4c8","title":"编程智能体的上下文工程","link":"https://martinfowler.com/articles/exploring-gen-ai/context-engineering-coding-agents.html","date":"2026-02-05 15:36:00","oneSentenceSummary":"本文为 AI 编程智能体中的“上下文工程”提供了一个全面的框架，探讨了如何通过战略性地策划提示词、工具和接口来优化 LLM 的性能。","summary":"文章将上下文工程定义为对提供给 LLM 的信息进行刻意策划，以提高其输出质量。它将上下文分为“可重用提示词”（区分特定任务的指令 Instructions 和通用指南/规则 Guidance/Rules）以及“上下文接口”（工具、MCP 服务器和技能 Skills）。作者以 Claude Code 为主要案例研究，详细介绍了各种配置功能，例如用于项目级规范的 CLAUDE.md 以及用于特定文件约束的模块化规则。一个核心主题是上下文规模的“金发姑娘”挑战：既要提供足够的信息以保证准确性，又要避免因上下文过多而导致的性能下降和成本开销。最后，作者强调，尽管使用了“工程”一词，该过程仍然是概率性的，需要迭代优化和人工监督，而不是期望确定性的控制。","archive_path":"data/articles/2026/02/RAW_eb4ed4c8.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"Martin Fowler","resourceType":"ARTICLE","readTime":8,"score":92},{"id":"RAW_226b1d59","title":"自动化评测的九九归一——评测 agent","link":"https://mp.weixin.qq.com/s?__biz=MzIzOTU0NTQ0MA==&mid=2247558178&idx=1&sn=eaa639c6255e7dd20e13f07bc9bf4670","date":"2026-02-05 00:30:00","archive_path":"data/articles/2026/02/RAW_226b1d59.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"阿里云开发者","resourceType":"ARTICLE","readTime":34,"score":92},{"id":"RAW_8fb9eeb9","title":"解构 Clawdbot：本地架构、记忆管理、Agent 编排与上下文组装原理","link":"https://mp.weixin.qq.com/s?__biz=MzI2NDU4OTExOQ==&mid=2247694343&idx=1&sn=8974e62e0c74a0011c6fdf6d037f957c","date":"2026-02-03 00:45:00","archive_path":"data/articles/2026/02/RAW_8fb9eeb9.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"腾讯云开发者","resourceType":"ARTICLE","readTime":27,"score":93},{"id":"RAW_bc19b98b","title":"从传统编程转向大模型编程","link":"https://mp.weixin.qq.com/s?__biz=MzIzOTU0NTQ0MA==&mid=2247558172&idx=1&sn=4352d94bba884ceac8f3f231a9074910","date":"2026-02-03 00:30:00","archive_path":"data/articles/2026/02/RAW_bc19b98b.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"阿里云开发者","resourceType":"ARTICLE","readTime":42,"score":93},{"id":"RAW_df4d1702","title":"生产级 Prompt 自动化推理评估 A/B 实验结果的工程实践","link":"https://mp.weixin.qq.com/s?__biz=MzIzOTU0NTQ0MA==&mid=2247558131&idx=1&sn=73317842c9c513c3bde07efac9cee952","date":"2026-02-02 00:31:00","archive_path":"data/articles/2026/02/RAW_df4d1702.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"阿里云开发者","resourceType":"ARTICLE","readTime":95,"score":92},{"id":"RAW_3f0cd641","title":"刚刚，ChatGPT 和 Claude 同时大更新，不会给 AI 当老板的打工人要被淘汰","link":"https://www.ifanr.com/1654369?utm_source=rss&utm_medium=rss&utm_campaign=","date":"2026-02-06 06:26:22","oneSentenceSummary":"OpenAI 与 Anthropic 同步更新 GPT-5.3-Codex 与 Claude Opus 4.6，标志着 AI 从辅助工具向自主智能体团队演进，职场核心能力将从提示词工程转向智能体管理。","summary":"本文深度解析了 OpenAI 和 Anthropic 的最新技术突破。OpenAI 推出的 GPT-5.3-Codex 在计算机操作（OSWorld）和硬核编程（SWE-Bench Pro）基准测试中表现卓越，展现出“AI 创造 AI”的自我进化能力与极高的工程可靠性。与此同时，Anthropic 发布了 Claude Opus 4.6，凭借 1M 超长上下文窗口和 76% 的高召回率解决了“上下文腐蚀”痛点，并引入了革命性的 Agent Teams 功能，支持多智能体自主协作完成复杂软件工程。文章对比了两者“稳健工程师”与“激进天才”的不同特质，强调未来职场的核心竞争力将在于如何作为管理者去调度和审核硅基智能体团队。","archive_path":"data/articles/2026/02/RAW_3f0cd641.json","topicTag":"ai-llm","category":"Business_Tech","sourceName":"爱范儿","resourceType":"ARTICLE","readTime":11,"score":82},{"id":"RAW_9f4cc823","title":"Mitchell Hashimoto：我的 AI 采用之旅","link":"https://simonwillison.net/2026/Feb/5/ai-adoption-journey/#atom-everything","date":"2026-02-05 23:39:07","oneSentenceSummary":"Mitchell Hashimoto 分享了通过刻意练习和战略委派，将 AI 编程智能体集成到专业工作流中的非常规、高杠杆策略。","summary":"本文总结了 Mitchell Hashimoto 采用 AI 编程智能体的结构化历程。它没有仅仅关注简单的提示词，而是为开发者概述了一套与 AI 建立信任并提高效率的方法论。核心策略包括：通过“复现手动工作”来对照已知的高质量产出校准智能体的能力；利用“下班前智能体”在低能量时段取得进展；以及在人类专注于更复杂的架构挑战时，将“稳操胜券”的任务委派给 AI。这种方法强调将 AI 视为实现可衡量生产力提升的工具，而不仅仅是新鲜事物。","archive_path":"data/articles/2026/02/RAW_9f4cc823.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"Simon Willison's Weblog","resourceType":"ARTICLE","readTime":1,"score":86},{"id":"RAW_473dec97","title":"谷歌北大联手学术版 Banana 爆火，论文图表 100%精确生成","link":"https://www.qbitai.com/2026/02/376451.html","date":"2026-02-05 06:15:38","oneSentenceSummary":"谷歌与北大联合推出 PaperBanana，通过五大智能体协作与代码生成技术，实现学术论文插图的高质量、高精度自动生成。","summary":"文章详细介绍了由谷歌和北京大学联合开发的学术插图生成工具 PaperBanana。该系统针对科研人员绘图难、耗时长的痛点，采用五大智能体（检索、规划、风格、可视化、批判）协作模式，模拟人类从寻找灵感到最终定稿的完整流程。其核心技术亮点在于提供“代码生成模式”，利用 Python 可视化库确保图表数值 100% 精确，有效解决了 AI 生图常见的“幻觉”问题。通过在专门构建的 PaperBananaBench 基准上的测试，该工具在忠实性、简洁性、可读性和美观性上均显著优于现有基线模型，并获得了高度的人类盲测认可，为全自动生成出版级学术插图提供了新路径。","archive_path":"data/articles/2026/02/RAW_473dec97.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"量子位","resourceType":"ARTICLE","readTime":12,"score":87},{"id":"RAW_05bfeee1","title":"退隐 3 年后回归，周末写的 AI 一夜刷屏、一周拿下 10 万 Star 增速超 Linux，Clawdbot 之父首次长谈：如今几乎不看自己发布的代码","link":"https://mp.weixin.qq.com/s?__biz=Mzg4NDQwNTI0OQ==&mid=2247588728&idx=1&sn=042881f37d34969c3b08f85ddbb23cbf","date":"2026-02-04 10:02:00","archive_path":"data/articles/2026/02/RAW_05bfeee1.json","topicTag":"ai-llm","category":"Artificial_Intelligence","sourceName":"AI科技大本营","resourceType":"ARTICLE","readTime":99,"score":91},{"id":"RAW_c347f932","title":"文本生成图像模型训练设计：消融实验的经验教训","link":"https://huggingface.co/blog/Photoroom/prx-part2","date":"2026-02-03 11:25:53","archive_path":"data/articles/2026/02/RAW_c347f932.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"Hugging Face Blog","resourceType":"ARTICLE","readTime":26,"score":89},{"id":"RAW_6dbd507b","title":"今日开源（2026-2-2）：阶跃智能 Step-3.5-Flash 系列上线，199B 基座+FP8/Int4 量化技术，压缩优化赋能低开销多硬件 NLP 部署","link":"https://mp.weixin.qq.com/s?__biz=MzkyMzcwMDIyMQ==&mid=2247501528&idx=1&sn=d4a1cacb26e74cdf45aa3055ca563728","date":"2026-02-02 10:30:00","archive_path":"data/articles/2026/02/RAW_6dbd507b.json","topicTag":"other","category":"Artificial_Intelligence","sourceName":"机器之心SOTA模型","resourceType":"ARTICLE","readTime":5,"score":89},{"id":"RAW_8262b259","title":"告别“伪智能”代码：用 Spec + RAG 打造真正懂你的 AI 程序员","link":"https://mp.weixin.qq.com/s?__biz=MzIzOTU0NTQ0MA==&mid=2247558194&idx=1&sn=ece018ca2921b2d51176c37a91bd23f3","date":"2026-02-06 00:32:00","oneSentenceSummary":"本文介绍了如何通过结合结构化规范（Spec）、检索增强生成（RAG）和模型上下文协议（MCP），构建一套高质量的 AI Coding 知识增强体系，以解决 AI 生成代码准确性不足的问题。","summary":"文章深入探讨了提升 AI 编程质量的路径，核心在于构建“认知基础设施”。作者提出了“Spec（硬规则）+ RAG（软上下文）+ MCP（标准化接口）”的三位一体架构。Spec 作为项目契约，提供强约束以减少模型幻觉；RAG 动态接入非结构化私有知识，弥补模型静态知识的不足；MCP 则作为通用接口协议，实现工具与数据的标准化集成。文章详细介绍了 RAG 的关键技术（如分块、检索、重排）及 MCP 的通信机制，并分享了在天猫超市业务中的落地实践，包括具体的目录分层、API 构建及 Aone Copilot 的集成方案。","archive_path":"data/articles/2026/02/RAW_8262b259.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"阿里云开发者","resourceType":"ARTICLE","readTime":43,"score":88},{"id":"RAW_f15666e2","title":"带爪子的机器人","link":"https://world.hey.com/dhh/clankers-with-claws-9f86fa71","date":"2026-02-05 15:30:07","oneSentenceSummary":"DHH 使用 OpenClaw 探索了 AI 智能体的未来，证明了现代 LLM 无需专门的 API 或协议，即可导航电子邮件和 SaaS 平台等以人为中心的数字界面。","summary":"本文记录了对 OpenClaw 的一次实操实验，这是一个提供持久执行和长期记忆的 AI 智能体框架。作者 David Heinemeier Hansson (DHH) 测试了一个假设：先进的 AI 智能体不再需要 API 或模型上下文协议 (MCP) 等专门的“机器适配”即可有效运作。通过让名为 Kef 的智能体仅使用标准 Web 界面独立注册电子邮箱账号和协作平台 Fizzy，他证明了高端模型 Claude 4.5 和 Kimi K2.5 可以成功导航为人类设计的数字世界。他得出结论，虽然专门的协议目前对提高效率很有用，但长期趋势倾向于通过人类功能入口与环境交互的智能体，这使得专门的机器对机器协议可能变得过时。","archive_path":"data/articles/2026/02/RAW_f15666e2.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"David Heinemeier Hansson","resourceType":"ARTICLE","readTime":3,"score":87},{"id":"RAW_53038dfa","title":"一次大文件处理性能优化实录","link":"https://mp.weixin.qq.com/s?__biz=MzAxNDEwNjk5OQ==&mid=2650542848&idx=1&sn=182f2cc442bb91d9e6db18d2e28bd403","date":"2026-02-04 09:29:00","archive_path":"data/articles/2026/02/RAW_53038dfa.json","topicTag":"other","category":"Programming_Technology","sourceName":"大淘宝技术","resourceType":"ARTICLE","readTime":38,"score":91},{"id":"RAW_28e7cf74","title":"百度沧海·存储 Mantle 系统架构演进之路，SOSP'25 论文背后的故事","link":"https://mp.weixin.qq.com/s?__biz=MjM5MDE0Mjc4MA==&mid=2651274349&idx=3&sn=497e917454ddfc7d2572bd8c7a258f16","date":"2026-02-04 05:31:00","archive_path":"data/articles/2026/02/RAW_28e7cf74.json","topicTag":"other","category":"Programming_Technology","sourceName":"InfoQ 中文","resourceType":"ARTICLE","readTime":62,"score":91},{"id":"RAW_c1c30c76","title":"用 Go 重构 C++老系统，一次降本 82%的极致之旅","link":"https://mp.weixin.qq.com/s?__biz=MzI2NDU4OTExOQ==&mid=2247694348&idx=1&sn=9e955e9aec449ec3245339142575cd1e","date":"2026-02-04 00:46:00","archive_path":"data/articles/2026/02/RAW_c1c30c76.json","topicTag":"other","category":"Programming_Technology","sourceName":"腾讯云开发者","resourceType":"ARTICLE","readTime":12,"score":88},{"id":"RAW_9661d297","title":"【第 3653 期】一个 CLAUDE.md，让 AI 真正懂你的项目：从配置到长期提效的完整指南","link":"https://mp.weixin.qq.com/s?__biz=MjM5MTA1MjAxMQ==&mid=2651278571&idx=1&sn=66e4f199ff6c325a9415c9c4bf3dcaad","date":"2026-02-03 01:01:00","archive_path":"data/articles/2026/02/RAW_9661d297.json","topicTag":"ai-llm","category":"Programming_Technology","sourceName":"前端早读课","resourceType":"ARTICLE","readTime":17,"score":91},{"id":"RAW_9bee791b","title":"视频超分与补帧框架，AI 驱动画质流畅升级 | 开源日报 No.870","link":"https://mp.weixin.qq.com/s?__biz=Mzg2NTk2OTM2OA==&mid=2247494014&idx=1&sn=42fc8f26ea2a193dc6bdb5317a96b45c","date":"2026-02-03 00:00:00","archive_path":"data/articles/2026/02/RAW_9bee791b.json","topicTag":"ai-llm","category":"Pr