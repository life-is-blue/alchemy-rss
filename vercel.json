{
  "version": 2,
  "rewrites": [
    {
      "source": "/u/:id",
      "destination": "/api/u?id=:id"
    },
    {
      "source": "/atom.xml",
      "destination": "/atom.xml"
    },
    {
      "source": "/details/:path*",
      "destination": "/details/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "/static/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
