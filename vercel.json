{
  "version": 2,
  "builds": [
    {
      "src": "site/api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "site/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/u/(?<id>[^/]*)",
      "dest": "site/api/index.js?id=$id"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/details/(.*)",
      "dest": "/details/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/atom.xml",
      "dest": "/atom.xml"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}